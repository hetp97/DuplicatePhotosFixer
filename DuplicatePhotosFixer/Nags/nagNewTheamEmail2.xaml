<Window x:Class="DuplicatePhotosFixer.Nags.nagNewTheamEmail2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Nags"
        mc:Ignorable="d"
        Title="nagNewTheamEmail2" Height="470" Width="819" WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto" MinHeight="81"/>
            <RowDefinition Height="Auto" MinHeight="54"/>
            <RowDefinition Height="Auto" MinHeight="79"/>
        </Grid.RowDefinitions>
        <StackPanel >
            <DockPanel>
                <Button x:Name="btn_close" Background="#3E3E3E" Width="25"
                        Height="20"
                        Margin="0 5 10 0"
                        Foreground="White"                      
                        DockPanel.Dock="Right"                       
                        VerticalAlignment="Top"
                        >x
                </Button>
                <Image x:Name="img" Source="{DynamicResource img_logo_dpf}" Width="81"
                       Height="75"
                       Margin="0 20 0 0"/>

            </DockPanel>
            <DockPanel HorizontalAlignment="Center" Margin="0 15 0 0">
                <TextBlock x:Name="label1"
                           FontSize="15"
                           FontWeight="Bold">Duplicate Photos found :</TextBlock>
                <TextBlock x:Name="lblDupPhotos"
                             FontSize="15"
                           FontWeight="Bold"
                           Foreground="#A30000">0</TextBlock>
            </DockPanel>
            <DockPanel HorizontalAlignment="Center" Margin="0 15 0 0">
                <TextBlock x:Name="label2"
                           FontSize="15"
                           FontWeight="Bold">Space to be Saved :</TextBlock>
                <TextBlock x:Name="lblSpace"
                             FontSize="15"
                           FontWeight="Bold"
                           Foreground="#A30000">0</TextBlock>
            </DockPanel>
            <TextBlock x:Name="label3" Margin="0 25 0 0" FontSize="13"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Center">
               Your may remove upto 0 duplicate photos for FREE.
            </TextBlock>
        </StackPanel>
        <Grid Grid.Row="1">
            <Grid.Background>
                <ImageBrush ImageSource="{DynamicResource img_bg_gradient}"/>
            </Grid.Background>
            <DockPanel>
                <Image x:Name="img_mb" Source="/Resources/mbc_icon.png" Width="85"
                       Height="79" Margin="25 0 15 0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="txt5"
                               FontWeight="Bold"
                               FontSize="16">
                        label1
                    </TextBlock>
                    <TextBlock x:Name="txt6" Padding="0 10 0 0">                              
                      label2
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Grid>
        <Grid Grid.Row="2">
            <DockPanel VerticalAlignment="Center"
                       HorizontalAlignment="Center">
                <TextBlock x:Name="txt_block1">
                    Already purchased Duplicate Photos Fixer Pro ?
                </TextBlock>
                <TextBlock Width="50"/>
                <TextBlock x:Name="txt_block2">
                    <Hyperlink x:Name="llEnterKey">
                        Click here to enter your key
                    </Hyperlink>
                </TextBlock>
            </DockPanel>
        </Grid>
        <Grid Grid.Row="3">
            <DockPanel Margin="20 0 10 0">
                <Button x:Name="btnGetFullVer" Width="369" Height="37"
                        Content="Get limited time full version for FREE"
                        Style="{DynamicResource stl_btnScanForDuplicates}"
                        FontWeight="Normal"
                        BorderBrush="Transparent"/>

                <Button x:Name="btnUpgNow" Width="369" Height="37"
                        Content="Upgrade now at special discount"
                        Style="{DynamicResource stylGreenBtn}"
                        FontWeight="Normal"
                        BorderBrush="Transparent"/>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
