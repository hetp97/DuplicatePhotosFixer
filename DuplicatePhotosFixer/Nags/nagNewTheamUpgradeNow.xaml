<Window x:Class="DuplicatePhotosFixer.Nags.nagNewTheamUpgradeNow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Nags"
        mc:Ignorable="d"
        Title="nagNewTheamUpgradeNow" Height="490" Width="665" WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto" MinHeight="165"/>
            <RowDefinition Height="66"/>
        </Grid.RowDefinitions>
        <StackPanel >
            <DockPanel>
                <Button x:Name="btn_close" Background="#3E3E3E" Width="25"
                        Height="20"
                        Margin="0 5 10 0"
                        Foreground="White"                      
                        DockPanel.Dock="Right"                       
                        VerticalAlignment="Top"
                        >x
                </Button>
                <Image x:Name="img" Source="{DynamicResource img_logo_dpf}" Width="61"
                       Height="61"
                       Margin="0 10 0 0"/>
               
            </DockPanel>
            <TextBlock x:Name="label"
                       FontSize="18"
                       Foreground="Black" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       >
                Thank you for trying Duplicate Photos Fixer Pro!
            </TextBlock>
            <DockPanel HorizontalAlignment="Center" Margin="0 15 0 0">
                <TextBlock x:Name="label1"
                           FontSize="15"
                           FontWeight="Bold">Duplicate Photos found : </TextBlock>
                <TextBlock x:Name="lblDupPhotos"
                             FontSize="15"
                           FontWeight="Bold"
                           Foreground="#A30000">0</TextBlock>
            </DockPanel>
            <DockPanel HorizontalAlignment="Center" Margin="0 15 0 0">
                <TextBlock x:Name="label2"
                           FontSize="15"
                           FontWeight="Bold">Space to be Saved :</TextBlock>
                <TextBlock x:Name="lblSpace"
                             FontSize="15"
                           FontWeight="Bold"
                           Foreground="#A30000">0</TextBlock>
            </DockPanel>
            <TextBlock x:Name="label3" Margin="0 25 0 0" FontSize="13"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Center">
                Click or <Hyperlink x:Name="llUpgradeNow"> Upgrade Now</Hyperlink> to start cleaning duplicates and recover space <Hyperlink x:Name="llAlreadyKey"> Already have a key ?</Hyperlink>
            </TextBlock>
        </StackPanel>
        <Grid Grid.Row="1" Margin="0 0 0 20" >
            <Grid.Background>
                <ImageBrush ImageSource="{DynamicResource img_bg_gradient}"/>
            </Grid.Background>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto" MinWidth="298"/>
            </Grid.ColumnDefinitions>
            <StackPanel Margin="15 10 0 0">
                <TextBlock x:Name="txt_block" FontWeight="Bold">
                    Why Upgrade ?
                </TextBlock>
                <DockPanel Margin="0 10 0 0">
                    <Image x:Name="img_tick1" Width="12" Height="10" 
                          Margin="0 0 5 0" Source="{DynamicResource img_green_tick}"/>
                    <TextBlock x:Name="txt1" Text="Organizes and streamlines phote colloction"/>
                </DockPanel>
                <DockPanel Margin="0 10 0 0">
                    <Image x:Name="img_tick2" Width="12" Height="10" 
                          Margin="0 0 5 0" Source="{DynamicResource img_green_tick}"/>
                    <TextBlock x:Name="txt2" Text="Maximizes Free Space by removing duplicates"/>
                </DockPanel>
                <DockPanel Margin="0 10 0 0">
                    <Image x:Name="img_tick3" Width="12" Height="10" 
                          Margin="0 0 5 0" Source="{DynamicResource img_green_tick}"/>
                    <TextBlock x:Name="txt3" Text="Saves time and precious disk space"/>
                </DockPanel>
                <DockPanel Margin="0 10 0 0">
                    <Image x:Name="img_tick4" Width="12" Height="10" 
                          Margin="0 0 5 0" Source="{DynamicResource img_green_tick}"/>
                    <TextBlock x:Name="txt4" Text="Cleans duplicate photos from removable devices"/>
                </DockPanel>
            </StackPanel>
            <Grid Grid.Column="1">
                <Button x:Name="btnUpgrade"
                        Width="258"
                        Height="39"
                        Style="{DynamicResource stylGreenBtn}">
                    Upgrade Now with special discount
                </Button>
            </Grid>
        </Grid>
        <Grid Grid.Row="2" Background="#EBEBEB">
            <DockPanel>
                <Image x:Name="img_mb" Source="/Resources/mbc_icon.png" Width="67"
                       Height="66" Margin="5 0 5 0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="txt5"
                               FontWeight="Bold">
                        No-Risk, Money Back Guarantee.
                    </TextBlock>
                    <TextBlock x:Name="txt6">
                              
                        Satisfication guaranteed or your money back.
                    </TextBlock>
                </StackPanel>
                <Button x:Name="btnContinueUn" Width="144" Height="27"
                    Content="Continue unregistered"
                    Background="White"
                    BorderBrush="#3399FF"
                        Foreground="#005FB8"
                    BorderThickness="1.5"
                        Margin="0 0 10 0"
                        HorizontalAlignment="Right"/>
            </DockPanel>
        </Grid>
        
    </Grid>
</Window>
