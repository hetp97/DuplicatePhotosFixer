<Window x:Class="DuplicatePhotosFixer.Nags.RecommendedAppsNags.frmInstallNowADU"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Nags.RecommendedAppsNags"
        mc:Ignorable="d"
        Title="frmInstallNowUtilities" Height="510" Width="827" WindowStyle="None" ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="btn_custhover" TargetType="Button">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" >
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <LinearGradientBrush.GradientStops>
                                    <GradientStop Color="#C3C0C3" Offset="0"/>
                                </LinearGradientBrush.GradientStops>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </Trigger>

                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background"  >
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <LinearGradientBrush.GradientStops>
                                    <GradientStop Color="#C3C0C3" Offset="0"/>
                                </LinearGradientBrush.GradientStops>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition MaxHeight="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition MaxHeight="108"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <DockPanel VerticalAlignment="Center">
                <cust:ImageButton
                            x:Name="close_btn"
                            Width="12"
                            Height="12"
                            Margin="10 0"
                            DockPanel.Dock="Right"                          
                            Style="{DynamicResource imageButton}"
                            Image="{DynamicResource img_close_black}"
                            HoverImage="{DynamicResource img_close_black}"
                            SelectedImage="{DynamicResource img_close_black}" />
                <Label x:Name="header_lbl" Content="Optional Offer by Systweak " 
                       FontSize="15"
                       Padding="10 0"
                       Foreground="{DynamicResource cl_fg_primary2}"/>
            </DockPanel>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Image x:Name="app_img" Stretch="None"  VerticalAlignment="Top"/>
            <Grid Grid.Column="1">
                <StackPanel>
                    <TextBlock x:Name="product_Name" 
                               Foreground="{DynamicResource cl_fg_primary2}"
                               FontWeight="SemiBold"
                               Text="Advanced Screen Recorder"
                               FontSize="22"/>
                    <TextBlock x:Name="product_info"
                               Foreground="{DynamicResource cl_fg_AppInfo_ac}"
                               FontStyle="Italic"
                               Text="Screen Recorder"
                               Padding="0 8"
                               FontSize="14"/>
                    <!-- Feature Section 1 -->
                    <StackPanel>
                        <DockPanel>
                            <Image x:Name="bullet_img" Source="{DynamicResource img_green_bullet1}" Stretch="None"/>
                            <TextBlock x:Name="feature1_Name"
                                      Foreground="{DynamicResource cl_fg_primary2}"
                                       FontSize="15"
                                       Padding="8 0"
                                       Text="Multiple Features"/>
                        </DockPanel>
                        <TextBlock x:Name="feature1_desc"
                                   Text="test data"
                                   MinWidth="400"
                                   TextWrapping="Wrap"
                                   Margin="22 8"
                                   Foreground="{DynamicResource cl_fg_RA_cont}"/>
                    </StackPanel>
                    <!-- Feature Section 2 -->
                    <StackPanel>
                        <DockPanel>
                            <Image x:Name="bullet_img2" Source="{DynamicResource img_green_bullet1}" Stretch="None"/>
                            <TextBlock x:Name="feature2_Name"
                                      Foreground="{DynamicResource cl_fg_primary2}"
                                       FontSize="15"
                                       Padding="8 0"
                                       Text="Multiple Features"/>
                        </DockPanel>
                        <TextBlock x:Name="feature2_desc"
                                   Text="test data"
                                   MinWidth="400"
                                   TextWrapping="Wrap"
                                   Margin="22 8"
                                   Foreground="{DynamicResource cl_fg_RA_cont}"/>
                    </StackPanel>
                    <!-- Feature Section 3 -->
                    <StackPanel>
                        <DockPanel>
                            <Image x:Name="bullet_img3" Source="{DynamicResource img_green_bullet1}" Stretch="None"/>
                            <TextBlock x:Name="feature3_Name"
                                      Foreground="{DynamicResource cl_fg_primary2}"
                                       FontSize="15"
                                       Padding="8 0"
                                       Text="Multiple Features"/>
                        </DockPanel>
                        <TextBlock x:Name="feature3_desc"
                                   Text="test data"
                                   MinWidth="400"
                                   TextWrapping="Wrap"
                                   Margin="22 8"
                                   Foreground="{DynamicResource cl_fg_RA_cont}"/>
                    </StackPanel>
                    <!-- Feature Section 4 -->
                    <StackPanel>
                        <DockPanel>
                            <Image x:Name="bullet_img4" Source="{DynamicResource img_green_bullet1}" Stretch="None"/>
                            <TextBlock x:Name="feature4_Name"
                                      Foreground="{DynamicResource cl_fg_primary2}"
                                       FontSize="15"
                                       Padding="8 0"
                                       Text="Multiple Features"/>
                        </DockPanel>
                        <TextBlock x:Name="feature4_desc"
                                   Text="test data"
                                   MinWidth="400"
                                   TextWrapping="Wrap"
                                   Margin="22 8"
                                   Foreground="{DynamicResource cl_fg_RA_cont}"/>
                    </StackPanel>

                </StackPanel>
            </Grid>
        </Grid>
        <Grid Grid.Row="2">
            <StackPanel>
                <DockPanel HorizontalAlignment="Center">
                    <Button x:Name="btn_Cancel"
                            Width="150"
                            Height="42"
                            Content="Cancel"
                            FontWeight="Bold"
                            FontSize="15"
                            Style="{StaticResource btn_custhover}"
                            Foreground="{DynamicResource cl_fg_btn_cont}"
                            Background="{DynamicResource cl_bg_btn1_feature}"
                            Margin="10 0"/>
                    <Button x:Name="btn_Install"
                             Width="150"
                            Height="42"
                            Content="Install Now"
                            FontWeight="Bold"
                              Style="{StaticResource btn_custhover}"
                            Foreground="{DynamicResource cl_fg_btn_cont}"
                            Background="{DynamicResource cl_bg_btn2_feature}"
                            FontSize="15"
                            Margin="10 0"/>
                </DockPanel>
                <WrapPanel HorizontalAlignment="Center" Margin="0 10">
                    <TextBlock Name="lbl_info" Foreground="{DynamicResource cl_fg_RA_cont}"
                   TextAlignment="Center"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   FontSize="16"
                   Margin="5 0 5 0"
                   FontWeight="SemiBold"
                   Text="By clicking Install, you agree to install Advance System Protector and accept its ">
                    </TextBlock>
                    <TextBlock Name="txt_EULA"
                    VerticalAlignment="Center"
                    Cursor="Hand"
                    TextDecorations="Underline"
                    FontSize="16"
                    Foreground="{DynamicResource cl_fg_abthighlight}"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                   
                    Text="EULA"
                    ></TextBlock>
                    <TextBlock Name="txtAnd" Foreground="{DynamicResource cl_fg_RA_cont}"
                       TextAlignment="Center"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       FontSize="16"
                       Margin="5 0"
                       FontWeight="SemiBold"
                       Text=" and ">
                    </TextBlock>
                    <TextBlock Name="tb_privacyPolicy"
                    FontSize="16"
                    Foreground="{DynamicResource cl_fg_abthighlight}"
                    TextDecorations="Underline"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                   
                    Cursor="Hand"
                    Text="Privacy Policy"
                   ></TextBlock>
                </WrapPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
