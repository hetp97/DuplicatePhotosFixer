<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucOneDayAfterClean"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="271" d:DesignWidth="640" >
    <UserControl.Background>
        <ImageBrush ImageSource="{DynamicResource img_bg}" />
    </UserControl.Background>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Image Source="/Resources/alert_trial.png"
               Margin="30 20 0 0"
               Width="32"
               Height="28"
               VerticalAlignment="Top"/>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <StackPanel>
                <Label x:Name="lblRegisterNowHeader"
                   Content="This free trial version will clean all duplicate photos for 24 hours only."
                   FontSize="14"
                   Margin="0 20 0 0"
                   Width="466"
                   HorizontalAlignment="Left"/>
                <Border BorderThickness="0 1  0 0" BorderBrush="Black"
                        Margin="5 -5 0 0" Width="430" 
                        HorizontalAlignment="Left"/>

            </StackPanel>
           
           
            <Grid Grid.Row="1" >
                <StackPanel Orientation="Vertical" Grid.Row="1" Margin="0 20 0 0">
                    <TextBlock x:Name="lblRegisterText" Text="Please register your copy of Duplicate Photos Fixer Pro, to clean selected duplicate photos and recover tons of space." TextWrapping="Wrap"
                          Width="464"
                               HorizontalAlignment="Left"
                           FontSize="13"/>
                    <TextBlock Height="21" />

                    <TextBlock x:Name="lblSelectOption" Text="Select an Action" 
                               FontWeight="Bold" FontSize="14" 
                                 HorizontalAlignment="Left"
                               Width="464"/>
                    <Border BorderBrush="#EDEDED" BorderThickness="0 0 0 0.5" Width="464" HorizontalAlignment="Left" Padding="0 3 0 0"/>
                
                </StackPanel>
                
            </Grid>

            <Grid Grid.Row="2">
                <StackPanel Margin="5">
                    <RadioButton x:Name="radioButton1" IsChecked="True"
                                 Content="Purchase Duplicate Photos Fixer Pro (Recommended)."
                                 Foreground="#404040" FontSize="13" Margin="3"/>
                    <RadioButton x:Name="radioButton2" IsChecked="False"
                                 Content="Continue with trial version."
                                 Foreground="#404040" FontSize="13" Margin="3"/>
                    <Button x:Name="btnNext" Content="Next" Width="120" 
                            Height="34" 
                            HorizontalAlignment="Left"
                            
                            Margin="0 0 3 0"
                            Style="{DynamicResource stl_btnScanDeleteMarked}"/>

                </StackPanel>
            </Grid>
          
        </Grid>
        
    </Grid>
</UserControl>
