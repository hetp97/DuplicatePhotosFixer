                                                <GradientStop Color="#E1E1E1" Offset="0.567" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <StackPanel>
                                        <Image x:Name="imgMoveup" Source="{DynamicResource img_arrow_up}" Stretch="None" Margin="0 5 0 0"/>
