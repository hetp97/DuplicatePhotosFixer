<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucRBOffer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="270" d:DesignWidth="780" Background="#F0F0F0">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="350"/>
            <ColumnDefinition MinWidth="430"/>
        </Grid.ColumnDefinitions>

        <StackPanel >
            <DockPanel Margin="12 5 0 0">
                <Image x:Name="img_arrow" Source="/Resources/orange-arrow.png"
                       Width="17"
                       Height="16"
                       Margin="3"/>
                <Label x:Name="label" Content="Recommended download:"
                       Foreground="Black"
                       FontSize="14"
                       Margin="3, 0, 3, 0"/>
            </DockPanel>
            <Label x:Name="label2" Content="Right Backup- Secure online storage" VerticalAlignment="Center" 
                   FontSize="16"
                   Foreground="Black"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>

            <Image x:Name="backupImage" Source="/Resources/right-backup-image.png"
                   Width="224" Height="174"/>
        </StackPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition />
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Image Source="/Resources/right-backup-logo.png" x:Name="img" Height="46" Width="73"
                       HorizontalAlignment="Left"/>
                <Grid Grid.Column="1">
                    <StackPanel HorizontalAlignment="Left">
                        <Label x:Name="right_backup" Content="Right Backup" 
                               Foreground="Black"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0 0 0 0"
                               />
                        <TextBlock x:Name="backup_desc" Foreground="Black"
                               FontSize="13"
                                   Text="The easiest, safest and most decure online storage"/>
                    </StackPanel>
                </Grid>
            </Grid>
            <Grid Grid.Row="1">
                <StackPanel Margin="0 10 0 0">
                    <StackPanel Orientation="Horizontal" Margin="0 10 0 0" >
                        <Image Source="/Resources/green_-right-mark.png" Width="14" Height="14" Margin="0 0 5 0"/>
                        <TextBlock Text="Automatically backup files to the cloud" FontSize="14" Foreground="Black"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 5 0 0">
                        <Image Source="/Resources/green_-right-mark.png" Width="14" Height="14" Margin="0 0 5 0"/>
                        <TextBlock Text="Access files anywhere you go" FontSize="14" Foreground="Black"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 5 0 0">
                        <Image Source="/Resources/green_-right-mark.png" Width="14" Height="14" Margin="0 0 5 0"/>
                        <TextBlock Text="Easily Share files with anyone" FontSize="14" Foreground="Black"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0 5 0 0">
                        <Image Source="/Resources/green_-right-mark.png" Width="14" Height="14" Margin="0 0 5 0"/>
                        <TextBlock Text="Restore files quickly even if your Device breaks down" FontSize="14" Foreground="Black"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="2">
                <Button x:Name="cbtn_InstallNow" Content="Install Now" Width="296" Height="47"
                        HorizontalAlignment="Left" Style="{DynamicResource stylGreenBtn}" />
            </Grid>
            <Grid Grid.Row="3">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                    <TextBlock Text="label1" Padding="0 0 5 0"/>
                    <TextBlock Padding="0 0 5 0">
                        <Hyperlink>Privacy Policy</Hyperlink>
                    </TextBlock>
                    <TextBlock Text="label2" Padding="0 0 5 0"/>
                    <TextBlock Padding="0 0 5 0">
                        <Hyperlink>EULA</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
