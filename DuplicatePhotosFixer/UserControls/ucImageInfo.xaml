<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucImageInfo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="336">
    <UserControl.Resources>
        <!-- Label style: right-aligned, light weight -->
        <Style x:Key="MetaLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Foreground" Value="{DynamicResource cl_fg_homeprimary}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="MinWidth" Value="120"/>
        </Style>
        <!-- Value style: left-aligned -->
        <Style x:Key="MetaValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Foreground" Value="{DynamicResource cl_fg_homeprimary}"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource bgclr_lightdark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="47"/>
            <RowDefinition Height="27"/>
            <RowDefinition Height="210"/>
            <RowDefinition Height="27"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Matching Level slider -->
        <DockPanel Grid.Row="0" Margin="18 0" VerticalAlignment="Center">
            <TextBlock x:Name="lbl_matchingLevel" Text="Matching Level : " Padding="0 0 5 0"
                       Foreground="{DynamicResource cl_fg_homeprimary}"/>
            <Slider x:Name="matchLevelSlider" Margin="0" ValueChanged="matchLevelSlider_ValueChanged"
                    TickPlacement="BottomRight" TickFrequency="0"/>
        </DockPanel>

        <!-- Preview header -->
        <Border Grid.Row="1" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1"
                Background="{DynamicResource bgclr_soliddark}">
            <TextBlock x:Name="lblPreview" Text="Preview"
                       Foreground="{DynamicResource cl_fg_homeprimary}"
                       VerticalAlignment="Center" Padding="10 0" FontWeight="SemiBold"/>
        </Border>

        <!-- Preview image -->
        <Image x:Name="previewimg" Grid.Row="2" Stretch="Uniform" Margin="5"/>

        <!-- Metadata header -->
        <Border Grid.Row="3" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1 0 1 1"
                Background="{DynamicResource bgclr_soliddark}">
            <TextBlock x:Name="lbl_metadata" Text="Metadata"
                       FontWeight="SemiBold" Foreground="{DynamicResource cl_fg_homeprimary}"
                       VerticalAlignment="Center" Padding="10 0"/>
        </Border>

        <!-- Metadata scroll area — two-column Grid (label | value) -->
        <ScrollViewer Grid.Row="4" Padding="0 4 4 4">
            <Grid Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <!-- Basic file info -->
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <!-- Image info -->
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <!-- More -->
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                </Grid.RowDefinitions>

                <!-- Row 0: File Name -->
                <TextBlock x:Name="lbl_fileName" Grid.Row="0" Grid.Column="0" Text="File Name:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_fileName"  Grid.Row="0" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 1: File Size -->
                <TextBlock x:Name="lbl_fileSize" Grid.Row="1" Grid.Column="0" Text="File Size:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_fileSize"  Grid.Row="1" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 2: File Label -->
                <TextBlock x:Name="lbl_fileLabel" Grid.Row="2" Grid.Column="0" Text="File Label:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_fileLabel"  Grid.Row="2" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 3: File Created -->
                <TextBlock x:Name="lbl_fileCreated" Grid.Row="3" Grid.Column="0" Text="File Created:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_fileCreated"  Grid.Row="3" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 4: File Modified -->
                <TextBlock x:Name="lbl_fileModified" Grid.Row="4" Grid.Column="0" Text="File Modified:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_fileModified"  Grid.Row="4" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 5: Folder Name -->
                <TextBlock x:Name="lbl_folderName" Grid.Row="5" Grid.Column="0" Text="Folder Name:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_folderName"  Grid.Row="5" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 6: Rating -->
                <TextBlock x:Name="lbl_rating" Grid.Row="6" Grid.Column="0" Text="Rating:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_rating"  Grid.Row="6" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 7: Keywords -->
                <TextBlock x:Name="lbl_keywords" Grid.Row="7" Grid.Column="0" Text="Keywords:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_keywords"  Grid.Row="7" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 8: Image Size -->
                <TextBlock x:Name="lbl_imageSize" Grid.Row="8" Grid.Column="0" Text="Image Size:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_imageSize"  Grid.Row="8" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 9: Image DPI -->
                <TextBlock x:Name="lbl_imageDPI" Grid.Row="9" Grid.Column="0" Text="Image DPI:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_imageDPI"  Grid.Row="9" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 10: Bit Depth -->
                <TextBlock x:Name="lbl_bitDepth" Grid.Row="10" Grid.Column="0" Text="Bit Depth:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_bitDepth"  Grid.Row="10" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 11: Orientation -->
                <TextBlock x:Name="lbl_orientation" Grid.Row="11" Grid.Column="0" Text="Orientation:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_orientation"  Grid.Row="11" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 12: Digital Zoom Ratio -->
                <TextBlock x:Name="lbl_digitalZoomRatio" Grid.Row="12" Grid.Column="0" Text="Digital Zoom Ratio:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_digitalZoomRatio"  Grid.Row="12" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 13: Capture Date -->
                <TextBlock x:Name="lbl_captureDate" Grid.Row="13" Grid.Column="0" Text="Capture Date:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_captureDate"  Grid.Row="13" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 14: Editing Software -->
                <TextBlock x:Name="lbl_editingSoftware" Grid.Row="14" Grid.Column="0" Text="Editing Software:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_editingSoftware"  Grid.Row="14" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 15: Exposure -->
                <TextBlock x:Name="lbl_exposure" Grid.Row="15" Grid.Column="0" Text="Exposure:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_exposure"  Grid.Row="15" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 16: Focal Length -->
                <TextBlock x:Name="lbl_focalLength" Grid.Row="16" Grid.Column="0" Text="Focal Length:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_focalLength"  Grid.Row="16" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 17: Exposure Bias -->
                <TextBlock x:Name="lbl_exposureBias" Grid.Row="17" Grid.Column="0" Text="Exposure Bias:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_exposureBias"  Grid.Row="17" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 18: ISO Speed Rating -->
                <TextBlock x:Name="lbl_ISOSpeedRating" Grid.Row="18" Grid.Column="0" Text="ISO Speed Rating:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_ISOSpeedRating"  Grid.Row="18" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 19: Exposure Mode -->
                <TextBlock x:Name="lbl_exposureMode" Grid.Row="19" Grid.Column="0" Text="Exposure Mode:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_exposureMode"  Grid.Row="19" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 20: Exposure Program -->
                <TextBlock x:Name="lbl_exposureProgram" Grid.Row="20" Grid.Column="0" Text="Exposure Program:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_exposureProgram"  Grid.Row="20" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 21: Metering Mode -->
                <TextBlock x:Name="lbl_meteringMode" Grid.Row="21" Grid.Column="0" Text="Metering Mode:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_meteringMode"  Grid.Row="21" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 22: Light Source -->
                <TextBlock x:Name="lbl_lightSource" Grid.Row="22" Grid.Column="0" Text="Light Source:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_lightSource"  Grid.Row="22" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 23: Sensing Method -->
                <TextBlock x:Name="lbl_sensingMethod" Grid.Row="23" Grid.Column="0" Text="Sensing Method:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_sensingMethod"  Grid.Row="23" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 24: Scene Capture Type -->
                <TextBlock x:Name="lbl_scenceCaptureType" Grid.Row="24" Grid.Column="0" Text="Scene Capture Type:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_scenceCaptureType"  Grid.Row="24" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 25: Camera Maker -->
                <TextBlock x:Name="lbl_cameraMaker" Grid.Row="25" Grid.Column="0" Text="Camera Maker:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_cameraMaker"  Grid.Row="25" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 26: Camera Model -->
                <TextBlock x:Name="lbl_cameraModel" Grid.Row="26" Grid.Column="0" Text="Camera Model:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_cameraModel"  Grid.Row="26" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 27: Camera Lens Model -->
                <TextBlock x:Name="lbl_cameraLensModel" Grid.Row="27" Grid.Column="0" Text="Camera Lens Model:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_cameraLensModel"  Grid.Row="27" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 28: Camera Firmware -->
                <TextBlock x:Name="lbl_cameraFirmware" Grid.Row="28" Grid.Column="0" Text="Camera Firmware:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_cameraFirmware"  Grid.Row="28" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 29: Color Model -->
                <TextBlock x:Name="lbl_colorModel" Grid.Row="29" Grid.Column="0" Text="Color Model:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_colorModel"  Grid.Row="29" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 30: Color Space -->
                <TextBlock x:Name="lbl_colorSpace" Grid.Row="30" Grid.Column="0" Text="Color Space:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_colorSpace"  Grid.Row="30" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Row 31: GPS -->
                <TextBlock x:Name="lbl_GPSLatitude" Grid.Row="31" Grid.Column="0" Text="GPS Lat/Long:" Style="{StaticResource MetaLabel}"/>
                <TextBlock x:Name="val_GPSLatitude"  Grid.Row="31" Grid.Column="1" Text="---" Style="{StaticResource MetaValue}"/>

                <!-- Hidden label controls required by LoadStrings() in code-behind -->
                <TextBlock x:Name="lbl_profileName"    Visibility="Collapsed"/>
                <TextBlock x:Name="lbl_GPSAltitude"    Visibility="Collapsed"/>
                <TextBlock x:Name="lbl_GPSLongitude"   Visibility="Collapsed"/>
                <TextBlock x:Name="val_profileName"    Visibility="Collapsed"/>
                <TextBlock x:Name="val_GPSAltitude"    Visibility="Collapsed"/>
                <TextBlock x:Name="val_GPSLongitude"   Visibility="Collapsed"/>
                <TextBlock x:Name="val_imageWidth"     Visibility="Collapsed"/>
                <TextBlock x:Name="val_imageHeight"    Visibility="Collapsed"/>

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
