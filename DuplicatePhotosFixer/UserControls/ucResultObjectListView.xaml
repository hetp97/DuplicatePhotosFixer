<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucResultObjectListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="900"
             Background="#494949">

    <UserControl.Resources>

        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,0"/>
        </Style>

        <Style x:Key="CellText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

    </UserControl.Resources>

    <!--
        Single-table layout matching photo2.png:
        - One fixed column header row
        - ItemsControl rows: either a group-header bar or a file data row
        - Parent ScrollViewer (in ucResultView) handles all scrolling
    -->
    <StackPanel>

        <!-- ══════════════ COLUMN HEADER ══════════════ -->
        <Border Background="#3A3A3A"
                Height="26"
                BorderBrush="#5F5F5F"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28"/>   <!-- checkbox -->
                    <ColumnDefinition Width="30"/>   <!-- # -->
                    <ColumnDefinition Width="200"/>  <!-- File Name -->
                    <ColumnDefinition Width="320"/>  <!-- Path -->
                    <ColumnDefinition Width="75"/>   <!-- Size -->
                    <ColumnDefinition Width="115"/>  <!-- Created -->
                    <ColumnDefinition Width="115"/>  <!-- Modified -->
                    <ColumnDefinition Width="70"/>   <!-- File Type -->
                    <ColumnDefinition Width="90"/>   <!-- Image Width -->
                    <ColumnDefinition Width="90"/>   <!-- Image Height -->
                </Grid.ColumnDefinitions>

                <!-- vertical separators -->
                <Rectangle Grid.Column="1" Width="1" HorizontalAlignment="Left" Fill="#5F5F5F"/>
                <Rectangle Grid.Column="2" Width="1" HorizontalAlignment="Left" Fill="#5F5F5F"/>
                <Rectangle Grid.Column="3" Width="1" HorizontalAlignment="Left" Fill="#5F5F5F"/>
                <Rectangle Grid.Column="4" Width="1" HorizontalAlignment="Left" Fill="#5F5F5F"/>
                <Rectangle Grid.Column="5" Width="1" HorizontalAlignment="Left" Fill="#5F5F5F"/>
                <Rectangle Grid.Column="6" Width="1" HorizontalAlignment="Left" Fill="#5F5F5F"/>
                <Rectangle Grid.Column="7" Width="1" HorizontalAlignment="Left" Fill="#5F5F5F"/>
                <Rectangle Grid.Column="8" Width="1" HorizontalAlignment="Left" Fill="#5F5F5F"/>
                <Rectangle Grid.Column="9" Width="1" HorizontalAlignment="Left" Fill="#5F5F5F"/>

                <TextBlock Grid.Column="1" Text="Group"          Style="{StaticResource HeaderText}" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="File Name"  Style="{StaticResource HeaderText}"/>
                <TextBlock Grid.Column="3" Text="Path"       Style="{StaticResource HeaderText}"/>
                <TextBlock Grid.Column="4" Text="Size"       Style="{StaticResource HeaderText}" HorizontalAlignment="Right" Padding="5,0,8,0"/>
                <TextBlock Grid.Column="5" Text="Created"    Style="{StaticResource HeaderText}"/>
                <TextBlock Grid.Column="6" Text="Modified"   Style="{StaticResource HeaderText}"/>
                <TextBlock Grid.Column="7" Text="File Type"  Style="{StaticResource HeaderText}"/>
                <TextBlock Grid.Column="8" Text="Image Width"  Style="{StaticResource HeaderText}" HorizontalAlignment="Right" Padding="5,0,8,0"/>
                <TextBlock Grid.Column="9" Text="Image Height" Style="{StaticResource HeaderText}" HorizontalAlignment="Right" Padding="5,0,8,0"/>
            </Grid>
        </Border>

        <!-- ══════════════ ROWS (group headers + file rows interleaved) ══════════════ -->
        <ItemsControl ItemsSource="{Binding DetailedRows}"
                      VirtualizingPanel.IsVirtualizing="False"
                      Background="#494949">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid>

                        <!-- ── GROUP HEADER ROW ── -->
                        <Border x:Name="groupHeader"
                                Visibility="Collapsed"
                                Background="#252526"
                                BorderBrush="#555555"
                                BorderThickness="0,0,0,1"
                                Padding="8,5">
                            <TextBlock Text="{Binding GroupLabel}"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- ── FILE DATA ROW ── -->
                        <Grid x:Name="fileRow"
                              Height="22"
                              Cursor="Arrow"
                              Tag="{Binding}"
                              MouseLeftButtonDown="FileRow_MouseLeftButtonDown">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#5A5A5A"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding File.IsHighlighted}" Value="True">
                                            <Setter Property="Background" Value="#094771"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="320"/>
                                <ColumnDefinition Width="75"/>
                                <ColumnDefinition Width="115"/>
                                <ColumnDefinition Width="115"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>

                            <!-- Checkbox — OneWay so validation runs before IsSelected is set -->
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding File.IsSelected, Mode=OneWay, FallbackValue=False}"
                                      Click="FileCheckBox_Click"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                            <!-- # (group number) -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding File.RowIndex, FallbackValue=''}"
                                       Style="{StaticResource CellText}"
                                       HorizontalAlignment="Center"/>

                            <!-- File Name -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding File.FileName, FallbackValue=''}"
                                       Style="{StaticResource CellText}"
                                       ToolTip="{Binding File.FileName}"/>

                            <!-- Path -->
                            <TextBlock Grid.Column="3"
                                       Text="{Binding File.FilePath, FallbackValue=''}"
                                       Style="{StaticResource CellText}"
                                       ToolTip="{Binding File.FilePath}"/>

                            <!-- Size -->
                            <TextBlock Grid.Column="4"
                                       Text="{Binding File.FileSizeFormatted, FallbackValue=''}"
                                       Style="{StaticResource CellText}"
                                       HorizontalAlignment="Right"
                                       Padding="5,0,8,0"/>

                            <!-- Created -->
                            <TextBlock Grid.Column="5"
                                       Text="{Binding File.CreatedDate, StringFormat='M/d/yyyy h:mm', FallbackValue=''}"
                                       Style="{StaticResource CellText}"/>

                            <!-- Modified -->
                            <TextBlock Grid.Column="6"
                                       Text="{Binding File.ModifiedDate, StringFormat='M/d/yyyy h:mm', FallbackValue=''}"
                                       Style="{StaticResource CellText}"/>

                            <!-- File Type -->
                            <TextBlock Grid.Column="7"
                                       Text="{Binding File.FileType, FallbackValue=''}"
                                       Style="{StaticResource CellText}"/>

                            <!-- Image Width -->
                            <TextBlock Grid.Column="8"
                                       Text="{Binding File.ImageWidth, FallbackValue=''}"
                                       Style="{StaticResource CellText}"
                                       HorizontalAlignment="Right"
                                       Padding="5,0,8,0"/>

                            <!-- Image Height -->
                            <TextBlock Grid.Column="9"
                                       Text="{Binding File.ImageHeight, FallbackValue=''}"
                                       Style="{StaticResource CellText}"
                                       HorizontalAlignment="Right"
                                       Padding="5,0,8,0"/>

                            <!-- Row separator -->
                            <Rectangle Grid.Column="0" Grid.ColumnSpan="10"
                                       Height="1" VerticalAlignment="Bottom"
                                       Fill="#444444"/>
                        </Grid>

                    </Grid>

                    <!-- Switch: show group header OR file row based on IsGroupHeader -->
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsGroupHeader}" Value="True">
                            <Setter TargetName="groupHeader" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="fileRow"     Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </StackPanel>
</UserControl>
