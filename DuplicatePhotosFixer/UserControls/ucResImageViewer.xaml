<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucResImageViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <ItemsControl x:Name="groupsItemsControl"
                  ItemsSource="{Binding DuplicateGroups}"
                  Background="Transparent">
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <!-- Each Duplicate Group -->
                <Border Background="{DynamicResource bgrclr_whitish}"
                        BorderBrush="{DynamicResource clr_grayborder}"
                        BorderThickness="1"
                        Margin="10"
                        CornerRadius="2">
                    <StackPanel>
                        <!-- Group Header -->
                        <Border Background="{DynamicResource bgclr_dark}"
                                BorderBrush="{DynamicResource clr_darkborder}"
                                BorderThickness="0 0 0 1"
                                Padding="10 8">
                            <DockPanel>
                                <TextBlock Text="{Binding GroupName}"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Foreground="{DynamicResource cl_fg_primary}"/>
                                <TextBlock DockPanel.Dock="Right"
                                           FontSize="14"
                                           Foreground="{DynamicResource cl_fg_primary}">
                                    <Run Text=" |"/>
                                    <Run Text="{Binding PhotoCount, Mode=OneWay}"/>
                                    <Run Text="Photos"/>
                                </TextBlock>
                            </DockPanel>
                        </Border>

                        <!-- Photos Grid -->
                        <ItemsControl ItemsSource="{Binding Photos}"
                                      Margin="10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"
                                     ItemWidth="250"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Individual Photo Card -->
                                    <Border x:Name="photoCardBorder"
                                            Background="White"
                                            Width="240"
                                            BorderThickness="1"
                                            Margin="5"
                                            CornerRadius="2"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="PhotoCard_MouseLeftButtonDown"
                                            Tag="{Binding}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="{DynamicResource clr_grayborder}"/>
                                                <Style.Triggers>
                                                    <!-- Blue border when this file is the SelectedFile in the ViewModel -->
                                                    <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#1E90FF"/>
                                                        <Setter Property="BorderThickness" Value="3"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource frg_clr_blue}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="200"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Image Preview -->
                                            <Border Grid.Row="0"
                                                    Background="#F5F5F5"
                                                    BorderBrush="{DynamicResource clr_grayborder}"
                                                    BorderThickness="0 0 0 1">
                                                <Grid>
                                                    <Image x:Name="imgPreview"
                                                           Source="{Binding ImageSource}"
                                                           Stretch="Uniform"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           MaxHeight="190"
                                                           MaxWidth="200"/>

                                                    <!-- Fallback if no thumbnail -->
                                                    <TextBlock Text="No Preview"
                                                               FontSize="14"
                                                               Foreground="Gray"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ImageSource}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>



                                                </Grid>
                                            </Border>

                                            <!-- File Info -->
                                            <Border Grid.Row="1"
                                                     Background="#6F8F4E"
                                                    Padding="6">        

                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- File Name (TOP) -->
                                                    <TextBlock Grid.Row="0"
           Text="{Binding FileName}"
           FontSize="12"
           FontWeight="SemiBold"
           Foreground="White"
           TextTrimming="CharacterEllipsis"
           ToolTip="{Binding FileName}"/>

                                                    <!-- Checkbox + Date + Size (BOTTOM) -->
                                                    <Grid Grid.Row="1" Margin="0 5 0 0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Checkbox -->
                                                        <CheckBox Grid.Column="0"
              IsChecked="{Binding IsSelected, Mode=OneWay}"
              Width="16"
              Height="16"
              VerticalAlignment="Center"
              Margin="0 0 8 0"
              Background="White"
              Click="PhotoCheckBox_Click"/>

                                                        <!-- Date -->
                                                        <TextBlock Grid.Column="1"
               Text="{Binding ModifiedDate, StringFormat='MMM dd, yyyy'}"
               FontSize="12"
               Foreground="White"
               VerticalAlignment="Center"/>

                                                        <!-- File Size -->
                                                        <TextBlock Grid.Column="2"
               Text="{Binding FileSizeFormatted}"
               FontSize="12"
               Foreground="White"
               VerticalAlignment="Center"/>
                                                    </Grid>




                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
