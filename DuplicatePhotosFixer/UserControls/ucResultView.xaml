<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucResultView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
             mc:Ignorable="d"
             d:DesignHeight="684" d:DesignWidth="998" >
   
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="27"/>
            <RowDefinition Height="51"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="336"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="49"/>
                    <RowDefinition/>

                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="0 1 0 1">
                    <Border.Background>
                        <ImageBrush ImageSource="{DynamicResource img_top_header}"/>
                    </Border.Background>

                    <Grid >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition MinWidth="92" Width="Auto"/>
                            <ColumnDefinition MinWidth="98" Width="Auto"/>
                            <ColumnDefinition MinWidth="98" Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition MinWidth="98" Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!--<cust:ImageButton x:Name="autoMarkbtn" Grid.Column="1" 
                                          Image="{DynamicResource img_automark}"  
                                          HoverImage="{DynamicResource img_automark_over}"
                                          SelectedImage="{DynamicResource img_automark}"
                                          FontSize="12" 
                                          Foreground="#FFF"
                                          Content="Auto Mark"  
                                          Visibility="Visible"
                                          Style="{DynamicResource imgBtn_TopImageText}"/>-->
                        
                        <Button Grid.Column="1" x:Name="btn_autoMark" VerticalContentAlignment="Bottom" Content="Auto Mark" FontWeight="SemiBold" FontSize="12"
                            Foreground="{DynamicResource cl_fg_primary}" BorderThickness="1 0 1 0" BorderBrush="{DynamicResource clr_darkborder}" 
                                Click="Button_Click_1" >
                            <Button.Style>
                                <Style  TargetType="Button">
                                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="1 0 1 0"
                                                    Background="{TemplateBinding Background}">
                                                    <ContentPresenter VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <Button.Background>
                                <ImageBrush ImageSource="{DynamicResource img_automark}" Stretch="Uniform"/>
                            </Button.Background>
            
                        </Button>

                        <!--<cust:ImageButton x:Name="unMarkbtn" Grid.Column="2" 
                                          Image="{DynamicResource img_mark}"  
                                          HoverImage="{DynamicResource img_mark_over}"
                                          SelectedImage="{DynamicResource img_mark}"                                       
                                          Content="UnMark All"  
                                          Visibility="Visible"
                                          Style="{DynamicResource imgBtn_TopImageText}" Click="unMarkbtn_Click"/>-->

                        <Button x:Name="btn_unMarkAll" Grid.Column="2" Margin="0" VerticalContentAlignment="Bottom" Content="UnMark all" FontWeight="SemiBold" FontSize="12"
                            Foreground="{DynamicResource cl_fg_primary}"  BorderThickness="0" Click="Button_Click_2" >
                            <Button.Style>
                                <Style  TargetType="Button">
                                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="1 0 1 0"
                                                    Background="{TemplateBinding Background}">
                                                    <ContentPresenter VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <ImageBrush ImageSource="{DynamicResource img_mark_over}"></ImageBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <Button.Background>
                                <ImageBrush ImageSource="{DynamicResource img_mark}" Stretch="Uniform"/>
                            </Button.Background>
                        </Button>

                        <Border Grid.Column="3" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1 0 1 0">
                            <DockPanel  VerticalAlignment="Center" HorizontalAlignment="Right" Margin="40 0">
                                <TextBlock x:Name="lblSelectionAssitant" Text="Selection Assistant" FontSize="13" Foreground="{DynamicResource frgclr_whitish}" VerticalAlignment="Center"/>
                                <cust:ImageButton
                            x:Name="btn_selectionAssistanceOptionA"
                            Height="25"
                            ToolTip="Select Assistant"
                            Width="25"
                            Margin="10 0 5 0"
                            Style="{DynamicResource imageButton}"
                            Image="{DynamicResource img_selection_assistant_A_icon}"
                            HoverImage="{DynamicResource img_selection_assistant_A_icon_hover}"
                            SelectedImage="{DynamicResource img_selection_assistant_A_icon}" Click="btn_selectionAssistanceOptionA_Click" />
                                <cust:ImageButton
                            x:Name="btn_selectionAssistanceOptionB"
                            Height="25"
                            ToolTip="Clear Cache"
                            Width="25"
                            Margin="5 0"
                            Style="{DynamicResource imageButton}"
                            Image="{DynamicResource img_selection_assistant_B_icon}"
                            HoverImage="{DynamicResource img_selection_assistant_B_icon_hover}"
                            SelectedImage="{DynamicResource img_selection_assistant_B_icon}" Click="btn_selectionAssistanceOptionB_Click" />

                            </DockPanel>
                        </Border >


                        <Grid Grid.Column="4">
                            <DockPanel HorizontalAlignment="Right" Width="98" >
                                <Button x:Name="imageViewbtn" Margin="15 0 0 0" VerticalContentAlignment="Bottom" FontWeight="SemiBold" FontSize="12" 
                            Foreground="{DynamicResource cl_fg_primary}" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="0"
                            Background="Transparent" Click="ImgeView_change">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="White" />
                                            <Setter Property="TextBlock.TextAlignment" Value="Center" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bdr_main"  BorderThickness="1" Background="Transparent">
                                                            <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="White">
                                                            </ContentPresenter>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                              
                                                                <Setter Property="Background" TargetName="bdr_main" Value="Transparent"></Setter>
                                                            </Trigger>
                                                            <!--<Trigger Property="IsPressed" Value="true">
                                                                <Setter Property="BorderBrush" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                                <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                                <Setter Property="Background" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                                                <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                                            </Trigger>-->
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel>
                                        <Image Source="{DynamicResource img_imageView}" Height="25"/>
                                        <TextBlock x:Name="btnView" Text="Image View"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="detailedViewbtn" Margin="13 0 0 0" VerticalContentAlignment="Bottom" FontWeight="SemiBold" FontSize="12" Visibility="Collapsed"
                            Foreground="{DynamicResource cl_fg_primary}" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="0"
                            Background="Transparent" Click="Detailed_View_Change" >
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="White" />
                                            <Setter Property="TextBlock.TextAlignment" Value="Center" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bdr_main"  BorderThickness="1" Background="Transparent">
                                                            <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="White">
                                                            </ContentPresenter>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">

                                                                <Setter Property="Background" TargetName="bdr_main" Value="Transparent"></Setter>
                                                            </Trigger>
                                                            <!--<Trigger Property="IsPressed" Value="true">
                                                                <Setter Property="BorderBrush" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                                <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                                <Setter Property="Background" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                                                <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                                            </Trigger>-->
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel>
                                        <Image Source="{DynamicResource img_detailedView}" Height="25"/>
                                        <TextBlock Text="Detailed View"/>
                                    </StackPanel>

                                </Button>
                            </DockPanel>
                           
                            <Popup x:Name="resultViewGridSelection"  IsOpen="False" Placement="Mouse" StaysOpen="False">
                                <StackPanel>
                                    <Button x:Name="btnImageView" Height="25" BorderThickness="0" Visibility="Collapsed"
                                    BorderBrush="Transparent" Click="btnImageView_Click" >
                                        <DockPanel Background="White" >
                                            <Border Background="#F8F8F8">
                                                <Image Source="{DynamicResource img_imageViewIcon}" Margin="5" />
                                            </Border>
                                            <Border BorderBrush="{DynamicResource clr_grayborder}" BorderThickness="0 0 0 0">
                                                <TextBlock Text="ImageView" Padding="0" Width="150" Background="White"
                                                   VerticalAlignment="Center" Margin="5 0 0 0"/>
                                            </Border>
                                        </DockPanel>
                                    </Button>

                                    <Button x:Name="btnDetailedView" Height="25" BorderThickness="0" 
                                    BorderBrush="Transparent" Click="btnDetailedView_Click" >
                                        <DockPanel Background="White" >
                                            <Border Background="#F8F8F8">
                                                <Image Source="{DynamicResource img_detailed_view_icon}" Margin="5"    />
                                            </Border>
                                            <Border BorderBrush="{DynamicResource clr_grayborder}" BorderThickness="0 0 0 0">
                                                <TextBlock Text="Detailed View" Padding="0" Width="150" Background="White"
                                                   VerticalAlignment="Center" Margin="5 0 0 0"/>
                                            </Border>
                                        </DockPanel>
                                    </Button>
                                </StackPanel>
                            </Popup>
                        </Grid>

                    </Grid>
                </Border>
                <Grid Grid.Row="1" Background="{DynamicResource bgrclr_gray}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Background="{DynamicResource bgrclr_whitish}" Margin="10 5">
                        <Image Source="{DynamicResource img_alert_icon_trans}" Height="24" Width="24" Margin="10 0"/>
                        <DockPanel VerticalAlignment="Center" Margin="5 0">
                            <TextBlock x:Name="lbl_DuplicatePhotosSubHeadingText" Text="Duplicate Photos found : " FontWeight="Bold" FontSize="15" Foreground="#262626"/>
                            <TextBlock x:Name="lbl_DuplicatePhotosCount" Text="0" Foreground="#2F6FDB" FontWeight="Bold" FontSize="15" Padding="5 0" x:FieldModifier="public"/>
                        </DockPanel>
                        <Image Source="{DynamicResource img_seprator}" Width="2" Height="25" Margin="5"/>
                        <DockPanel VerticalAlignment="Center" Margin="5 0">
                            <TextBlock x:Name="lbl_SaveSpaceSubHeadingText" Text="Space to be Saved : " FontWeight="Bold" FontSize="15" Foreground="#262626"/>
                            <TextBlock x:Name="lbl_SpaceSavedValue" Text="0 KB" Foreground="#2F6FDB" FontWeight="Bold" FontSize="15" Padding="5 0" x:FieldModifier="public"/>
                        </DockPanel>
                        <DockPanel>
                            <Button Width="Auto" Height="30" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="DeleteMarked_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="White" />
                                        <Setter Property="TextBlock.TextAlignment" Value="Center" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bdr_main"  BorderThickness="1" Background="Transparent">
                                                        <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="White">
                                                        </ContentPresenter>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">

                                                            <Setter Property="Background" TargetName="bdr_main" Value="Transparent"></Setter>
                                                        </Trigger>
                                                        <!--<Trigger Property="IsPressed" Value="true">
                                                                <Setter Property="BorderBrush" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                                <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                                <Setter Property="Background" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                                                <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                                            </Trigger>-->
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <TextBlock x:Name="llbl_deleteMarked" Text="Delete Marked" TextDecorations="Underline" Foreground="{DynamicResource frg_clr_blue}" FontWeight="Bold" Padding="0 0 5 0" FontSize="15"/>
                            </Button>
                        </DockPanel>
                    </DockPanel>
                    <!-- Detailed view: horizontal scroll enabled for wide table columns -->
                    <ScrollViewer x:Name="svDetailed" Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed">
                        <local:ucResultObjectListView x:Name="ucDetailedView"/>
                    </ScrollViewer>

                    <!-- Image view: horizontal scroll disabled so WrapPanel fills width and wraps into columns -->
                    <ScrollViewer x:Name="svImage" Grid.Row="1"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="Visible">
                        <local:ucResImageViewer x:Name="ucImageView"/>
                    </ScrollViewer>
                </Grid>
            </Grid>
            <local:ucImageInfo x:Name="ucInfoPanel" Grid.Column="1" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1 1 1 0"/>
        </Grid>
        <Border Grid.Row="1" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="0 1 0 0">
            <Border.Background>
                <ImageBrush ImageSource="{DynamicResource img_top_header}"/>
            </Border.Background>
            <DockPanel Background="{DynamicResource bgclr_dark}">
                <!-- Left: "X duplicate photos in Y groups" -->
                <TextBlock x:Name="lbl_footerDuplicateInfo"
                           Width="229" Padding="20 0"
                           Foreground="{DynamicResource cl_fg_primary}"
                           VerticalAlignment="Center"
                           Text="{Binding DuplicateSummary}"/>

                <!-- Middle: "X Marked (Y MB)" -->
                <Border BorderBrush="#000000" BorderThickness="1 0 1 0">
                    <TextBlock x:Name="lbl_footerMarked"
                               Width="200" Padding="20 0"
                               Foreground="{DynamicResource cl_fg_primary}"
                               VerticalAlignment="Center"
                               Text="{Binding MarkedSummary}"/>
                </Border>

                <!-- Right: highlighted file path -->
                <DockPanel DockPanel.Dock="Right" Margin="20 0">
                    <Image Source="{DynamicResource img_btnfolder}" Height="15" Width="15"/>
                    <TextBlock x:Name="lbl_footerPath"
                               Padding="5 0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource cl_fg_primary}"
                               Text="{Binding SelectedFilePath}"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </DockPanel>
        </Border>
        <Border Grid.Row="2" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="0 1 0 0">
            <Border.Background>
                <ImageBrush ImageSource="{DynamicResource img_top_header}"/>
            </Border.Background>
            <Grid Grid.Row="2" Height="51" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"  Height="32" Width="82" Content="Back" HorizontalAlignment="Left" Margin="20 0"
                    BorderThickness="0" Style="{DynamicResource stl_btnBack}" Click="Button_Click" >
                    <Button.Background>
                        <ImageBrush ImageSource="{DynamicResource img_btnback}"/>
                    </Button.Background>
                </Button>
                <Button Grid.Column="1"  Height="34" Width="235" Content="Delete Marked"
                    HorizontalAlignment="Center" Style="{DynamicResource stl_btnScanDeleteMarked}" Click="DeleteMarked_Click"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
