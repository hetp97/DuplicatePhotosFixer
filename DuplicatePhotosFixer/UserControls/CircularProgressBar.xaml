<UserControl x:Class="DuplicatePhotosFixer.UserControls.CircularProgressBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <!-- Background Circle -->
        <Ellipse Stroke="{Binding BackgroundStroke, RelativeSource={RelativeSource AncestorType=UserControl}}"
                 StrokeThickness="{Binding BackgroundStrokeThickness, RelativeSource={RelativeSource AncestorType=UserControl}}"
                 Opacity="0.3"/>

        <!-- Progress Arc -->
        <Path x:Name="ProgressPath"
              Stroke="{Binding ForegroundStroke, RelativeSource={RelativeSource AncestorType=UserControl}}"
              StrokeThickness="{Binding StrokeThickness, RelativeSource={RelativeSource AncestorType=UserControl}}"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Round"
              Fill="Transparent" />

        <!-- Percentage Text -->
        <!--<TextBlock Text="{Binding ProgressText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontWeight="Bold"
                   FontSize="18"/>-->
    </Grid>
</UserControl>
