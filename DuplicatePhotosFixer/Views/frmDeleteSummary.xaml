<Window x:Class="DuplicatePhotosFixer.Views.frmDeleteSummary"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" AllowsTransparency="True" ResizeMode="NoResize"
        Title="Duplicate Photos Fixer Pro" Height="340" Width="560"
        WindowStyle="None" Background="#2D2D30"
        WindowStartupLocation="CenterOwner">

    <Border BorderBrush="#555555" BorderThickness="1" CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#3C3C3C" CornerRadius="4 4 0 0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel Margin="10 0">
                    <Image Source="{DynamicResource img_update_dpf}" Width="22" Height="22"
                           VerticalAlignment="Center" Margin="0 0 8 0"/>
                    <TextBlock Text="Duplicate Photos Fixer Pro" Foreground="White"
                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button x:Name="btn_close" DockPanel.Dock="Right" Content="✕"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="28" Height="28" FontSize="14"
                            Foreground="White" Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Click="btn_close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#E81123"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </DockPanel>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Circle Gauge -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid Width="170" Height="170">
                        <!-- Background circle -->
                        <Ellipse Width="170" Height="170" Stroke="#3C3C3C" StrokeThickness="14" Fill="Transparent"/>
                        <!-- Foreground circle (orange) -->
                        <Ellipse Width="170" Height="170" Stroke="#F5A623" StrokeThickness="14" Fill="Transparent"/>
                        <!-- Center text -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Total" Foreground="#AAAAAA" FontSize="13"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="txt_totalCount" Text="0" Foreground="White"
                                       FontSize="38" FontWeight="Bold" HorizontalAlignment="Center"
                                       Margin="0 -4 0 0"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock x:Name="txt_totalSize" Text="Size: 0 KB" Foreground="#AAAAAA"
                               FontSize="13" HorizontalAlignment="Center" Margin="0 8 0 0"/>
                </StackPanel>

                <!-- Right: Stats + Button -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10 0 0 0">
                    <!-- Duplicate Photos Found -->
                    <DockPanel Margin="0 0 0 8">
                        <TextBlock Text="Duplicate Photos Found:  " Foreground="White" FontSize="14"/>
                        <TextBlock x:Name="txt_dupCount" Text="0" Foreground="#E04040"
                                   FontSize="14" FontWeight="Bold"/>
                    </DockPanel>

                    <!-- Space to be Saved -->
                    <DockPanel Margin="0 0 0 20">
                        <TextBlock Text="Space to be Saved:  " Foreground="White" FontSize="14"/>
                        <TextBlock x:Name="txt_spaceSaved" Text="0 KB" Foreground="#E04040"
                                   FontSize="14" FontWeight="Bold"/>
                    </DockPanel>

                    <!-- Remove Photos button -->
                    <Button x:Name="btn_removePhotos" Height="38" Cursor="Hand"
                            Click="btn_removePhotos_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bdr" Background="#4CAF50" CornerRadius="4"
                                        Padding="20 6">
                                    <TextBlock Text="Remove Photos" Foreground="White"
                                               FontSize="15" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bdr" Property="Background" Value="#45A049"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Info text -->
                    <TextBlock Text="To remove all duplicate photos, first click the Trash icon next to each group on the Scan result screen."
                               Foreground="#999999" FontSize="11" TextWrapping="Wrap"
                               Margin="0 14 0 0"/>

                    <!-- Purchase section -->
                    <TextBlock Text="Purchase Duplicate Photos Fixer Pro to:"
                               Foreground="White" FontSize="12" FontWeight="SemiBold"
                               Margin="0 14 0 6"/>
                    <TextBlock Text="✔ Remove all duplicate photos" Foreground="#BBBBBB" FontSize="11" Margin="4 1"/>
                    <TextBlock Text="✔ Heal corrupt photos" Foreground="#BBBBBB" FontSize="11" Margin="4 1"/>
                    <TextBlock Text="✔ Organize your photo collection" Foreground="#BBBBBB" FontSize="11" Margin="4 1"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
