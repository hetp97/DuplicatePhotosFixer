<Window x:Class="DuplicatePhotosFixer.Views.frmUpdator"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        mc:Ignorable="d"
        Height="322" Width="525">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="67"/>
        </Grid.RowDefinitions>

        <StackPanel VerticalAlignment="Center">
            <Image x:Name="img_device" Width="38"
                   Height="38"
                   Source="{DynamicResource img_device}"
                   HorizontalAlignment="Left"
                   Margin="20 0 0 0"/>

            <TextBlock x:Name="lblupdatetitle1" 
                        
                       Width="463"
                       Height="31"
                       />
            <ProgressBar x:Name="progUpdate"
                         Width="460" Height="23"/>
        </StackPanel>
        

        <Grid Grid.Row="1" >
            <Grid.Background>
                <LinearGradientBrush  StartPoint="0,0" EndPoint="0 ,1">
                    <GradientStop Color="#F2F2F2" Offset="0.200"/>
                    <GradientStop Color="#F1F1F1" Offset="0"/>
                    <GradientStop Color="#F1F1F1" Offset="0"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Button x:Name="btn_cancel" Width="75" Height="23"
                    HorizontalAlignment="Right"
                    Margin="0 0 15 0"/>
        </Grid>
    </Grid>
</Window>
