<Window x:Class="DuplicatePhotosFixer.Views.frmDeleteConfirm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" ResizeMode="NoResize"
        Title="Duplicate Photos Fixer Pro" Height="210" Width="430"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterOwner" Background="#2D2D30">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Info icon -->
        <Image Grid.Column="0" Grid.Row="0"
               Source="{DynamicResource img_alert_icon_trans}"
               Width="36" Height="36" VerticalAlignment="Top" Margin="0 4 0 0"/>

        <!-- Message text -->
        <StackPanel Grid.Column="1" Grid.Row="0" Margin="4 0 0 0">
            <TextBlock Text="Do you really want to delete the duplicate photos. Deleted photos will be moved to Recycle Bin!"
                       Foreground="White" FontSize="13" TextWrapping="Wrap"
                       Margin="0 0 0 10"/>
            <TextBlock Text="If photos are located on network drive, they are deleted permanently."
                       Foreground="#CCCCCC" FontSize="12" TextWrapping="Wrap"
                       Margin="0 0 0 14"/>
            <CheckBox x:Name="chk_dontShowAgain" Content="Don't show again"
                      Foreground="#BBBBBB" FontSize="12"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                    Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0 12 0 0">
            <Button x:Name="btn_cancel" Content="Cancel" Width="90" Height="30"
                    Margin="0 0 10 0" FontSize="12" Cursor="Hand"
                    Background="#555555" Foreground="White" BorderThickness="0"
                    Click="btn_cancel_Click"/>
            <Button x:Name="btn_ok" Content="OK" Width="90" Height="30"
                    FontSize="12" Cursor="Hand"
                    Click="btn_ok_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="#0078D7" CornerRadius="2"
                                Padding="8 4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#1A8CE0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
