<Window x:Class="DuplicatePhotosFixer.Views.frmDeleteProgress"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" ResizeMode="NoResize"
        Title="Duplicate Photos Fixer Pro" Height="260" Width="430"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterOwner" Background="#F0F0F0">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Left: Circle animation area -->
        <Grid Grid.Column="0" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Ellipse x:Name="progressRing" Width="100" Height="100"
                     Stroke="#CCCCCC" StrokeThickness="8" Fill="Transparent"
                     StrokeDashArray="3.927 1.309"
                     RenderTransformOrigin="0.5 0.5">
                <Ellipse.RenderTransform>
                    <RotateTransform x:Name="ringRotation" Angle="0"/>
                </Ellipse.RenderTransform>
            </Ellipse>
            <TextBlock Text="Deleting" Foreground="#666666" FontSize="13"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- Right: Status info -->
        <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Center" Margin="10 0 0 0">
            <TextBlock Text="Deleting photos..." FontSize="16" FontWeight="Bold"
                       Foreground="#333333" Margin="0 0 0 4"/>
            <TextBlock Text="Deleting marked photos please wait..."
                       Foreground="#777777" FontSize="12" Margin="0 0 0 18"/>

            <!-- Delete Marked count -->
            <DockPanel Margin="0 0 0 8">
                <Image Source="{DynamicResource img_mark}" Width="20" Height="20" Margin="0 0 8 0"/>
                <StackPanel>
                    <TextBlock x:Name="txt_deleteMarkedCount" Text="0"
                               FontSize="16" FontWeight="Bold" Foreground="#333333"/>
                    <TextBlock Text="Delete Marked" Foreground="#888888" FontSize="11"/>
                </StackPanel>
            </DockPanel>

            <!-- Marked Photos Deleted count -->
            <DockPanel>
                <Image Source="{DynamicResource img_mark}" Width="20" Height="20" Margin="0 0 8 0"/>
                <StackPanel>
                    <TextBlock x:Name="txt_deletedCount" Text="0"
                               FontSize="16" FontWeight="Bold" Foreground="#333333"/>
                    <TextBlock Text="Marked Photos Deleted" Foreground="#888888" FontSize="11"/>
                </StackPanel>
            </DockPanel>
        </StackPanel>

        <!-- Cancel button -->
        <Button x:Name="btn_cancel" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                Content="Cancel" Width="90" Height="30"
                HorizontalAlignment="Right" Margin="0 14 0 0"
                FontSize="12" Cursor="Hand"
                Background="#E0E0E0" Foreground="#333333" BorderBrush="#BBBBBB" BorderThickness="1"
                Click="btn_cancel_Click"/>
    </Grid>
</Window>
