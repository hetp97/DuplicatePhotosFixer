<Window x:Class="DuplicatePhotosFixer.Views.frmAfterScan"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
        xmlns:cpb="clr-namespace:DuplicatePhotosFixer.CustomExtendClass"
        mc:Ignorable="d" AllowsTransparency="True" ResizeMode="NoResize"
        Title="frmAfterScan" x:Name="frmAfterScanMark" Height="300" Width="620"
        WindowStyle="None" Background="{DynamicResource cl_bg_theme}" 
        WindowStartupLocation="CenterScreen"
        Loaded="frmAfterScanMark_Loaded">
    <Window.Resources>
        <Style x:Key="CircularProgressBar" TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Ellipse  Width="180" Height="180" Stroke="{DynamicResource cl_bg_Stroke}" Fill="#454545" StrokeThickness="20" Margin="10 0">
                            <Ellipse.StrokeDashArray>
                                <DoubleCollection>1 0</DoubleCollection>
                            </Ellipse.StrokeDashArray>
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="rotateTransform" CenterX="100" CenterY="100" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border BorderBrush="{DynamicResource cl_br_AfterSacn}" BorderThickness="0 0 0 1">
            <DockPanel>
                <Image x:Name="dpf_logo" Source="{DynamicResource img_update_dpf}" 
                       DockPanel.Dock="Left" Margin="10 0 5 0" Width="30" Height="25" 
                       VerticalAlignment="Center"/>
                <cust:ImageButton
                    x:Name="btn_close"
                    Width="10"
                    Height="10"
                    DockPanel.Dock="Right"
                    Margin="10 0 10 0"
                    Style="{DynamicResource imageButton}"
                    Image="{DynamicResource img_close_plain}"
                    HoverImage="{DynamicResource img_close_plain}"
                    SelectedImage="{DynamicResource img_close_plain}" 
                    Click="btn_close_Click"/>
                <Label DockPanel.Dock="Left" x:Name="lbl_heading" 
                       FontSize="15" VerticalAlignment="Center" 
                       Content="Duplicate Photo Fixer Pro" 
                       Margin="0, 0, 2, 0" 
                       Foreground="{DynamicResource cl_fg_setHeading}"/>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top: progress + info -->
            <Grid Grid.Row="0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Side - Circular Progress -->
                <Grid Grid.Column="0">
                    <cust:CircularProgressBar
                        x:Name="progressBar1"
                        Width="165"
                        Height="165"
                       VerticalAlignment="Center"
                       Margin="10 0 10 0"
                        Value="100"
                        Maximum="100"
                        BarColor1="#2196F3"
                        BarColor2="#2196F3"
                        BarWidth="15"
                        LineColor="#3A3A3A"
                        LineWidth="10"
                        ProgressShapeValue="Flat"
                        TextModeValue="None"
                        Background="#2D2D2D"/>

                    <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                        <TextBlock
                            Text="100%"
                            FontSize="25"
                            FontWeight="Bold"
                            Foreground="White"
                            Margin="0,0,0,0"/>
                        <TextBlock x:Name="txt_progressUpdate"
                            Text="Scanned"
                            FontSize="15"
                            Margin="5 0 0 0"
                            Foreground="White"/>
                    </StackPanel>
                </Grid>

                <!-- Right Side - Result Content -->
                <Grid Grid.Column="1" Margin="10 0 20 0">
                    <StackPanel VerticalAlignment="Center" Margin="0 0 20 0">

                        <!-- Duplicate Photos Found INLINE -->
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                                <TextBlock
                Text="Duplicate Photos Found:"
                Foreground="White"
                FontSize="22"
                FontWeight="SemiBold"/>

                            <TextBlock
                Text="{Binding DuplicateCount}"
                Foreground="#00E676"
                FontSize="22"
                FontWeight="Bold"
                Margin="10 0 0 0"/> 
                        </StackPanel>

                        <!-- Description -->
                        <TextBlock
        Text="{Binding Description}"
        FontSize="14"
        Foreground="#CFCFCF"
        TextWrapping="Wrap"
        LineHeight="22"
        Width="360"
        Margin="0 0 0 20"/>

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">

                            <!-- Select Manually -->
                            <Button x:Name="btn_selectManually"
            Content="Select Manually"
            Width="160"
            Height="45"
            FontWeight="SemiBold"
            Foreground="White"
            Margin="0 0 15 0"
            Click="btn_selectManually_Click">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#2D9CDB" Offset="0"/>
                                        <GradientStop Color="#1C6ED5" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <Button.BorderThickness>0</Button.BorderThickness>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="6"
                        Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Auto Mark -->
                            <Button x:Name="btn_autoMark"
            Content="Auto Mark"
            Width="160"
            Height="45"
            FontWeight="SemiBold"
            Foreground="White"
            Click="btn_autoMark_Click">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#00C853" Offset="0"/>
                                        <GradientStop Color="#00A844" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <Button.BorderThickness>0</Button.BorderThickness>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="6"
                        Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>



        </Grid>
    </Grid>
</Window>