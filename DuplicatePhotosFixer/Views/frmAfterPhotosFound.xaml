<Window x:Class="DuplicatePhotosFixer.Views.frmAfterPhotosFound"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        mc:Ignorable="d"
        Title="frmAfterPhotosFound" Height="484" Width="700" WindowStyle="None" AllowsTransparency="True" Background="{DynamicResource cl_bg_theme}">
 
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="{DynamicResource bgclr_soliddark}">
            <DockPanel>
               
                <Button DockPanel.Dock="Right"  Margin="0,0,20,0" Background="Transparent" BorderBrush="Transparent" >
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="TextBlock.TextAlignment" Value="Center" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bdr_main">
                                            <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"                                                              
                                                              TextElement.FontSize="13"
                                                              TextElement.Foreground="White">
                                            </ContentPresenter>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" TargetName="bdr_main" Value="#3FB3E6">
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="true">
                                                <Setter Property="Background" TargetName="bdr_main" Value="#178BBE">
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                                <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>

                    <Image Source="{DynamicResource img_close_plain}" Stretch="None"/>
                </Button>
                <Label DockPanel.Dock="Left" x:Name="lbl_heading" FontSize="15" VerticalAlignment="Center" Content="Duplicate Photos Fixer Pro" Margin="2, 0, 2, 0" Foreground="#c1c1c1" />
            </DockPanel>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="295"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Margin="0 40 0 0">
                <StackPanel>
                    <Image x:Name="img_duplicatee_bg" Source="{DynamicResource img_duplicate_number_bg_orange}" Margin="0 00 0 20" Stretch="None"/>
                    <!--<TextBlock >
                        <TextBlock.Background>
                            <ImageBrush ImageSource="{DynamicResource img_duplicate_number_bg_orange}" Stretch="None"/>
                        </TextBlock.Background>
                    </TextBlock>-->
                    <TextBlock x:Name="txt_lbl" Foreground="#BdBdBd" FontSize="14" FontWeight="Regular" HorizontalAlignment="Center" Margin="0 30 0 0">
                        No-Risk Money Back Guarantee <LineBreak/>Immediate Download after Purchase, <LineBreak/> World Class Customer Support.
                    </TextBlock>
                </StackPanel>
               
            </Grid>
            <Image x:Name="divider" Source="{DynamicResource img_divider-line}" HorizontalAlignment="Right" Height="500"/>
            <Grid Grid.Column="1" Margin="30 40 0 0">
                <StackPanel>
                <TextBlock x:Name="txt_info" Foreground="#DbDbDb" FontSize="14" FontWeight="Regular">
                    <Bold Foreground="#fff" FontWeight="SemiBold" >{0}</Bold> Duplicate Photos were found. To remove upto 15 <LineBreak/> duplicate and 15 and similar looking photos, click on <LineBreak/> the below button.
                </TextBlock>
                    <Button x:Name="remove_btn" Width="267" Height="45" Margin="0 20 " BorderBrush="Transparent"
                            Content="Remove 10 Photos" Style="{DynamicResource stl_btnScanForDuplicates}" 
                           />
                    <TextBlock x:Name="lbl_header" Text="Purchase Dupliacte Photos Fixer Pro to:" Foreground="#fefefe" FontWeight="Regular"/>
                    <DockPanel Margin="0 10 0 0">
                        <Image x:Name="img1" Source="{DynamicResource img_green_bullet }" Stretch="None" Margin="0 0 8 0"/>
                        <TextBlock Foreground="#fefefe" FontSize="13" FontWeight="Regular" Text="Remove all duplicate photos"/>
                    </DockPanel>
                    <DockPanel Margin="0 10 0 0">
                        <Image x:Name="img2" Source="{DynamicResource img_green_bullet }" Stretch="None" Margin="0 0 8 0"/>
                        <TextBlock Foreground="#fefefe" FontSize="13" FontWeight="Regular" Text="Save your time and effort"/>
                    </DockPanel>
                    <DockPanel Margin="0 10 0 0">
                        <Image x:Name="img3" Source="{DynamicResource img_green_bullet }" Stretch="None" Margin="0 0 8 0"/>
                        <TextBlock Foreground="#fefefe" FontSize="13" FontWeight="Regular" Text="Recover vast amount of space"/>
                    </DockPanel>
                    <DockPanel Margin="0 10 0 0">
                        <Image x:Name="img4" Source="{DynamicResource img_green_bullet }" Stretch="None" Margin="0 0 8 0"/>
                        <TextBlock Foreground="#fefefe" FontSize="13" FontWeight="Regular" Text="Organize your photos collection"/>
                    </DockPanel>
                    <DockPanel Margin="0 25 0 10">
                        <Button x:Name="purchase_btn" Width="267" Height="50" Content="Purchase Now"  BorderBrush="Transparent" Foreground="#fff" FontSize="24"
                                FontWeight="Bold">
                            <Button.Style>
                                <Style  TargetType="Button">
                                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="1 0 1 0"
                                                    Background="{TemplateBinding Background}">
                                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 0 30 0"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <ImageBrush ImageSource="{DynamicResource img_mark_over}"></ImageBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <Button.Background>
                                <ImageBrush ImageSource="{DynamicResource img_green_btn_n}"/>
                            </Button.Background>
                        </Button>
                        <Image x:Name="mb_icon" Source="{DynamicResource img_mb}" Width="50"/>
                    </DockPanel>
                    <DockPanel>
                        <Image x:Name="img_lock" Source="{DynamicResource img_lock__exit}" Stretch="None" Margin="0 0 4 0"/>
                        <TextBlock x:Name="key_label" FontSize="13" Foreground="#fefefe" FontWeight="Regular" Padding="5 0 0 0">Already Purchased?</TextBlock>
                        <Button x:Name="activation_link_btn" Background="Transparent" VerticalAlignment="Top"
                                Foreground="#fff" BorderBrush="#fff" BorderThickness="0 0 0 1"
                                Content="Click here to activate" 
                                HorizontalAlignment="Left"/>
                    </DockPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
