<UserControl x:Class="DuplicatePhotosFixer.UserControls.Selection_Assistant.ucProtectedFolders"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls.Selection_Assistant"
             mc:Ignorable="d" 
             d:DesignHeight="260" d:DesignWidth="643" Background="{DynamicResource cl_bg_theme}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="47"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="10 10 10 20">
            <DataGrid Background="Transparent" SelectionChanged="DataGrid_SelectionChanged" BorderBrush="{DynamicResource cl_br_selcAss}">
                <DataGrid.ColumnHeaderStyle>
                    <Style  TargetType="{x:Type DataGridColumnHeader}">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type DataGridColumnHeader}">
                                    <Border BorderBrush="{DynamicResource cl_br_selcAss}"
                                    BorderThickness=" 0.5 0 0.6 0.6"
                                Background="{DynamicResource cl_bg_theme}"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <TextBlock Text="{TemplateBinding Content}" Padding="5,5,0,0" Height="28"  Width="{TemplateBinding Width}" TextAlignment="Left"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource cl_fg_selcAss}"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="path_lbl" Header="Path" Width="*" />
                    <DataGridTextColumn x:Name="sub_folder_lbl" Header="Include Sub Folder" Width="Auto" MinWidth="200"/>
                    <!--<DataGridTextColumn Header="" Width="Auto" MinWidth=""/>-->
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
        
        <Grid Grid.Row="1" Margin="10 0 10 0">
            <Border BorderBrush="{DynamicResource cl_br_selcAss}" BorderThickness="1" Margin="0 5 0 0">
                <DockPanel>
                    <Button x:Name="browseFoldersPath" Content="..." DockPanel.Dock="Right" Width="25" Height="19" FontWeight="Bold"
                            Margin="0 0  10 0"/>
                    <TextBlock x:Name="tbFoldersPrioritySelectPath" VerticalAlignment="Center" />
                </DockPanel>
            </Border>
        </Grid>
        <Grid Grid.Row="2">
            <DockPanel Margin="0 5 0 0">
                <Button x:Name="btnRemove" Width="120" Height="33"  Content="Remove" Margin="0 0 20 0"
                         DockPanel.Dock="Right" VerticalAlignment="Center"  Grid.Column="3" >
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="TextBlock.TextAlignment" Value="Center" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bdr_main"  BorderThickness="1" Background="#2B9FD2">
                                            <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"                                                              
                                                              TextElement.FontSize="13"
                                                              TextElement.Foreground="White">
                                            </ContentPresenter>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" TargetName="bdr_main" Value="#3FB3E6">
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="true">
                                                <Setter Property="Background" TargetName="bdr_main" Value="#178BBE">
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                                <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="btnAdd" Content="Add" Grid.Column="2" Width="120" Height="33" 
                         DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,10,0"  >
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="TextBlock.TextAlignment" Value="Center" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bdr_main"  BorderThickness="1" BorderBrush="{DynamicResource cl_br_selcAss}" Background="Transparent">
                                            <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="White">
                                            </ContentPresenter>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" TargetName="bdr_main" Value="#494949"></Setter>
                                                <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                <Setter Property="Background" TargetName="bdr_main" Value="#494949"></Setter>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="true">
                                                <Setter Property="BorderBrush" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                <Setter Property="Background" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                                <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <CheckBox x:Name="cbIncludeSubFolders" FontSize="13" Foreground="#E9E9E9"
                          Content="Include sub folders of this path" IsChecked="True" VerticalAlignment="Top" Margin="10 8 0 0" Checked="cbIncludeSubFolders_Checked">
                    <CheckBox.LayoutTransform>
                        <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                    </CheckBox.LayoutTransform>
                </CheckBox>
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
