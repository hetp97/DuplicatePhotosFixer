                                            Value="{x:Null}" />
                    -->
                <!--<Style.Triggers>
                                    <Trigger Property="IsKeyboardFocusWithin"
                                             Value="True">
                                        <Setter Property="IsSelected"
                                                Value="True" />
                                    </Trigger>
                                </Style.Triggers>-->
                <!--
                </Style>
            </ListView.ItemContainerStyle>-->
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid HorizontalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"></RowDefinition>
                                <RowDefinition Height="192"></RowDefinition>
                            </Grid.RowDefinitions>
                            <DockPanel Background="#313131"
                                                           Width="{Binding ActualWidth, ElementName=docresultView}"
                                                           HorizontalAlignment="Stretch"
                                                           VerticalAlignment="Bottom"
                                                           x:Name="ImageGroupHeader">
                                <Grid VerticalAlignment="Bottom">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition></ColumnDefinition>
                                        <ColumnDefinition></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <DockPanel HorizontalAlignment="Stretch"
                                                                   VerticalAlignment="Bottom">
                                        <TextBlock Text="{Binding GroupHeaderLeft, IsAsync=True}"
                                                                       VerticalAlignment="Bottom"
                                                                       DockPanel.Dock="Left"
                                                                       Foreground="#C3C3C3"
                                                                       HorizontalAlignment="Left"
                                                                       FontSize="14"></TextBlock>
                                        <Border HorizontalAlignment="Stretch"
                                                                    DockPanel.Dock="Left"
                                                                    BorderThickness="0 0 0 1"
                                                                    Margin="5 0 0 5"
                                                                    BorderBrush="#565656">

                                        </Border>
                                    </DockPanel>
                                    <DockPanel HorizontalAlignment="Stretch"
                                                                   Grid.Column="1">
                                        <TextBlock Text="{Binding GroupHeaderRight, IsAsync=True}"
                                                                       DockPanel.Dock="Right"
                                                                       Foreground="#C3C3C3"
                                                                       HorizontalAlignment="Right"
                                                                       Margin="0 0 50 0"
                                                                       FontSize="14"></TextBlock>
                                        <Border HorizontalAlignment="Stretch"
                                                                    DockPanel.Dock="Right"
                                                                    BorderThickness="0 0 0 1"
                                                                    Margin="0 0 5 5"
                                                                    BorderBrush="#565656">

                                        </Border>
                                    </DockPanel>
                                </Grid>
                                <DockPanel.Style>
                                    <Style TargetType="DockPanel">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Path=IsFileItemForImageView}"
                                                                             Value="False">
                                                <Setter Property="Visibility"
                                                                            Value="Visible" />
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding Path=IsFileItemForImageView}"
                                                                             Value="True">
                                                <Setter Property="Visibility"
                                                                            Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DockPanel.Style>
                            </DockPanel>
                            <StackPanel HorizontalAlignment="Stretch"
                                                            Grid.Row="1"
                                                            Background="#313131">
                                <StackPanel.Resources>
                                    <!--<con:BindingProxy x:Key="proxy"
                                                          Data="{Binding RelativeSource={RelativeSource AncestorType=UserControl}}" />-->
                                </StackPanel.Resources>
                                <!--<StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="ContextMenu"
                                                                    Value="{StaticResource ImageListItemResultMenu}" />
                                    </Style>
                                </StackPanel.Style>-->
                                <Border Margin="0 7 0 0"
                                                            CornerRadius="2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderThickness"
                                                                        Value="2" />
                                            <Setter Property="BorderBrush"
                                                                        Value="#313131" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                                                 Value="True">
                                                    <Setter Property="BorderBrush"
                                                                                Value="#00B1FF" />
                                                    <Setter Property="BorderThickness"
                                                                                Value="2" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Stretch"
                                                                    Width="156"
                                                                    Height="181"
                                                                    Orientation="Vertical"
                                                                    Background="Black"
                                                                    VerticalAlignment="Top"
                                                                    RenderOptions.BitmapScalingMode="HighQuality"
                                                                    RenderOptions.ClearTypeHint="Enabled"
                                                                    TextOptions.TextRenderingMode="ClearType"
                                                                    x:Name="ImageListViewItem">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Path=IsFileItemForImageView}"
                                                                                     Value="False">
                                                        <Setter Property="Visibility"
                                                                                    Value="Collapsed" />
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding Path=IsFileItemForImageView}"
                                                                                     Value="True">
                                                        <Setter Property="Visibility"
                                                                                    Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <Grid VerticalAlignment="Top">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="140"></RowDefinition>
                                                <RowDefinition Height="41"></RowDefinition>
                                            </Grid.RowDefinitions>
                                            <Border BorderThickness="4"
                                                                        BorderBrush="White"
                                                                        VerticalAlignment="Top">
                                                <Image x:Name="BackgroundImage"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Top"
                                                                           Focusable="False"
                                                                           MaxHeight="132"
                                                                           Height="132"
                                                                           Stretch="Uniform"
                                                                           Source="{Binding FileThumbnailPath,Mode=OneWay,IsAsync=True}" />
                                            </Border>
                                            <Grid Grid.Row="1">
                                                <Grid Margin="0 0 0 0"
                                                                          Background="#E4EBED"
                                                                          Grid.Row="1"
                                                                          VerticalAlignment="Bottom">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="auto"></ColumnDefinition>
                                                        <ColumnDefinition Width="*"></ColumnDefinition>
                                                        <ColumnDefinition Width="auto"></ColumnDefinition>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="auto"></RowDefinition>
                                                        <RowDefinition Height="auto"></RowDefinition>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Text="{Binding FileName,Mode=OneWay,IsAsync=True}"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   VerticalAlignment="Top"
                                                                                   Margin="5 0 0 2"
                                                                                   TextWrapping="NoWrap"
                                                                                   Grid.ColumnSpan="2"
                                                                                   FontSize="13"
                                                                                   FontWeight="DemiBold"
                                                                                   Foreground="black">
                                                        <TextBlock.ToolTip>
                                                            <ToolTip DataContext="{Binding Path=PlacementTarget, RelativeSource={x:Static RelativeSource.Self}}">
                                                                <TextBlock Text="{Binding Text}" />
                                                                <!-- tooltip content -->
                                                            </ToolTip>
                                                        </TextBlock.ToolTip>
                                </TextBlock>
                                                    <StackPanel Grid.Row="1"
                                                                                    VerticalAlignment="Top"
                                                                                    Orientation="Horizontal"
                                                                                    Margin="5 0 0 0">
                                                        <TextBlock HorizontalAlignment="Left"
                                                                                       Text="{Binding LastWriteTimeThumbViewStr,Mode=OneWay,IsAsync=True}"
                                                                                       MaxWidth="70"
                                                                                       FontSize="10"
                                                                                       Margin="0 -1 0 0"
                                                                                       Foreground="black" />
                                                        <TextBlock Text="|"
                                                                                       HorizontalAlignment="Right"
                                                                                       FontSize="10"
                                                                                       Margin="8,-2,8,0"
                                                                                       Foreground="Black" />
                                                    </StackPanel>

                                                    <TextBlock HorizontalAlignment="Left"
                                                                                   VerticalAlignment="Top"
                                                                                   Text="{Binding FileSizeStr, Mode=OneWay,IsAsync=True}"
                                                                                   FontSize="10"
                                                                                   Margin="0 -1 0 0"
                                                                                   Grid.Column="1"
                                                                                   Grid.Row="1"
                                                                                   MaxWidth="70"
                                                                                   Foreground="black" />
                                                    <CheckBox Grid.Row="1"
                                                                                  Grid.Column="2"
                                                                                  Margin="0 0 1 1"
                                                                                  HorizontalAlignment="Right"
                                                                                  VerticalAlignment="Bottom"
                                                                                  x:Name="chkImageView"
                                                                                  Style="{StaticResource CustomResultCheckBox}"
                                                                                  Checked="chk_isSelected_Checked"
                                                                                  Unchecked="chk_isSelected_Unchecked"
                                                                                  IsThreeState="False"
                                                                                  IsChecked="{Binding Path=bIsChecked,Mode=TwoWay}"
                                                                                  Tag="{Binding Path=DupFileLogId, Mode=OneWay}"
                                                                                  Background="Transparent" />
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <!--<main:VirtualizingTilePanel x:Name="virtualImageView"
                                                                        HorizontalAlignment="Center"
                                                                        IsItemsHost="True"
                                                                        ChildWidth="160"
                                                                        ChildHeight="200">

                        </main:VirtualizingTilePanel>-->
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ListView>
        </Border>
