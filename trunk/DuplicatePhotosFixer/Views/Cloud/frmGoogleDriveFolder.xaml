<Window x:Class="DuplicatePhotosFixer.Views.Cloud.frmGoogleDriveFolder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views.Cloud"
        mc:Ignorable="d"
        Title="frmGoogleDriveFolder" Height="490" Width="515" WindowStyle="None">
    <Window.Resources>
        <Style  x:Key="btn_customStyle" TargetType="Button">
            <Setter Property="Background" Value="#5D5D5D" />
            <Setter Property="TextBlock.TextAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr_main"  BorderThickness="1" BorderBrush="{TemplateBinding BorderBrush}" Background="{TemplateBinding Background}">
                            <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                             TextElement.Foreground="{TemplateBinding Foreground}">
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" TargetName="bdr_main" Value="Transparent"></Setter>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition/>
            <RowDefinition Height="61"/>
        </Grid.RowDefinitions>
        <DockPanel Background="Black">
            <Button x:Name="btn_close" DockPanel.Dock="Right" Width="24"
                    Height="24" Background="Transparent" 
                    VerticalAlignment="Top"
                    BorderBrush="Black">
                <Image x:Name="img_close" Source="/Resources/close.png"  />
            </Button>
            <Label x:Name="lbl_heading" Content="label1" Foreground="White" Margin="10 0 0 0"/>

        </DockPanel>
        <Grid Grid.Row="1">
            <TreeView Grid.Row="0" x:Name="DropBoxFoldersTreeView">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate  ItemsSource="{Binding Members}">
                        <TextBlock Text="{Binding folderName}" FontSize="14"/>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>
        <Grid Grid.Row="2" Background="#D5D5D5">
            <cust:ImageButton x:Name="btnRefresh"                                
                                  Margin="10"
                                 HorizontalAlignment="Left"
                                  Style="{DynamicResource stl_btnRefresh}"
                                  HoverImage="{DynamicResource img_btnpic}"
                                  SelectedImage="{DynamicResource img_btnpic}"
                                  Content="Refresh" FontWeight="SemiBold"
                                      >

            </cust:ImageButton>

            <DockPanel HorizontalAlignment="Right">
                <Button x:Name="btnCancel" 
                        Content="Cancel"
                        Background="White"  
                        Margin="0 0 10 0"
                        FontWeight="Bold"
                        Style="{DynamicResource btn_customStyle}"
                        Width="124" Height="33"/>
                <Button x:Name="btnAdd" 
                        Content="Add"
                        Foreground="White"
                        Background="#0283C1"
                        FontWeight="Bold"
                         Margin="0 0 15 0"
                         Style="{DynamicResource btn_customStyle}"
                        Width="124" Height="33"/>
            </DockPanel>


        </Grid>
    </Grid>
</Window>
