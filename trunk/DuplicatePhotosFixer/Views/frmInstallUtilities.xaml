<Window x:Class="DuplicatePhotosFixer.Views.frmInstallUtilities"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        mc:Ignorable="d"
        Title="frmInstallUtilities" Height="508" Width="825" ResizeMode="NoResize" WindowStyle="None">
    <Window.Resources>
        <Style x:Key="styl_noDefaulthover" TargetType="Button">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="False">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="False">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Border BorderThickness="1 1 1 1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                    
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="60"></RowDefinition>
                </Grid.RowDefinitions>
                <DockPanel Margin="0 0 0 0" >

                    <cust:ImageButton
                            x:Name="close_btn"
                            Width="12"
                        VerticalAlignment="Top"
                            Height="12"
                            DockPanel.Dock="Right"
                            Margin="10 15 10 0"
                            Style="{DynamicResource imageButton}"
                            Image="{DynamicResource img_close_black}"
                            HoverImage="{DynamicResource img_close_black}"
                            SelectedImage="{DynamicResource img_close_black}" Click="close_btn_Click"  />
                    <TextBlock x:Name="lbl_ProductName"
                           FontSize="15"
                           FontWeight="Regular"
                           Margin="15 0 0 0"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Text="Optional offer by Systweak"
                           Foreground="{DynamicResource cl_fg_RA_Header}">
                    </TextBlock>
                </DockPanel>

                <DockPanel Grid.Row="1" Margin="58 0 58 0">
                    <Image Name="img_banner" DockPanel.Dock="Left" Margin="0 7 0 0" Stretch="None" VerticalAlignment="Top"></Image>

                    <Grid Margin="55 0 0 0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Name="txt_productName" 
                           Margin="16 5 0 5"
                           Foreground="{DynamicResource cl_fg_RA_Header}"
                           FontWeight="Medium"
                           TextWrapping="Wrap"
                               Text="{Binding ProductName}"
                               FontSize="29">

                            </TextBlock>
                            <TextBlock Name="txt_BestSeller" 
                           Margin="16 0 0 5"
                           Foreground="{DynamicResource cl_fg_AppInfo_ac}"
                           FontWeight="Regular"
                           TextWrapping="Wrap"
                           Text="Best Seller"
                           FontStyle="Italic"
                           FontSize="14">
                            </TextBlock>
                        </StackPanel>
                        <!-- Feature Section 1 -->
                        <StackPanel Name="pnl1" Grid.Row="1" Orientation="Horizontal"
                                Margin="0 10 0 5">
                            <Image Width="16" Stretch="None" Source="{DynamicResource img_green_bullet1}" VerticalAlignment="Center" HorizontalAlignment="Left"></Image>
                            <TextBlock  Name="txt_feature1" Margin="10 0 0 0"
                                Foreground="{DynamicResource cl_fg_RA_Header }"
                                   FontWeight="Regular"
                                   FontSize="15">Malware Scan
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Name="txt_featureInfo1"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource cl_fg_RA_cont}"
                               FontWeight="Regular"
                               Margin="26 0 0 5"
                               FontSize="13"
                               Grid.Row="2">
                    Scans and eliminates all spyware, adware and malware threats from your PC in a jiffy.
                        </TextBlock>

                        <!-- Feature Section 2 -->
                        <StackPanel Name="pnl2" Grid.Row="3" Orientation="Horizontal"
                                Margin="0 10 0 5">
                            <Image Width="16" Stretch="None" Source="{DynamicResource img_green_bullet1}" VerticalAlignment="Center" HorizontalAlignment="Left"></Image>
                            <TextBlock Name="txt_feature2"
                                   Margin="10 0 0 0"
                                   Foreground="{DynamicResource cl_fg_RA_Header}"
                                   FontWeight="Regular"
                                   FontSize="15">
                        Malware Scan
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Name="txt_featureInfo2"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource cl_fg_RA_cont}"
                               FontWeight="Regular"
                               Margin="26 0 0 5"
                               FontSize="13"
                               Grid.Row="4">
                        Scans and eliminates all spyware, adware and malware threats from your PC in a jiffy.
                        </TextBlock>

                        <!-- Feature Section 3 -->
                        <StackPanel Name="pnl3" Grid.Row="5" Orientation="Horizontal"
                                Margin="0 10 0 5">
                            <Image Width="16" Stretch="None" Source="{DynamicResource img_green_bullet1}" VerticalAlignment="Center" HorizontalAlignment="Left"></Image>
                            <TextBlock Name="txt_feature3"
                                   Margin="10 0 0 0"
                                   Foreground="{DynamicResource cl_fg_RA_Header}"
                                   FontWeight="Regular"
                                   FontSize="15">
                        Malware Scan
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Name="txt_featureInfo3"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource cl_fg_RA_cont}"
                               FontWeight="Regular"
                               Margin="26 0 0 5"
                               FontSize="13"
                               Grid.Row="6">
                        Scans and eliminates all spyware, adware and malware threats from your PC in a jiffy.
                        </TextBlock>


                        <!-- Feature Section 4 -->
                        <StackPanel Name="pnl4" Grid.Row="7" Orientation="Horizontal"
                                Margin="0 10 0 5">
                            <Image Width="16" Stretch="None" Source="{DynamicResource img_green_bullet1}" VerticalAlignment="Center" HorizontalAlignment="Left"></Image>
                            <TextBlock Name="txt_feature4"
                                   Margin="10 0 0 0"
                                   Foreground="{DynamicResource cl_fg_RA_Header}"
                                   FontWeight="Regular"
                                   FontSize="15">
                        Malware Scan
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Name="txt_featureInfo4"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource cl_fg_RA_cont}"
                               FontWeight="Regular"
                               Margin="26 0 0 5"
                               FontSize="13"
                               Grid.Row="8">
                        Scans and eliminates all spyware, adware and malware threats from your PC in a jiffy.
                        </TextBlock>
                    </Grid>

                </DockPanel>

                <StackPanel Grid.Row="2" Margin="0 0 0 0" Orientation="Horizontal" HorizontalAlignment="Center">

                    <Button
                        x:Name="btn_Cancel"
                    Width="150"
                    Height="42"                   
                    FontSize="16"     
                   Style="{DynamicResource nodefaultHoverbtn}"
                   Foreground="{DynamicResource cl_fg_btn_cont}"
                    Background="{DynamicResource cl_bg_btn1_feature}"
                    Margin="0 0 10 0"
                    FontWeight="SemiBold"
                    Content="Cancel"
                       
                    HorizontalAlignment="Left" Click="btn_Cancel_Click">
                    </Button>
                    <Button
                        x:Name="btn_Install"
                    Width="150"
                    Height="42"
                         Foreground="{DynamicResource cl_fg_btn_cont}"
                         Style="{DynamicResource nodefaultHoverbtn}"
                    Background="{DynamicResource cl_bg_btn2_feature}"
                        Margin="10 0 0 0"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Content="Install"
                    HorizontalAlignment="Left" Click="btn_Install_Click">
                    </Button>




                    <!--<Button x:Name="btn_Installnotregistered" Visibility="Collapsed" HorizontalAlignment="Left" Cursor="Hand" Height="34"
                        Width="250" Margin="20 60" Content="" Style="{DynamicResource stl_btnGrey_InstallUtilitiesBuyNow}" 
                        Click="btn_Installnotregistered_Click">
                    </Button>-->

                </StackPanel>


                <TextBlock x:Name="txtDiscountOffer" Visibility="Collapsed" Margin="173 -20 0 0" Grid.Row="4" FontSize="14" FontWeight="Regular" Foreground="{DynamicResource cl_fg_RA_cont}" Text="Limited Time Offer-Flat 20% Discount"></TextBlock>


                <WrapPanel x:Name="wrpFooter" Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20 15 0 0">
                    <TextBlock Name="lbl_info" Foreground="{DynamicResource cl_fg_RA_cont}"
                   TextAlignment="Center"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   FontSize="15"
                   Margin="5 0 5 0"
                   FontWeight="SemiBold"
                   Text="By clicking Install, you agree to install Advance System Protector and accept its ">
                    </TextBlock>
                    <TextBlock Name="txt_EULA"
                    VerticalAlignment="Center"
                    Cursor="Hand"
                    TextDecorations="Underline"
                    FontSize="15"
                    Foreground="{DynamicResource cl_txt_link}"
                    FontWeight="Regular"
                    HorizontalAlignment="Center"
                    Text="EULA"
                    MouseDown="txt_EULA_MouseDown"></TextBlock>
                    <TextBlock Name="txtAnd" Foreground="{DynamicResource cl_fg_RA_cont}"
                       TextAlignment="Center"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       FontSize="15"
                       Margin="5 0"
                       FontWeight="Regular"
                       Text=" &amp; ">
                    </TextBlock>
                    <TextBlock Name="tb_privacyPolicy"
                    FontSize="15"
                    Foreground="{DynamicResource cl_txt_link}"
                    TextDecorations="Underline"
                    FontWeight="Regular"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Cursor="Hand"
                    Text="Privacy Policy"
                   MouseDown="tb_privacyPolicy_MouseDown"></TextBlock>
                </WrapPanel>

            </Grid>
        </Border>
    </Grid>
</Window>
