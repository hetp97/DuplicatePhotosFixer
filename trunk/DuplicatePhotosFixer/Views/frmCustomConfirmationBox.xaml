<Window x:Class="DuplicatePhotosFixer.Views.frmCustomConfirmation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        mc:Ignorable="d"
        Title="frmCustomConfirmation" Height="200" Width="513" WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition/>
            
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#494949">
      
        </Grid>

        <Grid Grid.Row="1">
            <StackPanel Margin="3, 5, 3, 4" >
                <TextBlock x:Name="lbl_searchingDuplicates"
                          
                           Foreground="Black"
                           FontSize="14"
                           TextWrapping="Wrap">
                    Searching for duplicates...Searching for duplicates...Searching for duplicates...Searching for duplicates...
                </TextBlock>
                <TextBlock x:Name="info" Margin="0 5 0 0">
                    By installing you agree to <Hyperlink>EULA</Hyperlink> and <Hyperlink>Privacy Policy</Hyperlink>
                </TextBlock>
                <DockPanel HorizontalAlignment="Right">
                    <Button x:Name="btn_yes" Width="109" Height="30"
                            Content="Yes"
                            Margin="0 10 20 0">
                        <Button.Background>
                            <LinearGradientBrush  StartPoint="0,0" EndPoint="0 ,1">
                                <GradientStop Color="#F1F1F1" Offset="0"/>
                                <GradientStop Color="LightGray" Offset="0.555"/>
                                <GradientStop Color="#F1F1F1" Offset="0.03"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                    <Button x:Name="btn_Cancel" Width="109" Height="30"
                            Content="Cancel"
                            Margin="0 10 10 0">
                        <Button.Background>
                            <LinearGradientBrush  StartPoint="0,0" EndPoint="0 ,1">
                                <GradientStop Color="#F1F1F1" Offset="0"/>
                                <GradientStop Color="LightGray" Offset="0.555"/>
                                <GradientStop Color="#F1F1F1" Offset="0.03"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </DockPanel>
                <DockPanel Margin="0 20 0 0" >
                    <Image x:Name="img_outdate" Source="/Resources/error_outdate.png"
                           Width="18"
                           Height="18"
                           Margin="0 0 5 0"
                           />
                    <TextBlock x:Name="lbl_infoRaw"
                               FontSize="12"
                               Foreground="#858585"
                            >
                        Selecting NO will skip RAW photos from the scanning process.
                    </TextBlock>
                    
                </DockPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
