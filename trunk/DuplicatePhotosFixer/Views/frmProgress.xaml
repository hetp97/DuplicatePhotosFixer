<Window x:Class="DuplicatePhotosFixer.Views.frmProgress"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        mc:Ignorable="d"
        Title="frmProgress" Height="229" Width="513" WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition/>

        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#494949">

        </Grid>

        <Grid Grid.Row="1">
            <StackPanel Margin="3, 15, 3, 4" >
                <DockPanel>
                    <TextBlock x:Name="lbl_percentage" Text="0%" Margin="0 0 20 0"
                              DockPanel.Dock="Right"/>
                    <TextBlock x:Name="lbl_searchingDuplicates"
                          Margin="18 0 0 0"
                           Foreground="Black"
                           FontSize="14"
                           TextWrapping="Wrap">
                    Searching for duplicates...
                    </TextBlock>
                  
                </DockPanel>
                <Image x:Name="scanBar_progress" Source="{DynamicResource scan_progress}"
                       Width="467"
                       Margin="0 10 0 0"/>

                <TextBlock x:Name="lbl_progressInfo" Margin="0 5 0 0"
                           Height="53"
                           Width="467">
                    labe1
                </TextBlock>
                <Image x:Name="scanBar"/>
                <DockPanel HorizontalAlignment="Right">
                    <Button x:Name="btn_yes" Width="109" Height="30"
                            Content="Yes"
                            Margin="0 10 20 0">
                        <Button.Background>
                            <LinearGradientBrush  StartPoint="0,0" EndPoint="0 ,1">
                                <GradientStop Color="#F1F1F1" Offset="0"/>
                                <GradientStop Color="LightGray" Offset="0.555"/>
                                <GradientStop Color="#F1F1F1" Offset="0.03"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                    <Button x:Name="btn_Cancel" Width="109" Height="30"
                            Content="Cancel"
                            Margin="0 10 10 0">
                        <Button.Background>
                            <LinearGradientBrush  StartPoint="0,0" EndPoint="0 ,1">
                                <GradientStop Color="#F1F1F1" Offset="0"/>
                                <GradientStop Color="LightGray" Offset="0.555"/>
                                <GradientStop Color="#F1F1F1" Offset="0.03"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </DockPanel>
                <DockPanel Margin="0 20 0 0" >
                    <Image x:Name="img_outdate" Source="/Resources/error_outdate.png"
                           Width="18"
                           Height="18"
                           Margin="0 0 5 0"
                           />
                    <TextBlock x:Name="lbl_infoRaw"
                               FontSize="12"
                               Foreground="#858585"
                            >
                        Selecting NO will skip RAW photos from the scanning process.
                    </TextBlock>

                </DockPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
