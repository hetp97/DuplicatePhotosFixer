<Window x:Class="DuplicatePhotosFixer.Nags.frmTrayOfferFixFiles"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Nags"
        mc:Ignorable="d"
        Title="frmTrayOfferFixFiles" Height="239" Width="422" WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#ECECEC">
            <DockPanel>
                <Button x:Name="btn_Close"
                        DockPanel.Dock="Right"
                        Width="30"
                        Height="30"
                       Foreground="#4A4A4A"
                        FontSize="15"
                        FontWeight="Bold">X

                </Button>
                <TextBlock x:Name="lbl_recommendedApp"
                           FontSize="13"
                           VerticalAlignment="Center">
                    Recommendation
                </TextBlock>
            </DockPanel>
        </Grid>
        <Grid Grid.Row="1" Margin="8">
            <StackPanel>
                <DockPanel>
                    <Image x:Name="ms_logo_small" Width="102"
                           Height="37"
                           DockPanel.Dock="Right" Source="{DynamicResource img_ms_logo_small}"/>
                    <TextBlock x:Name="lbl_dff" FontSize="17">
                        Duplicate Files Fixer
                    </TextBlock>
                </DockPanel>
                <DockPanel>
                    <Image x:Name="dff_logo" Width="55"
                           Height="55" Source="{DynamicResource img_dff_logo}" />
                    <TextBlock x:Name="lbl_OfferInfo"
                               FontSize="17">
                        Find and remove duplicate files and recover<LineBreak/> valuable space on your hard disk.
                    </TextBlock>
                </DockPanel>
                <Button x:Name="btn_tryNow" 
                        Width="225" 
                        Height="50"
                       Style="{DynamicResource stylGreenBtn}"
                        FontSize="17"
                        FontWeight="Bold"
                        >
                    Try it Now
                </Button>
                <TextBlock x:Name="text_info" Margin="0 5 20 0"
                           HorizontalAlignment="Right">
                    label7 <Hyperlink>Privacy Policy</Hyperlink> label8 <Hyperlink>EULA</Hyperlink>  
                </TextBlock>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
