<Window x:Class="DuplicatePhotosFixer.Nags.nagUpdateOfferTSR"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Nags"
        mc:Ignorable="d"
        Title="nagUpdateOfferTSR" Height="534" Width="928" WindowStyle="None">
    <Window.Background>
        <ImageBrush ImageSource="{DynamicResource img_nag_bg}"/>
    </Window.Background>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="51"/>
            <RowDefinition Height="50"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" >
            <DockPanel Margin="10 0 10 0">
                <Button x:Name="pb_Close" Width="15" Height="14"
                        Background="Transparent" BorderBrush="Transparent"
                        DockPanel.Dock="Right">
                    <Image  Source="/Resources/close_tsr.png"/>
                </Button>
                <Image x:Name="pb_Icon" Width="36" Height="33" Source="{DynamicResource img_dpf_updatelogo}"/>
                <TextBlock x:Name="label_heading"
                           Foreground="#FAFAFA"
                           FontSize="14"
                           Padding="5 0 0 0"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center">
                  Duplicate Photo Fixer Pro has been updated sucessfully.
                </TextBlock>
            </DockPanel>
        </Grid>
        <Grid Grid.Row="1">
            <TextBlock x:Name="label1" FontSize="14"
                       Foreground="#A4A4A7" VerticalAlignment="Center"  Padding="10 0 0 0" >
                    Recommended Product by Systweak:
            </TextBlock>
        </Grid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="390"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Image x:Name="picGraphic" Source="/Resources/graphic.png" Width="332" Height="243"/>
            <Grid Grid.Column="1">
                <StackPanel Margin="10 0 0 0 ">
                    <DockPanel>
                        <Image x:Name="tsr_logo" Width="53" Height="53" Source="{DynamicResource img_tsr_logo}"
                               Margin="0 0 10 0 "/>
                        <StackPanel>
                            <DockPanel>
                                <TextBlock x:Name="lblProdName" Padding="5 0 5 0"
                               Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold">
                            TweakShot

                                </TextBlock>
                                <TextBlock x:Name="lblProdN" Padding="5 0 5 0"
                               Foreground="White" VerticalAlignment="Center"
                                   FontSize="20"
                                   FontWeight="Bold">
                           -Screen Recoder
                                </TextBlock>
                                <Image x:Name="img" Width="86" Height="36" Source="{DynamicResource img_new}"/>
                            </DockPanel>
                            <TextBlock x:Name="lbldesc" Foreground="White" FontSize="20" Padding="5 0 0 0">
                                All-in-one Screen Recorder For Windows PC
                            </TextBlock>
                        </StackPanel>
                    </DockPanel>
                    <TextBlock Height="50"/>
                    <DockPanel Margin="10 0 0 10">
                        <Image x:Name="pbBullet" Width="6" Height="10" 
                               Margin="10 0 0 0 " Source="{DynamicResource img_arrow}"/>
                        <TextBlock x:Name="lblDes1" Padding="5 0 0 5"
                                       FontSize="16" Foreground="White">
                              Record online classes, webinars &amp; streaming content limitlessly.
                        </TextBlock>
                    </DockPanel>
                    <DockPanel Margin="10 0 0 10">
                        <Image x:Name="pbBullet1" Width="6" Height="10" 
                               Margin="10 0 0 0 " Source="{DynamicResource img_arrow}"/>
                        <TextBlock x:Name="lblDes2" Padding="5 0 0 5"
                                       FontSize="16" Foreground="White">
                              Record screen, webcam, system sound &amp; voice via microphone.
                        </TextBlock>
                    </DockPanel>
                    <DockPanel Margin="10 0 0 10">
                        <Image x:Name="pbBullet2" Width="6" Height="10" 
                               Margin="10 0 0 0 " Source="{DynamicResource img_arrow}"/>
                        <TextBlock x:Name="lblDes3" Padding="5 0 0 5"
                                       FontSize="16" Foreground="White">
                              Record 4K/HD videos with or without watermark.                        </TextBlock>
                    </DockPanel>
                    <DockPanel Margin="10 0 0 10">
                        <Image x:Name="pbBullet3" Width="6" Height="10" 
                               Margin="10 0 0 0 " Source="{DynamicResource img_arrow}"/>
                        <TextBlock x:Name="lblDes4" Padding="5 0 0 5"
                                       FontSize="16" Foreground="White">
                             Save extra audio file with video.                        </TextBlock>
                    </DockPanel>
                    <TextBlock Height="50"/>
                    <DockPanel>
                        <Button x:Name="btnDownloadNow" Width="216" Height="52" 
                                BorderBrush="Transparent" Foreground="White" FontSize="20" FontWeight="Bold">
                            <Button.Background>
                                <ImageBrush ImageSource="{DynamicResource img_btn_orange}"/>
                            </Button.Background>
                            Install Now
                        </Button>
                        <Button x:Name="btnDiscount" Width="258" Height="54"
                                Background="Transparent" BorderBrush="White"  
                                Foreground="White" FontSize="19"
                                FontWeight="Bold"
                                BorderThickness="1.5">Buy Now At Flat 20% Off</Button>
                    </DockPanel>
                    <DockPanel Margin="0 5 0 0">
                        <TextBlock x:Name="lblFooter1"
                               Foreground="#7D7C85"
                                   FontSize="13"
                               Padding="0 0 20 0">
                      By clicking "Install Now", you agree to the
                        </TextBlock>
                        <TextBlock x:Name="lblEula" FontSize="14" Padding="0 0 10 0">
                    <Hyperlink Foreground="#7D7C85"> EULA </Hyperlink>
                        </TextBlock>
                        <TextBlock x:Name="txt" FontSize="14" Padding="0 0 10 0"  Foreground="#7D7C85" Text="and"/>
                        <TextBlock x:Name="lblPP" FontSize="14" Padding="0 0 10 0" >
                    <Hyperlink Foreground="#7D7C85"> Privacy Policy </Hyperlink>
                        </TextBlock>
                    </DockPanel>
                </StackPanel>
               
            </Grid>
                
        </Grid>
        
    </Grid>
</Window>
