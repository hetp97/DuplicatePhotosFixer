        public void ChangeScanMode(eScanMode scanMode)
        {

            chk_rotatedImages.IsChecked= true;
            chk_flippedImages.IsChecked = true;
            switch (scanMode)
            {
                case eScanMode.GoogleDrive:
                    {
                        //rbtn_exactMatch.Checked = true;
                    }
                    break;
                case eScanMode.Dropbox:
                    {
                        chk_rotatedImages.IsChecked = true;
                        chk_flippedImages.IsChecked = true;
                    }
                    break;
                case eScanMode.BoxCloud:
                    {
                        chk_rotatedImages.IsChecked = true;
                        chk_flippedImages.IsChecked = true;
                    }
                    break;
                case eScanMode.AmazonS3:
                    {
                        chk_rotatedImages.IsChecked = true;
                        chk_flippedImages.IsChecked = true;
                    }
                    break;
                //case eScanMode.DeleteEmptyFolder:
                    break;
                case eScanMode.FileSearch:
                default:
                    //rbtn_FileSystem.Checked = true;
                    break;
            }
        }

      public  void RefreshSettings()
        {
            try
            {

                if (cGlobalSettings.MatchSettingsData.MatchMethod == eMatchMethod.Similar)
                {
                    rdbtnSimilarMatch.IsChecked = true;
                }
                else
                {
                    rdbtnExactMatch.IsChecked = true;
                }

                if (cGlobalSettings.ExtraSettings.DbConsiderTimeInterval)
                {
                    TimeIntervalSettings.Visibility = Visibility.Visible;
                    ucTimeIntervalSettings.Visibility = Visibility.Collapsed;
                }

                else
                {
                    TimeIntervalSettings.Visibility = Visibility.Collapsed;
                    ucTimeIntervalSettings.Visibility = Visibility.Visible;
                }

                if (cGlobalSettings.ExtraSettings.DbConsiderGPS)
                {
                    GPSSettings.Visibility = Visibility.Visible;
                    ucGPSSettings.Visibility = Visibility.Collapsed;
                }

                else
                {
                    GPSSettings.Visibility = Visibility.Collapsed;
                    ucGPSSettings.Visibility = Visibility.Visible;
                }

                chk_rotatedImages.IsChecked = cGlobalSettings.ExtraSettings.DbIncludeRotatedImages;
                chk_flippedImages.IsChecked = cGlobalSettings.ExtraSettings.DbIncludeFlippedImages;




            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("ucHomeComparisonMethod :: RefreshSettings : ", ex);

            }
        }

        private void loadDefault_btn_Click(object sender, RoutedEventArgs e)
        {
            try
            {
                objModel.LoadScanMethodSettings(true);
                UpdateUIData();
               
            }
            catch (Exception ex)
            {

                cGlobalSettings.oLogger.WriteLogException("loadDefault_btn_Click::", ex);
            }

        }

