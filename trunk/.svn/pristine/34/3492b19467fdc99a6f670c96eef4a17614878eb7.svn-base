                SelectedPaths = HelperClasses.cSelectFilesFolders.ShowFolder_System(App.oMainReference);

                if (SelectedPaths == null || SelectedPaths.Length <= 0)
                    return false;
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("SystemScanWrapper:: Browse: ", ex);
            }
            return true;

        }

