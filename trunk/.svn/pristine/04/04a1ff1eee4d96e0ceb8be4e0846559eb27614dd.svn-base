        cArmadilloHelper oArmHelper = new cArmadilloHelper();
        private void oBgActivationChecker_DoWork(object sender, DoWorkEventArgs e)
        {
            try
            {
                IntPtr oHandle = IntPtr.Zero;
                App.oMainReference.Dispatcher.Invoke(new Action(() => oHandle = new WindowInteropHelper(App.oMainReference.frmRegistration).Handle));
                using (new HourGlass(ref oHandle))
                {
                    //DisableEnableFrom(true);

                    string[] arrArgs = (string[])e.Argument;
                    string sEmailAddress = arrArgs[0];
                    string sKey = arrArgs[1];

                    enumClass.eKeyActionToTake oKeyStatus = enumClass.eKeyActionToTake.KEY_RESERVED;
                    int eReturnStats = 0;
                    int nMessages = 0;

                    int oOnlineRetVal = oArmHelper.ActivateOnline(sKey, oHandle, (int)enumClass.LanguageIdentifier.Lang_English, enumClass.eVerificationTime.Register, out oKeyStatus, out eReturnStats, out nMessages);

                    if (oOnlineRetVal == cArmadilloHelper.ACTIVATION_CHECK_SUCCESS)
                    {
                        if (oArmHelper.IsKeyAllowedToRegister(oKeyStatus))
                        {

                            if (oArmHelper.InstallKey(string.Empty, sKey, true))
                            {
                                ChangeRegistrationLinksState(true, sKey, sEmailAddress, eUTM_BTN_TYPE.RegistrationNagRegisterNow.ToString());
                                Program.GetArmStatus();

                                // You have successfully register the product.
                                App.oMainReference.showMessage(cResourceManager.LoadString("IDS_STR_THANKS"), "");

                                //HideRegistrationLinks();
                                return;
                            }
                            else
                            {

                                cArmadilloHelper oArmadilloHelper = new cArmadilloHelper();
                                if ((!oArmadilloHelper.Expired()))
                                {

                                    //hide registration links
                                    ChangeRegistrationLinksState(true, sKey, sEmailAddress, eUTM_BTN_TYPE.RegistrationNagRegisterNow.ToString());
                                    Program.GetArmStatus();
                                    //HideRegistrationLinks();

                                    // You have successfully register the product.
                                    App.oMainReference.showMessage(cResourceManager.LoadString("IDS_STR_THANKS"), "");
                                    return;
                                }
                                else
                                {

                                    //this.UIThread(() => MessageBoxEx.Show(this, cResourceManager.LoadString("IDS_UNREGSTING_EXPIRED"), cGlobal.GetProductNameFromDesc(), MessageBoxButtons.OK, MessageBoxIcon.Information));
                                    App.oMainReference.Dispatcher.Invoke(new Action(() =>
                                    {
                                        App.oMainReference.showMessage(cResourceManager.LoadString("DPF_REGISTRATION_UNREGISTER_EXPIRE"), "");
                                        //MessageBox.Show("Unregister/Expired version", cGlobalSettings.GetProductNameFromDesc(), MessageBoxButtons.OK, MessageBoxIcon.Information));
                                    }));
                                }
                            }

                            try
                            {
                                string reason1 = string.Format("oArmHelper.IsKeyAllowedToRegister(oKeyStatus):{0}", oKeyStatus);
                                KVO.ReportExpireCurrentKeyReason(cGlobalSettings.ProductId, reason1, KVO.ReportExpireCurrentKeyReasonType.OnRegister);
                            }
                            catch (Exception ex)
                            {
                                cGlobalSettings.oLogger.WriteLogException("OnRegister", ex);
                            }
                        }
                        else
                        {
                            //  cEnums.ACTIVATION_MESSAGES oMsg = (cEnums.ACTIVATION_MESSAGES)Enum.Parse(typeof(cEnums.ACTIVATION_MESSAGES), nMessages.ToString());
                            enumClass.ACTIVATION_MESSAGES oMsg = (enumClass.ACTIVATION_MESSAGES)Enum.Parse(typeof(enumClass.ACTIVATION_MESSAGES), ((int)oKeyStatus).ToString()/*nMessages.ToString()*/);
                            string sMesgToDisplay = oArmHelper.GetActivationMessege(oMsg);
                            /*this.UIThread(() => MessageBoxEx.Show(this, sMesgToDisplay, cGlobal.GetProductNameFromDesc(), MessageBoxButtons.OK, MessageBoxIcon.Information));*/
                            App.oMainReference.Dispatcher.Invoke(new Action(() =>
                            {
                                App.oMainReference.showMessageEx(App.oMainReference, cGlobalSettings.GetProductNameFromDesc(), sMesgToDisplay);
                                //MessageBox.Show(sMesgToDisplay, cGlobalSettings.GetProductNameFromDesc(), MessageBoxButtons.OK, MessageBoxIcon.Information)
                            }));
                        }
                        //DisableEnableFrom(false);
                    }
                    else
                    {
                        // case should occur only if service fails to check
                        if (oOnlineRetVal == cArmadilloHelper.ACTIVATION_CHECK_FAILED)
                        {
                            if (!AppFunctions.isInternetConnected())
                            {
                                App.oMainReference.showMessage(cResourceManager.LoadString("IDS_ERROR_CONNECTING_INTERNET"), "");
                                return;
                            }

                            if (oArmHelper.InstallKey(string.Empty, sKey, true))
                            {

                                //hide registration links
                                ChangeRegistrationLinksState(true, sKey, sEmailAddress, eUTM_BTN_TYPE.RegistrationNagRegisterNow.ToString());
                                Program.GetArmStatus();
                                //HideRegistrationLinks();

                                // You have successfully register the product.
                                App.oMainReference.showMessage(cResourceManager.LoadString("IDS_STR_THANKS"), "");
                                return;
                            }
                            else
                            {
                                cArmadilloHelper oArmadilloHelper = new cArmadilloHelper();
                                if ((!oArmadilloHelper.Expired()))
                                {

                                    //hide registration links
                                    ChangeRegistrationLinksState(true, sKey, sEmailAddress, eUTM_BTN_TYPE.RegistrationNagRegisterNow.ToString());
                                    Program.GetArmStatus();
                                    //HideRegistrationLinks();3

                                    // You have successfully register the product.
                                    Program.oMainReference.showMessage(cResourceManager.LoadString("IDS_STR_THANKS"), "");
                                    return;
                                }
                                else
                                {
                                    //this.UIThread(() => MessageBoxEx.Show(this, cResourceManager.LoadString("IDS_UNREGSTING_EXPIRED"), cGlobal.GetProductNameFromDesc(), MessageBoxButtons.OK, MessageBoxIcon.Information));
                                    App.oMainReference.Dispatcher.Invoke(new Action(() =>
                                    {
                                        App.oMainReference.showMessageEx(App.oMainReference, "", cResourceManager.LoadString("DPF_REGISTRATION_UNREGISTER_EXPIRE"));
                                        //MessageBox.Show(cResourceManager.LoadString("DPF_REGISTRATION_UNREGISTER_EXPIRE"), cGlobalSettings.GetProductNameFromDesc(), MessageBoxButtons.OK, MessageBoxIcon.Information)
                                    }));
                                }
                            }

                        }
                        //DisableEnableFrom(false);

                    }
                }
            }
            catch (System.Exception ex)
            {
                //DisableEnableFrom(false);
                cGlobalSettings.oLogger.WriteLogException("oBgActivationChecker_DoWork ::", ex);
                //oUtils.WriteToFile(string.Format("{0}|oBgActivationChecker_DoWork()|Error:{1}", this.Name, ex.Message));
            }
        }

        public class HourGlass : IDisposable
        {
            static IntPtr oHandle = IntPtr.Zero;
            public HourGlass()
            {
                Enabled = true;
            }
            public HourGlass(ref IntPtr Handle)
            {
                oHandle = Handle;
                Enabled = true;
            }
            public void Dispose()
            {
                Enabled = false;
            }
            public static bool Enabled
            {
                get { return System.Windows.Forms.Application.UseWaitCursor; }
                set
                {
                    if (value == System.Windows.Forms.Application.UseWaitCursor) return;
                    System.Windows.Forms.Application.UseWaitCursor = value;

                    if (oHandle != null)   // Send WM_SETCURSOR
                        SendMessage(oHandle, 0x20, oHandle, (IntPtr)1);

                }
            }
            [System.Runtime.InteropServices.DllImport("user32.dll")]
            private static extern IntPtr SendMessage(IntPtr hWnd, int msg, IntPtr wp, IntPtr lp);
        }

