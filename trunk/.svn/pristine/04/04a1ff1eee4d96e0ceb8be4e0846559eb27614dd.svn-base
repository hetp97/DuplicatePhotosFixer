        void Init()
        {
            txtLicenseKey = "";
            txtEmail = "";
            LoadMBGLogoLang();
            oBgActivationChecker = new BackgroundWorker();
            oBgActivationChecker.DoWork += oBgActivationChecker_DoWork;
