            }
        }

        public void Licence_PreviewDown(System.Windows.Input.KeyEventArgs e)
        {
            try
            {
                switch (e.Key)
                {
                    // Enable copy/paste and selection of all text.
                    case Key.C:
                    case Key.V:
                    case Key.A:
                        if ((Keyboard.Modifiers & ModifierKeys.Control) == ModifierKeys.Control)
                            return;
                        break;

                    // Enable keyboard navigation/selection.
                    case Key.Left:
                    case Key.Up:
                    case Key.Right:
                    case Key.Down:
                    case Key.PageUp:
                    case Key.PageDown:
                    case Key.Home:
                    case Key.End:
                        return;
                }
                e.Handled = false;
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("frmActivateViewModel :: Licence_PreviewDown : ", ex);
            }
        }

        public void ActivateNow()
        {
            try
            {
                if (cGlobal.IS_LB_BUILD == 1)
                {
#if LB_WINMAC_REGISTER
                    LifeBoatWinMacRegisterNow();
#else
                    RegisterNow();
#endif
                }
                else
                {
                    RegisterNow();
                }

                //Program.mainWindow.TrackEvent(string.Format("{0}{1}", cTrackingParameters.eUTM_BTN_TYPE.BTN_ActivateNow.ToString(), ""), cTrackingParameters.eProductName.ActivationWindow.ToString(), true, bActivateTracking, 0, (int)cTrackingParameters.eReminderEventType.actionbuttonprimary);
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("frmActivate::btnActivateNow_Click ::", ex);
            }
        }


        public void RegisterNow()
        {

            string sEmailAddress = string.Empty;
            string sKey = string.Empty;

            try
            {
                //VG310820 - consider email also for NL builds
                if (cGlobal.setupType == eSetupType.NL_ONE_TIME_EMAIL_REGISTER)
                {
                    sEmailAddress = txtEmail.Trim();
                }

                sKey = txtLicenseKey.Trim();

                if (String.IsNullOrEmpty(sKey))
                {
                    App.oMainReference.Dispatcher.Invoke(new Action(() =>
                    {
                        //MessageBoxWithCheckBox.SimpleMsgBox(this, cResourceManager.LoadString("IDS_KEY_NOT_FOUND"), cGlobalSettings.GetProductName() + " ", MessageBoxButton.OK, MessageBoxImage.Information);
                        System.Windows.MessageBox.Show(cResourceManager.LoadString("DPF_REGISTRATION_KEY_NOT_FOUND"));
                    }));
                    return;
                }

                if (cGlobal.setupType == eSetupType.NL_ONE_TIME_EMAIL_REGISTER)
                {
                    if (!AppFunctions.IsValidEmail(sEmailAddress))
                    {
                        App.oMainReference.Dispatcher.Invoke(new Action(() =>
                        {
                            //MessageBoxWithCheckBox.SimpleMsgBox(this, cResourceManager.LoadString("IDS_NAG_MSG_VALID_EMAIL"), cGlobalSettings.GetProductName() + " ", MessageBoxButton.OK, MessageBoxImage.Information);
                            System.Windows.MessageBox.Show(cResourceManager.LoadString("IDS_NAG_MSG_VALID_EMAIL"));
                        }));
                        return;
                    }
                }

                if (!oArmHelper.IsValidKey(string.Empty, sKey, false))
                {
                    // Key is Invalid and application is expired then show "Unregister/Expired version" message
                    if (cGlobalSettings.cRegDetails.IsExpired && cGlobalSettings.cRegDetails.Key.ToLower() == sKey.ToLower())
                    {
                        //MessageBoxWithCheckBox.SimpleMsgBox(this, cResourceManager.LoadString("IDS_UNREGISTERED_EXPIRED_VERSION"), cGlobalSettings.GetProductName() + " ", MessageBoxButton.OK, MessageBoxImage.Information);
                        System.Windows.MessageBox.Show(cResourceManager.LoadString("DPF_REGISTRATION_UNREGISTER_EXPIRE"));
                    }
                    // If key is Invalid and setup type is NL_ONE_TIME_EMAIL_REGISTER, then 
                    // check for 1 time full access of application 
                    //VG200820 - will be used for only activation
                    else if (cGlobal.setupType == eSetupType.NL_ONE_TIME_EMAIL_REGISTER)
                    {
                        string message = string.Empty;
                        bool isSuccess = false;
                        if (!string.IsNullOrEmpty(sKey) && AppFunctions.IsValidEmail(sEmailAddress))
                        {
                            isSuccess = FreeAppTrialProtection.ValidateFreeKey(sEmailAddress, sKey, out message);
                        }
                        else
                        {
                            message = cResourceManager.LoadString("IDS_NAG_MSG_VALID_EMAIL");
                            if (string.IsNullOrEmpty(sKey))
                                message = cResourceManager.LoadString("DPF_REGISTRATION_KEY_NOT_FOUND");
                        }

                        if (!string.IsNullOrEmpty(message))
                        {
                            if (isSuccess)
                            {
                                message = cResourceManager.LoadString("DPF_REGISTRATION_UNREGISTER_EXPIRE");
                                //MessageBoxResult result = MessageBoxWithCheckBox.SimpleMsgBox(this, message, cGlobalSettings.GetProductName() + " ", MessageBoxButton.OK, MessageBoxImage.Information);
                                //MessageBoxWithCheckBox.show(message, "", cGlobalSettings.GetProductName(), cResourceManager.LoadString("DFF_MESSAGEBOX_OK_TEXT"));
                                System.Windows.MessageBox.Show(cResourceManager.LoadString(message));

                                //MessageBoxResult result = MessageBoxWithCheckBox.SimpleMsgBox(this, message, cGlobalSettings.GetProductName() + " ", MessageBoxButton.YesNo, MessageBoxImage.Information);
                                //if (result == System.Windows.MessageBoxResult.Yes)
                                //{
                                //    cGlobal.frmNagReturnCode = FORM_RETURN_CODES.START_CLEAN;
                                //}
                                //else
                                //{
                                //    cGlobal.frmNagReturnCode = FORM_RETURN_CODES.DO_NOTHING;
                                //}
                                //this.Close();
                            }
                            else
                            {
                                //MessageBoxWithCheckBox.SimpleMsgBox(this, message, cGlobalSettings.GetProductName() + " ", MessageBoxButton.OK, MessageBoxImage.Information);
                                System.Windows.MessageBox.Show(cResourceManager.LoadString(message));
                                txtLicenseKey = string.Empty;
                            }
                        }

                        if (isSuccess)
                            return;

                    }
                    else
                    {
                        //MessageBoxWithCheckBox.SimpleMsgBox(this, cResourceManager.LoadString("IDS_INVALID_KEY"), cGlobalSettings.GetProductName() + " ", MessageBoxButton.OK, MessageBoxImage.Information);
                        System.Windows.MessageBox.Show(cResourceManager.LoadString("IDS_WRONGKEY"));
                    }
                    return;
                }
                else
                {
                    oBgActivationChecker.RunWorkerAsync(new string[] { sEmailAddress, sKey });
                    //Program.oMainFormReference.oFooter.SetRegistrationSettings();                    
                }
            }
            catch (System.Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("RegisterNow ::", ex);
            }
        }

        void LicenseKeyValueChange()
        {
            try
            {
                if (txtLicenseKey.Length > 0)
                {
                    IsActivationBtnEnable = true;
                }
                else
                {
                    IsActivationBtnEnable = false;
                }
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("vmRegsitration :: LicenseKeyValueChange :", ex);
            }
        }
    }
