        void LoadMBGLogoLang()
        {
            try
            {
                if (ImgMoneyBack != null)
                    ImgMoneyBack = null;

                switch (cGlobalSettings.oScanSettings.LanguageCode.ToLower())
                {

                    case "fr":
                        ImgMoneyBack = @"/Resources/mbc_icon_fr.png";
                        break;

                    case "ja":
                        ImgMoneyBack = @"/Resources/mbc_icon_ja.png";
                        break;

                    case "de":
                        ImgMoneyBack = @"/Resources/mbc_icon_de.png";
                        break;
                    case "es":
                        ImgMoneyBack = @"/Resources/mbc_icon_es.png";
                        break;
                    case "ptbr":
                        ImgMoneyBack = @"/Resources/mbc_icon_pt-br.png";
                        break;

                    case "nl":
                        ImgMoneyBack = @"/Resources/mbc_icon_nl.png";
                        break;

                    case "ru":
                        ImgMoneyBack = @"/Resources/mbc_icon_ru.png";
                        break;

                    case "it":
                        ImgMoneyBack = @"/Resources/mbc_icon_it.png";
                        break;

                    case "da":
                        ImgMoneyBack = @"/Resources/mbc_icon_da.png";
                        break;

                    case "sv":
                        ImgMoneyBack = @"/Resources/mbc_icon_sv.png";
                        break;

                    case "no":
                        ImgMoneyBack = @"/Resources/mbc_icon_no.png";
                        break;

                    case "fi":
                        ImgMoneyBack = @"/Resources/mbc_icon_fi.png";
                        break;

                    case "zhcn":
                        ImgMoneyBack = @"/Resources/mbc_icon_zhcn.png";
                        break;

                    case "en":
                    default:
                        ImgMoneyBack = @"/Resources/mbc_icon.png";
                        break;
                }
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("vmRegistration :: LoadMBGLogoLang : ", ex);
            }
        }

     

