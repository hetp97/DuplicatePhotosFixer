                //App.oMainFormReference.TrackEvent(string.Format("{0}{1}", cTrackingParameters.eUTM_BTN_TYPE.BTN_PasteLicenseKey.ToString(), ""), cTrackingParameters.eProductName.ActivationWindow.ToString(), cGlobalSettings.bEnableGATrackingVerbose, bActivateTracking, 0, (int)cTrackingParameters.eReminderEventType.actionbuttonsecondary);
            }
            catch (Exception ex)
