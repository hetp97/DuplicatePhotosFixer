using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows.Media;
using DuplicatePhotosFixer.ClassDictionary;

namespace DuplicatePhotosFixer.Models
{
   public class vmNagThemeSettings : INotifyPropertyChanged
    {
        public event PropertyChangedEventHandler PropertyChanged;
        public void OnPropertyChanged(string name)
        {
            PropertyChangedEventHandler handler = PropertyChanged;
            if (handler != null)
            {
                handler(this, new PropertyChangedEventArgs(name));
            }
        }
   


        bool _LightTheme;
        public bool LightTheme
        {
            get
            {
                return _LightTheme;
            }
            set
            {
                _LightTheme = value;

                if (value)
                {
                    cGlobalSettings.NagSettings.NagTheme = cClientEnum.eThemeMode.Light;
                }

                OnPropertyChanged("LightTheme");
            }
        }

        bool _DarkTheme;
        public bool DarkTheme
        {
            get
            {
                return _DarkTheme;
            }
            set
            {
                _DarkTheme = value;

                if (value)
                {
                    cGlobalSettings.NagSettings.NagTheme = cClientEnum.eThemeMode.Dark;

                }
                OnPropertyChanged("DarkTheme");
            }
        }

        public void SetUIPropertiesValue()
        {
            if (cGlobalSettings.NagSettings == null)
                LoadNagThemeSettings();

           
            switch (cGlobalSettings.NagSettings.NagTheme)
            {
                case cClientEnum.eThemeMode.Light:
                    LightTheme = true;
                    break;
                case cClientEnum.eThemeMode.Dark:
                default:
                    DarkTheme = true;
                    break;
            }

        }

        public void LoadNagThemeSettings(bool bLoadDefaultFocefully = false)
        {
            try
            {
                if (bLoadDefaultFocefully)
                {
                    LoadDefaultSettings();
                    return;
                }

                if (cGlobalSettings.NagSettings == null)
                    LoadNagThemeSettings(true);

            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("vmNagThemeSettings:: LoadNagThemeSettings: ", ex);
            }
        }

        void LoadDefaultSettings()
        {

            cGlobalSettings.NagSettings = new cNagSettings()
            {
                NagTheme = cClientEnum.eThemeMode.Dark,
            };
        }

    }
}
