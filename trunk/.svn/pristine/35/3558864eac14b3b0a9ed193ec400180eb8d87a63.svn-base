<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucMainBoder"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
              xmlns:cust ="clr-namespace:DuplicatePhotosFixer.CustomControl"
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="70" d:DesignWidth="725" Background="Black">

    <UserControl.Resources>
        <Style TargetType="ContextMenu" x:Key="customContextMenu">
            <Setter Property="Background" Value="{DynamicResource cl_bg_dropdown}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource cl_br_dropdown}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="180"/>
        </Style>

        <Style TargetType="MenuItem" x:Key="customMenuItem">
            <Setter Property="Padding" Value="3 0 0 0"/>
            <Setter Property="Foreground" Value="{DynamicResource cl_fg_helpmenuItem}"/>
            <Setter Property="Background" Value="{DynamicResource cl_bg_dropdown}"/>
            <Setter Property="MinHeight" Value="25" />
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource cl_br_dropdown}"/>
            <Setter Property="BorderThickness" Value="1 1 1 0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource cl_bg_hover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        
        <Style  x:Key="btn_customStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" >
                            <ContentControl Content="{TemplateBinding Content}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="False">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource cl_fg_helpmenuItem}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Border  BorderBrush="{DynamicResource clr_darkborder}"  BorderThickness="0 1 0 0">
            <Border.Background>
                <ImageBrush ImageSource="{DynamicResource img_top_header}"/>
            </Border.Background>
            <Grid Grid.Row="0" Background="#3E3E3E"  >
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>

            </Grid.ColumnDefinitions>
            <!--<Image x:Name="dpf_logo" Source="/Resources/Application-0.png" HorizontalAlignment="Left"
                           Margin="5 10 0 0" Width="50" Height="50"/>-->
                <Label x:Name="lblAppTitle" Content="Duplicate Photos Fixer Pro" Foreground="{DynamicResource cl_fg_homeprimary}" VerticalAlignment="Top"
                   HorizontalAlignment="Center" 
                   FontSize="18"
                  />
            <Grid Grid.Column="1">

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <!--<DockPanel VerticalAlignment="Top" Margin="0 5 0 0">-->
                            <StackPanel Orientation="Horizontal"  VerticalAlignment="Top" Margin=" 0 5 10 0" Cursor="Hand" PreviewMouseLeftButtonDown="stkLang_PreviewMouseLeftButtonDown" x:Name="stkLang">
                                <StackPanel.ContextMenu>
                                    <ContextMenu x:Name="mnuLang">
                                        <MenuItem Header="English" x:Name="mnuEnglish" Tag="en" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_english}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Japanese" x:Name="mnuJapanese" Tag="ja" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_japnese}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="German" x:Name="mnuGerman" Tag="de" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_german}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Dutch" x:Name="mnuDutch" Tag="nl" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_dutch}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Finnish" x:Name="mnuFinnish" Tag="fi" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_finnish}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="French" x:Name="mnuFrench" Tag="fr" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_french}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Danish" x:Name="mnuDanish" Tag="da" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_danish}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Italian" x:Name="mnuItalian" Tag="it" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_italian}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Norwegian" x:Name="mnuNorwegian" Tag="no" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_norwegian}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Portugal" x:Name="mnuPortugal" Tag="ptbr" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_portuguese}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Russian" x:Name="mnuRussian" Tag="ru" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_russian}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Spanish" x:Name="mnuSpanish" Tag="es" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_spanish}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Swedish" x:Name="mnuSwedish" Tag="sv" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_sweddish}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </StackPanel.ContextMenu>
                                <Image Grid.Column="0"
                                           x:Name="imgLang"
                   Margin="0"
                   Stretch="None"
                   Source="/Resources/en.png" />
                                <Image Grid.Column="0"                   
                                           Stretch="None"
                                           Margin="3 0 0 0"
                                            Source="{DynamicResource img_dropdownarrow}" />

                            </StackPanel>
                            <!--<cust:ImageButton x:Name="lnkLblLang"                                                              
                                  Image="{DynamicResource img_en_flag}"
                                         Cursor="Hand"
                                   Style="{DynamicResource stl_btnLanguage}"
                        HoverImage="{DynamicResource  img_cart}"
                                  SelectedImage="{DynamicResource  img_cart}"
                                          Click="lnkLblLang_Click">
                            <ComboBox x:Name="languageComboBox" SelectionChanged="LanguageComboBox_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Image x:Name="flag_img" Source="{Binding FlagImagePath}" Width="20" Height="20" Margin="0 0 5 0"/>
                                            <TextBlock Text="{Binding LanguageName}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                        </cust:ImageButton>
                        <cust:ImageButton x:Name="lnkLblLangArrow"   VerticalAlignment="Top" Margin="0 5 0 0"                                                           
                                 
                                   Style="{DynamicResource stl_btnLanguageArrow}"
                                     Image="{DynamicResource img_dropdownarrow}"   
                        HoverImage="{DynamicResource  img_cart}"
                                          Cursor="Hand"
                                  SelectedImage="{DynamicResource  img_cart}" Click="lnkLblLangArrow_Click">

                                <ComboBox x:Name="languageComboBox1" SelectionChanged="LanguageComboBox_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{Binding FlagImagePath}" Width="20" Height="20" Margin="0 0 5 0"/>
                                            <TextBlock Text="{Binding LanguageName}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </cust:ImageButton>-->

                    <!--</DockPanel>-->
                    <!--<cust:ImageButton x:Name="btnCart"                                                              
                                  Image="{DynamicResource img_cart}"
                                   Style="{DynamicResource stl_btnCart}"
                        HoverImage="{DynamicResource  img_cart}"
                                  SelectedImage="{DynamicResource  img_cart}">
                    </cust:ImageButton>-->
                    <cust:ImageButton x:Name="btnActionCenter"  
                                      Margin="0 2 0 0"
                                     
                                      VerticalAlignment="Top"
                                  Image="{DynamicResource img_actioncenter}"
                                   Style="{DynamicResource stl_imgbtn}"
                        HoverImage="{DynamicResource  img_cart}"
                                      Cursor="Hand"                                      
                                  SelectedImage="{DynamicResource  img_close_clicked}" Click="btnActionCenter_Click">
                    </cust:ImageButton>
                        <Image Source="{DynamicResource img_footer}" x:Name="linkDivider" Margin="0 3 0 0" Width="20" Height="15" VerticalAlignment="Top" />

                        <cust:ImageButton
                    x:Name="linklblSettings"
                    VerticalAlignment="Top"
                    Width="auto"
                    Margin="0 0 0 0"
                    Padding="2 0 0 0"
                    Content="Settings"
                    Foreground="{DynamicResource cl_fg_homeprimary}"
                    FontSize="13"
                    Image="{DynamicResource img_settings_sm}"
                    HoverImage="{DynamicResource img_settings_sm}"
                    SelectedImage="{DynamicResource img_settings_sm}"
                    Style="{DynamicResource StyleImageTextButton_setting}"
                    Click="linklblSettings_Click"/>
                        <!--<cust:ImageButton x:Name="linklblSettings"                                
                                                                     
                                VerticalAlignment="Top"
                                  Image="{DynamicResource img_settings_sm}"
                                  Style="{DynamicResource StyleImageTextButton_setting}"
                                  HoverImage="{DynamicResource img_settings_sm}"
                                  SelectedImage="{DynamicResource img_settings_sm}"
                                        Content="Settings" 
                                       Padding="-10 0 0 0"
                                           Margin="-3 0 0 0"  
                                       FontSize="13"
                                        Foreground="{DynamicResource cl_fg_homeprimary}"                                   
                                      Click="linklblSettings_Click">
                        </cust:ImageButton>-->

                        <cust:ImageButton x:Name="lnkLblHelp"
                              DockPanel.Dock="Right"
                              Margin="0,0,10,0"                                   
                             Image="{DynamicResource img_dropdownarrow}"  
                              HoverImage="{DynamicResource img_dropdownarrow}"
                              SelectedImage="{DynamicResource img_dropdownarrow}"
                    FontSize="13" VerticalAlignment="Top" Padding="5 0" 
                              Content="? Help"                                       
                              Visibility="Visible"   
                                          Foreground="{DynamicResource cl_fg_homeprimary}"
                    Style="{DynamicResource TextImagebtn}" Click="lnkLblHelp_Click">
                           
                        </cust:ImageButton>
                        <Popup x:Name="settingspopup"  IsOpen="False" Placement="Mouse" StaysOpen="False">
                            <StackPanel>
                                                             
                        <!--<Button x:Name="btnHelp" Height="28"  Style="{DynamicResource btn_customStyle}"
                                    Background="{DynamicResource cl_bg_dropdown}" MinHeight="28" MinWidth="180" BorderBrush="Transparent" >
                                    <DockPanel Background="{DynamicResource cl_bg_dropdown}">
                                        <Border Background="#fff"  >
                                            <Image Source="{DynamicResource img_helpicon}" Stretch="None" Margin="5"/>
                                        </Border>
                                        <Border BorderBrush="{DynamicResource cl_br_dropdown}"
                                                BorderThickness="0 0 0 1" Padding="6 0 0 0 ">
                                            <TextBlock Text="Help"  Foreground="{DynamicResource cl_fg_helpmenuItem}" MinWidth="150"                                                   VerticalAlignment="Center"  Padding="6 0 0 0"/>
                                        </Border>
                                    </DockPanel>

                                </Button>-->
                        
                                <cust:ImageButton
                                    x:Name="btnhelp"
                                    Background="{DynamicResource cl_bg_dropdown}"                                  
                                    Image="{DynamicResource img_helpicon}"
                                    Style="{DynamicResource stl_ImgTextButton}"
                                    HoverImage="{DynamicResource img_contactus}"
                                    SelectedImage="{DynamicResource img_contactus}"
                                    Content="Help" FontWeight="Normal"
                                      Height="28" MinWidth="180"                                       
                                       Padding="6 0 0 0"
                                       FontSize="12"
                                       Foreground="{DynamicResource cl_fg_helpmenuItem}"
                                       BorderBrush="{DynamicResource clr_darkborder}"
                                    BorderThickness="1 1 1 0"
                                    Click="btnhelp_Click">
                                </cust:ImageButton>
                                <cust:ImageButton
                                    x:Name="btnUserGuide"
                                    Background="{DynamicResource cl_bg_dropdown}"                                  
                                    Image="{DynamicResource img_userguide}"
                                    Style="{DynamicResource stl_ImgTextButton}"
                                    HoverImage="{DynamicResource img_contactus}"
                                    SelectedImage="{DynamicResource img_contactus}"
                                    Content="User Guide" FontWeight="Normal"
                                      Height="28" MinWidth="180"                                       
                                       Padding="6 0 0 0"
                                       FontSize="12"
                                       Foreground="{DynamicResource cl_fg_helpmenuItem}"
                                       BorderBrush="{DynamicResource clr_darkborder}"
                                    BorderThickness="1 1 1 0"
                                    Click="btnUserGuide_Click">
                                </cust:ImageButton>
                                <cust:ImageButton
                                    x:Name="btnContactUs"
                                    Background="{DynamicResource cl_bg_dropdown}"                                  
                                    Image="{DynamicResource img_contactus}"
                                    Style="{DynamicResource stl_ImgTextButton}"
                                    HoverImage="{DynamicResource img_contactus}"
                                    SelectedImage="{DynamicResource img_contactus}"
                                    Content="Contact Us" FontWeight="Normal"
                                      Height="28" MinWidth="180"                                  
                                       Padding="6 0 0 0"
                                       FontSize="12"
                                       Foreground="{DynamicResource cl_fg_helpmenuItem}"
                                       BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1 1 1 0" Click="btnContactUs_Click"
                                    >
                                </cust:ImageButton>
                                <cust:ImageButton
                                    x:Name="btnClearCache"
                                    Background="{DynamicResource cl_bg_dropdown}"                                  
                                    Image="{DynamicResource img_cache}"
                                    Style="{DynamicResource stl_ImgTextButton}"
                                    HoverImage="{DynamicResource img_contactus}"
                                    SelectedImage="{DynamicResource img_contactus}"
                                    Content="Clear Cache" FontWeight="Normal"
                                      Height="28" MinWidth="180"                                  
                                       Padding="6 0 0 0"
                                       FontSize="12"
                                       Foreground="{DynamicResource cl_fg_helpmenuItem}"
                                        Click="btnClearCache_Click"
                                       BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1 1 1 0">
                                </cust:ImageButton>

                                <cust:ImageButton
                                    x:Name="btnRegistration"
                                    Background="{DynamicResource cl_bg_dropdown}"                                  
                                    Image="{DynamicResource img_registration}"
                                    Style="{DynamicResource stl_ImgTextButton}"
                                    HoverImage="{DynamicResource img_registration}"
                                    SelectedImage="{DynamicResource img_registration}"
                                    Content="Enter Registration Key" FontWeight="Normal"
                                      Height="28" MinWidth="180"                                  
                                       Padding="6 0 0 0"
                                       FontSize="12"
                                       Foreground="{DynamicResource cl_fg_helpmenuItem}"                                     
                                       BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1 1 1 0"
                                    Click="btnRegistration_Click">
                                </cust:ImageButton>

                                <cust:ImageButton
                                    x:Name="btnUpdates"
                                    Background="{DynamicResource cl_bg_dropdown}"                                  
                                    Image="{DynamicResource img_updates}"
                                    Style="{DynamicResource stl_ImgTextButton}"
                                    HoverImage="{DynamicResource img_updates}"
                                    SelectedImage="{DynamicResource img_updates}"
                                    Content="Check for Updates" FontWeight="Normal"
                                      Height="28" MinWidth="180"                                  
                                       Padding="6 0 0 0"
                                       FontSize="12"
                                       Foreground="{DynamicResource cl_fg_helpmenuItem}"
                                       BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1 1 1 0">
                                </cust:ImageButton>

                                <cust:ImageButton
                                    x:Name="btnFeedBack"
                                    Background="{DynamicResource cl_bg_dropdown}"                                  
                                    Image="{DynamicResource img_feedback}"
                                    Style="{DynamicResource stl_ImgTextButton}"
                                    HoverImage="{DynamicResource img_feedback}"
                                    SelectedImage="{DynamicResource img_feedback}"
                                    Content="FeedBack" FontWeight="Normal"
                                      Height="28" MinWidth="180"                                  
                                       Padding="6 0 0 0"
                                       FontSize="12"
                                       Foreground="{DynamicResource cl_fg_helpmenuItem}"
                                    Click="btnFeedBack_Click"
                                       BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1 1 1 0">
                                </cust:ImageButton>

                                <cust:ImageButton
                                    x:Name="btnVideo"
                                    Background="{DynamicResource cl_bg_dropdown}"                                  
                                    Image="{DynamicResource img_video}"
                                    Style="{DynamicResource stl_ImgTextButton}"
                                    HoverImage="{DynamicResource img_video}"
                                    SelectedImage="{DynamicResource img_video}"
                                    Content="Go to Video Channel" FontWeight="Normal"
                                      Height="28" MinWidth="180"                                  
                                       Padding="6 0 0 0"
                                       FontSize="12"
                                       Foreground="{DynamicResource cl_fg_helpmenuItem}"
                                       BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1 1 1 0">
                                </cust:ImageButton>

                                <cust:ImageButton
                                    x:Name="btnAboutUs"
                                    Background="{DynamicResource cl_bg_dropdown}"                                  
                                    Image="{DynamicResource img_about_icon}"
                                    Style="{DynamicResource stl_ImgTextButton}"
                                    HoverImage="{DynamicResource img_video}"
                                    SelectedImage="{DynamicResource img_video}"
                                    Content="About Us" FontWeight="Normal"
                                      Height="28" MinWidth="180"                                  
                                       Padding="6 0 0 0"
                                       FontSize="12"
                                       Click="btnAboutus_Click"
                                       Foreground="{DynamicResource cl_fg_helpmenuItem}"
                                       BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1">
                                </cust:ImageButton>
                            </StackPanel>
                       
                    </Popup> 

                        <DockPanel HorizontalAlignment="Right" Margin="0 0 5 0">
                        <cust:ImageButton x:Name="btn_close"  DockPanel.Dock="Right"                              
                                 
                                         
                                  Width="28"
                                Height="26"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"  
                                  Image="{DynamicResource img_close_normal}"
                                   Style="{DynamicResource stl_imgbtn}"
                        HoverImage="{DynamicResource  img_close_hover}"
                                  SelectedImage="{DynamicResource  img_close_clicked}" Click="btn_close_Click" >
                        </cust:ImageButton>
                     
                        <cust:ImageButton x:Name="btnMaximize"    
                                  DockPanel.Dock="Right"                                                         
                                  Width="28"
                                Height="26"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"  
                                  Image="{DynamicResource img_max_normal}"
                                   Style="{DynamicResource stl_imgbtn}"
                        HoverImage="{DynamicResource  img_max_hover}"
                                  SelectedImage="{DynamicResource  img_max_clicked}" Click="btnMaximize_Click" >
                        </cust:ImageButton>
                        <cust:ImageButton x:Name="btnMinimize"   DockPanel.Dock="Right" 
                                  Width="28"
                                Height="26"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"  
                           
                                  Image="{DynamicResource img_min_normal}"
                                   Style="{DynamicResource stl_imgbtn}"
                        HoverImage="{DynamicResource  img_min_hover}"
                                  SelectedImage="{DynamicResource  img_min_clicked}" Click="btnMinimize_Click" >
                        </cust:ImageButton>

                    </DockPanel>


                </StackPanel>
            </Grid>
        </Grid>

        </Border>
    </Grid>
</UserControl>
