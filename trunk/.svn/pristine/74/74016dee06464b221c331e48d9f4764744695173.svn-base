<Window x:Class="DuplicatePhotosFixer.Views.frmFeedBack"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        mc:Ignorable="d" AllowsTransparency="True"
        Title="frmFeedBack" Height="435" Width="571" WindowStyle="None" Background="{DynamicResource bgclr_soliddark}">
    <Window.Resources>
        <DataTemplate x:Key="cmbTemplate">
            <WrapPanel Height="40">
                <Label Content="{Binding}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#FFFFFF" />
            </WrapPanel>
        </DataTemplate>
        <Style x:Key="customComboScanMode"
           TargetType="{x:Type ComboBox}">
            <Setter Property="SnapsToDevicePixels"
                Value="true" />
            <Setter Property="OverridesDefaultStyle"
                Value="true" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility"
                Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility"
                Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll"
                Value="true" />
            <Setter Property="MinWidth"
                Value="20" />
            <Setter Property="MinHeight"
                Value="20" />
            <Setter Property="Foreground"
                Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton Name="ToggleButton"
                                      
                                      Grid.Column="2"
                                      Focusable="false"
                                      IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press" />

                            <ContentPresenter Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          Margin="3,3,23,3"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left" />

                            <TextBox x:Name="PART_EditableTextBox"
                                 Style="{x:Null}"
                                 Template="{StaticResource ComboBoxTextBox}"
                                 HorizontalAlignment="Left"
                                 BorderBrush="{TemplateBinding BorderBrush}"
                                 VerticalAlignment="Center"
                                 Focusable="True"
                                 Background="#ffffff"
                                 Foreground="Green"
                                 Visibility="Hidden"
                                 IsReadOnly="{TemplateBinding IsReadOnly}" />

                            <Popup Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                                <Grid Name="DropDown"
                                  SnapsToDevicePixels="True"
                                  MinWidth="{TemplateBinding ActualWidth}"
                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">

                                    <Border x:Name="DropDownBorder"
                                        Background="#ffffff"
                                        BorderThickness="1"
                                        BorderBrush="#4C4C4C" />

                                    <ScrollViewer Margin="4,6,4,6"
                                              SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems"
                                 Value="false">
                                <Setter TargetName="DropDownBorder"
                                    Property="Height"
                                    Value="40" />
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                 Value="false">
                                <Setter Property="Foreground"
                                    Value="#888888" />
                            </Trigger>
                            <Trigger Property="IsGrouping"
                                 Value="true">
                                <Setter Property="ScrollViewer.CanContentScroll"
                                    Value="false" />
                            </Trigger>
                            <Trigger SourceName="Popup"
                                 Property="Popup.AllowsTransparency"
                                 Value="true">
                                <Setter TargetName="DropDownBorder"
                                    Property="CornerRadius"
                                    Value="0" />
                                <Setter TargetName="DropDownBorder"
                                    Property="Margin"
                                    Value="0,2,0,0" />

                            </Trigger>
                            <Trigger Property="IsEditable"
                                 Value="true">
                                <Setter Property="IsTabStop"
                                    Value="false" />
                                <Setter TargetName="PART_EditableTextBox"
                                    Property="Visibility"
                                    Value="Visible" />
                                <Setter TargetName="ContentSite"
                                    Property="Visibility"
                                    Value="Hidden" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition MinHeight="41" Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <DockPanel>
                <Button DockPanel.Dock="Right"  Background="Transparent"
                    Margin="0 0 20 0"
                    BorderBrush="Transparent"
                    Click="Button_Click">
                    <Image Source="/Resources/closevpn.png" Stretch="None"/>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="TextBlock.TextAlignment" Value="Center" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bdr_main">
                                            <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"                                                              
                                                              TextElement.FontSize="13"
                                                              TextElement.Foreground="White">
                                            </ContentPresenter>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" TargetName="bdr_main" Value="#3FB3E6">
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="true">
                                                <Setter Property="Background" TargetName="bdr_main" Value="#178BBE">
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                                <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>

                </Button>
                <Image x:Name="dpf_logo" Source="/Resources/dpf_updateofr_icon.png" DockPanel.Dock="Left" Margin="10 0" Stretch="None"/>
                <TextBlock x:Name="dpf_header" Text="Duplicate Photos Fixer Pro - " Foreground="#f9f9f9"
                       FontSize="15" FontWeight="Regular" 
                       VerticalAlignment="Center" />
                <TextBlock x:Name="dpf_header_info" Text="FeedBack" VerticalAlignment="Center" FontSize="15" FontWeight="Regular" Foreground="#919191" />
            </DockPanel>

        </Grid>
        <Grid Grid.Row="1" Margin="5" Background="#2F2F2F" >
            <StackPanel>
                <TextBlock x:Name="tbDearUser" 
                           Foreground="#e9e9e9"
                           FontWeight="Regular"
                           Padding="8"
                           TextWrapping="Wrap" 
                           FontSize="12">
                    Dear user, please share your experience by filling this feedback form. This will give us a better idea<LineBreak/> of the application's performance and help us provide better solutions to fix the issues reported.
                </TextBlock>
                <TextBlock x:Name="tbProvideEmail"
                           TextWrapping="Wrap"
                           Padding="8"
                           FontWeight="Regular"
                           FontSize="13"
                           Foreground="#0095fe">
                    Provide your email address and select the Feedback type from  the dropdown  list.
                </TextBlock>
                <DockPanel Height="40" >
                    <TextBlock x:Name="tbEmail"
                             VerticalAlignment="Center" 
                               MinWidth="170"
                               Width="Auto"
                               Padding="8"
                               Foreground="#e9e9e9"
                               FontSize="13"
                              >
                        Your Email Address
                    </TextBlock>
                    <TextBox x:Name="txtEmail"
                            VerticalAlignment="Center" 
                             MinHeight="25"
                             Background="#383838"
                             BorderBrush="#4E4E4E"
                             Width="Auto"
                             MinWidth="290">
                             
                    </TextBox>
                </DockPanel>
                <DockPanel Height="40" >
                    <TextBlock x:Name="tbFeedBacktype"
                             VerticalAlignment="Center" 
                               MinWidth="170"
                               Width="Auto"
                                Padding="8"
                               Foreground="#e9e9e9"
                               FontSize="13"
                              >
                        FeedBack Type:
                    </TextBlock>
                    <!--<ComboBox x:Name="cboFeedBacktype" Width="Auto" MinWidth="353"
                              VerticalAlignment="Center" SelectionChanged="cboFeedBacktype_SelectionChanged" />-->
                    <Border 
                            Grid.Column="1"
                                Margin="0 10"
                               
                           Background="#383838"
                             BorderBrush="#4E4E4E" BorderThickness="1,1,1,1">
                        <DockPanel>
                            <ComboBox x:Name="cboScanModes" Grid.Column="1"
                                      Padding="2"
                                      Height="34"                          
                                      Foreground="#FFFFFF" 
                                      FontWeight="Normal"
                                      Background="#FFF"
                                      Margin="0,0,0,0"
                                      MinWidth="300"
                                      ItemTemplate="{StaticResource cmbTemplate}"
                                      Style="{StaticResource customComboScanMode}" >
                            </ComboBox>
                            <!--<Button Width="10" Height="10" Background="#ffffff" BorderBrush="#E6E8EA" BorderThickness="1,0,0,0"  >
                            
                            <Button.Content >
                                    <Image Source="/Resources/down_minsize.png"/>
                                </Button.Content>
                            
                        </Button>-->
                        </DockPanel>
                    </Border>

                </DockPanel>
                   

                <TextBlock x:Name="tbBriefly"
                           TextWrapping="Wrap"
                           Padding="8"
                           FontSize="14"
                           Foreground="#0096FF"
                           >
                    Briefly describe your experience:
                </TextBlock>
                <TextBox x:Name="txtBrief"
                         Width="530"
                         Height="124"
                         Margin="10 0"
                         Background="#383838"
                         BorderBrush="#4e4e4e"
                         BorderThickness="1"
                         HorizontalAlignment="Left"/>
                <DockPanel HorizontalAlignment="Right" Margin="0 10 0 0">
                    
                    <Button x:Name="btn_Cancel" Width="109" Height="29" Background="Transparent" 
                            Foreground="#8c8c8c"  BorderBrush="#4e4e4e"

                            Content="Cancel"
                            Margin="0 10 10 0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="White" />
                                <Setter Property="TextBlock.TextAlignment" Value="Center" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bdr_main"  BorderThickness="1" BorderBrush="#4E4E4E" Background="Transparent">
                                                <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="#8c8c8c">
                                                </ContentPresenter>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" TargetName="bdr_main" Value="#494949"></Setter>
                                                    <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                    <Setter Property="Background" TargetName="bdr_main" Value="#494949"></Setter>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="true">
                                                    <Setter Property="BorderBrush" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                    <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                    <Setter Property="Background" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                                    <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="btnSubmit" Width="109" Height="29" Foreground="#fff" Background="#017AED" BorderBrush="Transparent"
                            Content="Submit"
                            Margin="0 10 20 0">
                    </Button>
                </DockPanel>

            </StackPanel>
        </Grid>
        
    </Grid>
</Window>
