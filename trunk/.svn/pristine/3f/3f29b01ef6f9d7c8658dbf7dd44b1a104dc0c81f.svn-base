                switch (cGlobalSettings.CurrentScanMode)
                {
                    case eScanMode.FileSearch:
                        {
                            //enumClass.ePathType pathtype = enumClass.ePathType.file;
                            foreach (csScanPaths ScanPathData in listOfSelectedPath)
                            {
                                csScanPaths oScanPathData = ScanPathData;
                                bool isValid = ValidatePath(ref oScanPathData, ref statusMessage);

                                // All is well, add path to scan list
                                if (isValid)
                                {
                                    oScanPathData.isSelected = true;
                                    ScanPathData.isSelected = true;
                                    oScanPathData.ScanIncludeSubfolder = true;
                                    ScanPathData.ScanIncludeSubfolder = true;
                                    //Program.oMainReference.Home_addSelectedPath(oScanPathData, true);
