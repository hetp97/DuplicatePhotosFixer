        public static ReaderWriterLockSlim ScanLock = new ReaderWriterLockSlim();
        public void startCompare()
        {
            try
            {
                if (!ScanLock.TryEnterWriteLock(0))
                {
                    return;
                }


                try
                {
                    Init();

                    //if (Environment.OSVersion.Version.Major >= 6)
                    //    Microsoft.WindowsAPICodePack.Taskbar.TaskbarManager.Instance.SetProgressState((Microsoft.WindowsAPICodePack.Taskbar.TaskbarProgressBarState.Normal));

                    Program.oMainReference.fProgress.progressType = ProgressType.Scan;
                    Program.oMainReference.fProgress.LoadStringsForScan();

#if TrayScan
                    if (Program.oMainReference.bTrayScan && Program.bAutoscan)
                    {
                        Program.oMainReference.fProgress.Opacity = 0;
                    }
                    else
                    {
                        Program.oMainReference.fProgress.Opacity = 100;
                    }
#endif

                    Program.oMainReference.Progress_Show(Program.oMainReference.fProgress, true);
                    if (Program.bIsFirstInstall)
                    {
                        switch (cGlobal.setupType)
                        {
                            case eSetupType.SCAN_DEFAULT:
                            case eSetupType.SCAN_ALL:
                                //case eSetupType.ADD_All:
                                Program.oMainReference.MinimizeAppToTray(false);
                                break;
                            default:
                                break;
                        }
                    }
                }
                finally
                {
                    ScanLock.SafeExitWriteLock();
                }
            }
            catch (System.Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("SearchDuplicates", ex);
            }
        }
        private void btnScanForDuplicates_Click(object sender, RoutedEventArgs e)
        {
            try
            {
                if (cGlobalSettings.listScanPath.Where(path => path.isSelected == true).Count() < 1 && !Program.IsCommandLine)
                {
                    GC.Collect();

                    if (Program.bSilentScan)
                        Program.oMainReference.ForceApplicationExit();

                    return;
                }

                cGlobalSettings.isAddPhotoClicked = false;
                cGlobalSettings.resetTotalDuplicatesParams();   // Reset parameters

                cGlobalSettings.oRegSettings.SetTotalDuplicatesFound(cGlobalSettings.TotalDuplicatePhotos);
                cGlobalSettings.oRegSettings.SetTotalDuplicatesFoundStr(cGlobalSettings.TotalDuplicatePhotos); //VG300320
                cGlobalSettings.oRegSettings.SetTotalDuplicatesSpace(cGlobalSettings.TotalDuplicatePhotosSizeMatchLevel);

                //by default always open the result with Image View
                cGlobalSettings.bShowDuplicatesInListForm = false;


                //if ((!cGlobalSettings.cRegDetails.IsRegistered || cGlobalSettings.cRegDetails.IsExpired) && cGlobal.setupTrialType == eTrialType.Trial24)
                //{
                //    if (cGlobal.setupType != eSetupType.NL_ONE_TIME_EMAIL_REGISTER && cGlobalSettings.oScanSettings.LanguageCode.ToLower() == "en")
                //    {
                //        bool isStarted;
                //        bool isExpired = Program.oMainReference.IsTrialPeriodExpired(false, out isStarted);

                //        if (isStarted && isExpired)
                //        {
                //            Program.oMainReference.Display24TrialNag();

                //            return;
                //        }
                //    }
                //}



               // showScanDuplicateButton((int)enumClass.eBtnVisableStatus.Disable, true, false);
                //});
                Program.oMainReference.Home_startCompare();
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("extBtn_scanForDuplicates_Click :: ", ex);
            }
            App.oMainReference.ShowResults();


            //try
            //{

            //    //foreach (var item in selectedFiles)
            //    //{
            //    //    if (Directory.Exists(item.filePath))
            //    //    {
            //    //        //string[] files = 
            //    //    }
            //    //}

            //}
            //catch (Exception ex)
            //{

            //}

        }

