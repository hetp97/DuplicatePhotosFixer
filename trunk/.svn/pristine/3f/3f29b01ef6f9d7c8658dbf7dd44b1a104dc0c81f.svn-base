        private void btnAddPhotos_Click(object sender, RoutedEventArgs e)
        {
           
            btnScanForDuplicates.IsEnabled = true;
            



               //openFileBox = new Microsoft.Win32.OpenFileDialog();
               //openFileBox.Multiselect = true;
               //openFileBox.Title = "Select a picture";
               //openFileBox.Filter = "All supported graphics|*.jpg;*.jpeg;*.png|" +
               //  "JPEG (*.jpg;*.jpeg)|*.jpg;*.jpeg|" +
               //  "Portable Network Graphic (*.png)|*.png";

               //if (openFileBox.ShowDialog() == true)
               //{
               //    string[] paths = openFileBox.FileNames;

               //    foreach( var path in paths)
               //    {
               //        selectedFiles.Add(new Helpers.csSelectedFiles()
               //        {
               //            isSelected = true,
               //            fileIcon = "/Resources/btn_pic.png",
               //            filePath = path,
               //            deleteButtonIcon = "/Resources/delete_normal.png",
               //        });
               //    }

               //    checkListSize(selectedFiles);




               openFileDialog1 = new OpenFileDialog();
          //  openFileDialog1.Filter = cGlobalSettings.FileDialogFilterList;
            openFileDialog1.Filter = "Image Files (*.png;*.jpeg;*.jpg;*.gif;*.bmp)|*.png;*.jpeg;*.jpg;*.gif;*.bmp|All Files (*.*)|*.*";
            openFileDialog1.Multiselect = true;
            openFileDialog1.FileName = "";
            string InitDir = cGlobalSettings.GetInitialDirectory;
            if (!string.IsNullOrEmpty(InitDir))
                openFileDialog1.InitialDirectory = InitDir;
            DialogResult result = openFileDialog1.ShowDialog();

            if (result == DialogResult.OK)
            {
                List<csScanPaths> lstScanPath = null;
                try
                {
                    lstScanPath = new List<csScanPaths>();
                    foreach (string strPath in openFileDialog1.FileNames)
                    {
                        csScanPaths oScanPath = new csScanPaths {
                            strPath = strPath,
                            fileIcon = "/Resources/btn_pic.png",
                            deleteButtonIcon = "/Resources/delete_normal.png",                           

                        };
                        lstScanPath.Add(oScanPath);                      
                    }
                    string statusMessage = addValidScanPath(lstScanPath.ToArray());

                    if (!string.IsNullOrEmpty(statusMessage))
                    {
                        //MessageBoxEx.Show(this, statusMessage, cGlobalSettings.GetProductName(), MessageBoxButtons.OK, MessageBoxIcon.Information);
                        System.Windows.Forms.MessageBox.Show(statusMessage);
                    }
                }
                catch (Exception ex)
                {
                    //cGlobalSettings.oLogger.WriteLogException("btn_AddPhotos_Click", ex);
                }
                finally
                {
                    if (lstScanPath != null) lstScanPath.Clear();
                    lstScanPath = null;
                }
            }
            
            gridFileFolder.ItemsSource = null;
            gridFileFolder.ItemsSource = cGlobalSettings.listScanPath;

            //checkListSize(cGlobalSettings.listScanPath);
        }

