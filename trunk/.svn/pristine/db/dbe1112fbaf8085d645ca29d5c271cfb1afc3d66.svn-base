        static public long minFileSize
        {
            get
            {
                long minSize = cGlobalSettings.DefaultMinFileSize;// 50 * 1024;
                string val = Read(enumClass.eRegistryKeys.minSize.ToString(), minSize, RegistryValueKind.QWord);
                //val = "1";
                if (val == null)
                    return minSize;
                else
                {

                    if (long.TryParse(val, out minSize))
                    {
                        if (minSize < 1073741824 && minSize >= 10240) // If(size < 1GB and size >= 10KB)
                            return minSize;
                        else
                            return cGlobalSettings.DefaultMinFileSize;
                    }
                    return minSize;
                }
            }
            set
            {
                Write(enumClass.eRegistryKeys.minSize.ToString(), value, RegistryValueKind.QWord);
            }
        }


        static public Int64 totalFileDeleted
        {
            get
            {
                int filesDeletedCount = 0;// 50 * 1024;
                string val = Read(enumClass.eRegistryKeys.FilesDeleted.ToString(), filesDeletedCount, RegistryValueKind.DWord);
                if (val == null)
                    return filesDeletedCount;
                else
                {
                    if (int.TryParse(val, out filesDeletedCount))
                    {
                        if (filesDeletedCount >= cGlobalSettings.maxTrialDeleteLimit) // If(size < 1GB and size >= 10KB)
                            return cGlobalSettings.maxTrialDeleteLimit;
                        else if (filesDeletedCount < 0)
                            return 0;
                        else
                            return filesDeletedCount;
                    }
                    return filesDeletedCount;
                }
            }
            set
            {
                Write(enumClass.eRegistryKeys.FilesDeleted.ToString(), value, RegistryValueKind.DWord);
            }
        }


