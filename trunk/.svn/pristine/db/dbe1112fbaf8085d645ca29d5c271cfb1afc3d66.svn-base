        public const string REGSTR_IS_GIVE_AWAY_SHOWN = "GA";


        public const string REGSTR_IS_SERVER_INFORMED_FOR_FREE_CLEANING = "IsServerInformedForFreeCleaning";
        public const string REGSTR_IS_FREE_CLEANING_DONE = "IsFreeCleanDone";
        public const string REGSTR_IS_FIRST_RESULT_LOAD = "bRFTL";

        public static bool isResultLoadFirstTime
        {
            get
            {
                bool isShown = true;
                string val = Read(REGSTR_IS_FIRST_RESULT_LOAD, 1, RegistryValueKind.DWord);
                if (val == null)
                    isShown = true;
                else
                {
                    isShown = Convert.ToByte(val) == 0 ? false : true;
                }
                return isShown;
            }
            set
            {
                if (value)
                    Write(REGSTR_IS_FIRST_RESULT_LOAD, 1, RegistryValueKind.DWord);
                else
                    Write(REGSTR_IS_FIRST_RESULT_LOAD, 0, RegistryValueKind.DWord);
            }
        }

        public static bool isGiveAwayShown
        {
            get
            {
                bool isShown = true;
                string val = Read(REGSTR_IS_GIVE_AWAY_SHOWN, 0, RegistryValueKind.DWord);
                if (val == null)
                    isShown = false;
                else
                {
                    isShown = Convert.ToByte(val) == 0 ? false : true;
                }
                return isShown;
            }
            set
            {
                if (value)
                    Write(REGSTR_IS_GIVE_AWAY_SHOWN, 1, RegistryValueKind.DWord);
                else
                    Write(REGSTR_IS_GIVE_AWAY_SHOWN, 0, RegistryValueKind.DWord);
            }
        }

        public static int IsFreeCleanDone
        {
            get
            {
                string val = Read(REGSTR_IS_FREE_CLEANING_DONE, 1, RegistryValueKind.DWord);
                if (val == null)
                    return 1;
                else
                    return Convert.ToByte(val);
            }
            set
            {
                Write(REGSTR_IS_FREE_CLEANING_DONE, value, RegistryValueKind.DWord);
            }
        }

        /* By default assumed that Server knows the status,
         * In case after removing duplicates not able to inform server (due to internet lost),
         * update value to 0(Server not informed for free cleaning, but cleaning is done).
         */
        public static int IsServerInformedForFreeCleaning
        {
            get
            {
                string val = Read(REGSTR_IS_SERVER_INFORMED_FOR_FREE_CLEANING, 1, RegistryValueKind.DWord);
                if (val == null)
                    return 1;
                else
                    return Convert.ToByte(val);
            }
            set
            {
                Write(REGSTR_IS_SERVER_INFORMED_FOR_FREE_CLEANING, value, RegistryValueKind.DWord);
            }
        }

