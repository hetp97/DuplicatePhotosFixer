        /// <summary>
        /// Read the key value
        /// </summary>
        /// <param name="KeyName"> Name of key whose value to read.</param>
        /// <param name="defaultValue"> Key value in case if Key is not exist. </param>
        /// <returns></returns>
        static string Read(string KeyName, object defaultValue, RegistryValueKind ValueTypeOf)
        {
            string keyValue = null;
            
            // Open a subKey as read-only
            try
            {
                keyValue = Convert.ToString(cGlobalSettings.GetCommonAppDataRegistryValue(KeyName, defaultValue));
                RegistryKey sk1 = Registry.CurrentUser.OpenSubKey(cGlobalSettings.VersionIndependentCommonRegKeyNoHive);// rk.OpenSubKey(cGlobalSettings.CurrentUser_SubKey);
                // If the RegistrySubKey doesn't exist -> (null)
                if (sk1 == null)
                {
                    return null;
                }
                else
                {
                    try
                    {
                        // If the RegistryKey exists I get its value
                        // or null is returned.
                        keyValue = Convert.ToString(sk1.GetValue(KeyName.ToUpper()));
                        if (string.IsNullOrEmpty(keyValue))
                        {
                            // Write/Create key
                            if (Write(KeyName, defaultValue, ValueTypeOf))
                            {
                                try
                                {
                                    // Read the key
                                    keyValue = Convert.ToString(sk1.GetValue(KeyName.ToUpper()));
                                }
                                catch
                                {
                                    keyValue = null;
                                }
                            }
                        }
                    }
                    catch (Exception e)
                    {
                        cGlobalSettings.oLogger.WriteLogException("RegistryTool- Read:: OpenSubKey : keyName : " + KeyName + " Value :" + Convert.ToString(defaultValue), e);
                        //ShowErrorMessage(e, "Reading registry " + KeyName.ToUpper());
                        keyValue = null;
                    }
                }
            }
            catch(Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("RegistryTool:: OpenSubKey : ", ex);
            }

            return keyValue;
        }


        static bool Write(string KeyName, object Value, RegistryValueKind ValueTypeOf)
        {
            try
            {

                //RegistryValueKind ValueTypeOf;
                if (Value == null)
                    return false;

                // Setting
                // I have to use CreateSubKey 
                // (create or open it if already exits), 
                // 'cause OpenSubKey open a subKey as read-only
                RegistryKey sk1 = Registry.CurrentUser.CreateSubKey(cGlobalSettings.VersionIndependentCommonRegKeyNoHive); //rk.CreateSubKey(cGlobalSettings.CurrentUser_SubKey);
                // Save the value
                sk1.SetValue(KeyName.ToUpper(), Value, ValueTypeOf);

                return true;
            }
            catch (Exception e)
            {
                // AAAAAAAAAAARGH, an error!
                //ShowErrorMessage(e, "Writing registry " + KeyName.ToUpper());
                cGlobalSettings.oLogger.WriteLogException("RegistryTool:: Write() : keyName : " + KeyName + " Value :" + Convert.ToString(Value), e);
                return false;
            }
        }

        public static bool DeleteKey(string KeyName)
        {
            try
            {
                // Setting
                RegistryKey sk1 = Registry.CurrentUser.CreateSubKey(cGlobalSettings.VersionIndependentCommonRegKeyNoHive);
                // If the RegistrySubKey doesn't exists -> (true)
                if (sk1 == null)
                    return true;
                else
                    sk1.DeleteValue(KeyName);

                return true;
            }
            catch (Exception e)
            {
                // AAAAAAAAAAARGH, an error!
                //ShowErrorMessage(e, "Deleting SubKey " + subKey);
                cGlobalSettings.oLogger.WriteLogException("RegistryTool:: DeleteKey() : keyName : " + KeyName, e);
                return false;
            }
        }

    }
