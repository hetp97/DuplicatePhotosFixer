<Window x:Class="DuplicatePhotosFixer.Views.frmSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        mc:Ignorable="d"
        Title="frmSettings" Height="575" Width="664" WindowStyle="None"
        Background="{DynamicResource bgrclr_solidgray}" Visibility="Visible" x:Name="settingsWindow">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Margin="20 5">
            <TextBlock Text="Duplicate Photo Fixer Pro" Foreground="{DynamicResource frgclr_white}" VerticalAlignment="Center" FontSize="15"/>

            <Button DockPanel.Dock="Right" Height="20" Width="20" Background="{DynamicResource bgrclr_solidgray}" BorderBrush="{DynamicResource clr_darkborder}">
                <Image Source="{DynamicResource img_close}"/>
            </Button>
            <TextBlock Text="Settings" Foreground="{DynamicResource frgclr_gray}" FontSize="15" VerticalAlignment="Center" Padding="10 0"/>
        </DockPanel>
        <Grid Grid.Row="2" Background="{DynamicResource frgclr_white}" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="141"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="{DynamicResource bgrclr_grayish}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="57"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Background="{DynamicResource bgrclr_menuitemstackpanel}">
                    <Menu>
                        <Menu.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </Menu.ItemsPanel>
                        <MenuItem Header="General" Height="42"/>
                        <Border BorderBrush="{DynamicResource clr_grayborder}" Width="140" BorderThickness="0 0 0 1"/>
                        
                        <MenuItem Header="File Format" Height="42"/>
                        <Border BorderBrush="{DynamicResource clr_grayborder}" Width="140" BorderThickness="0 0 0 1"/>
                        
                        <MenuItem Header="Excluded Folders" Height="42"/>
                        <Border BorderBrush="{DynamicResource clr_grayborder}" Width="140" BorderThickness="0 0 0 1"/>
                        
                        <MenuItem Header="Scan criteria" Height="42"/>
                        <Border BorderBrush="{DynamicResource clr_grayborder}" Width="140" BorderThickness="0 0 0 1"/>
                        
                        <MenuItem Header="Move Duplicates" Height="42"/>
                        <Border BorderBrush="{DynamicResource clr_grayborder}" Width="140" BorderThickness="0 0 0 1"/>
                    </Menu>
                    
                </StackPanel>

                <Button Grid.Row="1" x:Name="btnReset" Content="Reset" Height="32" Width="125" HorizontalAlignment="Right">
                    
                </Button>
            </Grid>

            <Grid Grid.Column="1">
                
            </Grid>

        </Grid>
    </Grid>
</Window>
