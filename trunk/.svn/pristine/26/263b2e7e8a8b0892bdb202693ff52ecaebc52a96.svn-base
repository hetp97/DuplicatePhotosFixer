        void SetLangImage()
        {
            BitmapImage bmpImg;
            switch (cGlobalSettings.oScanSettings.LanguageCode)
            {

                case "en":
                    {
                        imgLang.Source = new BitmapImage(new Uri(@"/Resources/Flags/English.png", UriKind.Relative));
                        break;
                    }
                case "de":
                    {
                        imgLang.Source = new BitmapImage(new Uri(@"/Resources/Flags/Deutsch.png", UriKind.Relative));
                        break;
                    }
                case "ja":
                    {
                        imgLang.Source = new BitmapImage(new Uri(@"/Resources/Flags/Japanese.png", UriKind.Relative));
                        break;
                    }
                case "es":
                    {
                        imgLang.Source = new BitmapImage(new Uri(@"/Resources/Flags/Spanish.png", UriKind.Relative));
                        break;
                    }
                case "sv":
                    {
                        imgLang.Source = new BitmapImage(new Uri(@"/Resources/Flags/Swedish.png", UriKind.Relative));
                        break;
                    }

                case "it":
                    {
                        imgLang.Source = new BitmapImage(new Uri(@"/Resources/Flags/Italiano.png", UriKind.Relative));
                        break;
                    }

                case "no":
                    {
                        imgLang.Source = new BitmapImage(new Uri(@"/Resources/Flags/Norsk.png", UriKind.Relative));
                        break;
                    }
                case "fr":
                    {
                        imgLang.Source = new BitmapImage(new Uri(@"/Resources/Flags/Francais.png", UriKind.Relative));
                        break;
                    }
                case "fi":
                    {
                        imgLang.Source = new BitmapImage(new Uri(@"/Resources/Flags/Finnish.png", UriKind.Relative));
                        break;
                    }
                case "ptbr":
                    {
                        imgLang.Source = new BitmapImage(new Uri(@"/Resources/Flags/Portugues.png", UriKind.Relative));
                        break;
                    }
                case "nl":
                    {
                        imgLang.Source = new BitmapImage(new Uri(@"/Resources/Flags/Nederlands.png", UriKind.Relative));
                        break;
                    }
                case "ru":
                    {
                        imgLang.Source = new BitmapImage(new Uri(@"/Resources/Flags/Russian.png", UriKind.Relative));
                        break;
                    }
                case "da":
                    {
                        imgLang.Source = new BitmapImage(new Uri(@"/Resources/Flags/Danske.png", UriKind.Relative));
                        break;
                    }
                default:
                    {
                        imgLang.Source = new BitmapImage(new Uri(@"/Resources/Flags/English.png", UriKind.Relative));
                        break;
                    }

            }


        }


