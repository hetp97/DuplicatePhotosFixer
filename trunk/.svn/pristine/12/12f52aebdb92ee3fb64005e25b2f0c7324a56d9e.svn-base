<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucActionCentre"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="694" d:DesignWidth="752" Background="#1A1A1A">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition MinHeight="49" Height="Auto"/>
            <RowDefinition MinHeight="70" Height="Auto"/>
            <RowDefinition/>
            <RowDefinition MinHeight="52" Height="Auto"/>
            <RowDefinition MinHeight="60" Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="pnl_imageCount" Background="#343434" />
        <Grid Grid.Row="1"  Background="#313131" >
            <StackPanel>
                <TextBlock x:Name="lblHeader" Text="Recommended Applications" 
                       Padding="10 0 10 0"
                       Foreground="{DynamicResource bgrclr_grayish}"
                       FontSize="18"
                      />
                <TextBlock x:Name="lblHeadermsg"
                              Padding="10 0 10 0"
                           FontSize="13"
                           Foreground="#A9ABAB">
                      Organize your photos, secure it from threats and boost PC's performance with these recommended apps for your<LineBreak/> PC.
                </TextBlock>

            </StackPanel>
            
        </Grid>
        <Grid Grid.Row="2" Margin="20 0 10 0">
            <TextBlock x:Name="pnlInner"/>
        </Grid>
        <Grid Grid.Row="3">
            <StackPanel Orientation="Horizontal">
                <Image x:Name="info_icon" 
                       Source="/Resources/info_bottom.png" Width="24" Height="24" 
                       VerticalAlignment="Center"
                       Margin="20 0 0 0"/>
                <TextBlock x:Name="lblfooter" 
                           Foreground="#A9ABAB"
                           FontSize="13"
                           Margin="10 0 3 0"
                           VerticalAlignment="Center">
                    To protect your computer, enrich it with organized files &amp; update drivers use above recommended    <LineBreak/> applications.
                </TextBlock>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="4" Margin="20 0 20 0">
            <DockPanel>
                <Button x:Name="btnBack" Content="Back" 
                        Foreground="White" 
                        BorderBrush="Transparent"
                        Width="75" 
                        Height="35" HorizontalAlignment="Left">
                    <Button.Background>
                        <ImageBrush ImageSource="/Resources/back_n.png" />
                    </Button.Background>
                </Button>
                <Button x:Name="lblRegisteredVersion" Content="Registered Version"
                        Foreground="White"
                         BorderBrush="Transparent"
                        Width="129"
                        Height="20"
                        HorizontalAlignment="Right"
                        Background="Transparent">
                    
                </Button>
                
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
