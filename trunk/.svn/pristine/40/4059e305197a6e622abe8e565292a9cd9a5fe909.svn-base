        public void SetMsg(string msgHeading, string message)
        {
            if (!string.IsNullOrEmpty(msgHeading))
                lblinfo.Text = msgHeading;
            else
                lblinfo.Text = cGlobalSettings.GetProductName();

            lblinfo.Text = message.Trim();

        }

        void SetButtons()
        {
            try
            {
                switch (msgBoxButtons)
                {
                    case MessageBoxButtons.OK:
                        {



                            btnOk.Content = cResourceManager.LoadString("DPF_MESSAGEBOX_OK_TEXT");
                            //btn_cancel.Text = cResourceManager.LoadString("IDS_CANCEL");

                            //btnOk.Tag = DialogResult.;
                            //btn_cancel.Tag = DialogResult.Cancel;
                        }
                        break;
                    case MessageBoxButtons.OKCancel:
                        {
                           
                        }
                        break;
                    case MessageBoxButtons.AbortRetryIgnore:
                        {
                        }
                        break;
                    case MessageBoxButtons.YesNoCancel:
                        {
                        }
                        break;
                    case MessageBoxButtons.YesNo:
                        {
                            
                        }
                        break;
                    case MessageBoxButtons.RetryCancel:
                        {
                        }
                        break;
                }
            }
            catch (Exception ex)
            {

            }
        }

        private void close_btn_click(object sender, RoutedEventArgs e)
        {
            Close();
            
        }

        private void btnOk_Click(object sender, RoutedEventArgs e)
        {
            Close();
        }
    }
