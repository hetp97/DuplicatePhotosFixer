            InitializeComponent();
        }


        public void ShowMsg(Window owner, string msgHeading, string message)
        {
            //this.SuspendLayout();

            if (owner != null)
                this.Owner = owner;

            SetMsg(msgHeading, message);
            SetButtons();
            /*
            foreach (Control ctr in panel1.Controls)
            {
                AppFunctions.SetDoubleBuffered(ctr);
            }
            */
