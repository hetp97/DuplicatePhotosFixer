<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucAfterClean"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
             mc:Ignorable="d" 
             d:DesignHeight="309" d:DesignWidth="1000" Background="#2f2f2f">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="49"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="0 1 0 0">
            <Border.Background>
                <ImageBrush ImageSource="{DynamicResource img_top_header}"/>
            </Border.Background>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="235"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Image x:Name="chk_mark" Source="{DynamicResource img_checkmark}" Stretch="None" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0 20 0 0"/>
            </Grid>
            <Grid Grid.Column="1" Margin="10 17 0 0">
                <StackPanel>
                    <TextBlock x:Name="lbl_heading" Text="Cleaned Successfully" FontSize="20" Foreground="#fff" />
                    <TextBlock x:Name="lbl_info"  FontSize="14" Foreground="#c9c9c9" FontWeight="Regular" Padding="0 5 0 5">
                        Selected Duplicate Photos have been deleted successfully.If all duplicate photos of a group are <LineBreak/> selected for deletion , one unique photo from the group is retained.
                    </TextBlock>
                    <DockPanel Margin="0 15 0 5" >
                        <TextBlock x:Name="lbl1" Foreground="#c9c9c9" FontSize="14" FontWeight="Regular">Duplicate Photos Found</TextBlock>
                        <TextBlock Foreground="#c9c9c9" FontSize="14" FontWeight="Regular" Margin="28 0 20 0">:</TextBlock>
                        <TextBlock x:Name="duplicatephotoFound"  Foreground="#c9c9c9" FontSize="14" FontWeight="Regular">{0}</TextBlock>
                    </DockPanel>
                    <DockPanel Margin="0 0 0 5">
                        <TextBlock x:Name="lbl2"  Foreground="#c9c9c9" FontSize="14" FontWeight="Regular"> Duplicate Photos Deleted</TextBlock>
                        <TextBlock Foreground="#c9c9c9" FontSize="14" FontWeight="Regular"  Margin="20 0 20 0">:</TextBlock>
                        <TextBlock x:Name="duplicatephotoDeleted"  Foreground="#c9c9c9" FontSize="14" FontWeight="Regular">{0}</TextBlock>
                    </DockPanel>
                    <DockPanel>
                        <TextBlock x:Name="lbl3"  Foreground="#c9c9c9" FontSize="14" FontWeight="Regular">Unique Photos Retained</TextBlock>
                        <TextBlock Foreground="#c9c9c9" FontSize="14" FontWeight="Regular" Margin="28 0 20 0">:</TextBlock>
                        <TextBlock x:Name="duplicatephotoRetained"  Foreground="#c9c9c9" FontSize="14" FontWeight="Regular">{0}</TextBlock>
                    </DockPanel>
                    <DockPanel VerticalAlignment="Bottom" Margin="0  25 25 0" HorizontalAlignment="Right">
                        <Button x:Name="btnOK" Content="Ok" Grid.Column="1" Width="120" Height="33" 
                      DockPanel.Dock="Right" VerticalAlignment="Center"  >
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="White" />
                                    <Setter Property="TextBlock.TextAlignment" Value="Center" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bdr_main"  BorderThickness="1" BorderBrush="#4E4E4E" Background="Transparent">
                                                    <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="White">
                                                    </ContentPresenter>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" TargetName="bdr_main" Value="#494949"></Setter>
                                                        <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                        <Setter Property="Background" TargetName="bdr_main" Value="#494949"></Setter>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="true">
                                                        <Setter Property="BorderBrush" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                        <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                        <Setter Property="Background" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                                        <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <cust:ImageButton x:Name="linklblSettings"
                              DockPanel.Dock="Right"
                              Margin="0 0 15 0" 
                                        
                               Foreground="#AcAcAC"
                             Image="{DynamicResource img_reset_icon}"  
                              HoverImage="{DynamicResource img_dropdownarrow}"
                              SelectedImage="{DynamicResource img_dropdownarrow}"
                    FontSize="14" VerticalAlignment="Center" Padding="5 0" 
                              Content="Undo"                             
                              Visibility="Visible"
                    
                    Style="{DynamicResource stl_btnSettings}" />
                       

                    </DockPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
