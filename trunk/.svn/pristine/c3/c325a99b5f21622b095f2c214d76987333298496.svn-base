<Window x:Class="DuplicatePhotosFixer.Nags.frmTrayNagGrabOffer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Nags"
        mc:Ignorable="d"
        Title="frmTrayNagGrabOffer" Height="362" Width="452" WindowStyle="None" Background="#0E1317">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>
        <DockPanel>
            <Button x:Name="btn_Close" Width="18" Height="18"
                        Background="Transparent" DockPanel.Dock="Right"
                    VerticalAlignment="Top">
                <Image x:Name="close_btn" Source="/Resources/grab_close.png"/>
            </Button>
            <Image x:Name="discount_img" Width="95" Height="95"
                   Source="{DynamicResource img_corner_50}"/>

            <Image x:Name="pb_preview" Width="225" Height="179"></Image>

        </DockPanel>
        <Grid Grid.Row="1" Background="#191E18">
            <StackPanel >
                <Button x:Name="btn_counts"
                        Width="150"
                        Height="22"
                        Foreground="White"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Content="3 Similar Photos">
                    <Button.Background>
                        <ImageBrush ImageSource="/Resources/red_counts_middle.png"/>
                    </Button.Background>
                </Button>
                <TextBlock x:Name="lbl_saveSpace"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="#FFC300"
                           HorizontalAlignment="Center"
                           Margin="3 0 3 5">
                    Save 76.6 MB of space with a special price.
                </TextBlock>
                <TextBlock x:Name="lbl_activateNow"
                           FontSize="15"
                           Foreground="White"
                           HorizontalAlignment="Center">
                    Activate now and Clean 117 similar photos and save 7606 MB<LineBreak/> space with a special discounted price only for you.
                </TextBlock>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="2">
            <Button x:Name="btn_claimOffer"
                    Width="113"
                    Height="32"
                    Foreground="White"
                    Background="#006DBF">
                Claim Offer
            </Button>
        </Grid>
        
    </Grid>
</Window>
