<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucExcludeSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="352" d:DesignWidth="561" Background="#272727">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="57"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Margin="10 20 30 0">
                <TextBlock x:Name="lbl_heading1" Text="Manage Folders to be Excluded" FontSize="24" Foreground="#fff"/>
                <TextBlock x:Name="lbl_heading2" Text="Add folders you want to exclude from scan"
                       TextWrapping="Wrap" Foreground="#AeAeAE" Margin="0 0 0 20" 
                       FontSize="14"/>
                <Border BorderBrush="#A8ABB1" BorderThickness="1 1 1 0">
                    <Label x:Name="lbl_excluded" Content="Excluded Folder" Foreground="#E9e9E9" FontWeight="Medium"/>
                </Border>
                <TreeView Grid.Row="0" x:Name="TreeView" BorderBrush="#A8ABB1" Height="Auto" BorderThickness="1 0 1 1 " >
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type local:ucExcludeSettings}" ItemsSource="{Binding Members}">
                            <TextBlock Text="{Binding folderName}" FontSize="14"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

            </StackPanel>

            <Grid Grid.Row="1" Background="{DynamicResource bgclr_soliddark}" >
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 0 30 0"  >

                    <Button x:Name="btnremove" Content="Remove" Width="120" Height="30"
                            Margin="0 0 20 0"  Foreground="#8c8c8c"
                        BorderBrush="#4E4E4E" FontSize="13" 
                            Background="Transparent"
                        BorderThickness="1" >
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="White" />
                                <Setter Property="TextBlock.TextAlignment" Value="Center" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bdr_main"  BorderThickness="1" BorderBrush="#4E4E4E" Background="Transparent">
                                                <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="White">
                                                </ContentPresenter>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" TargetName="bdr_main" Value="#494949"></Setter>
                                                    <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                    <Setter Property="Background" TargetName="bdr_main" Value="#494949"></Setter>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="true">
                                                    <Setter Property="BorderBrush" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                    <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                    <Setter Property="Background" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                                    <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                  
                    <Button x:Name="btnadd" Content="Add" Width="120" Height="30" Style="{DynamicResource styl_add_excludebtn}"
                         BorderBrush="Transparent"   Background="#1CA2E5" Foreground="#ffffff" Click="btnadd_Click">
                       
                    </Button>
                   

                </StackPanel>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
