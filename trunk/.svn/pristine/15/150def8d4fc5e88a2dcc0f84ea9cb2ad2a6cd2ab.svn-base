<Window x:Class="DuplicatePhotosFixer.Views.frmYTTutorial"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        mc:Ignorable="d" 
        Title="frmYTTutorial" x:Name="formYTTutorial" Height="562" Width="532" WindowStyle="None" ResizeMode="NoResize"
        Background="{DynamicResource cl_bg_theme}"
        Loaded="formYTTutorial_Loaded"  >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <Image x:Name="imgAppIcon"  Width="20" Height="20"
                   Source="{DynamicResource img_play_icon}" Margin="5 0"/>

                <TextBlock x:Name="dpf_heading" VerticalAlignment="Center"
                       Text=" Watch Video - Duplicate Photos Fixer Pro" FontSize="14" Foreground="{DynamicResource cl_fg_msgboxHeader}" />
            </StackPanel>
            <DockPanel HorizontalAlignment="Right">
                
                <cust:ImageButton x:Name="btn_close"  DockPanel.Dock="Right"                              
                                  Margin="0,0,0,0"                                        
                                  Width="28"
                                 Height="26"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"  
                                Image="{DynamicResource img_close_normal}"
                                 Style="{DynamicResource stl_imgbtn}"
                        HoverImage="{DynamicResource  img_close_hover}"
                                  SelectedImage="{DynamicResource  img_close_clicked}" Click="btn_close_Click" >
                </cust:ImageButton>

                <cust:ImageButton x:Name="btnMaximize"    
                                  DockPanel.Dock="Right"                                                         
                                  Width="28"
                                  Height="26"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"  
                                  Image="{DynamicResource img_max_normal}"
                                   Style="{DynamicResource stl_imgbtn}"
                        HoverImage="{DynamicResource  img_max_hover}"
                                  SelectedImage="{DynamicResource  img_max_clicked}" Click="btnMaximize_Click" >
                </cust:ImageButton>

             
            </DockPanel>
        </Grid>
        <Grid Grid.Row="1">
            <WebBrowser x:Name="webBrowserOfferADU" />
        </Grid>
        
    </Grid>
</Window>
