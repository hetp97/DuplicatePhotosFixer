        public static string GetProductName()
        {
            //return cResourceManager.LoadString("IDS_DU_APP_NAME");
            string name = "Duplicate Photo Fixer";
            return name;
        }

        public static uint GetTimeInterval()
        {
            return GetTimeIntervalEx((enumClass.eTimeInterval)cGlobalSettings.timeInterval);
        }
        public static uint GetTimeIntervalEx(enumClass.eTimeInterval timeInterval)
        {
            switch (timeInterval)
            {
                case enumClass.eTimeInterval._24_hours_and_less:
                    return 86400; // 60 * 60 * 24
                case enumClass.eTimeInterval._12_hours_and_less:
                    return 43200;
                case enumClass.eTimeInterval._6_hours_and_less:
                    return 21600;
                case enumClass.eTimeInterval._3_hours_and_less:
                    return 10800;
                case enumClass.eTimeInterval._2_hours_and_less:
                    return 7200;
                case enumClass.eTimeInterval._1_hours_and_less:
                    return 3600;
                case enumClass.eTimeInterval._30_minutes_and_less:
                    return 1800;
                case enumClass.eTimeInterval._10_minutes_and_less:
                    return 600;
                case enumClass.eTimeInterval._5_minutes_and_less:
                    return 300;
                case enumClass.eTimeInterval._3_minutes_and_less:
                    return 180;
                case enumClass.eTimeInterval._2_minutes_and_less:
                    return 120;
                case enumClass.eTimeInterval._1_minutes_and_less:
                    return 60;
                case enumClass.eTimeInterval._10_seconds_and_less:
                    return 10;
                case enumClass.eTimeInterval._5_seconds_and_less:
                    return 5;
                case enumClass.eTimeInterval._3_seconds_and_less:
                    return 3;
                case enumClass.eTimeInterval._2_seconds_and_less:
                    return 2;
                case enumClass.eTimeInterval._1_second_and_less:
                    return 1;
                case enumClass.eTimeInterval._30_seconds_and_less:
                default:
                    return 30;
            }
        }

        public static uint GetGPS()
        {
            return GetGPSEx((enumClass.eGPS)cGlobalSettings.gpsValue);
        }
        public static uint GetGPSEx(enumClass.eGPS gps)
        {
            switch (gps)
            {
                case enumClass.eGPS._1_Meter:
                    return 1;
                case enumClass.eGPS._2_Meters:
                    return 2;
                case enumClass.eGPS._10_Meters:
                    return 10;
                case enumClass.eGPS._20_Meters:
                    return 20;
                case enumClass.eGPS._50_Meters:
                    return 50;
                case enumClass.eGPS._100_Meters:
                    return 100;
                case enumClass.eGPS._5_Meters:
                default:
                    return 5;
            }
        }

        public static uint GetBitmapSize()
        {
            return GetBitmapSizeEx((enumClass.eBitmapSize)cGlobalSettings.gpsValue);
        }

        public static uint GetBitmapSizeEx(enumClass.eBitmapSize bmpSize)
        {
            switch (bmpSize)
            {
                case enumClass.eBitmapSize._48x48_pixels:
                    return 48;
                case enumClass.eBitmapSize._56x56_pixels:
                    return 56;
                case enumClass.eBitmapSize._72x72_pixels:
                    return 72;
                case enumClass.eBitmapSize._80x80_pixels:
                    return 80;
                case enumClass.eBitmapSize._88x88_pixels:
                    return 88;
                case enumClass.eBitmapSize._96x96_pixels:
                    return 96;
                case enumClass.eBitmapSize._64x64_pixels:
                default:
                    return 64;
            }

        }

        public static float GetMatchingLevel()
        {
            return GetMatchingLevelEx((enumClass.eMatchingLevel)cGlobalSettings.matchingLevel);
        }
        public static float GetMatchingLevelEx(enumClass.eMatchingLevel matchingLevel)
        {
            switch (matchingLevel)
            {
                case enumClass.eMatchingLevel._85:
                    return 0.85f;
                case enumClass.eMatchingLevel._88:
                    return 0.88f;
                case enumClass.eMatchingLevel._90:
                    return 0.90f;
                case enumClass.eMatchingLevel._92:
                    return 0.92f;
                case enumClass.eMatchingLevel._94:
                    return 0.94f;
                case enumClass.eMatchingLevel._96:
                    return 0.96f;
                case enumClass.eMatchingLevel._98:
                    return 0.98f;
                case enumClass.eMatchingLevel._100:
                default:
                    return 0.99f;
            }
        }

        public static string ImageFileExtensionsList = "";
        public static string FileDialogFilterList = "";
        public static string FileDialogFilterList_Picasa = "";

        public static string GetFileDialogFileFilter
        {
            get
            {
                switch (CurrentScanMode)
                {
                    case eScanMode.FileSearch:
                        return FileDialogFilterList;
                    case eScanMode.GoogleDrive:
                        break;
                    //case eScanMode.PicasaLibrary:
                    //    //Digital Negative and ProRaw RAW Image File (*.dng)|*.dn
                    //    return cResourceManager.LoadString("IDS_PICASA_LIB_FORMAT") + @" (thumbindex.db)|thumbindex.db";
                    //case eScanMode.Dropbox:
                    //    break;
                    //case eScanMode.DeleteEmptyFolder:
                    //    break;
                }
                return "";
            }
        }
        static eScanMode? _CurrentScanMode;
        public static eScanMode CurrentScanMode
        {
            get
            {
                if (_CurrentScanMode == null)
                {
                    _CurrentScanMode = eScanMode.FileSearch;
                }

                return (eScanMode)_CurrentScanMode;
            }
            set
            {
                _CurrentScanMode = value;
                //SetUserAppDataRegistryValue(cRegistrySettings.REGSTR_APP_SCAN_MODE, (int)_CurrentScanMode, RegistryValueKind.DWord);
            }
        }


        public static string GetProductNameFromDesc()
        {
            return ((AssemblyProductAttribute)System.Reflection.Assembly.GetExecutingAssembly().GetCustomAttributes(typeof(AssemblyProductAttribute), true)[0]).Product;
            // return ((AssemblyDescriptionAttribute)System.Reflection.Assembly.GetExecutingAssembly().GetCustomAttributes(typeof(AssemblyDescriptionAttribute), true)[0]).Description;
        }


        public static string GetImageFileExtensionsList
        {
            get
            {
                switch (CurrentScanMode)
                {
                    case eScanMode.FileSearch:
                        return ImageFileExtensionsList;
                    //case eScanMode.GoogleDrive:
                    //case eScanMode.Dropbox:
                    //    break;
                    //case eScanMode.PicasaLibrary:
                    //    return @"(thumbindex.db)";
                    //case eScanMode.DeleteEmptyFolder:
                    //    break;
                }
                return ImageFileExtensionsList;
            }
        }

        public static string GetInitialDirectory
        {
            get
            {
                switch (CurrentScanMode)
                {
                    case eScanMode.PicasaLibrary:
                        {
                            string DBPath = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData), @"Google\Picasa2\db3");
                            if (!Directory.Exists(DBPath))
                            {
                                DBPath = Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments);
                            }
                            return DBPath;
                        }
                    default:
                        return null;
                }
                return null;
            }
        }

        public static object GetCommonAppDataRegistryValue(string name, object defaultValue)
        {
            try
            {
                return null;
                //return Registry.GetValue(VersionIndependentCommonRegKey, name, defaultValue) ?? defaultValue;
            }
            catch (System.Exception ex)
            {
                oLogger.WriteLog(string.Format("cGlobal|GetCommonAppDataRegistryValue|{0}", ex.Message));
                return string.Empty;
            }

        }

        public static string VersionIndependentCommonRegKeyNoHive
        {
            get
            {
                string versionDependent = System.Windows.Forms.Application.UserAppDataRegistry.Name; // not need to find the key from LM as whole key is version independent
                //string versionDependent = System.Windows.Forms.Application.CommonAppDataRegistry.Name;
                string versionIndependent =
                       versionDependent.Substring(0, versionDependent.LastIndexOf("\\"));

                versionIndependent = versionIndependent.Substring(versionIndependent.IndexOf("\\") + 1);

                //  versionIndependent = string.Format("{0}\\{1}", versionIndependent, cGlobalSettings.nUserMachineId);
                return versionIndependent;
            }
        }
        public static object GetCommonAppDataRegistryValue(string name)
        {
            return GetCommonAppDataRegistryValue(name, null);
        }

    }
}
