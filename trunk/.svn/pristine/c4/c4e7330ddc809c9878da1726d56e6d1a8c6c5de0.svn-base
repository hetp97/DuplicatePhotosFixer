<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucSettingsMove"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="441" d:DesignWidth="482" Background="#272727">
    <UserControl.Resources>
        <Style TargetType="Button" x:Name="styl_btn">
            <Setter Property="Background" Value="#888888"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>

            </Style.Triggers>
        </Style>

    </UserControl.Resources>
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="70" />
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="57"/>
        </Grid.RowDefinitions>
        <StackPanel Margin="10">
            <TextBlock x:Name="move_heading" Foreground="#fff"
                       FontSize="22" >
                Manage duplicate photos
            </TextBlock>
            <TextBlock x:Name="heading_info"
                       Foreground="#AEAEAE" FontSize="14" TextWrapping="Wrap" FontWeight="Regular"
                       >
                This setting will allow you to select which action to perform on duplicate photos
            </TextBlock>
        </StackPanel>
        <Grid Grid.Row="1" Margin="10 0">
            <DockPanel Grid.Row="1" VerticalAlignment="Center" Margin="0 0 0 5">
                <RadioButton  x:Name="rb_MoveToBin" Margin="5 2 0 0"  IsChecked="True" Style="{DynamicResource stl_MoveSettingsRadiobtn}" />
                <TextBlock x:Name="rb_MoveToBinText" Foreground="#E9E9E9" FontSize="13" Padding="3 0 0 0">
                 Send duplicate photos to Recycle Bin
                </TextBlock>
            </DockPanel>
        </Grid>



        <Grid Grid.Row="2" Margin="10 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <DockPanel>
                    <RadioButton x:Name="rb_MoveToLocation" Style="{DynamicResource stl_MoveSettingsRadiobtn}"
                              Margin="5 2 0 5"  IsChecked="False" />
                    <TextBlock x:Name="rb_MoveToLocationText" Foreground="#E9E9E9" FontSize="13"  Padding="3 0 0 0">
                     Move duplicate photos to selected path 
                        <LineBreak x:Name="txt_moveLocation"/> "C:\\users\\picture\\"
                    </TextBlock>
                </DockPanel>
                
                <!--<TextBlock x:Name="txt_moveLocation" Text="C:\\users\\picture\\" Margin="10 0 0 0" Foreground="#565656"/>-->
            </StackPanel>
            <Grid Grid.Column="1">
                <Button x:Name="btn_AddFolder" Content="Browse" 
                        Width="99" 
                        Height="33"                      
                        Foreground="#8c8c8c"
                        BorderBrush="#989898"
                        BorderThickness="1"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        FontWeight="Bold"
                        Margin="0 0 10 0"
                        >
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="TextBlock.TextAlignment" Value="Center" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bdr_main" BorderBrush="#8c8c8c"  BorderThickness="1" >
                                            <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="White">
                                            </ContentPresenter>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">

                                                <Setter Property="Background" TargetName="bdr_main" Value="Transparent"></Setter>
                                            </Trigger>
                                            <!--<Trigger Property="IsPressed" Value="true">
                                                                <Setter Property="BorderBrush" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                                <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                                <Setter Property="Background" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                                                <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                                            </Trigger>-->
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>

                </Button>
            </Grid>
        </Grid>

        <!--<TextBlock Grid.Row="3"  Background="#D5D5D5" VerticalAlignment="Bottom"/>-->
    </Grid>
</UserControl>
