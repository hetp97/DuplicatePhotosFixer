<Window x:Class="DuplicatePhotosFixer.Views.frmAfterScan"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
        xmlns:cpb="clr-namespace:DuplicatePhotosFixer.CustomExtendClass"
        mc:Ignorable="d" AllowsTransparency="True"
        Title="frmAfterScan" x:Name="frmAfterScanMark" Height="327" Width="630" WindowStyle="None" Background="{DynamicResource cl_bg_theme}" Loaded="frmAfterScanMark_Loaded" >
    <Window.Resources>
        <Style x:Key="CircularProgressBar" TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Ellipse  Width="180" Height="180" Stroke="{DynamicResource cl_bg_Stroke}" Fill="#454545" StrokeThickness="20" Margin="10 0">
                            <Ellipse.StrokeDashArray>
                                <DoubleCollection>1 0</DoubleCollection>
                            </Ellipse.StrokeDashArray>
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="rotateTransform" CenterX="100" CenterY="100" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Border BorderBrush="{DynamicResource cl_br_AfterSacn}" BorderThickness="0 0 0 1">
        <DockPanel>
                <Image x:Name="dpf_logo" Source="{DynamicResource img_update_dpf}" DockPanel.Dock="Left" Margin="10 0 5 0" Width="30" Height="25" VerticalAlignment="Center"/>
                <cust:ImageButton
                            x:Name="btn_close"
                            Width="10"
                            Height="10"
                            DockPanel.Dock="Right"
                            Margin="10 0 10 0"
                            Style="{DynamicResource imageButton}"
                            Image="{DynamicResource img_close_plain}"
                            HoverImage="{DynamicResource img_close_plain}"
                            SelectedImage="{DynamicResource img_close_plain}" Click="btn_close_Click"  />
                <Label DockPanel.Dock="Left" x:Name="lbl_heading" FontSize="15" VerticalAlignment="Center" Content="Duplicate Photo Fixer Pro" Margin="0, 0, 2, 0" Foreground="{DynamicResource cl_fg_setHeading}" />
                <TextBlock x:Name="lbl_title" Text="Progress" Foreground="{DynamicResource cl_fg_subHeading}"
                       FontSize="15" FontWeight="Regular" Margin="10 0 0 0"
                       VerticalAlignment="Center" />
            </DockPanel>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!--<TextBlock x:Name="no_of_duplicates" Grid.Column="0">
                <TextBlock.Background>
                    <ImageBrush ImageSource="{DynamicResource img_duplicate_number_bg_orange}"/>
                </TextBlock.Background>
            </TextBlock>-->

            
            <ProgressBar x:Name="progressBar1"  Style="{StaticResource CircularProgressBar}" VerticalAlignment="Top" Margin="0 20 0 0"/>
            <StackPanel VerticalAlignment="Top" Margin="0 80 0 0">
                <Label x:Name="lbl_percentage" Margin="0 0 0 0"
                       Content="100%" FontSize="25" 
                       Foreground="{DynamicResource cl_fg_pgrlbl1}" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center" />
                <Label x:Name="label10" FontSize="13" Foreground="{DynamicResource cl_fg_pgrlbl1}"
                       Content="Scanned" Margin="0 -10 0 0"
                       HorizontalAlignment="Center" />
            </StackPanel>
            <Grid Grid.Column="1" Margin="0 0 0 0">
                <StackPanel>
                <DockPanel>
                        <TextBlock x:Name="label1" Text="Duplicate Photos Found:" Foreground="{DynamicResource cl_fg_primary}" FontSize="22" FontWeight="Bold" Margin="4, 35, 3, 3"/>
                        <TextBlock x:Name="cbtn_totalCount" Text="1081" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource cl_fg_Count}" Margin="4, 35, 3, 3"/>
                </DockPanel>
                    <!--<TextBlock x:Name="label3"  FontSize="14" FontWeight="Regular" Foreground="{DynamicResource cl_fg_ScanHighlight}" Margin="3, 0, 0, 0">
                        Use Auto Mark to conveniently mark duplicates based on <LineBreak/> set hierarchy.
                    </TextBlock>-->
                    <TextBlock x:Name="lbl_tip" Margin="0 5 0 0"
                               TextWrapping="Wrap" Foreground="{DynamicResource cl_fg_ScanContent}" FontSize="14" FontWeight="Regular" >
                        We found {0} duplicates occupying {1} space on your <LineBreak/>  computer. It is recommended to delete these unwanted <LineBreak/> photos immediately to de-cluster your system and recover <LineBreak/>
                        storage space.
                    </TextBlock>
                    <DockPanel Margin="0 50 0 0">
                        <Button x:Name="btn_selectManually" Content="Select Manually"  Background="{DynamicResource cl_bg_Scanbtn1}" Style="{DynamicResource stl_btnPhotoSelection}"
                                Margin="0 0 20 0" Click="btn_selectManually_Click" />
                        <Button x:Name="btn_autoMark" Content="Auto Mark" Background="{DynamicResource cl_bg_Scanbtn2}" Style="{DynamicResource stl_btnPhotoSelection}" Click="btn_autoMark_Click" />
                    </DockPanel>
                </StackPanel>
                

            </Grid>
        </Grid>
    </Grid>
</Window>
