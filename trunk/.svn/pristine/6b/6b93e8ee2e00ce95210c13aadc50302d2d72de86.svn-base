<Window x:Class="DuplicatePhotosFixer.Nags.nagUpdateOffer_VPN"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Nags"
        mc:Ignorable="d"
        Title="nagUpdateOffer_VPN" Height="596" Width="929" WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="52"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#353535">
            <DockPanel Margin="10 0 10 0">
                <Button x:Name="pb_Close" Width="15" Height="14"
                        Background="Transparent" BorderBrush="Transparent"
                        DockPanel.Dock="Right">
                    <Image  Source="/Resources/closevpn.png"/>
                </Button>
                <Image x:Name="pb_Icon" Width="36" Height="33" Source="{DynamicResource img_dpf_updatelogo}"/>
                <TextBlock x:Name="label_heading"
                           Foreground="#FAFAFA"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center">
                  Duplicate Photo Fixer Pro has been updated sucessfully.
                </TextBlock>
            </DockPanel>
        </Grid>
        <Grid Grid.Row="1">
            <DockPanel Margin="10 0 10 0"  VerticalAlignment="Center">
                <TextBlock x:Name="label1" FontSize="14"
                          >
                    Recommended Product: by Systweak:
                </TextBlock>
                <TextBlock Width="50"/>
                <TextBlock x:Name="label2" FontSize="14"
                           FontWeight="Bold" Foreground="#3F3F3F">Systweak VPN</TextBlock>
            </DockPanel>
        </Grid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="430"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Image x:Name="pb_leftImage" Width="345" Height="421" Source="/Resources/vpn-app-screen.png"/>
            <Grid Grid.Column="1">
                <StackPanel>
                    <TextBlock x:Name="lblDes" FontSize="40"
                               FontWeight="Bold" Height="Auto" MinHeight="212">
                        Get secure and private <LineBreak/> access to the Internet                       
                    </TextBlock>
                    <Button x:Name="btn_Install" Width="412" Height="64"
                            Content="Get Systweak VPN"
                            Foreground="White" FontWeight="SemiBold"
                            FontSize="20">
                        <Button.Background>
                            <ImageBrush ImageSource="{DynamicResource img_install_btn_red}"/>
                        </Button.Background>
                    </Button>
                    <DockPanel HorizontalAlignment="Center">
                        <Image x:Name="pb_clock" Width="24" Height="20" Source="{DynamicResource img_limited_offer_clock}"/>
                        <TextBlock x:Name="txt" FontSize="14" Padding="5 0 0 0" Text="Hurry, Limited Time Offer"/>
                    </DockPanel>
                    <TextBlock Height="100"/>
                    <DockPanel Margin="20 20 0 0"
                            HorizontalAlignment="Center"   >
                        <TextBlock x:Name="lblFooter1"
                               Foreground="DimGray"
                               Padding="0 0 20 0">
                        By installing Systweak VPN agree to
                        </TextBlock>
                        <TextBlock x:Name="lblFooter2">
                        <Hyperlink x:Name="lblEula"> EULA </Hyperlink> and 
                        <Hyperlink x:Name="lblPP"> Privacy Policy </Hyperlink>
                        </TextBlock>
                    </DockPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
