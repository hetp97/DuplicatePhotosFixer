<Window x:Class="DuplicatePhotosFixer.Views.frmAfterScan"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
        mc:Ignorable="d" AllowsTransparency="True"
        Title="frmAfterScan" Height="327" Width="630" WindowStyle="None" Background="{DynamicResource cl_bg_theme}">
    <Window.Resources>
       
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Border BorderBrush="{DynamicResource cl_br_AfterSacn}" BorderThickness="0 0 0 1">
        <DockPanel>
                <Image x:Name="dpf_logo" Source="{DynamicResource img_update_dpf}" DockPanel.Dock="Left" Margin="10 0" Stretch="None" VerticalAlignment="Center"/>
                <cust:ImageButton
                            x:Name="btn_close"
                            Width="10"
                            Height="10"
                            DockPanel.Dock="Right"
                            Margin="10 0 10 0"
                            Style="{DynamicResource imageButton}"
                            Image="{DynamicResource img_close_plain}"
                            HoverImage="{DynamicResource img_close_plain}"
                            SelectedImage="{DynamicResource img_close_plain}"  />
                <Label DockPanel.Dock="Left" x:Name="lbl_heading" FontSize="15" VerticalAlignment="Center" Content="Duplicate Photo Fixer Pro" Margin="2, 0, 2, 0" Foreground="{DynamicResource cl_fg_setHeading}" />
        </DockPanel>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!--<TextBlock x:Name="no_of_duplicates" Grid.Column="0">
                <TextBlock.Background>
                    <ImageBrush ImageSource="{DynamicResource img_duplicate_number_bg_orange}"/>
                </TextBlock.Background>
            </TextBlock>-->
            <Image Source="{DynamicResource img_circle}" Height="100" Width="105" Margin="27, 35, 3, 3" VerticalAlignment="Top"/>
            <Grid Grid.Column="1" Margin="0 0 0 0">
                <StackPanel>
                <DockPanel>
                        <TextBlock x:Name="label1" Text="Duplicate Photos Found:" Foreground="{DynamicResource cl_fg_primary}" FontSize="22" FontWeight="Bold" Margin="4, 35, 3, 3"/>
                        <TextBlock x:Name="cbtn_totalCount" Text="1081" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource cl_fg_Count}" Margin="4, 35, 3, 3"/>
                </DockPanel>
                    <TextBlock x:Name="label3"  FontSize="14" FontWeight="Regular" Foreground="{DynamicResource cl_fg_ScanHighlight}" Margin="3, 0, 0, 0">
                        Use Auto Mark to conveniently mark duplicates based on <LineBreak/> set hierarchy.
                    </TextBlock>
                    <TextBlock x:Name="lbl_tip" 
                               TextWrapping="Wrap" Foreground="{DynamicResource cl_fg_ScanContent}" FontSize="14" FontWeight="Regular" >
                        We found {0} duplicates occupying {1} space on your <LineBreak/>  computer. It is recommended to delete these unwanted <LineBreak/> photos immediately to de-cluster your system and recover <LineBreak/>
                        storage space.
                    </TextBlock>
                    <DockPanel Margin="0 20 0 0">
                        <Button x:Name="btn_selectManually" Content="Select Manually"  Background="{DynamicResource cl_bg_Scanbtn1}" Style="{DynamicResource stl_btnPhotoSelection}"
                                Margin="0 0 20 0"/>
                        <Button x:Name="btn_autoMark" Content="Auto Mark" Background="{DynamicResource cl_bg_Scanbtn2}" Style="{DynamicResource stl_btnPhotoSelection}" />
                    </DockPanel>
                </StackPanel>
                

            </Grid>
        </Grid>
    </Grid>
</Window>
