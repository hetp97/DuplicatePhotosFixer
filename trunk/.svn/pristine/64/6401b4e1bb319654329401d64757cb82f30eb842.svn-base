<Window x:Class="DuplicatePhotosFixer.Nags.frmTaskbarNotification"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Nags"
        mc:Ignorable="d"
        Title="frmTaskbarNotification" Height="412" Width="396" WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#404040">
            <DockPanel>
                <Button x:Name="btn_close" Background="#3E3E3E" Width="20"
                        Height="25"
                        Foreground="White"
                        FontSize="15"
                        FontWeight="SemiBold"
                        DockPanel.Dock="Right"
                        Margin="0 2 5 0"
                        VerticalAlignment="Top"
                        HorizontalContentAlignment="Center">X
                </Button>
                <TextBlock x:Name="lbl_head"
                           VerticalAlignment="Center"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="3 0 3 0">
                    Attention
                </TextBlock>
            </DockPanel>
        </Grid>

        <Grid Grid.Row="1">
            <StackPanel >
            <TextBlock x:Name="lbl_attention"
                       Margin="4 0 4 0"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#3E3E3E">
                Your PC requires Attention
            </TextBlock>
               
                <!--<DockPanel>
                    <TextBlock x:Name="txtblock_info"
                         Width="363"
                         Height="106"
                         Margin="13,4,13.6,4">
                        <TextBlock.Background>
                            <ImageBrush ImageSource="/Resources/duplicate_info_box.jpg"/>

                        </TextBlock.Background>

                    </TextBlock>
                    <TextBlock>
                    
                    </TextBlock>
                </DockPanel>-->
            </StackPanel>
        </Grid>
    </Grid>
</Window>
