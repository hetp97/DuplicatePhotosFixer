        public bool bConfirmationBox { get; set; }

        public void LoadStringsForScan()
        {
            try
            {
                lbl_searchingDuplicates.Text = cResourceManager.LoadString("DPF_PROGRESS_SEARCHING_DUPLICATE_TEXT");
                progressBar1.Value = 0;
                btn_cancel.Content = cResourceManager.LoadString("IDS_CANCEL");
                lbl_progressInfo.Text = String.Empty;
                lbl_percentage.Content = string.Empty;
                lbl_counter1.Text = "0";
                lbl_counter2.Text = "0";
                lbl_scanPath.Text = "";
                progressBar1.Value = 0;
                lbl_percentage.Content = progressBar1.Value + "%";
                label10.Content = cResourceManager.LoadString("DPF_ADDING");
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("frmProcessing:: LoadStringsForScan: ", ex);
            }
        }

        public void ScanProgress(cClientEnum.eScanPhase scanPhaseType, string message, int percentageCompleted, string counterMsg, string subMsg, bool showScanBar = false)
        {
            try
            {
                //label4.Text = string.IsNullOrEmpty(counterMsg) ? "" : counterMsg;

                if (bConfirmationBox)
                {
                    lbl_progressInfo.Text = string.IsNullOrEmpty(subMsg) ? "" : subMsg;
                    lbl_searchingDuplicates.Text = string.IsNullOrEmpty(message) ? "" : message;
                    //lbl_percentage.Text = string.IsNullOrEmpty(counterMsg) ? "" : counterMsg;
                }
                else
                {
                    int currentPercentage = percentageCompleted / 2;

                    switch (scanPhaseType)
                    {
                        case cClientEnum.eScanPhase.Search:
                            lbl_searchingDuplicates.Text = cResourceManager.LoadString("DPF_SCAN_PHOTOS_ADDING_PHOTOS");
                            lbl_progressInfo.Text = cResourceManager.LoadString("DPF_SCAN_PHOTOS_PLEASE_BE_PATIENT_MSG");
                            progressBar1.Value = 5;
                            lbl_counter1.Text = string.IsNullOrEmpty(counterMsg) ? "" : counterMsg;
                            lbl_subInfo1.Text = string.Format(cResourceManager.LoadString("DPF_SCAN_PHOTOS_PHOTOS_ADDED"), "").Trim(new char[] { ':', '*' }).Trim();
                            lbl_scanPath.Text = string.IsNullOrEmpty(subMsg) ? "" : subMsg;
                            // pic_loading.Visible = false;
                            break;
                        case cClientEnum.eScanPhase.Read:
                            int nCounter = -1;
                            int.TryParse(counterMsg, out nCounter);

                            lbl_searchingDuplicates.Text = cResourceManager.LoadString("DPF_PROCESSOR_PROGRESS_SEARCHING_DUPLICATE_TEXT");
                            lbl_progressInfo.Text = cResourceManager.LoadString("DFP_PROCESSOR_SCAN_PLEASE_BE_PATIENT_MSG");
                           progressBar1.Value = currentPercentage > 5 ? currentPercentage : 5;
                            lbl_counter1.Text = nCounter > 0 ? string.Format("{0}/{1}", counterMsg, cGlobalSettings.listImageFileInfo.Count) : "";
                            lbl_subInfo1.Text = string.Format(cResourceManager.LoadString("DPF_PROCESSOR_PERCENT_PROCESSED"), "", "").Trim(new char[] { '/', ' ', '*', ':' }).Trim();
                            label10.Content = cResourceManager.LoadString("DPF_SCANNING");
                            lbl_scan.Text = string.Format("{0}:", cResourceManager.LoadString("IDS_SCAN_PATH"));
                            if (cGlobalSettings.listImageFileInfo != null && cGlobalSettings.listImageFileInfo.ContainsKey(nCounter) && nCounter > 0)
                                lbl_scanPath.Text = cGlobalSettings.listImageFileInfo[nCounter].filePath;
                            //pic_loading.Visible = false;
                            break;
                        case cClientEnum.eScanPhase.Compare:
                            {
                                progressBar1.Value = currentPercentage + 50;
                                lbl_searchingDuplicates.Text = cResourceManager.LoadString("DPF_PROCESSOR_COMPARING_PHOTOS");
                                lbl_progressInfo.Text = cResourceManager.LoadString("DFP_PROCESSOR_SCAN_PATIENT_WHILE_COMPARING_MSG");
                                lbl_counter1.Text = cGlobalSettings.listImageFileInfo.Count + "";
                                lbl_counter2.Text = string.IsNullOrEmpty(counterMsg) ? "" : counterMsg;
                                lbl_scanPath.Text = lbl_scan.Text = "";
                                label10.Content = cResourceManager.LoadString("DPF_COMPARING");
                                lbl_subInfo1.Text = cResourceManager.LoadString("DPF_PHOTOS_FOUND");
                                //pic_loading.Visible = false;
                            }
                            break;
                        case cClientEnum.eScanPhase.ComponentDownload:
                            {
                                lbl_searchingDuplicates.Text = message;
                                lbl_progressInfo.Text = subMsg;
                                //pic_loading.Visible = true;
                                lbl_scanPath.Text = counterMsg;
                                lbl_scan.Text = cResourceManager.LoadString("IDS_DOWNLOADING");
                                label10.Content = cResourceManager.LoadString("SCANTAB4");
                                lbl_scanPath.Text = "";
                            }
                            break;
                    }
                    lbl_percentage.Content = progressBar1.Value + "%";
                    lbl_searchingDuplicates.Text = string.IsNullOrEmpty(message) ? "" : message;
                    //lbl_percentage.Text = string.IsNullOrEmpty(counterMsg) ? "" : counterMsg;
                    //scanBar.Visible = showScanBar;

                    //if (cGlobalSettings.b_COMPONENT_INSTALL_STARTED)
                    //{
                    //    btn_cancel.Visible = false;
                    //    btn_close.Enabled = false;
                    //    //progressbarMainBorder.btn_close.Update();
                    //    btn_close.Refresh();
                    //    //progressbarMainBorder.btn_close.Visible = false;
                    //}
                    //else
                    //{
                    //    btn_cancel.Visible = true;
                    //    btn_close.Enabled = true;

                    //    //progressbarMainBorder.btn_close.Update();
                    //    btn_close.Refresh();
                    //    //progressbarMainBorder.btn_close.Visible = true;
                    //}

                }
            }
            catch (Exception ex)
            {

            }
        }

       

        public enum ProgressType
        {
            Scan,
            Clean,
            Other
        }

        [ValueConversion(typeof(int), typeof(double))]
        public class ValueToAngleConverter : IValueConverter
        {
            public object Convert(object value, Type targetType, object parameter, CultureInfo culture)
            {
                return (double)(((int)value * 0.01) * 360);

            }

            public object ConvertBack(object value, Type targetType, object parameter, CultureInfo culture)
            {
                return (int)((double)value * 360) * 100;
            }
        }

        public void LoadStringsForClean()
        {
            try
            {
                lbl_searchingDuplicates.Text = (RemoveFromPhotoListOnly ? cResourceManager.LoadString("DPF_RESULT_REMOVING_PHOTOS") : cResourceManager.LoadString("DPF_RESULT_DELETING_PHOTOS"));
                progressBar1.Value = 0;
                btn_cancel.Content = cResourceManager.LoadString("IDS_CANCEL");

                lbl_progressInfo.Text = cResourceManager.LoadString("DPF_DELETING_PLEASE_WAIT");
                lbl_percentage.Content = string.Empty;
                label10.Content = cResourceManager.LoadString("DPF_DELETING");
                lbl_counter1.Text = cGlobalSettings.TotalDuplicateMarkPhotos + "";
                lbl_subInfo1.Text = cResourceManager.LoadString("DPF_FOOTER_UC_DELETE_MARKED_TEXT");

                lbl_counter2.Text = "0";
                lbl_subInfo2.Text = cResourceManager.LoadString("DPF_RESULT_MARKED_PHOTOS_DELETED").Trim(new char[] { '.', '。' });

                lbl_scanPath.Text = "";

            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("frmProcessing:: LoadStringsForClean:: ", ex);
            }
        }

        void Close_Process()
        {
            try
            {
                if (bConfirmationBox)
                {
                    cGlobal.frmNagReturnCode = FORM_RETURN_CODES.NO_THANKS;
                    this.Close();
                    return;
                }

                if (progressType == ProgressType.Scan)
                {
                    cGlobalSettings.oManualReset.Reset();
                    //cGlobalSettings.pause = true;
                    DialogResult result = System.Windows.Forms.DialogResult.No;
                    /// Do nothing 
                    if (cGlobalSettings.b_COMPONENT_INSTALL_STARTED)
                        App.oMainReference.showMessage(cResourceManager.LoadString("IDS_WIAT_INSTALL_COMPONENT"), "");
                    else
                        result = App.oMainReference.showYesNoMessage(cResourceManager.LoadString("IDS_STOP_SCAN_DES"));

                    //cGlobalSettings.pause = false;
                    cGlobalSettings.oManualReset.Set();

                    if (result != System.Windows.Forms.DialogResult.Yes)
                    {
                        return;
                    }
                }
                else if (progressType == ProgressType.Other)
                {
                    cGlobal.frmNagReturnCode = FORM_RETURN_CODES.NO_THANKS;
                    this.Close();
                }

                cGlobalSettings.abortNow = true;

            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("", ex);
            }
        }

