            {
                Program.oMainReference.MinimizeAppToTray();
                Program.oMainReference.Opacity = 100;
            }
#endif
            //this.CenterToParent();

            switch (progressType)
            {
                case ProgressType.Scan:
                    if (!bConfirmationBox)
                    {
                        LoadStringsForScan();
                        /// start scan here
                        //if (App.oMainReference != null)
                        //{
                        //    if (App.oMainReference.oSelectFolder != null)
                        //    {
                        //        if (App.oMainReference.oSelectFolder.objScanPhotos != null)
                        //        {
                        //            App.oMainReference.oSelectFolder.objScanPhotos.startCompare();
                        //        }
                        //    }
                        //    else
                        //    {
                                
                        //    }
                        //}
                       // App.oMainReference.oSelectFolder.objScanPhotos.startCompare();
                    }
                    break;
                case ProgressType.Clean:
                    LoadStringsForClean();
                  //  Program.oMainReference.oResult.startDeleting(RemoveFromPhotoListOnly, groupIDs);  will add after adding fn in ucResult
                    break;
                default:
                    break;
            }

        }

