<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucExcludeSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="352" d:DesignWidth="561" Background="White">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="57"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Margin="10 20 30 0">
                <TextBlock Text="Manage Folders to be Excluded" FontSize="22" Foreground="{DynamicResource frgclr_solidgray}"/>
                <TextBlock Text="Add folders you want to exclude from scan"
                       TextWrapping="Wrap" Foreground="{DynamicResource frgclr_solidgray}" Margin="0 0 0 20" 
                       FontSize="14"/>
                <Border BorderBrush="#A8ABB1" BorderThickness="1 1 1 0">
                    <Label x:Name="lb_excluded" Content="Excluded Folder" FontWeight="Medium"/>
                </Border>
                <TreeView Grid.Row="0" x:Name="TreeView" BorderBrush="#A8ABB1" Height="Auto" BorderThickness="1 0 1 1 " >
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type local:ucExcludeSettings}" ItemsSource="{Binding Members}">
                            <TextBlock Text="{Binding folderName}" FontSize="14"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

            </StackPanel>

            <Grid Grid.Row="1"  Background="#D5D5D5">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 0 30 0"  >
                    <Button x:Name="btnremove" Content="Remove" Width="120" Height="30"
                            Margin="0 0 20 0" BorderBrush="Transparent"
                            Background="#B2AFAF"
                            Foreground="#FFFFFF" Style="{DynamicResource styl_reset_btn}">
                        
                    </Button>
                    <Button x:Name="btnadd" Content="Add" Width="120" Height="30" Style="{DynamicResource styl_add_excludebtn}"
                         BorderBrush="Transparent"   Background="#1CA2E5" Foreground="#ffffff" Click="btnadd_Click">
                       
                    </Button>
                   

                </StackPanel>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
