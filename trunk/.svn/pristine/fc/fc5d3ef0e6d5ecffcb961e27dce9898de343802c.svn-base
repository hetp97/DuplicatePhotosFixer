<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucDragAndDrop"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="170" d:DesignWidth="588">
    <UserControl.Resources>
        <Style x:Key="stlucHomeDragDrop" TargetType="UserControl">
            <Setter Property="Background" Value="#3D3D3D"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource bgrclr_ucHomeDragDrop}" AllowDrop="True">
        <!--<Border x:Name="ucHomeDragDropBorder" BorderBrush="#000000" BorderThickness="3">
            
        </Border>-->
        <DockPanel Margin="25 10 25 18">
            <Image Height="110" Width="120" Source="{DynamicResource img_ucHomedragdrop}" />
            
            <StackPanel Margin="45 17" VerticalAlignment="Top">
                <TextBlock x:Name="Drag_Drop" Text="Drag and Drop photos here" Foreground="{DynamicResource frg_clr_dragdropbox}" FontSize="18" FontWeight="Medium" Padding="5 0"/>
                <TextBlock x:Name="Drag_drop_info" Text="Hint: Drag photos, folder with your photos from Explorer to scan for similar photos" TextWrapping="Wrap" Foreground="{DynamicResource frg_clr_dragdropbox}" Padding="5" FontSize="12"/>
            </StackPanel>
            
        </DockPanel>
        <Rectangle Stroke="{DynamicResource clr_darkborder}" StrokeThickness="3" StrokeDashArray="3 2" SnapsToDevicePixels="True">
           
        </Rectangle>
    </Grid>
</UserControl>
