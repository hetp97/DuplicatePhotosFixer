<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucGeneral"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="464" d:DesignWidth="515" Background="#272727">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="57"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Margin="10 20">
            <TextBlock x:Name="alert_settings_lbl" Text="Alert Settings" FontSize="24" Foreground="#fff" FontWeight="Regular"/>
            <TextBlock x:Name="lbl_info" Text="The settings below allow you to hide/unhide confirmation dialog boxes shown in the application while performing actions like delete, auto-mark &amp; moving back. You can change settings as per your requirements."
                       TextWrapping="Wrap" Foreground="#AEAEAE" Margin="0 5 0 15" FontWeight="Regular"
                       FontSize="14"/>

            <CheckBox x:Name="chk_confirmationDialog" Content="Do not show confirmation dialog on delete." FontSize="13" Foreground="#E9E9E9" Margin="0 10">
                <CheckBox.LayoutTransform>
                    <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                </CheckBox.LayoutTransform>

            </CheckBox>

            <CheckBox x:Name="chk_AutoMark" Content="Do not show auto mark dialog on Auto Mark." FontSize="13"  Foreground="#E9E9E9" Margin="0 10">
                <CheckBox.LayoutTransform>
                    <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                </CheckBox.LayoutTransform>
            </CheckBox>

            <CheckBox x:Name="chk_confirmationWindow" Content="Do not show confirmation window on moving back." FontSize="13" Foreground="#E9E9E9" Margin="0 10">
                <CheckBox.LayoutTransform>
                    <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                </CheckBox.LayoutTransform>
            </CheckBox>
        </StackPanel>
        <Grid Grid.Row="1" Background="{DynamicResource bgclr_soliddark}" >
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 0 30 0">

                <Button x:Name="btncancel" Content="Cancel" Width="120" Height="30"
                            Margin="0 0 20 0"  Foreground="#8c8c8c"
                        BorderBrush="#4E4E4E" 
                        FontSize="13"
                            Background="Transparent"
                        BorderThickness="1" >
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="TextBlock.TextAlignment" Value="Center" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bdr_main"  BorderThickness="1" BorderBrush="#4E4E4E" Background="Transparent">
                                            <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="White">
                                            </ContentPresenter>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" TargetName="bdr_main" Value="#494949"></Setter>
                                                <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                <Setter Property="Background" TargetName="bdr_main" Value="#494949"></Setter>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="true">
                                                <Setter Property="BorderBrush" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                <Setter Property="Background" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                                <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="btndone" Content="Done" Width="120" Height="30" Style="{DynamicResource styl_add_excludebtn}"
                         BorderBrush="Transparent"   Background="#1CA2E5" Foreground="#ffffff" >

                </Button>


            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
