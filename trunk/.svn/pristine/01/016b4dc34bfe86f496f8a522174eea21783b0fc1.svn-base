using System;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Media.Animation;
using DuplicatePhotosFixer.CustomExtendClass;
using DuplicatePhotosFixer.Models;

namespace DuplicatePhotosFixer.UserControls
{
    /// <summary>
    /// Interaction logic for ucSettingsMove.xaml
    /// </summary>
    public partial class ucSettingsMove : UserControl
    {
       
        public ucSettingsMove()
        {
            InitializeComponent();
            PreInit();
            Init();
        }

        void PreInit()
        {
            try
            {
                if (App.oMainReference.objMove == null)
                    App.oMainReference.objMove = new vmMoveSettings();
                this.DataContext = App.oMainReference.objMove;

            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("ucMoveSettings:: PreInit: ", ex);
            }
        }

        void Init()
        {
            try
            {
                LoadStrings();
                UpdateUIData();
               App.oMainReference.objMove.parentControl = this;
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("ucMoveSettings:: Init: ", ex);
            }
        }
        void LoadStrings()
        {
            move_heading.Text = cResourceManager.LoadString("IDS_MANAGE_DUPLICATE_PHOTOS");
            heading_info.Text = cResourceManager.LoadString("IDS_MOVE_IMAGES_BIN");
            //rb_MoveToBin.Content = cResourceManager.LoadString("IDS_MOVE_IMAGES_BIN");
            rb_MoveToLocationText.Text = cResourceManager.LoadString("IDS_MOVE_PATH");
        }

        public void UpdateUIData()
        {
            try
            {
                App.oMainReference.objMove.SetUIPropertiesValue();
                return;

            }
            catch (Exception ex)
            {

                cGlobalSettings.oLogger.WriteLogException("ucExtraSettings:: UpdateUIData: ", ex);
            }
        }

        private void UserControl_Loaded(object sender, RoutedEventArgs e)
        {
            //UpdateUIData();
        }

        private void btn_AddFolder_Click(object sender, RoutedEventArgs e)
        {
            try
            {
                App.oMainReference.objMove.BrowseLocation();
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("btn_AddFolder_Click ucSettingsMove: ", ex);
            }
        }

        private void rb_MoveToLocation_Click(object sender, RoutedEventArgs e)
        {
            DoubleAnimation fadeOutAnimation = new DoubleAnimation();
            fadeOutAnimation.From = 1.0; // Starting opacity (fully visible)
            fadeOutAnimation.To = 0.0;   // Ending opacity (completely transparent)
            fadeOutAnimation.Duration = TimeSpan.FromSeconds(1); // Duration of the animation

            // Set up an event handler for when the animation completes
            fadeOutAnimation.Completed += FadeOutAnimation_Completed;

            // Apply the animation to the Opacity property of the label
            lbl_settingsApplied.BeginAnimation(Label.OpacityProperty, fadeOutAnimation);
            lbl_settingsApplied.Visibility = Visibility.Visible;
        }

        private void rb_MoveToBin_Click(object sender, RoutedEventArgs e)
        {
            DoubleAnimation fadeOutAnimation = new DoubleAnimation();
            fadeOutAnimation.From = 1.0; // Starting opacity (fully visible)
            fadeOutAnimation.To = 0.0;   // Ending opacity (completely transparent)
            fadeOutAnimation.Duration = TimeSpan.FromSeconds(1); // Duration of the animation

            // Set up an event handler for when the animation completes
            fadeOutAnimation.Completed += FadeOutAnimation_Completed;

            // Apply the animation to the Opacity property of the label
            lbl_settingsApplied.BeginAnimation(Label.OpacityProperty, fadeOutAnimation);
            lbl_settingsApplied.Visibility = Visibility.Visible;
        }

        private void FadeOutAnimation_Completed(object sender, EventArgs e)
        {
            // Reset the label's opacity once the fade out animation is complete
            lbl_settingsApplied.Opacity = 1.0;
            lbl_settingsApplied.Visibility = Visibility.Hidden;
        }

    }
}
