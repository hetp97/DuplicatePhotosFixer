    /// <summary>
    /// Interaction logic for frmRegistrationDPF.xaml
    /// </summary>
    public partial class frmRegistrationDPF : Window
    {

        vmRegistration objRegistrationViewModel = null;
        public frmRegistrationDPF()
        {
            PreInit();
            InitializeComponent();
            Init();
        }
        
        void PreInit()
        {
            objRegistrationViewModel = new vmRegistration();
            this.DataContext = objRegistrationViewModel;
        }
        void Init()
        {
            LoadStrings();
        }

        void LoadStrings()
        {
            try
            {
                dpf_header.Text = cGlobalSettings.GetProductName();
                dpf_header_Registraionfrm.Text = cResourceManager.LoadString("IDS_REGISTER");
                //txt_reg_key.Text = "XXXXX-XXXXX-XXXXX-XXXXX";
                lbl_heading.Text = cResourceManager.LoadString("DPF_REGISTRATION_CHOOSING");
                lbl_info.Text = cResourceManager.LoadString("IDS_ACTIVATE_LICENSE");
                feature_heading1.Text = cResourceManager.LoadString("IDS_REGISTER_FEATURE1");
                feature_heading2.Text = cResourceManager.LoadString("IDS_REGISTER_FEATURE2");
                feature_heading3.Text = cResourceManager.LoadString("IDS_REGISTER_FEATURE3");
                feature_heading4.Text = cResourceManager.LoadString("IDS_REGISTER_FEATURE4");
                feature_desc1.Text = cResourceManager.LoadString("IDS_REGISTER_FEATURE_INFO1");
                feature_desc2.Text = cResourceManager.LoadString("IDS_REGISTER_FEATURE_INFO2");
                feature_desc3.Text = cResourceManager.LoadString("IDS_REGISTER_FEATURE_INFO3");
                feature_desc4.Text = cResourceManager.LoadString("IDS_REGISTER_FEATURE_INFO4");

                label_key.Text = cResourceManager.LoadString("IDS_NAG_MSG_HAVE_KEY");
                //label_key_info1.Text = cResourceManager.LoadString("");
                //label_key_info2.Text = cResourceManager.LoadString("");
                hyperlink_text.Text = cResourceManager.LoadString("IDS_COPY_CLIPBOARD");
                lbl_moneyBack.Text = cResourceManager.LoadString("IDS_N_DAYS_MONEY_BACK");
                lbl_noQuestion.Text = cResourceManager.LoadString("IDS_NO_QUESTION");
                btn_registerNow.Content = cResourceManager.LoadString("IDS_ACTIVATE_NOW");
                btn_Upgrade.Content = cResourceManager.LoadString("IDS_PURCHASE_NOW");


            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("frmRegistrationDPF:: LoadStrings: ", ex);
            }
        }




        private void close_btn_Click(object sender, RoutedEventArgs e)
        {
            //this.Close();
            this.Visibility = Visibility.Hidden;
        }

       

       

        private void hyperlink_text_PreviewMouseDown(object sender, MouseButtonEventArgs e)
        {
            try
            {
                objRegistrationViewModel.PasteCopiedKey();
            }
            catch (Exception ex)
            {

                cGlobalSettings.oLogger.WriteLogException("frmRegistrationDPF :: hyperlink_text_PreviewMouseDown : ", ex);
            }

        }

        private void btn_Upgrade_Click(object sender, RoutedEventArgs e)
        {
            try
            {
                objRegistrationViewModel.PurchaseClick();
            }
            catch (Exception ex)
            {

                cGlobalSettings.oLogger.WriteLogException("frmRegistrationDPF :: btnPurchase_Click : ", ex);
            }

        }

        private void txt_reg_key_PreviewKeyDown(object sender, KeyEventArgs e)
        {
            try
            {
                objRegistrationViewModel.Licence_PreviewDown(e);
            }
            catch (Exception ex)
            {

                cGlobalSettings.oLogger.WriteLogException("frmRegistrationDPF :: txt_reg_key_PreviewKeyDown : ", ex);
            }

        }

        private void txt_reg_key_TextChanged(object sender, TextChangedEventArgs e)
        {
            try
            {

            }
            catch (Exception ex)
            {


            }
        }

        private void btn_registerNow_Click(object sender, RoutedEventArgs e)
        {
            try
            {
                objRegistrationViewModel.ActivateNow();
                this.Close();
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("frmRegistrationDPF :: btn_registerNow_Click : ", ex);
            }

        }
    }
}
