    public partial class ucSettings : UserControl
    {
        public ucSettings()
        {
            InitializeComponent();
            LoadStrings();
        }

        void LoadStrings()
        {
            general_settings.Header = cResourceManager.LoadString("DPF_PREFERENCES_GENERAL_HEADING_TEXT");
            fileformat_settings.Header = cResourceManager.LoadString("IDS_MARKFILES_TABPAGE_FILEFORMATS");
            excludedfolders_settings.Header = cResourceManager.LoadString("DPF_PREFERENCES_EXCLUSION_EXCLUDED_FOLDERS_TEXT");
            scancriteria_settings.Header = cResourceManager.LoadString("DPF_PREFERENCES_FILTER_SORT_TEXT");
            moveduplicates_settings.Header = cResourceManager.LoadString("IDS_MOVE_DUPLICATES");
        }

        private void ucGeneral_Loaded(object sender, RoutedEventArgs e)
        {

        }
    }
}
