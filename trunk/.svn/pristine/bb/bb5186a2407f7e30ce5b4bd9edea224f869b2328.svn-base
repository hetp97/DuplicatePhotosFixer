<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucResImageViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="261" d:DesignWidth="628"  >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition MinHeight="30" Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#3F3F3F" Margin="10 0 5 0">
            <DockPanel >
                <DockPanel VerticalAlignment="Center" Margin="5 0">
                    <TextBlock x:Name="lbl_grpName" Text="Group " FontWeight="SemiBold" FontSize="15" Foreground="#fff"/>
                    <TextBlock x:Name="lbl_groupNumber" Text="0" Foreground="#fff" FontWeight="SemiBold" FontSize="15" Padding="5 0"/>
                </DockPanel>
                <TextBlock x:Name="separator" Text="|" Foreground="#fff" FontWeight="SemiBold" FontSize="15" Padding="0" VerticalAlignment="Center"/>
                <DockPanel VerticalAlignment="Center" Margin="2 0 5 0">
                    <TextBlock x:Name="lbl_imgCount" Text=" 0" FontWeight="SemiBold" FontSize="15" Foreground="#FFA500"/>
                    <TextBlock x:Name="text_name" Text="Photos" Foreground="#fff" FontWeight="SemiBold" FontSize="15" Padding="5 0"/>
                </DockPanel>
            </DockPanel>

        </Grid>

        <Grid Grid.Row="1" >
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>
            <Border BorderBrush="#000" Background="White"  Width="250" HorizontalAlignment="Left" Margin="10 5 5 0" >
                <Image x:Name="thumnailImage" Height="180" />
            </Border>
           
            <Grid Grid.Row="1">
                <Border BorderBrush="Black" BorderThickness="0 1 0 0" Width="250" HorizontalAlignment="Left" Margin="10 0 5 5">
                    <StackPanel x:Name="infoDisplayGrid" Width="250" Background="#739250" HorizontalAlignment="Left"  >
                        <TextBlock x:Name="fileName" Text="fileName.png" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#fff" />
                        <DockPanel VerticalAlignment="Center"  >
                            <CheckBox Margin="5" HorizontalAlignment="Left" Width="55" x:Name="chkbox" Click="chkbox_Click" ></CheckBox>
                            <TextBlock x:Name="fileDate" Text="Jan 11, 2023" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#fff" />
                            <TextBlock x:Name="fileSize" Text="100 KB" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="10 0 0 0"  Foreground="#fff" />
                            <TextBlock/>
                        </DockPanel>
                    </StackPanel>
                </Border>
            </Grid>
            <!--<Image x:Name="thumbnailviewer" />
            <StackPanel MinHeight="52">
                <TextBlock x:Name="fileName" Text="xyz.png"/>
                <DockPanel>
                    <CheckBox></CheckBox>
                    <TextBlock x:Name="fileDate" Text="22/11/2023"/>
                    <TextBlock x:Name="fileSize" Text=",121 KB"/>
                </DockPanel>--><!--


            </StackPanel>-->
           

        </Grid>
    </Grid>
</UserControl>
