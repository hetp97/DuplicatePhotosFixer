<Window x:Class="DuplicatePhotosFixer.Views.frmThemeMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
        mc:Ignorable="d"
        Title="frmThemeMessageBox" Height="207" Width="451" ResizeMode ="NoResize" WindowStyle="None" 
        Background="{DynamicResource cl_bg_theme}" Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <DockPanel  Background="{DynamicResource cl_bg_header}">
            <cust:ImageButton
                            x:Name="close_btn"
                            Width="10"
                            Height="10"
                            DockPanel.Dock="Right"
                            Margin="10 0 10 0"
                            Style="{DynamicResource imageButton}"
                            Image="{DynamicResource img_cross}"
                            HoverImage="{DynamicResource img_cross}"
                            SelectedImage="{DynamicResource img_cross}"  Click="close_btn_Click"/>

            <Image x:Name="imgAppIcon" Stretch="None"
                   Source="{DynamicResource img_dpf_updatelogo}" Margin="5 0"/>

            <TextBlock x:Name="dpf_heading" VerticalAlignment="Center"
                       Text="Duplicate Photos Fixer Pro" FontSize="14" Foreground="{DynamicResource cl_fg_msgboxHeader}" />
        </DockPanel>
        <Grid Grid.Row="1">
            <DockPanel Margin="20 0 20 0">
                <Image x:Name="exclaim_image" Source="{DynamicResource img_alert_icon_trans}" Stretch="None" Margin="0 0 5 0"/>
                <TextBlock x:Name="lblinfo" VerticalAlignment="Center"
                            FontWeight="Regular"
                           FontSize="15"
                           Margin="10 0"
                           Foreground="{DynamicResource cl_fg_msgboxCont}" TextWrapping="Wrap">
                  Dear user,
                </TextBlock>
            </DockPanel>
        </Grid>
        <Grid Grid.Row="2" >
            <DockPanel HorizontalAlignment="Right">
                <Button x:Name="btnCancel" Content="Cancel" Grid.Column="2" Width="120" Height="34"
                        Foreground="#fff"
                        Style="{DynamicResource btn_Transparent_style}"
                         HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Click="btnCancel_Click" >
                  
                </Button>
                <Button x:Name="btnOk" Width="120" Height="34"  Content="OK" Margin="0 0 15 0" Foreground="#fff"
                        Style="{DynamicResource btn_contrastTransparent}"
                         HorizontalAlignment="Right" VerticalAlignment="Center"  Grid.Column="3" Click="btnOK_Click" >
                  
                </Button>

             

            </DockPanel>
        </Grid>

    </Grid>
</Window>
