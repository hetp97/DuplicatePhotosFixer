        public static void DownloadNInstallSetupInThread(string DownloadSetupLink, bool showProgress, string installArgs = "/verysilent", string fileName = "")
        {
            try
            {
                new Thread(() =>
                {
                    DownloadNInstallSetup(DownloadSetupLink, showProgress, installArgs, fileName);

                })
                { Name = "ThreadDwnldInstall" }.Start();
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("DownloadNInstallRBSetup:: ", ex);
            }
        }

        //has commented some code ,, have to add it on mainwinddows
        public static cClientEnum.eDownloadStatus DownloadNInstallSetup(string DownloadSetupLink, bool showProgress, string installArgs = "/verysilent", string fileName = "")
        {
            cClientEnum.eDownloadStatus status = cClientEnum.eDownloadStatus.DownloadError;
            try
            {
                csDownloadFile oDownload = null;

                System.Diagnostics.Process proc = null;
                try
                {
                    if (oDownload == null)
                    {
                        oDownload = new csDownloadFile();
                        if (showProgress)
                        {
                            //oDownload.OnProgress += (percentage, strMsg) => Program.oMainReference.oDownload_OnProgress(0, "");
                        }
                    }

                    string fullDownloadedPath = string.Empty;
                    try
                    {
                        //{
                        //    if (showProgress)
                        //    {
                        //        if (Program.oMainReference.oCustomProgress == null)
                        //        {
                        //            Program.oMainReference.oCustomProgress = new frmCustomProgress();
                        //        }
                        //        Program.oMainReference.UIThread(() =>
                        //        {
                        //            WindowsFormsSynchronizationContext.Current.Post(_ =>
                        //            {
                        //                if (Program.oMainReference.oCustomProgress == null || Program.oMainReference.oCustomProgress.IsDisposed)
                        //                {
                        //                    Program.oMainReference.oCustomProgress = new frmCustomProgress();
                        //                    Program.oMainReference.oCustomProgress.Parent = Program.oMainReference;
                        //                }
                        //                Program.oMainReference.oCustomProgress.StartPosition = FormStartPosition.CenterParent;

                        //                Program.oMainReference.oCustomProgress.Location = new Point(Program.oMainReference.Right - Program.oMainReference.oCustomProgress.Width - 5, Program.oMainReference.Bottom - Program.oMainReference.oCustomProgress.Height - 60);

                        //                Program.oMainReference.oCustomProgress.Show();
                        //            }, null);

                        //        });
                    
                        //string downUrl = cGlobalSettings.GetRPDownloadUrl();

                        status = oDownload.DownloadFile(DownloadSetupLink, string.IsNullOrEmpty(fileName) ? GetFileNameFromUrl(DownloadSetupLink) : fileName/*Path.GetFileName(DownloadSetupLink)*/, cGlobalSettings.GetDownloadPath, out fullDownloadedPath);

                        if (status != cClientEnum.eDownloadStatus.DownloadSucessFull)
                        {
                            cGlobalSettings.oLogger.WriteLogVerbose("DownloadNInstallRBSetup:: Not able to download setup successfully");
                            return status;
                        }
                        if (!File.Exists(fullDownloadedPath))
                        {
                            cGlobalSettings.oLogger.WriteLogVerbose("DownloadNInstallRBSetup:: Downloaded setup not found on system");
                            return status;
                        }
                    }
                    catch (Exception ex)
                    {
                        cGlobalSettings.oLogger.WriteLogException("DownloadNInstallRBSetup:: While Downloading setup, :: ", ex);
                    }
                    finally
                    {

                    }

                    if (showProgress)
                        //App.oMainReference.oDownload_OnProgress(100, cResourceManager.LoadString("SCANTAB4"));

                        using (proc = new System.Diagnostics.Process())
                    {
                        proc.EnableRaisingEvents = false;
                        proc.StartInfo.FileName = fullDownloadedPath;
                        proc.StartInfo.Arguments = installArgs;

                        proc.Start();
                        proc.WaitForExit();
                    }
                }
                catch (Exception ex)
                {
                    cGlobalSettings.oLogger.WriteLogException("DownloadNInstallRBSetup:: Thread- ThreadRBInstall, :: ", ex);
                }
                finally
                {
                    //if (showProgress)
                    //{
                    //    Program.oMainReference.UIThread(() =>
                    //    {
                    //        if (Program.oMainReference.oCustomProgress != null || !Program.oMainReference.oCustomProgress.IsDisposed)
                    //        {
                    //            Program.oMainReference.oCustomProgress.Close();
                    //        }
                    //        //CloseForm();
                    //    });
                    //}
                    if (proc != null)
                    {
                        proc.Close();
                        proc.Dispose();
                        proc = null;
                    }
                }
            }
            catch (Exception)
            {
                ;
            }

            return status;
        }

        public static string GetFileNameFromUrl(string url)
        {
            Uri uri;
            if (!Uri.TryCreate(url, UriKind.Absolute, out uri))
                uri = new Uri(url);

            return Path.GetFileName(uri.LocalPath);
        }

