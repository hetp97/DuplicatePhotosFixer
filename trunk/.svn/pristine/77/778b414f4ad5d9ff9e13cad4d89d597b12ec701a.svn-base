        private static string m_CONTROL_PANEL_URL = string.Empty;
        public static string CONTROL_PANEL_URL
        {
            get
            {
                if (String.IsNullOrEmpty(m_CONTROL_PANEL_URL))
                {
                    m_CONTROL_PANEL_URL = Convert.ToString(cGlobalSettings.GetCommonAppDataRegistryValue(cRegistrySettings.REGSTR_APP_CONTROLPANEL_URL, string.Empty));
                    if (string.IsNullOrEmpty(m_CONTROL_PANEL_URL)) //if not found in Registry then check in configuration file
                    {

                        if (!String.IsNullOrEmpty(Convert.ToString(ConfigurationManager.AppSettings["CONTROL_PANEL_URL"])))
                        {
                            m_CONTROL_PANEL_URL = Convert.ToString(ConfigurationManager.AppSettings["CONTROL_PANEL_URL"]);

                        }
                    }
                }
                return m_CONTROL_PANEL_URL;
            }
            set { m_CONTROL_PANEL_URL = value; }
        }

