        private static string m_FINALPARAMS = string.Empty;
        public static string FINALPARAMS
        {
            get
            {
                if (String.IsNullOrEmpty(m_FINALPARAMS))
                {
                    if (String.IsNullOrEmpty(m_FINALPARAMS))
                    {
                        m_FINALPARAMS = Convert.ToString(cGlobalSettings.GetUserAppDataRegistryValue(cRegistrySettings.REGSTR_APP_FINALPARAMS, string.Empty));
                    }
                    if (String.IsNullOrEmpty(m_FINALPARAMS))
                    {
                        m_FINALPARAMS = Convert.ToString(cGlobalSettings.GetUserAppDataRegistryValue(cRegistrySettings.REGSTR_APP_FINALPARAMS, string.Empty));
                    }

                    if (String.IsNullOrEmpty(m_FINALPARAMS))
                    {
                        m_FINALPARAMS = string.Format("{0}&productid={1}&appversion={2}", "", cGlobalSettings.ProductId, cGlobalSettings.GetApplicationVersion());
                    }
                }

                if (!m_FINALPARAMS.StartsWith("&"))
                {
                    m_FINALPARAMS = "&" + m_FINALPARAMS;
                }

                return m_FINALPARAMS;
            }
            set { m_FINALPARAMS = value; }
        }

