                    if (String.IsNullOrEmpty(m_AFTER_UPDATE_URL))
                    {
                        m_AFTER_UPDATE_URL = Convert.ToString(cGlobalSettings.GetUserAppDataRegistryValue(cRegistrySettings.REGSTR_AFTER_UPDATE_URL, string.Empty));
                        //m_AFTER_UPDATE_URL = string.Format("{0}&marked={1}&dups={2}", m_AFTER_UPDATE_URL, (cGlobalSettings.oRegSettings.GetTotalFilesMarked()), (cGlobalSettings.oRegSettings.GetTotalDuplicatesFound()));
                    }
                }
                return m_AFTER_UPDATE_URL;
            }
            set { m_AFTER_UPDATE_URL = value; }
        }

        private static string m_FIRE_SILENT_AFT_LAUNCH_URL = string.Empty;
        /// <summary>
        /// 
        /// </summary>
        public static bool FIRE_SILENT_AFT_LAUNCH_URL
        {
            get
            {
                if (String.IsNullOrEmpty(m_FIRE_SILENT_AFT_LAUNCH_URL))
                {
                    if (String.IsNullOrEmpty(m_FIRE_SILENT_AFT_LAUNCH_URL))
                    {
                        m_FIRE_SILENT_AFT_LAUNCH_URL = Convert.ToString(cGlobalSettings.GetUserAppDataRegistryValue(cRegistrySettings.REGSTR_FIRE_SILENT_AFT_LAUNCH_URL, string.Empty));
                    }
                }
                if (m_FIRE_SILENT_AFT_LAUNCH_URL == "1")
                    return true;
                else
                {
                    return false;
                }
            }
        }


        private static string m_LIP = string.Empty;
        const string REGSTR_APP_LIP = "lip";
        public static string LIP
        {
            get
            {
                if (String.IsNullOrEmpty(m_LIP))
                {
                    //m_Device_Keyword = Convert.ToString(cGlobalSettings.GetCommonParamRegistryValue(REGSTR_APP_Device_Keyword, string.Empty));

                    if (String.IsNullOrEmpty(m_LIP))
                    {
                        m_LIP = Convert.ToString(cGlobalSettings.GetUserAppDataRegistryValue(REGSTR_APP_LIP, string.Empty));
                    }
                    if (String.IsNullOrEmpty(m_LIP))
                    {
                        m_LIP = Convert.ToString(cGlobalSettings.GetUserAppDataRegistryValue(REGSTR_APP_LIP, string.Empty));
                    }
                }
                return m_LIP;
            }
            set { m_LIP = value; }
        }

