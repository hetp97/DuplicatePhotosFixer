        private static string m_UTM_DAYS = string.Empty;
        internal static string UTM_DAYS
        {
            get
            {
                //DateTime d1; 
                //if (DateTime.TryParse(oRegSettings.FirstInstallDate, out d1)) 
                //{ 
                //    DateTime currentDate; 
                //    DateTime.TryParse(DateTime.Now.ToString("dd-MM-yyyy"), out currentDate); 
                //    System.TimeSpan diffResult = (currentDate - d1); 
                //    int days = diffResult.Days; 
                //    //int days = Convert.ToInt32((DateTime.Now.Date - d1.Date).TotalDays); 
                //    if (days >= 0) 
                //    { 
                //        m_UTM_DAYS = days.ToString(); 
                //    } 
                //} 
                //else 
                //{ 
                //    m_UTM_DAYS = string.Empty; 
                //} 

                if (!string.IsNullOrEmpty(cGlobalSettings.oRegSettings.FirstInstallDate))
                {
                    try
                    {
                        CultureInfo en = new CultureInfo("en-US");
                        //string format = "dd-MM-yyyy";
                        DateTime installDate = DateTime.ParseExact(cGlobalSettings.oRegSettings.FirstInstallDate, cGlobalSettings.strInstallDateFormat, CultureInfo.InvariantCulture);
                        //string d = DateTime.Now.ToString("dd-MM-yyyy");
                        //DateTime currentDate = DateTime.ParseExact(d, format, en.DateTimeFormat);
                        System.TimeSpan diffResult = (DateTime.Now - installDate);
                        int days = diffResult.Days;
                        if (days >= 0)
                        {
                            m_UTM_DAYS = days.ToString();
                        }

                        //format = null;
                        en = null;
                    }
                    catch (Exception ex)
                    {
                        cGlobalSettings.oLogger.WriteLogException("cGlobal:: UTM_DAYS: ", ex);
                    }
                }
                else
                {
                    m_UTM_DAYS = "0";
                }

                cGlobalSettings.SetUserAppDataRegistryValue(cRegistrySettings.REGSTR_APP_UTM_DAYS, m_UTM_DAYS, RegistryValueKind.String);
                return m_UTM_DAYS;
            }
            set
            {
                cGlobalSettings.SetUserAppDataRegistryValue(cRegistrySettings.REGSTR_APP_UTM_DAYS, value, RegistryValueKind.String);
            }
        }



        public static int UTM_NAG_DAYS_INT { get; set; }
        private static string m_UTM_NAG_DAYS = string.Empty;
        internal static string UTM_NAG_DAYS
        {
            get
            {
                if (!string.IsNullOrEmpty(cGlobalSettings.oRegSettings.FirstInstallDate))
                {
                    try
                    {
                        int diffResult = (int)DateTime.Now.Date.Subtract(FirstInstallDate.Date).TotalDays;
                        //int days = diffResult;
                        if (diffResult > 0)
                        {
                            UTM_NAG_DAYS_INT = diffResult;
                            m_UTM_NAG_DAYS = diffResult.ToString();
                        }
                        else
                        {
                            diffResult = 0;
                            UTM_NAG_DAYS_INT = diffResult;
                            m_UTM_NAG_DAYS = diffResult.ToString();
                        }
                    }
                    catch (Exception ex)
                    {
                        cGlobalSettings.oLogger.WriteLogException("cGlobal:: UTM_DAYS: ", ex);
                    }
                }
                else
                {
                    UTM_NAG_DAYS_INT = 0;
                    m_UTM_NAG_DAYS = "0";
                }

                cGlobalSettings.SetUserAppDataRegistryValue(cRegistrySettings.REGSTR_APP_UTM_NAG_DAYS, m_UTM_NAG_DAYS, RegistryValueKind.String);
                return m_UTM_NAG_DAYS;
            }
            set
            {
                cGlobalSettings.SetUserAppDataRegistryValue(cRegistrySettings.REGSTR_APP_UTM_NAG_DAYS, value, RegistryValueKind.String);
            }
        }



        private static DateTime m_FirstInstallDate = DateTime.Now;
        internal static DateTime FirstInstallDate
        {
            get
            {
                if (!string.IsNullOrEmpty(cGlobalSettings.oRegSettings.FirstInstallDate))
                {
                    try
                    {
                        CultureInfo en = new CultureInfo("en-US");
                        //string format = "dd-MM-yyyy";
                        DateTime installDate = DateTime.ParseExact(cGlobalSettings.oRegSettings.FirstInstallDate, cGlobalSettings.strInstallDateFormat, CultureInfo.InvariantCulture);

                        m_FirstInstallDate = installDate;

                    }
                    catch (Exception ex)
                    {
                        cGlobalSettings.oLogger.WriteLogException("cGlobal:: FirstInstallDate: ", ex);
                    }
                }
                else
                {
                    m_FirstInstallDate = DateTime.Now;
                }

                //cGlobalSettings.SetUserAppDataRegistryValue(cRegistrySettings.REGSTR_APP_UTM_DAYS, m_UTM_DAYS, RegistryValueKind.String);
                return m_FirstInstallDate;
            }
        }

