        public void StartScan()
        {
            try
            {
                new Thread(() =>
                {
                    StartScanTh();
                })
                { Name = "ThScanning" }.Start();

            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("", ex);
            }
        }

        void StartScanTh()
        {
            try
            {

                HashSet<FileRecord> lstScanFiles = new HashSet<FileRecord>();
                cGlobalSettings.objScanner.Scan(cGlobalSettings.listScanPaths.Where(p => p.IsSelected && p.TypeOfInclusion == eTypeOfInclusion.Included).ToList(), new List<string> { "*.*" }, System.IO.SearchOption.AllDirectories, ref lstScanFiles, null, -1);

            }
            catch (Exception ex)
            {

            }
        }

        #endregion

