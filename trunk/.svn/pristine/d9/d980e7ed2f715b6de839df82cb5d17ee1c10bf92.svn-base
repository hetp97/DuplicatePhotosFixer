        public void CloseApp()
        {
            try
            {
                //do not close app if any process in already running
                //if (cGlobalSettings.oScanSettings.ExitOnClose)
                //{
                //    if (NotifyIconContextMenu.Items.Count > 2)
                //    {
                //        if (!NotifyIconContextMenu.Items[2].Enabled)
                //        {
                //            this.UIThread(() => MessageBoxEx.Show(this, cResourceManager.LoadString("IDS_PROCESS_ALREADY_RUNNING"), cGlobalSettings.GetProductNameFromDesc(), MessageBoxButtons.OK, MessageBoxIcon.Information));
                //            return;
                //        }

                //    }
                //}

                if (notifyMainApp != null)
                { notifyMainApp.Dispose(); }
                notifyMainApp = null;

                this.Close();
                Application.Exit();
                Environment.Exit(0);
            }
            catch (System.Exception ex)
            {
                cGlobalSettings.oLogger.WriteLog(string.Format("MainWindow|Close |{0}", ex.Message));
            }
        }
