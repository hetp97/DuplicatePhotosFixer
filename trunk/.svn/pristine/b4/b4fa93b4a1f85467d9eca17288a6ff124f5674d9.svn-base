<Window x:Class="DuplicatePhotosFixer.Views.frmSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
         xmlns:uc="clr-namespace:DuplicatePhotosFixer.UserControls"
        xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
        mc:Ignorable="d"
        AllowsTransparency="True"
        Title="frmSettings" Height="494" Width="666" WindowStyle="None"
        Background="{DynamicResource cl_bg_theme}" Visibility="Visible" x:Name="settingsWindow" WindowStartupLocation="CenterScreen" ShowInTaskbar="False" BorderBrush ="Transparent" BorderThickness="0" SnapsToDevicePixels="True"
       >
    <Window.Resources>
       
       
    </Window.Resources>
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="57"/>

        </Grid.RowDefinitions>
        <DockPanel Background="{DynamicResource cl_bg_header}">
            <cust:ImageButton
                            x:Name="close_btn"
                            Width="10"
                            Height="10"
                            DockPanel.Dock="Right"
                            Margin="10 0 10 0"
                            Style="{DynamicResource imageButton}"
                            Image="{DynamicResource img_close_plain}"
                            HoverImage="{DynamicResource img_close_plain}"
                            SelectedImage="{DynamicResource img_close_plain}" Click="close_btn_Click"  />

            <Image x:Name="dpf_logo" Source="/Resources/dpf_updateofr_icon.png" DockPanel.Dock="Left" Margin="10 0" Stretch="None"/>
            <TextBlock x:Name="dpf_header" Text="Duplicate Photos Fixer Pro - " Foreground="{DynamicResource cl_fg_Heading}"
                       FontSize="15" FontWeight="Regular" 
                       VerticalAlignment="Center" />
            <TextBlock x:Name="dpf_header_info" Text="Settings" VerticalAlignment="Center" FontSize="15" FontWeight="Regular" Foreground="{DynamicResource cl_fg_subHeading}" />
        </DockPanel>

        <Grid Grid.Row="1" Grid.RowSpan="2" Background="{DynamicResource cl_bg_TabControl}">
            <TabControl                      
                    Name="tab_main" 
                    TabStripPlacement="Left"
                    Margin="0,0,0,0"
                    Padding="0"                   
                    BorderThickness="0"  
                
                    >
                <TabControl.Resources>
                    <!--<Style TargetType="{x:Type TabPanel}">
                    <Setter Property="HorizontalAlignment" Value="Center" />
                    <Setter Property="VerticalAlignment" Value="Top" />
                    <Setter Property="Margin" Value="0 0 0 0"/>
                    <Setter Property="Width" Value="150"/>
                </Style>
                <Style x:Key="tabcontrol" TargetType="TabItem">
                    <Setter Property="Margin" Value="0 0"/>
                    <Setter Property="FontSize" Value="13" />
                    <Setter Property="Padding" Value="0 0 0 0" />
                    <Setter Property="IsTabStop" Value="False" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Margin" Value="0 0"/>
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="#707070"/>
                    <Setter Property="FontWeight" Value="Bold"/>


                    <Setter Property="Height" Value="40" />
                   
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border"
                                                Padding="0"
                                        BorderBrush="#DFDFDF"
                                                    BorderThickness="0 0 0 1"
                                                    >
                                    <DockPanel HorizontalAlignment="Left"
                                               LastChildFill="False" VerticalAlignment="Center"
                                                               x:Name="stack" Margin="10 0 0 0">

                                        <TextBlock Name="txt_strHeader" Text="{TemplateBinding Header}" TextWrapping="Wrap" 
                                                   Foreground="#707070" FontWeight="SemiBold" FontSize="13"/>

                                        <DockPanel.ToolTip>
                                            <ContentPresenter x:Name="ContentSites"
                                                                              Margin="5,0"
                                                                              VerticalAlignment="Center"
                                                                              HorizontalAlignment="Center"
                                                                              ContentSource="Header">
                                            </ContentPresenter>
                                        </DockPanel.ToolTip>
                                    </DockPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="txt_strHeader"
                                                Property="Foreground"
                                                Value="#178DC6" />
                                        <Setter TargetName="Border"
                                                Property="Background"
                                                Value="#ffffff" />
                                    </Trigger>
                                   
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition  Property="IsMouseOver"
                                                                    Value="True" />
                                            <Condition Property="IsTabStop"
                                                                   Value="True" />
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="txt_strHeader"
                                                Property="Foreground"
                                                Value="#38A3DA" />
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>-->

                    <Style x:Key="stl_mainTabControl" TargetType="{x:Type TabControl}">
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabControl">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border CornerRadius="3 3 0 0" Grid.Row="1">
                                            <Border BorderThickness="{TemplateBinding BorderThickness}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter ContentSource="SelectedContent" />
                                                </Border>
                                            </Border>
                                        </Border>
                                        <TabPanel Grid.Row="0" IsItemsHost="true" />
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style TargetType="{x:Type TabPanel}">
                        <Setter Property="HorizontalAlignment" Value="Left" />

                    </Style>

                    <Style x:Key="stl_TabItem" TargetType="TabItem">
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource clr_border}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Width" Value="139"/>
                        <Setter Property="Height" Value="47"/>
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        <Setter Property="VerticalAlignment" Value="Stretch"/>
                        <Setter Property="Margin" Value="0 -5 0 0"/>
                        <Setter Property="Background" Value="{DynamicResource cl_bg_TabControl}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Height" Value="40" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="Border"
                                                Padding="0"
                                        BorderBrush="{DynamicResource cl_br_setting}"
                                                    BorderThickness="0 0 0 1">

                                        <DockPanel HorizontalAlignment="Left"
                                               LastChildFill="False" VerticalAlignment="Center"
                                                               x:Name="stack" Margin="10 0 0 0">

                                            <TextBlock Name="txt_strHeader" Text="{TemplateBinding Header}" TextWrapping="Wrap" 
                                                   Foreground="{DynamicResource cl_fg_tabItem}" FontWeight="Regular" FontSize="13"/>

                                            <DockPanel.ToolTip>
                                                <ContentPresenter x:Name="ContentSites"
                                                                              Margin="5,0"
                                                                              VerticalAlignment="Center"
                                                                              HorizontalAlignment="Center"
                                                                              ContentSource="Header">
                                                </ContentPresenter>
                                            </DockPanel.ToolTip>
                                        </DockPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="txt_strHeader"
                                                Property="Foreground"                                               
                                                Value="{DynamicResource cl_fg_tabhover }" />
                                            <!--<Setter Property="FontSize" Value="14"/>
                                        <Setter Property="FontWeight" Value="Bold"/>-->

                                            <Setter TargetName="Border"
                                                Property="Background"
                                                Value="{DynamicResource cl_bg_settingsTabItemHover}" />
                                        </Trigger>

                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition  Property="IsMouseOver"
                                                                    Value="True" />
                                                <Condition Property="IsTabStop"
                                                                   Value="True" />
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="txt_strHeader"
                                                Property="Foreground"
                                                Value="{DynamicResource cl_fg_tabhover}" />
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>


                        </Setter>
                    </Style>

                </TabControl.Resources>
                <TabItem x:Name="general_settings"  Header="General" Style="{StaticResource stl_TabItem}">
                    <uc:ucGeneral x:Name="ucGeneral" />
                </TabItem>
                <TabItem x:Name="fileformat_settings"  Header="File Formats" Style="{StaticResource stl_TabItem}" >
                    <uc:ucSettingsFileFormat x:Name="ucFileFormat"/>
                </TabItem>

                <TabItem x:Name="excludedfolders_settings" Header="Exclude Folders" Style="{StaticResource stl_TabItem}">
                    <uc:ucExcludeSettings x:Name="ucExcludeSettings"/>
                </TabItem>
                <TabItem x:Name="scancriteria_settings" Header="Scan Criteria" Style="{StaticResource stl_TabItem}">
                    <uc:ucExtraSettings x:Name="ucExtraSettings"/>
                </TabItem>
                <TabItem x:Name="moveduplicates_settings" Header="Move Duplicates" Style="{StaticResource stl_TabItem}">
                    <uc:ucSettingsMove x:Name="ucMoveSettings"/>
                </TabItem>
                <TabItem x:Name="nagtheme_settings" Header="Nag Theme" Style="{StaticResource stl_TabItem}">
                    <uc:ucNagSettings x:Name="ucNagSettings"/>
                </TabItem>
                <!--<TabItem x:Name="resetbtn" Style="{StaticResource stl_TabItem}" VerticalAlignment="Bottom">
                <Button>
                    
                </Button>
            </TabItem>-->

            </TabControl>
            <!--<uc:ucSettings Loaded="ucSettings_Loaded_1"  />-->
