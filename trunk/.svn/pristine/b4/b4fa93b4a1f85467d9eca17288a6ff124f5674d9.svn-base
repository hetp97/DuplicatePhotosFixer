            </TabItem>



        </TabControl>
                    
                </StackPanel>

              
            </Grid>

            <Grid Grid.Column="1">
                
            </Grid>-->

        </Grid>
        <Grid Grid.Row="2"  HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <cust:ImageButton x:Name="btnReset"                                                                
                                  Image="{DynamicResource img_reset_icon}"
                                  Style="{DynamicResource stl_ImgTextButton}"
                                  HoverImage="{DynamicResource img_reset_icon}"
                                  SelectedImage="{DynamicResource img_reset_icon}"
                                    Content="Reset Settings"  Foreground="{DynamicResource cl_fg_setHeading}"
                                    FontWeight="Regular"
                                    FontSize="13px"
                                    BorderThickness="1" BorderBrush="#4E4E4E"
                                    Height="33" MaxWidth="120" 
                                    Padding="6 0 0 0"
                                    Margin="10 0" Background="Transparent"
                                    HorizontalAlignment="Left" Click="btnReset_Click_1">

            </cust:ImageButton>


            <Label x:Name="lbl_settingsApplied" Content="Settings Applied" Grid.Column="1"
                   Foreground="{DynamicResource cl_fg_primary}"
                   FontSize="15"
                   FontWeight="Bold"
                   Margin="160 0 0 0"
                   VerticalAlignment="Center"
                   VerticalContentAlignment="Center"
                   HorizontalAlignment="Center"
                       Visibility="Collapsed"/>


            <!--<Button Grid.Row="2" x:Name="btnReset" 
                    Foreground="#A8A8A8"
                    FontWeight="Regular"
                    FontSize="13px"
