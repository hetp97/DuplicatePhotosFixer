                      Padding="3"
                     FontSize="12"
                      Width="145"
                      Height="40" Background="#F5F5F5">
                <uc:ucExcludeSettings/>
            </TabItem>
            <TabItem Header="Scan Criteria" 
                      Padding="3"
                     FontSize="12"
                      Width="145"
                      Height="40" Background="#F5F5F5">
                <uc:ucExtraSettings/>
            </TabItem>
            <TabItem Header="Move Duplicates" 
                      Padding="3"
                     FontSize="12"
