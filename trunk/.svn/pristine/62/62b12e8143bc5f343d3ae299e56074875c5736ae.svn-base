<Window x:Class="DuplicatePhotosFixer.Views.frmAfterScan"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        mc:Ignorable="d" AllowsTransparency="True"
        Title="frmAfterScan" Height="327" Width="630" WindowStyle="None" Background="{DynamicResource bgrclr_solidgray}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Border BorderBrush="#404040" BorderThickness="0 0 0 1">
        <DockPanel>
            <Image x:Name="dpf_logo" Source="/Resources/dpf_updateofr_icon.png" DockPanel.Dock="Left" Margin="10 0" Stretch="None" VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right"  Margin="0,0,10,0" Background="Transparent" BorderBrush="Transparent" Click="Button_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="TextBlock.TextAlignment" Value="Center" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bdr_main">
                                            <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"                                                              
                                                              TextElement.FontSize="13"
                                                              TextElement.Foreground="White">
                                            </ContentPresenter>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" TargetName="bdr_main" Value="#3FB3E6">
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="true">
                                                <Setter Property="Background" TargetName="bdr_main" Value="#178BBE">
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                                <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>

                    <Image Source="{DynamicResource img_close_plain}" Stretch="None"/>
            </Button>
            <Label DockPanel.Dock="Left" x:Name="lbl_heading" FontSize="15" VerticalAlignment="Center" Content="Duplicate Photo Fixer Pro" Margin="2, 0, 2, 0" Foreground="#f9f9f9" />
        </DockPanel>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!--<TextBlock x:Name="no_of_duplicates" Grid.Column="0">
                <TextBlock.Background>
                    <ImageBrush ImageSource="{DynamicResource img_duplicate_number_bg_orange}"/>
                </TextBlock.Background>
            </TextBlock>-->
            <Image Source="{DynamicResource img_circle}" Height="100" Width="105" Margin="27, 35, 3, 3" VerticalAlignment="Top"/>
            <Grid Grid.Column="1" Margin="0 0 0 0">
                <StackPanel>
                <DockPanel>
                        <TextBlock x:Name="label1" Text="Duplicate Photos Found:" Foreground="White" FontSize="22" FontWeight="Bold" Margin="4, 35, 3, 3"/>
                        <TextBlock x:Name="cbtn_totalCount" Text="1081" FontSize="22" FontWeight="Bold" Foreground="#00D735" Margin="4, 35, 3, 3"/>
                </DockPanel>
                    <TextBlock x:Name="label3"  FontSize="14" FontWeight="Regular" Foreground="#40A5FD" Margin="3, 0, 0, 0">
                        Use Auto Mark to conveniently mark duplicates based on <LineBreak/> set hierarchy.
                    </TextBlock>
                    <TextBlock x:Name="lbl_tip" 
                               TextWrapping="Wrap" Foreground="#C9C9C9" FontSize="14" FontWeight="Regular" >
                        We found {0} duplicates occupying {1} space on your <LineBreak/>  computer. It is recommended to delete these unwanted <LineBreak/> photos immediately to de-cluster your system and recover <LineBreak/>
                        storage space.
                    </TextBlock>
                    <DockPanel Margin="0 20 0 0">
                        <Button x:Name="btn_selectManually" Content="Select Manually" Width="192" Height="44" Foreground="White" FontSize="17" FontWeight="Bold" Background="#2B72E6" BorderBrush="#000"/>
                        <Button x:Name="btn_autoMark" Content="Auto Mark" Width="190" Height="44" Foreground="White" FontSize="17" FontWeight="Bold" Background="#009926" BorderBrush="#000"/>

                    </DockPanel>
                </StackPanel>
                

            </Grid>
        </Grid>
    </Grid>
</Window>
