<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucChangeSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="56" d:DesignWidth="262" Background="#2F2F2F">
    <Grid>
        <StackPanel Orientation="Horizontal">
            <Label x:Name="lbl_settingsDisable" Content="This setting is disabled." Foreground="#6D6D6D"/>
            <Button x:Name="btn_changeSettings" Content="Change Settings >" 
                    Background="Transparent" 
                    Height="Auto" Width="Auto" 
                    VerticalAlignment="Top"
                    Margin="0 3 0 0 "
                    Foreground="White"
                    Cursor="Hand"                    
                    BorderBrush="Transparent" />
        </StackPanel>   
    </Grid>
</UserControl>
