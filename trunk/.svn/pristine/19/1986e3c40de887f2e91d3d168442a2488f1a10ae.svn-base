<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucRecommendedApp"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
             mc:Ignorable="d" 
             d:DesignHeight="421" d:DesignWidth="960" Background="#1A1A1A">
    <Grid>
        <ScrollViewer>
            <StackPanel>
                <DockPanel Height="78" Background="#313131" Margin="0 10">
                    <Image x:Name="adu_img" Source="{DynamicResource img_adu_logo}" Stretch="None"/>
                    <StackPanel Margin="0 12">
                        <TextBlock x:Name="app_name1" Text ="Advanced Driver Updater" Foreground="#EAEAEA" FontSize="15" FontWeight="SemiBold" Padding="0 0 0 5" />
                        <TextBlock x:Name="app_info" FontSize="13" Foreground="#E0A814">
                        <Italic>Driver Update Utility </Italic>
                        </TextBlock>
                    </StackPanel>
                    <cust:ImageButton
                        x:Name="linklblInstall"
                              DockPanel.Dock="Right"
                              Margin="0 0 30 0"  
                              Cursor="Hand"
                             Image="{DynamicResource img_download}"  
                              HoverImage="{DynamicResource img_download}"
                              SelectedImage="{DynamicResource img_download}"
                    FontSize="14" VerticalAlignment="Center" Padding="5 0" 
                              Content="Install Now"                             
                              Visibility="Visible"
                    Style="{DynamicResource ImageTextbtn}">
                    </cust:ImageButton>
                    <TextBlock x:Name="app_desc1" Foreground="#BCBCBC" Width="500"
                               TextWrapping="Wrap" Margin="0 12" FontSize="13" DockPanel.Dock="Right">
                        The tool identifies outdated or missing drivers allows you to update them in a single click for uniterrupted and improved PC Performance
                    </TextBlock>
                </DockPanel>
                <DockPanel Height="78" Background="#313131" Margin="0 10">
                    <Image x:Name="tweak_img" Source="{DynamicResource img_adu_logo}" Stretch="None"/>
                    <StackPanel Margin="0 12">
                        <TextBlock x:Name="app_name2" Text ="TweakShot Screen Recoder" Foreground="#EAEAEA" FontSize="15" FontWeight="SemiBold" Padding="0 0 0 5" />
                        <TextBlock x:Name="app_info2" FontSize="13" Foreground="#E0A814">
                        <Italic>Screen Recoder</Italic>
                        </TextBlock>
                    </StackPanel>
                    <cust:ImageButton
                        x:Name="linklblInstall2"
                              DockPanel.Dock="Right"
                              Margin="0 0 30 0"                           
                             Image="{DynamicResource img_download}"  
                              HoverImage="{DynamicResource img_dropdownarrow}"
                              SelectedImage="{DynamicResource img_dropdownarrow}"
                    FontSize="14" VerticalAlignment="Center" Padding="5 0" 
                              Content="Install Now"                             
                              Visibility="Visible"
                    
                    Style="{DynamicResource ImageTextbtn}">
                    </cust:ImageButton>
                    <TextBlock x:Name="app_desc2" Foreground="#BCBCBC" Width="500"
                               TextWrapping="Wrap" Margin="0 12" FontSize="13" DockPanel.Dock="Right">
                        Record online classes, webinars streaming content limitlessly.
                    </TextBlock>

                </DockPanel>
                <DockPanel Height="78" Background="#313131" Margin="0 10">
                    <Image x:Name="systweak_img" Source="{DynamicResource img_adu_logo}" Stretch="None"/>
                    <StackPanel Margin="0 12">
                        <TextBlock x:Name="app_name3" Text ="Systweak Antivirus" Foreground="#EAEAEA" FontSize="15" FontWeight="SemiBold" Padding="0 0 0 5" />
                        <TextBlock x:Name="app_info3" FontSize="13" Foreground="#E0A814">
                        <Italic>Systweak for Antivirus</Italic>
                        </TextBlock>
                    </StackPanel>
                    <cust:ImageButton
                        x:Name="linklblInstall3"
                              DockPanel.Dock="Right"
                              Margin="0 0 30 0"                           
                             Image="{DynamicResource img_download}"  
                              HoverImage="{DynamicResource img_dropdownarrow}"
                              SelectedImage="{DynamicResource img_dropdownarrow}"
                    FontSize="14" VerticalAlignment="Center" Padding="5 0" 
                              Content="Install Now"                             
                              Visibility="Visible"
                    
                    Style="{DynamicResource ImageTextbtn}">
                    </cust:ImageButton>
                    <TextBlock x:Name="app_desc3" Foreground="#BCBCBC" Width="500"
                               TextWrapping="Wrap" Margin="0 12" FontSize="13" DockPanel.Dock="Right">
                        Systweak Antivirus shields your computer against malware, spyware , adware and trojan hiding in your PC to make sure that  its is protected against malicious threats.
                    </TextBlock>

                </DockPanel>
                <DockPanel Height="78" Background="#313131" Margin="0 10">
                    <Image x:Name="systweakVPN_img" Source="{DynamicResource img_adu_logo}" Stretch="None"/>
                    <StackPanel Margin="0 12">
                        <TextBlock x:Name="app_name4" VerticalAlignment="Center" Text ="Systweak VPN" Foreground="#EAEAEA" FontSize="15" FontWeight="SemiBold" Padding="0 10 0 5" />
                    </StackPanel>
                    <cust:ImageButton
                        x:Name="linklblInstall4" 
                              DockPanel.Dock="Right" 
                              Margin="0 0 30 0"                           
                             Image="{DynamicResource img_download}"  
                              HoverImage="{DynamicResource img_download}"
                              SelectedImage="{DynamicResource img_download}"
                    FontSize="14" VerticalAlignment="Center" Padding="5 0" 
                              Content="Install Now"                             
                              Visibility="Visible"                 
                    Style="{DynamicResource ImageTextbtn}">
                    </cust:ImageButton>
                    <TextBlock x:Name="app_desc4" Foreground="#BCBCBC" Width="500"
                               TextWrapping="Wrap" Margin="0 12" FontSize="13" DockPanel.Dock="Right">
                        Systweak VPN hides your IP address, lets you access favorite websites , entertainment content without any restrictions.
                    </TextBlock>
                </DockPanel>
                <DockPanel Height="78" Background="#313131" Margin="0 10">
                    <Image x:Name="rightbackup_img" Source="{DynamicResource img_right-backup}" Stretch="None"/>
                    <StackPanel Margin="0 12">
                        <TextBlock x:Name="app_name5" VerticalAlignment="Center" Text ="Systweak VPN" Foreground="#EAEAEA" FontSize="15" FontWeight="SemiBold" Padding="0 10 0 5" />
                    </StackPanel>
                    <cust:ImageButton
                        x:Name="linklblInstall5"
                              DockPanel.Dock="Right"
                              Margin="0 0 30 0"                           
                             Image="{DynamicResource img_download}"  
                              HoverImage="{DynamicResource img_download}"
                              SelectedImage="{DynamicResource img_download}"
                    FontSize="14" VerticalAlignment="Center" Padding="5 0" 
                              Content="Install Now"                             
                              Visibility="Visible"
                    
                    Style="{DynamicResource ImageTextbtn}">
                    </cust:ImageButton>
                    <TextBlock x:Name="app_desc5" Foreground="#BCBCBC" Width="500"
                               TextWrapping="Wrap" Margin="0 12" FontSize="13" DockPanel.Dock="Right">
                        Systweak VPN hides your IP address, lets you access favorite websites , entertainment content without any restrictions.
                    </TextBlock>
                </DockPanel>

                <DockPanel Height="78" Background="#313131" Margin="0 10">
                    <Image x:Name="sysSoftwareUpdator_img" Source="{DynamicResource img_right-backup}" Stretch="None"/>
                    <StackPanel Margin="0 12">
                        <TextBlock x:Name="app_name6" VerticalAlignment="Center" Text ="Systweak Software Updator" Foreground="#EAEAEA" FontSize="15" FontWeight="SemiBold" Padding="0 10 0 5" />
                    </StackPanel>
                    <cust:ImageButton
                        x:Name="linklblInstall6"
                              DockPanel.Dock="Right"
                              Margin="0 0 30 0"                           
                             Image="{DynamicResource img_download}"  
                              HoverImage="{DynamicResource img_download}"
                              SelectedImage="{DynamicResource img_download}"
                    FontSize="14" VerticalAlignment="Center" Padding="5 0" 
                              Content="Install Now"                             
                              Visibility="Visible"
                    
                    Style="{DynamicResource ImageTextbtn}">
                    </cust:ImageButton>
                    <TextBlock x:Name="app_desc6" Foreground="#BCBCBC" Width="500"
                               TextWrapping="Wrap" Margin="0 12" FontSize="13" DockPanel.Dock="Right">
                        Systweak Software Updater keeps installed software up to date on your Windows PC.
                    </TextBlock>
                </DockPanel>

                <DockPanel Height="78" Background="#313131" Margin="0 10">
                    <Image x:Name="tweakpassManager_img" Source="{DynamicResource img_adu_logo}" Stretch="None"/>
                    <StackPanel Margin="0 12">
                        <TextBlock x:Name="app_name7" Text ="TweakPass Password Manager" Foreground="#EAEAEA" FontSize="15" FontWeight="SemiBold" Padding="0 0 0 5" />
                        <TextBlock x:Name="app_info7" FontSize="13" Foreground="#E0A814">
                        <Italic>Safeguard your passwords in vault </Italic>
                        </TextBlock>
                    </StackPanel>
                    <cust:ImageButton
                        x:Name="linklblInstall7"
                              DockPanel.Dock="Right"
                              Margin="0 0 30 0"                           
                             Image="{DynamicResource img_download}"  
                              HoverImage="{DynamicResource img_dropdownarrow}"
                              SelectedImage="{DynamicResource img_dropdownarrow}"
                    FontSize="14" VerticalAlignment="Center" Padding="5 0" 
                              Content="Install Now"                             
                              Visibility="Visible"
                    
                    Style="{DynamicResource ImageTextbtn}">
                    </cust:ImageButton>
                    <TextBlock x:Name="app_desc7" Foreground="#BCBCBC" Width="500"
                               TextWrapping="Wrap" Margin="0 12" FontSize="13" DockPanel.Dock="Right">
                       Safeguard your sensitive information with World's strongest AES  encryption technology.Never forgot a password again
                    </TextBlock>
                </DockPanel>

                <DockPanel Height="78" Background="#313131" Margin="0 10">
                    <Image x:Name="DPF_img" Source="{DynamicResource img_right-backup}" Stretch="None"/>
                    <StackPanel Margin="0 12">
                        <TextBlock x:Name="app_name8" VerticalAlignment="Center" Text ="Duplicate Files Fixer" Foreground="#EAEAEA" FontSize="15" FontWeight="SemiBold" Padding="0 10 0 5" />
                    </StackPanel>
                    <cust:ImageButton
                        x:Name="linklblInstall8"
                              DockPanel.Dock="Right"
                              Margin="0 0 30 0"                           
                             Image="{DynamicResource img_download}"  
                              HoverImage="{DynamicResource img_download}"
                              SelectedImage="{DynamicResource img_download}"
                    FontSize="14" VerticalAlignment="Center" Padding="5 0" 
                              Content="Launch Now"                             
                              Visibility="Visible"
                    
                    Style="{DynamicResource ImageTextbtn}">
                    </cust:ImageButton>
                    <TextBlock x:Name="app_desc8" Foreground="#BCBCBC" Width="500"
                               TextWrapping="Wrap" Margin="0 12" FontSize="13" DockPanel.Dock="Right">
                       Recover disk space by removing duplicates
                    </TextBlock>
                </DockPanel>

                <DockPanel Height="78" Background="#313131" Margin="0 10">
                    <Image x:Name="TweakShotScreenCapture_img" Source="{DynamicResource img_right-backup}" Stretch="None"/>
                    <StackPanel Margin="0 12">
                        <TextBlock x:Name="app_name9" VerticalAlignment="Center" Text ="TweakShot Screen Capture" Foreground="#EAEAEA" FontSize="15" FontWeight="SemiBold" Padding="0 10 0 5" />
                    </StackPanel>
                    <cust:ImageButton
                        x:Name="linklblInstall9"
                              DockPanel.Dock="Right"
                              Margin="0 0 30 0"                           
                             Image="{DynamicResource img_download}"  
                              HoverImage="{DynamicResource img_download}"
                              SelectedImage="{DynamicResource img_download}"
                    FontSize="14" VerticalAlignment="Center" Padding="5 0" 
                              Content="Launch Now"                             
                              Visibility="Visible"
                    
                    Style="{DynamicResource ImageTextbtn}">
                    </cust:ImageButton>
                    <TextBlock x:Name="app_desc9" Foreground="#BCBCBC" Width="500"
                               TextWrapping="Wrap" Margin="0 12" FontSize="13" DockPanel.Dock="Right">
                    Record Screen Activities including online classes , live streaming events,online webinars and more in just one click.
                    </TextBlock>
                </DockPanel>


            </StackPanel>
        </ScrollViewer>  
    </Grid>
</UserControl>
