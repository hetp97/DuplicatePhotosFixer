<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucGeneral"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="397" d:DesignWidth="520" Background="#272727" Loaded="UserControl_Loaded" >
    <UserControl.Resources>
        <Style TargetType="CheckBox" x:Key="styl_chkbox_content">
            <Setter Property="FontSize" Value ="14"/>
            <Setter Property="Foreground" Value="#E9E9E9"/>
            <Setter Property="Margin" Value="0 10 0 18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="57"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="12 10 10 0">
            <TextBlock x:Name="alert_settings_lbl" Text="Alert Settings" FontSize="24" Foreground="#fff" FontWeight="Regular"/>
            <TextBlock x:Name="lbl_info" Text="The settings below allow you to hide/unhide confirmation dialog boxes shown in the application while performing actions like delete, auto-mark &amp; moving back. You can change settings as per your requirements."
                       TextWrapping="Wrap" Foreground="#AEAEAE" Margin="0 3 0 15" FontWeight="Regular"
                       FontSize="14"/>
        </StackPanel>
        <Grid Grid.Row="1" Margin="12 20 10 0">
            <ScrollViewer x:Name="settings_options">
                <StackPanel>
                    <CheckBox x:Name="chk_OpenAssistant" 
                              Content="Do not show Open Selection Assistant dialog on Auto Mark" 
                              Padding="5 -3 0 0"
                               IsChecked="{Binding Path=OpenAssistantChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource styl_chkbox_content}" Click="chk_OpenAssistant_Click" >
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                        </CheckBox.LayoutTransform>

                    </CheckBox>

                    <CheckBox x:Name="chk_Backbtn"
                                IsChecked="{Binding Path=BackbtnChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Padding="5 -3 0 0" Content="Do not show auto mark dialog on Auto Mark." 
                            Style="{StaticResource styl_chkbox_content}" Click="chk_Backbtn_Click" >
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                        </CheckBox.LayoutTransform>
                    </CheckBox>

                    <CheckBox x:Name="chk_launchSystm" Content="Launch at system startup" 
                                IsChecked="{Binding Path=SysStartupChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource styl_chkbox_content}" Click="chk_launchSystm_Click">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                        </CheckBox.LayoutTransform>
                    </CheckBox>
                    <CheckBox x:Name="chk_productMessage"
                                IsChecked="{Binding Path=ProductMesChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Content="Product Messages"   Padding="5 -3 0 0"                             
                              Style="{StaticResource styl_chkbox_content}" Click="chk_productMessage_Click">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                        </CheckBox.LayoutTransform>
                    </CheckBox>
                    <CheckBox x:Name="chk_otherProduct"   Padding="5 -3 0 0"
                                IsChecked="{Binding Path=OtherProductMesChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Content="Show other product recommendations for my PC " 
                           Style="{StaticResource styl_chkbox_content}" Click="chk_otherProduct_Click">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                        </CheckBox.LayoutTransform>
                    </CheckBox>
                    <CheckBox x:Name="chk_periodicMessage"   Padding="5 -3 0 0"
                                IsChecked="{Binding Path=PeriodicMesChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Content="Show Periodic update messages." 
                             Style="{StaticResource styl_chkbox_content}">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                        </CheckBox.LayoutTransform>
                    </CheckBox>

                </StackPanel>

            </ScrollViewer>
        </Grid>
  

       
        <Grid Grid.Row="2" Background="{DynamicResource bgclr_soliddark}" >
            <Label x:Name="lbl_settingsApplied" Content="Settings Applied" 
                   Foreground="#fff"
                   FontSize="15"
                   FontWeight="Bold"
                   VerticalContentAlignment="Center"
                   HorizontalAlignment="Center"
                   Visibility="Collapsed"/>
            <!--<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 0 30 0">

                <Button x:Name="btncancel" Content="Cancel" Width="120" Height="30"
                            Margin="0 0 20 0"  Foreground="#8c8c8c"
                        BorderBrush="#4E4E4E" 
                        FontSize="13"
                            Background="Transparent"
                        BorderThickness="1" Style="{DynamicResource styl_trans_btn}" >
                  
                </Button>

                <Button x:Name="btndone" Content="Done" Width="120" Height="30" Style="{DynamicResource styl_add_excludebtn}"
                         BorderBrush="Transparent"   Background="#1CA2E5" Foreground="#ffffff" >

                </Button>


            </StackPanel>-->
        </Grid>
    </Grid>
</UserControl>
