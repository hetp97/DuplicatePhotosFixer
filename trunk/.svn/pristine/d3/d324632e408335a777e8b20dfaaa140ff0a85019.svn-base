<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucExtraSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="441" d:DesignWidth="482" Background="{DynamicResource frgclr_white}">
    <Grid>
        <StackPanel Margin="10,20">
            <!--<CheckBox x:Name="chk_TimeInterval"
                                  VerticalAlignment="Center"
                                  Style="{DynamicResource SettingsCheckBoxStyle}"
                                Background="{DynamicResource frgclr_whitish}"
                      Content="Include Time Interval while scan"
                      Foreground="Black" 
                      FontSize="14"
                                 
                                  Width="17"
                                  Height="17"
                                  />-->
            <StackPanel Margin="0 0 0 20">
                <TextBlock x:Name="scan_heading" Foreground="{DynamicResource frgclr_solidgray}"
                       FontSize="20" >
                Manage scan criteria
                </TextBlock>
                <TextBlock x:Name="heading_info"
                       Foreground="#83878D"
                       >
                The settings will allow you to customize scan options</TextBlock>
            </StackPanel>
            <CheckBox x:Name="chk_TimeInterval" Content="Include Time Interval while scan" Foreground="Black"  FontSize="13" Margin="0 10"/>
            <TextBlock x:Name="lbl_TimeIntervalInfo" Text="Time Interval determines a time gap between photos ranging from less than a second to 24 hours. Choose an interval of your choice for preferred results." TextWrapping="Wrap"
                       Margin="17, 0, 15, 0" FontSize="13" Foreground="{DynamicResource frgclr_solidgray}"/>


            <CheckBox x:Name="chk_GPS" Content="Include GPS while scan" Foreground="Black"  FontSize="13" Margin="0 10"/>
            <TextBlock x:Name="lbl_GPSInfo" Text="GPS checks the embedded coordinates of photos. Location coordinates between photos should fall within the range of 0 to 100 meters" TextWrapping="Wrap"
                       Margin="17, 0, 15, 0" FontSize="13" Foreground="{DynamicResource frgclr_solidgray}"/>


            <CheckBox x:Name="chk_captureDate"  Content="Use Time Interval Settings if Capture Data is not available " Foreground="Black"  FontSize="13" Margin="0 10"/>
            <TextBlock x:Name="lbl_CaptureDateInfo" Text="If Capture Date is missing in exif data of photo, then Creation Date will be used instead" TextWrapping="Wrap"
                       Margin="17, 0, 15, 0" FontSize="13" Foreground="{DynamicResource frgclr_solidgray}"/>



            <CheckBox x:Name="chk_rotatedImages" Content="Include Rotated Images" Foreground="Black"  FontSize="13" Margin="0 20 0 0"/>
            <CheckBox x:Name="chk_flippedImages" Content="Include Flipped Images" Foreground="Black"  FontSize="13" Margin="0 10 0 0"/>

        </StackPanel>
            
    </Grid>
</UserControl>
