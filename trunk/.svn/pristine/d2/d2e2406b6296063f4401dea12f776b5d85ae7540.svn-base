        private void btn_deleteCurrentRow_Click(object sender, RoutedEventArgs e)
        {
            try
            {

                System.Windows.Controls.Button btn_deleteCurrentRow = sender as System.Windows.Controls.Button;
                if (btn_deleteCurrentRow.Tag == null)
                    return;

                if (btn_deleteCurrentRow.Tag is csScanPaths)
                {
                    App.oMainReference.objHomeViewModel.RemoveScanPath(btn_deleteCurrentRow.Tag as csScanPaths);
                    LoadScanPathsSource(true);
                }
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("btn_action_Click:: ucHome: ", ex);
            }
        }



        private void cboScanModes_SelectionChanged(object sender, SelectionChangedEventArgs e)
        {
            try
            {
                if (cboScanModes.SelectedIndex < 0)
                    return;

                ScanModeData SelectedMode = (ScanModeData)cboScanModes.SelectedItem;

                cGlobalSettings.CurrentScanMode = SelectedMode.ModeType;

                App.oMainReference.InitScanner();
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("ucHomeMain:: cboScanModes_SelectionChanged: ", ex);
            }
        }




        private void chkbxCheckAllgrid_Click(object sender, RoutedEventArgs e)
        {
            grid_file_folder.ItemsSource = null;
            
            if (chkbxCheckAllgrid.IsChecked == true)
            {
                foreach (var item in App.oMainReference.objHomeViewModel.lstScanPathsInclude)
                {
                    item.IsSelected = true;
                    item.IncludeSubfolder = true;
                }
            }
            else
            {
                foreach (var item in App.oMainReference.objHomeViewModel.lstScanPathsInclude)
                {
                    item.IsSelected = false;
                    item.IncludeSubfolder = false;
                }
            }
            //grid_file_folder.ItemsSource = null;

            grid_file_folder.ItemsSource = App.oMainReference.objHomeViewModel.lstScanPathsInclude;
            //App.oMainReference.objHomeFooter.IsScanbtnEnabled();


        }

        void CheckAll()
        {
            try
            {
               
                if (grid_file_folder.Items.Count == 0)
                {
                    chkbxCheckAllgrid.IsChecked = false;
                }

                else
                {
                    chkbxCheckAllgrid.IsChecked = true;
                }
            }
            catch (Exception ex)
            {

               
            }
            
        }
        protected void CloseMenu(object sender, MouseButtonEventArgs e)
        {
            try
            {
                FrameworkElement fe = sender as FrameworkElement;

                if (fe == null)
                    return;

                if (fe is ContextMenu)
                {
                    ((ContextMenu)fe).IsOpen = false;
                    return;
                }

                while (fe != null)
                {
                    if (fe.ContextMenu != null)
                    {
                        fe.ContextMenu.IsOpen = false;
                        break;
                    }
                    if (fe.Parent == null)
                        break;

                    fe = fe.Parent as FrameworkElement;
                }

                FrameworkElement btn = fe.TemplatedParent as FrameworkElement;

                CloseMenu(btn, e);
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("ucHome:: CloseMenu: ", ex);
            }
        }
        void UpdateGridLayout()
        {
           
            try
            {
               
                grid_file_folder.UpdateLayout();
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("UpdateGridLayout", ex);
