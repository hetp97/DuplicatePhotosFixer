        }
        private void txt_explorer_MouseLeftButtonUp(object sender, System.Windows.Input.MouseButtonEventArgs e)
        {
            CloseMenu(sender, e);
            App.oMainReference.objHomeViewModel.RevealExplorer(sender);          
        }

        private void txt_checkAll_MouseLeftButtonUp(object sender, MouseButtonEventArgs e)
        {
            CloseMenu(sender, e);
            App.oMainReference.objHomeViewModel.CheckAllScanFiles(sender);
            chkbxCheckAllgrid.IsChecked = true;
            UpdateGridLayout();
        }

        private void txt_uncheckAll_MouseLeftButtonUp(object sender, MouseButtonEventArgs e)
        {
            CloseMenu(sender, e);
            App.oMainReference.objHomeViewModel.UnCheckAllScanFiles(sender);
            chkbxCheckAllgrid.IsChecked = false;
            UpdateGridLayout();
        }

        private void txt_remove_MouseLeftButtonUp(object sender, MouseButtonEventArgs e)
