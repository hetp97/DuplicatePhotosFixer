        {
            CloseMenu(sender, e);
            App.oMainReference.objHomeViewModel.RemoveAllItemScanList(sender);
            UpdateGridLayout();
        }

        public void AddDragDropItems(System.Windows.DragEventArgs e)
        {
            App.oMainReference.objHomeViewModel.doDragDrop(e);
        }

