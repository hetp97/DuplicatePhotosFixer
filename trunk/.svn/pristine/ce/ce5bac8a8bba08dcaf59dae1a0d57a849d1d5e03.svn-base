<Window x:Class="DuplicatePhotosFixer.Views.frmFeedBack"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        mc:Ignorable="d"
        Title="frmFeedBack" Height="434" Width="568" WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition MinHeight="41" Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#404040">
            <DockPanel>
                <Button x:Name="btn_close" Background="#3E3E3E" Width="20"
                        Height="20"
                        Foreground="White"
                        FontSize="15"
                        FontWeight="SemiBold"
                        DockPanel.Dock="Right"
                        Margin="0 2 5 0"
                        VerticalAlignment="Top">X
                </Button>
                <Image x:Name="dpf_icon" Width="30" Height="20"
                       Source="/Resources/dpf_tsr.png"/>
                <TextBlock x:Name="lbl_head" Text="Duplicate Photos Fixer Pro" Foreground="White"
                           FontSize="15"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </DockPanel>
            
        </Grid>
        <Grid Grid.Row="1" Margin="10">
            <StackPanel>
                <TextBlock x:Name="tbDearUser" 
                           TextWrapping="Wrap" 
                           FontSize="12">
                    Dear user, please share your experience by filling this feedback form. This will give us a <LineBreak></LineBreak> idea of the application's performance and help us provide better solutions to fix <LineBreak/> the issues reported.
                </TextBlock>
                <TextBlock x:Name="tbProvideEmail"
                           TextWrapping="Wrap"
                           Padding="0 5 0 5"
                           FontSize="14"
                           Foreground="#0577CF">
                    Provide your email address and select the Feedback type from  the dropdown <LineBreak/> list.
                </TextBlock>
                <DockPanel Height="40" >
                    <TextBlock x:Name="tbEmail"
                             VerticalAlignment="Center" 
                               MinWidth="170"
                               Width="Auto"
                               
                              >
                        Your Email Address
                    </TextBlock>
                    <TextBox x:Name="txtEmail"
                            VerticalAlignment="Center" 
                             Width="Auto"
                             MinWidth="353">
                        
                    </TextBox>
                </DockPanel>
                <DockPanel Height="40" >
                    <TextBlock x:Name="tbFeedBacktype"
                             VerticalAlignment="Center" 
                               MinWidth="170"
                               Width="Auto"
                               
                              >
                        Your Email Address
                    </TextBlock>
                    <ComboBox x:Name="cboFeedBacktype" Width="Auto" MinWidth="353"
                              VerticalAlignment="Center"/>

                </DockPanel>

                <TextBlock x:Name="tbBriefly"
                           TextWrapping="Wrap"
                           Padding="0 5 0 5"
                           FontSize="14"
                           Foreground="#0577CF"
                           >
                    Briefly describe your experience:
                </TextBlock>
                <TextBox x:Name="txtBrief"
                         Width="530"
                         Height="124"/>
                <DockPanel HorizontalAlignment="Right">
                    <Button x:Name="btnSubmit" Width="82" Height="26"
                            Content="Submit"
                            Margin="0 10 20 0">
                        <Button.Background>
                            <LinearGradientBrush  StartPoint="0,0" EndPoint="0 ,1">
                                <GradientStop Color="#F1F1F1" Offset="0"/>
                                <GradientStop Color="LightGray" Offset="0.555"/>
                                <GradientStop Color="#F1F1F1" Offset="0.03"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                    <Button x:Name="btn_Cancel" Width="82" Height="26"
                            Content="Cancel"
                            Margin="0 10 10 0">
                        <Button.Background>
                            <LinearGradientBrush  StartPoint="0,0" EndPoint="0 ,1">
                                <GradientStop Color="#F1F1F1" Offset="0"/>
                                <GradientStop Color="LightGray" Offset="0.555"/>
                                <GradientStop Color="#F1F1F1" Offset="0.03"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </DockPanel>

            </StackPanel>
        </Grid>
        
    </Grid>
</Window>
