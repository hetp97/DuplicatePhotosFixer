<Window x:Class="DuplicatePhotosFixer.Views.frmSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
         xmlns:uc="clr-namespace:DuplicatePhotosFixer.UserControls"
        xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
        mc:Ignorable="d"
        AllowsTransparency="True"
        Title="frmSettings" Height="494" Width="666" WindowStyle="None"
        Background="{DynamicResource bgrclr_solidgray}" Visibility="Visible" x:Name="settingsWindow" WindowStartupLocation="CenterScreen" ShowInTaskbar="False" BorderBrush ="Transparent" BorderThickness="0" SnapsToDevicePixels="True">
    <Window.Resources>
       
            <Style TargetType="Button" x:Name="btn_close">
                <Setter Property="Background" Value="#888888"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="Transparent"/>
                    </Trigger>

                </Style.Triggers>
            </Style>
       
    </Window.Resources>
    <Grid Margin="3 0 3 3">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="57"/>

        </Grid.RowDefinitions>
        <DockPanel>
            <cust:ImageButton
                            x:Name="close_btn"
                            Width="10"
                            Height="10"
                            DockPanel.Dock="Right"
                            Margin="10 0 10 0"
                            Style="{DynamicResource imageButton}"
                            Image="{DynamicResource img_close_plain}"
                            HoverImage="{DynamicResource img_close_plain}"
                            SelectedImage="{DynamicResource img_close_plain}" Click="close_btn_Click"  />

            <Image x:Name="dpf_logo" Source="/Resources/dpf_updateofr_icon.png" DockPanel.Dock="Left" Margin="10 0" Stretch="None"/>
            <TextBlock x:Name="dpf_header" Text="Duplicate Photos Fixer Pro - " Foreground="#f9f9f9"
                       FontSize="15" FontWeight="Regular" 
                       VerticalAlignment="Center" />
            <TextBlock x:Name="dpf_header_info" Text="Settings" VerticalAlignment="Center" FontSize="15" FontWeight="Regular" Foreground="#919191" />
        </DockPanel>

        <Grid Grid.Row="1" Grid.RowSpan="2">
            <uc:ucSettings Loaded="ucSettings_Loaded_1"  />
            <!--<Grid.ColumnDefinitions>
                <ColumnDefinition Width="141"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="{DynamicResource bgrclr_grayish}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="57"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Background="{DynamicResource bgrclr_menuitemstackpanel}">
                    <TabControl
                       
                    Name="tab_main" 
                    TabStripPlacement="Left"
                    Margin="0,0,0,0"
                    Padding="0"        
                    Height="470"
          
                    BorderThickness="0" 
            Background="White"
           
                    >
            <TabItem Header="General"
                     Padding="3"
                     FontSize="12"
                    Width="145"
                      Height="40"
                     Background="#F5F5F5"
                     >
                <uc:ucGeneral/>

            </TabItem>
            <TabItem Header="File Formats"
                      Padding="3"
                     FontSize="12"
                      Width="145"
                     Height="40" Background="#F5F5F5">
                <uc:ucSettingsFileFormat/>
            </TabItem>

            <TabItem Header="Exclude Folder" 
                      Padding="3"
                     FontSize="12"
                      Width="145"
                      Height="40" Background="#F5F5F5">
                <uc:ucExcludeSettings/>
            </TabItem>
            <TabItem Header="Scan Criteria" 
                      Padding="3"
                     FontSize="12"
                      Width="145"
                      Height="40" Background="#F5F5F5">
                <uc:ucExtraSettings/>
            </TabItem>
            <TabItem Header="Move Duplicates" 
                      Padding="3"
                     FontSize="12"
                      Width="145"
                      Height="40"
                     Background="#F5F5F5">
                <uc:ucSettingsMove/>
            </TabItem>



        </TabControl>
                    
                </StackPanel>

              
            </Grid>

            <Grid Grid.Column="1">
                
            </Grid>-->

        </Grid>
        <Grid Grid.Row="2"  HorizontalAlignment="Left">
            
            <Button Grid.Row="2" x:Name="btnReset" 
                    Foreground="#A8A8A8"
                    FontWeight="Regular"
                    FontSize="13px"
                    BorderBrush="#989898"
              Height="33" Width="120" 
                    Margin="10 0" Background="Transparent"
                HorizontalAlignment="Left" Click="btnReset_Click">
                
            <DockPanel>
            <Image x:Name="reset" Source="{DynamicResource img_reset_icon}" Stretch="None" Margin="0 2 5 0"/>
                    <TextBlock Text = "Reset Settings" />
               </DockPanel>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="White" />
                        <Setter Property="TextBlock.TextAlignment" Value="Center" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bdr_main"  BorderThickness="1" BorderBrush="#4E4E4E" Background="Transparent">
                                        <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                          TextElement.FontSize="13"
                                                              Margin="3 0 3 0"
                                                              TextElement.Foreground="#FFFFFF">
                                        </ContentPresenter>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" TargetName="bdr_main" Value="#494949"></Setter>
                                            <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                            <Setter Property="Background" TargetName="bdr_main" Value="#494949"></Setter>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="true">
                                            <Setter Property="BorderBrush" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                            <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                            <Setter Property="Background" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                            <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
       
        <!--<Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
