<Window x:Class="DuplicatePhotosFixer.frmAfterClean"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:uc="clr-namespace:DuplicatePhotosFixer.UserControls"
        xmlns:local="clr-namespace:DuplicatePhotosFixer"
        mc:Ignorable="d"
        Title="frmAfterClean" Height="682" Width="1000" WindowStyle="None" AllowsTransparency="True" Background="{DynamicResource bgclr_soliddark}"   BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1 0 1 1">
    <Grid Margin="2 0 2 2">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="300"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="53"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <uc:ucAfterClean/>
        </Grid>
        <Grid Grid.Row="1">
            <uc:ucpromotionalADU/>
        </Grid>
        <Grid Grid.Row="2">
            <uc:ucfooterPromoADU/>
        </Grid>
    </Grid>
</Window>
