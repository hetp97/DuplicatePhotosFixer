<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucHomeFooter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="53" d:DesignWidth="1000">
    <Grid>
        <Border Grid.Row="1" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="0 1 0 0">
            <Grid Grid.Row="1" Height="51" Background="{DynamicResource bgrclr_solidgray}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="btnUpgradeNow" Height="35" Width="148" Content="Upgrade Now"  Style="{DynamicResource stl_btnUpgradeNow}" />

                <Button Grid.Column="1" x:Name="btnScanForDuplicates" Height="35" Width="235" Content="Scan for Duplicates" Style="{DynamicResource stl_btnScanForDuplicates}"
                    HorizontalAlignment="Center" IsEnabled="True" Click="btnScanForDuplicates_Click"  />


            </Grid>
        </Border>
    </Grid>
</UserControl>
