                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                            <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>-->
            </Button>
        </Grid>
    </Grid>
</Window>
