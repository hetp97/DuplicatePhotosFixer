<Window x:Class="DuplicatePhotosFixer.Views.frmSelectionAssistant"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
        xmlns:uc ="clr-namespace:DuplicatePhotosFixer.UserControls.Selection_Assistant" 
        mc:Ignorable="d"
        AllowsTransparency="True"
        Title="frmSelectionAssistant" Height="440" Width="698" WindowStyle="None" WindowStartupLocation="CenterScreen" ShowInTaskbar="False"   Background="{DynamicResource cl_bg_theme }">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="63"/>
        </Grid.RowDefinitions>
        <Border BorderBrush="{DynamicResource cl_br_frmselcAss}" BorderThickness="0 0 0 1">
            <DockPanel Grid.Row="0" Margin="0 5 20 0" >
                <cust:ImageButton
                            x:Name="btn_close"
                            Width="10"
                             Height="10"
                           DockPanel.Dock="Right"
                            Margin="10 0 5 0"
                            Style="{DynamicResource imageButton}"
                            Image="{DynamicResource img_close_plain}"
                            HoverImage="{DynamicResource img_close_plain}"
                            SelectedImage="{DynamicResource img_close_plain}" Click="btn_close_Click" />
                <Image x:Name="dpf_logo" Source="/Resources/dpf_updateofr_icon.png" DockPanel.Dock="Left" Margin="10 0" Stretch="None"/>
                <TextBlock x:Name="dpf_header" Text="Duplicate Photos Fixer Pro - " Foreground="{DynamicResource cl_fg_selcAssheading}"
                       FontSize="15" FontWeight="Regular" 
                       VerticalAlignment="Center" />
                <TextBlock x:Name="dpf_header_info" Text="Selection Assistant" VerticalAlignment="Center" FontSize="15" FontWeight="Regular" Foreground="#E9E9E9" />
                <!--<Button DockPanel.Dock="Right" Height="25" Width="30" Background="#444445"
                    BorderBrush="{DynamicResource clr_darkborder}" Style="{StaticResource stl_btnClose}"
                    Click="Button_Click">
                <Image Source="{DynamicResource img_close}" />
            </Button>-->

            </DockPanel>
        </Border>
        <Grid Grid.Row="1"  Margin="5 0 5 0">
            <TextBlock x:Name="lblInfoHeader" Text="Please Select the Auto Marking Priorities"  
                   HorizontalAlignment="Stretch" VerticalAlignment="Center" FontSize="15" Grid.Row="1" Foreground="#fff"  FontWeight="Regular" Margin="25,0,0,0"/>
        </Grid>
        <Grid Grid.Row="2" Margin="5 0 5 0" >
            <TabControl Grid.Row="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="{DynamicResource cl_bg_frmselcAss}"
                        BorderBrush="{DynamicResource cl_bg_frmselcAss}" Margin="20,0,20,0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="FontWeight" Value="Normal"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Height" Value="29"/>
                        <Setter Property="Background"
                                Value="{DynamicResource cl_bg_frmselcAss}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <StackPanel VerticalAlignment="Stretch">
                                        <Border Name="Border" BorderThickness="0,1,2,0" BorderBrush="#2A2A2A" VerticalAlignment="Stretch" Height="29" Margin="-1,0,0,0">
                                            <Border Name="TopBorder" BorderBrush="#0093EA" Margin="0,-2,-1,0">
                                                <ContentPresenter x:Name="ContentSite"
                                                                              VerticalAlignment="Center"
                                                                              HorizontalAlignment="Center"
                                                                              ContentSource="Header"
                                                                              Margin="5, 0, 5, 0" />
                                            </Border>
                                        </Border>
                                        <Border x:Name="BottomBorder" BorderBrush="{DynamicResource cl_br_stylfrmselcAss}" BorderThickness="0" Height="0" Margin="0,0,1,-1"></Border>
                                    </StackPanel>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Foreground" Value="#fff"/>
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter TargetName="Border" Property="BorderThickness" Value="0,0,2,0" />
                                            <Setter TargetName="Border"
                                                    Property="Background"
                                                    Value="{DynamicResource cl_bg_stylfrmselcAss}" />
                                            <Setter TargetName="TopBorder" Property="BorderThickness" Value="0,0,0,0" />
                                            <Setter TargetName="BottomBorder"
                                                    Property="BorderBrush"
                                                    Value="{DynamicResource cl_bg_stylfrmselcAss}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter Property="Foreground"
                                                    Value="{DynamicResource cl_fg_stylfrmselcAss}"/>
                                            <Setter TargetName="Border" Property="BorderThickness" Value="0,1,2,0" />
                                            <Setter TargetName="Border"
                                                    Property="Background"
                                                    Value="#2F2F2F" />
                                            <Setter Property="FontSize" Value="12"/>
                                            <Setter TargetName="TopBorder" Property="BorderThickness" Value="0" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Cursor" Value="Hand" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style x:Key="{x:Type TabControl}" TargetType="{x:Type TabControl}">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabControl">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border CornerRadius="3 3 0 0" Grid.Row="1">
                                            <Border BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter ContentSource="SelectedContent"/>
                                                </Border>
                                            </Border>
                                        </Border>
                                        <TabPanel Grid.Row="0" IsItemsHost="true"/>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style TargetType="{x:Type TabPanel}">
                        <Setter Property="HorizontalAlignment"
                                                    Value="Left" />
                    </Style>
                </TabControl.Resources>
                <TabItem x:Uid="0" x:Name="tbselectionPriority" Header="Selection Priorities"  Width="auto" >
                    <uc:ucSelectionPriority x:Name="viewSelectionPriority" />
                </TabItem>
                <TabItem x:Uid="1" x:Name="tbFileFormats" Header="File Formats"  Width="auto">
                    <uc:ucFileFormat x:Name="viewFileFormats"/>
                </TabItem>
                <TabItem x:Uid="2" x:Name="tbFolders" Header="Folders"  Width="auto">
                    <uc:ucFolders x:Name="viewFolders"/>
                </TabItem>
                <TabItem x:Uid="3" x:Name="tbProtectedFolders" Header="Protected Folders" Width="auto">
                    <uc:ucProtectedFolders x:Name="viewProtectedFolders"/>
                </TabItem>
            </TabControl>
        </Grid>
        <Grid Grid.Row="3"  Margin="5 0 5 5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" MinWidth="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <cust:ImageButton  x:Name="btnReset"                                        
                                       Image="{DynamicResource img_reset_icon}"
                                    HoverImage="{DynamicResource img_btnfolder}"
                                    SelectedImage="{DynamicResource img_btnfolder}"
                                       Foreground="{DynamicResource cl_fg_btnTrans}"
                                    FontWeight="Regular"
                                    FontSize="13px"
                                     Padding="5"
                                    BorderBrush="{DynamicResource cl_br_selcAss}"
                                     Height="32" Width="175" 
                                        Margin="10 0" Background="Transparent"
                                       BorderThickness="1"
                                HorizontalAlignment="Left"
                                  Style="{DynamicResource stl_ImgTextButton}"
                                  Content="Reset Selection Priority" 
                                       Click="btnAddFolder_Click">

            </cust:ImageButton>
            <!--<Button  x:Name="btnReset" 
                    Foreground="#A8A8A8"
                    FontWeight="Regular"
                    FontSize="13px"
                    BorderBrush="#4E4E4E"
              Height="32" Width="172" 
                    Margin="10 0" Background="Transparent"
                HorizontalAlignment="Left">

                <DockPanel>
                    <Image x:Name="reset" Source="{DynamicResource img_reset_icon}" Stretch="None" Margin="0 2 5 0"/>
                    <TextBlock Text = "Reset Selection Priority" />
                </DockPanel>
           
            <Button.Style>
