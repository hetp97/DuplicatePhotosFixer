    public partial class frmSettings : Window
    {
        System.Windows.Forms.Timer _tmrSaveSettings = null;
        public frmSettings()
        {
            if (App.oMainReference.objGeneral == null)
                App.oMainReference.objGeneral = new vmGeneralSettings();
            this.DataContext = App.oMainReference.objGeneral;
           

            InitializeComponent();
            Init();
          
        }

        void Init()
        {
            _tmrSaveSettings = new System.Windows.Forms.Timer();
            _tmrSaveSettings.Interval = 1500;
           // _tmrSaveSettings.Tick += _tmrSaveSettings_Tick;
            //UpdateUIData();
        }

       
       
      public void UpdateUIData()
        {
            try
            {
               // App.oMainReference.objGeneral.SetUIPropertiesValue();
                App.oMainReference.objFileFormat.SetUIPropertiesValue();
                App.oMainReference.objExcluded.LoadDefaultValue();
                //App.oMainReference.objExtra.SetUIPropertiesValue();
                //App.oMainReference.objMove.SetUIPropertiesValue();
                App.oMainReference.objNag.SetUIPropertiesValue();
                return;
            }
            catch (Exception)
            {

               
            }
        }
        public cClientEnum.eSettingsTab SettingsTabSelect = cClientEnum.eSettingsTab.General;
        public bool ResetDefaultSettings()
        {
            bool bReset = false;
            try
            {
                ucGeneral.LoadDefaults();
                ucExtraSettings.LoadDefaults();
                ucMoveSettings.LoadDefaults();
                App.oMainReference.objFileFormat.LoadFileFormatSettings(true);             
                App.oMainReference.objNag.LoadNagThemeSettings(true);

                bReset = true;
            }
            catch(Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("frmSettings :: ResetDefaultSettings :", ex);
                bReset = false;
            }
          

            return bReset;

        }
        private void btnReset_Click_1(object sender, RoutedEventArgs e)
        {
            try
            {
                if (ResetDefaultSettings())
                {
                    UpdateUIData();
                    App.oMainReference.showMessage(cResourceManager.LoadString("IDS_DEFAULT_SETTINGS_APPLICATED"), "");
                }               
                   // LoadSavedSettings();
                 
            }
            catch (Exception ex)
            {

                MessageBox.Show(ex.Message);
            }

        }

        private void FadeOutAnimation_Completed(object sender, EventArgs e)
        {
            // Reset the label's opacity once the fade out animation is complete
            lbl_settingsApplied.Opacity = 1.0;
            lbl_settingsApplied.Visibility = Visibility.Hidden;
        }
        public void ShowSettingsApplied()
        {
            DoubleAnimation fadeOutAnimation = new DoubleAnimation();
            fadeOutAnimation.From = 1.0; // Starting opacity (fully visible)
            fadeOutAnimation.To = 0.0;   // Ending opacity (completely transparent)
            fadeOutAnimation.Duration = TimeSpan.FromSeconds(1); // Duration of the animation

            // Set up an event handler for when the animation completes
            fadeOutAnimation.Completed += FadeOutAnimation_Completed;

            // Apply the animation to the Opacity property of the label
            lbl_settingsApplied.BeginAnimation(Label.OpacityProperty, fadeOutAnimation);
            lbl_settingsApplied.Visibility = Visibility.Visible;


        }




        private void close_btn_Click(object sender, RoutedEventArgs e)
        {
            try
            {
                this.Visibility = Visibility.Hidden;
                //this.Close();
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("btnClose::", ex);
            }

        }

       
    }
}
