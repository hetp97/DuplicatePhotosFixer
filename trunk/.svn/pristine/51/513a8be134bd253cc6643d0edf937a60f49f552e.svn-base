<Window x:Class="DuplicatePhotosFixer.Nags.nagUpdateOffer_New"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Nags"
        mc:Ignorable="d"
        Title="nagUpdateOffer_New" Height="596" Width="929" WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="52"/>
            <RowDefinition Height="Auto" MinHeight="98"/>
            <RowDefinition/>
            <RowDefinition Height="Auto" MinHeight="111"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#F2F2F2">
            <DockPanel Margin="10 0 10 0">
                <Button x:Name="pb_Close" Width="15" Height="14"
                        Background="Transparent" BorderBrush="Transparent"
                        DockPanel.Dock="Right">
                    <Image  Source="/Resources/closevpn.png"/>
                </Button>
                <Image x:Name="pb_Icon" Width="36" Height="33" Source="{DynamicResource img_dpf_updatelogo}"/>
                <TextBlock x:Name="label_heading"
                           Foreground="#333333"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center">
                    Advanced Driver updater has been updated sucessfully.
                </TextBlock>
            </DockPanel>
        </Grid>
        <Grid Grid.Row="1">
            <StackPanel Margin="15 5 15 5 ">
                <TextBlock x:Name="label1" Foreground="#313131"
                           Text="Recommended Product:"
                           FontSize="14"/>
                <TextBlock x:Name="label2"
                           Foreground="#313131" FontSize="36"
                           Padding="0 15 0 0">
                    Systweak VPN
                </TextBlock>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <StackPanel Margin="15 15 0 0 ">
                <TextBlock x:Name="label3" FontSize="14" Foreground="#313131"
                          MinHeight="98"  Margin="20 0 0 0">
                    Boost your online privacy and security with Systweak VPN. This<LineBreak/>
                    premium VPN with blazing fast speed gives you peace of mind each <LineBreak/> time you access personal accounts on public Wi-Fi.
                </TextBlock>

                <Button x:Name="btn_Install"
                        Width="300"
                        Height="48"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Margin="20 20 0 0"
                        Style="{DynamicResource stl_btnScanForDuplicates}">
                    INSTALL SYSTWEAK VPN
                </Button>
                <DockPanel Margin="20 20 0 0">
                    <TextBlock x:Name="lblFooter1"
                               Foreground="DimGray"
                               Padding="0 0 20 0">
                        By installing you agree to 
                    </TextBlock>
                    <TextBlock x:Name="lblFooter2">
                        <Hyperlink x:Name="lblEula"> EULA </Hyperlink> and 
                        <Hyperlink x:Name="lblPP"> Privacy Policy </Hyperlink>
                    </TextBlock>
                </DockPanel>
            </StackPanel>
            <Grid Grid.Column="1">
                <Image x:Name="pb_Image" Width="303" Height="256"
                       Source="{DynamicResource img_vpn_graphics}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Top"/>
            </Grid>
        </Grid>
        <Grid Grid.Row="3">
            <Border BorderBrush="#EAEAEA"></Border>
            <DockPanel VerticalAlignment="Center" Margin="20 0 0 0">
                
                <Image x:Name="pbInfo" Width="39" Height="36" Source="{DynamicResource img_limited_offer_clock}"/>
                <StackPanel>
                    <TextBlock x:Name="txt1" FontWeight="SemiBold"
                               FontSize="13" Padding="5 0 0 0"  Foreground="#313131">
                        Limited Time Offer
                    </TextBlock>
                    <DockPanel>
                        <TextBlock x:Name="txt2" FontSize="13" Padding="5 0 0 0"
                               Foreground="#313131">
                        Get 3 months of our most populer VPN for FREE &amp; Save 40% Today!
                        </TextBlock>
                        <TextBlock Width="50"/>
                        <TextBlock x:Name="txt3">
                            <Hyperlink>Get it Now > </Hyperlink>
                        </TextBlock>
                    </DockPanel>
                    
                </StackPanel>
              
            </DockPanel>
            
        </Grid>
    </Grid>
</Window>
