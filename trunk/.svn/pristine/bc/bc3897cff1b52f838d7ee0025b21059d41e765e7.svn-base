using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Data;
using System.Windows.Documents;
using System.Windows.Input;
using System.Windows.Media;
using System.Windows.Media.Imaging;
using System.Windows.Navigation;
using System.Windows.Shapes;
using DuplicatePhotoFixer;

namespace DuplicatePhotosFixer.UserControls
{
    /// <summary>
    /// Interaction logic for ucClearCache.xaml
    /// </summary>
    public partial class ucClearCache : Window
    {
        public ucClearCache()
        {
            InitializeComponent();
            LoadStrings();
        }
        public void LoadStrings()
        {
            dpf_heading.Text = cGlobalSettings.GetProductName();
            lblinfo.Text = cResourceManager.LoadString("IDS_CLEAR_SCAN_RESULT_CONFIRMATION");
            btnYes.Content = cResourceManager.LoadString("IDS_YES");
            btnNo.Content = cResourceManager.LoadString("IDS_NO");

        }

      
        private void close_btn_click(object sender, RoutedEventArgs e)
        {
            try
            {

                this.Visibility = Visibility.Hidden;
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("btnClose::", ex);
            }
        }
    }
}
