                <StackPanel DockPanel.Dock="Right">
                    <DockPanel>
                        <Button x:Name="btnClose" DockPanel.Dock="Right" Click="btnClose_Click" BorderBrush="{DynamicResource clr_darkborder}"
                                Style="{DynamicResource stl_btnClose}">
                            
                        </Button>
                        
                        <Button x:Name="btnMaximize" DockPanel.Dock="Right" Click="btnMaximize_Click" BorderBrush="{DynamicResource clr_darkborder}"
                                Style="{DynamicResource stl_btnMaximize}">
                            
                        </Button>
                        
                        <Button x:Name="btnMinimize" DockPanel.Dock="Right" BorderBrush="{DynamicResource clr_darkborder}"
                                Style="{DynamicResource stl_btnMinimize}" Click="btnMinimize_Click">
                            
                        </Button>

                        <Button x:Name="btnPopupHelp" Width="65" Height="19" DockPanel.Dock="Right" BorderThickness="0" 
                                Background="{DynamicResource bgclr_lightdark}" Click="btnPopupHelp_Click"
                                Style="{DynamicResource stl_btnHelpPopup}"
                                Cursor="Hand">
                            <DockPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image Source="{DynamicResource img_help}" Width="12" Height="12" Margin="0 0" VerticalAlignment="Center"/>
                                <TextBlock Text="help" Foreground="{DynamicResource frgclr_white}" Padding="0" Margin="2 0" VerticalAlignment="Center"/>
                                <Image Source="{DynamicResource img_dropdownarrow}" Width="10" Height="10" VerticalAlignment="Center" />
                            </DockPanel>
                        </Button>
                            <Popup x:Name="settingspopup" Width="180" IsOpen="False" Placement="Mouse" StaysOpen="False">
