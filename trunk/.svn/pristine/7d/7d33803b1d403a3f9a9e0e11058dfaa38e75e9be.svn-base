                                <Button x:Name="btnHelp" Height="25">
                                    <DockPanel >
                                        <Image Source="{DynamicResource img_helpicon}" Margin="2" />
                                        <Border BorderBrush="{DynamicResource clr_grayborder}" BorderThickness="0 0 0 2">
                                            <TextBlock Text="Help" Padding="0" Width="150"  VerticalAlignment="Center" Margin="5 0 0 0"/>
                                        </Border>
                                    </DockPanel>
                                </Button>

                                <Button Height="25">
                                    <DockPanel>
