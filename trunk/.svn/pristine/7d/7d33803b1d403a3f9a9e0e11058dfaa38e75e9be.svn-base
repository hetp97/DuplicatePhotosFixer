                        <cust:ImageButton x:Name="btnAction" Width="25" Height="19" DockPanel.Dock="Right" Background="{DynamicResource bgclr_lightdark}" 
                                          Image="{DynamicResource img_actioncenter}"
                                          SelectedImage="{DynamicResource img_actioncenter}"
                                          HoverImage="{DynamicResource img_actioncenter}"
