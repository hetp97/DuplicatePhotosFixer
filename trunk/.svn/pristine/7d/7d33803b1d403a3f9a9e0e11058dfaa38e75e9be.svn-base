                    <TextBlock/>
                </StackPanel>
                <TextBlock Text="Duplicate Photo Fixer Pro" Foreground="{DynamicResource frgclr_whitish}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" DockPanel.Dock="Right"/>
