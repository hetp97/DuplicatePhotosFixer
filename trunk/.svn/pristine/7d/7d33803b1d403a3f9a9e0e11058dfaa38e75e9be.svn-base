<Window x:Class="DuplicatePhotosFixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer"
        xmlns:UserControl="clr-namespace:DuplicatePhotosFixer.UserControls"
        xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
        mc:Ignorable="d"
        Title="Duplicate Photos Fixer Pro" Height="720" Width="1008"
        WindowStyle="None" WindowStartupLocation="CenterScreen" 
        Background="{DynamicResource bgclr_dark}" MouseLeftButtonDown="Window_MouseLeftButtonDown" ResizeMode="NoResize"
        BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1 0 1 1" Loaded="Window_Loaded" >



    <Grid Background="{DynamicResource bgclr_lightdark}" Margin="2 0 2 2">
        
        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            
            <UserControl:ucMainBoder />
        </Grid>

        <Border Grid.Row="1" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1 0 1 1" Margin="2 0 2 2" >
            <Grid >
                <UserControl:ucHomeMain x:Name="objHome" Visibility="Visible"/>
                <UserControl:ucResultView x:Name="objResult" Visibility="Collapsed"/>
                <UserControl:ucActionCentre x:Name="objActionCentre" Visibility="Collapsed"/>
                <UserControl:ucNagSettings x:Name="objucNagSetting" Visibility="Collapsed"/>
            </Grid>
        </Border>

        <Image Source="{DynamicResource img_update_dpf}" Stretch="Uniform" Margin="10 5 0 10" Width="80" Height="80" Grid.RowSpan="2" VerticalAlignment="Top" HorizontalAlignment="Left"/>


        <!--region Unused Code-->


        <!--<Border Grid.Row="0" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="0 0 0 1" >
            
            <DockPanel Margin="5 0">
                -->
        <!--<Image Width="67" Height="67" />-->
