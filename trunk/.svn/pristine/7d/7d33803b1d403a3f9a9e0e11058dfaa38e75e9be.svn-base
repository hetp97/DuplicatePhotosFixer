                                        </Border>
                                    </DockPanel>
                                </Button>

                                <Button Height="25">
                                    <DockPanel>
                                        <Image Source="{DynamicResource img_cache}" Margin="2"/>
                                        <Border BorderBrush="{DynamicResource clr_grayborder}" BorderThickness="0 0 0 2">
                                            <TextBlock Text="Clear cache" Padding="0" Width="150"  VerticalAlignment="Center" Margin="5 0 0 0"/>
                                        </Border>
                                    </DockPanel>
                                </Button>

                                <Button Height="25">
                                    <DockPanel>
                                        <Image Source="{DynamicResource img_registration}" Margin="2"/>
                                        <Border BorderBrush="{DynamicResource clr_grayborder}" BorderThickness="0 0 0 2">
                                            <TextBlock Text="Enter Registration key" Padding="0" Width="150"  VerticalAlignment="Center" Margin="5 0 0 0"/>
                                        </Border>
                                    </DockPanel>
                                </Button>

                                <Button Height="25">
                                    <DockPanel>
                                        <Image Source="{DynamicResource img_updates}" Margin="2"/>
                                        <Border BorderBrush="{DynamicResource clr_grayborder}" BorderThickness="0 0 0 2">
                                            <TextBlock Text="Check for updates" Padding="0" Width="150"  VerticalAlignment="Center" Margin="5 0 0 0"/>
                                        </Border>
                                    </DockPanel>
                                </Button>

                                <Button Height="25">
                                    <DockPanel>
                                        <Image Source="{DynamicResource img_feedback}" Margin="2"/>
                                        <Border BorderBrush="{DynamicResource clr_grayborder}" BorderThickness="0 0 0 2">
                                            <TextBlock Text="Feedback" Padding="0" Width="150"  VerticalAlignment="Center" Margin="5 0 0 0"/>
                                        </Border>
                                    </DockPanel>
                                </Button>

                                <Button Height="25">
                                    <DockPanel>
                                        <Image Source="{DynamicResource img_about_icon}" Margin="2"/>
                                        <Border BorderBrush="{DynamicResource clr_grayborder}" BorderThickness="0 0 0 2">
                                            <TextBlock Text="About us" Padding="0" Width="150"  VerticalAlignment="Center" Margin="5 0 0 0"/>
                                        </Border>
                                    </DockPanel>
                                </Button>
                            </StackPanel>
                        </Popup>
                        

                        <cust:ImageButton x:Name="btnSettings" Width="70" Height="19" DockPanel.Dock="Right" BorderThickness="0" 
                                Image="{DynamicResource img_settings}"
                                Content="Settings"
                                Background="{DynamicResource bgclr_lightdark}" Click="btnSettings_Click"
                                Style="{DynamicResource stl_btnSettings}" Cursor="Hand" />
