    <Style x:Key="StyleMainBorderHelpButton"
           TargetType="{x:Type cust:ImageButton}">
        
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Cursor"
                    Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Border x:Name="Border"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top">
                                <!--<Image   Width="8"
                                          Height="5"
                                           x:Name="lnkImageHelp"
                                           SnapsToDevicePixels="False"
                                           Source="{TemplateBinding Image}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />-->
                                <TextBlock  Padding="5,0,3,0"
                                            x:Name="lnkLblHelp"
                                           FontSize="13"
                                            Margin="0,0,0,0"
                                            VerticalAlignment="Top"
                                          Foreground="#ECECEC"
                                            Text="{TemplateBinding Content}"
                                            TextWrapping="WrapWithOverflow"/>
                                <Image   Width="8"
                                          Height="5"
                                         Margin="0,3,2,0"
                                           x:Name="lnkddImage"
                                           SnapsToDevicePixels="False"
                                           Source="{TemplateBinding Image}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                               
                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

        <Style x:Key="StyleMainBorderButtons"
        TargetType="{x:Type cust:ImageButton}">
        <!--<Setter Property="Background"
                Value="Transparent"/>-->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Image x:Name="btn_close"
                                Width="28"
                                Height="26"
                          
                          Source="{TemplateBinding Image}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"  
                           Stretch="Uniform"
                              />


                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>

    <Style x:Key="StyleComboboxTextButton"
        TargetType="{x:Type cust:ImageButton}">
        <Setter Property="Background"
                    Value="White" />
        
        <Setter Property="Foreground" Value="{DynamicResource clr_darkborder}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Border x:Name="Border"
                                Width="200"
                                Height="28"
                          
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                        <Grid HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch">
                                <Image 
                                       Width="15"
                                       Height="15"
                                        Margin="10,0,0,0"
                                           x:Name="imgOption"
                                           SnapsToDevicePixels="False"
                                           Source="{TemplateBinding Image}"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock  Padding="5,0,0,0"
                                            x:Name="txtName"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                           
                                            Text="{TemplateBinding Content}"
                                            TextWrapping="WrapWithOverflow" />
                            </StackPanel>
                        </Grid>
                    </Border>
                 
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style x:Key="StyleImageTextButton"
               TargetType="{x:Type cust:ImageButton}">
        <Setter Property="Background"
                    Value="{DynamicResource bgrclr_whitish}" />
        <Setter Property="BorderBrush" Value="{DynamicResource clr_darkborder}" />
        <Setter Property="Foreground" Value="{DynamicResource clr_darkborder}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Border x:Name="Border"
                                Width="120"
                                Height="33"                          
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                        <Grid HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch">
                                <Image 
                                       Width="15"
                                       Height="15"
                                        Margin="5,0,0,0"
                                           x:Name="imgOption"
                                           SnapsToDevicePixels="False"
                                           Source="{TemplateBinding Image}"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock  Padding="5,0,0,0"
                                            x:Name="txtName"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            FontSize="13.5"
                                            FontWeight="Bold"
                                            Text="{TemplateBinding Content}"
                                            TextWrapping="WrapWithOverflow" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                     Value="true">
                            <Setter TargetName="Border"
                                        Property="BorderThickness"
                                        Value="0,0,0,0" />
                            <Setter TargetName="Border"
                                        Property="BorderBrush"
                                        Value="{DynamicResource ucPdfViewerOptionsHoverForeColor}" />
                            <Setter TargetName="txtName"
                                        Property="Foreground"
                                        Value="{DynamicResource ucPdfViewerOptionsHoverForeColor}" />
                            <Setter TargetName="imgOption"
                                        Property="Image.Source"
                                        Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=HoverImage}" />

                        </Trigger>
                        <Trigger Property="IsPressed"
                                     Value="true">
                            <Setter TargetName="Border"
                                        Property="BorderThickness"
                                        Value="0,0,0,0" />
                            <Setter TargetName="Border"
                                        Property="BorderBrush"
                                        Value="{DynamicResource ucPdfViewerOptionsHoverForeColor}" />
                            <Setter TargetName="txtName"
                                        Property="Foreground"
                                        Value="{DynamicResource ucPdfViewerOptionsHoverForeColor}" />
                            <Setter TargetName="imgOption"
                                        Property="Image.Source"
                                        Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=HoverImage}" />
                        </Trigger>
                        <Trigger Property="IsFocused"
                                     Value="true">
                            <Setter TargetName="Border"
                                        Property="BorderThickness"
                                        Value="0,0,0,0" />
                            <Setter TargetName="Border"
                                        Property="BorderBrush"
                                        Value="{DynamicResource ucPdfViewerOptionsHoverForeColor}" />
                            <Setter TargetName="txtName"
                                        Property="Foreground"
                                        Value="{DynamicResource ucPdfViewerOptionsHoverForeColor}" />
                            <Setter TargetName="imgOption"
                                        Property="Image.Source"
                                        Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=SelectedImage}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    

    <Style x:Key="stl_btnAddPhotos" TargetType="Button">

        <Setter Property="Background" Value="{DynamicResource bgrclr_whitish}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource clr_darkborder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Height" Value="33"/>
        <Setter Property="Width" Value="120"/>
        
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                        BorderThickness="{TemplateBinding BorderThickness}" Height="{TemplateBinding Height}"
                                        Width="{TemplateBinding Width}">
                        <ContentControl Content="{TemplateBinding Content}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource frgclr_white}">
                                
                            </Setter>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
                
            </Setter.Value>
        </Setter>
    </Style>

    

    <Style x:Key="stl_MoveSettingsRadiobtn" TargetType="RadioButton">
        <Setter Property="Foreground" Value="#565656"/>
        
        <!--<Setter Property="Width" Value="244"/>
        <Setter Property="Height" Value="27"/>-->
        <Setter Property="IsChecked" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <RadioButton Foreground="{TemplateBinding Foreground}"
                                
                                 Padding="{TemplateBinding Padding}"
                                 IsChecked="{TemplateBinding IsChecked}">
                        <ContentControl Content="{TemplateBinding Content}"/>
                    </RadioButton>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="stl_btndeleteCurrentRow" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                        Height="{TemplateBinding Height}" Width="{TemplateBinding Width}"
                            Margin="{TemplateBinding Margin}" Padding="{TemplateBinding Padding}">
                        <ContentControl Content="{TemplateBinding Content}" HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers >
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="{DynamicResource img_deleteselectedfilefolder}" AlignmentX="Center"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>

            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="stl_btnEmptySelectedFileList" TargetType="Button">

        <Setter Property="Background" Value="{DynamicResource bgclr_soliddark}"/>

        <Setter Property="Height" Value="15"/>
        <Setter Property="Width" Value="15"/>
        <Setter Property="Padding" Value="0 0"/>
        <Setter Property="Margin" Value="0 0"/>
        <!--<Setter Property="BorderThickness" Value="0"/>-->

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                        Height="{TemplateBinding Height}" Width="{TemplateBinding Width}"
                            Margin="{TemplateBinding Margin}" Padding="{TemplateBinding Padding}">
                        <ContentControl Content="{TemplateBinding Content}" HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers >
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource bgclr_soliddark}">
                                
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>

            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="stl_btnRefresh" TargetType="cust:ImageButton">
        <Setter Property="Background" Value="#888888"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Width" Value="125"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Border x:Name="Border"
                                Width="125"
                                Height="32"
                              HorizontalAlignment="Left"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                        <Grid HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch">
                                <Image 
                                       Width="15"
                                       Height="15"
                                        Margin="10,0,0,0"
                                           x:Name="imgOption"
                                           SnapsToDevicePixels="False"
                                           Source="{TemplateBinding Image}"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock  Padding="5,0,0,0"
                                            x:Name="txtName"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                           
                                            Text="{TemplateBinding Content}"
                                            TextWrapping="WrapWithOverflow" />
                            </StackPanel>
                        </Grid>
                    </Border>
                            
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="stl_btnScanDeleteMarked" TargetType="Button">
        <Setter Property="BorderBrush" Value="#000000"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="#317AE6"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Margin" Value="0 0"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                        <ContentControl Content="{TemplateBinding Content}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="{TemplateBinding FontWeight}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource frgclr_gray}"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>

            <Trigger Property="IsMouseOver"
                     Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#87CEFA" Offset="0"/>
                            <GradientStop Color="#317AE6" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>

            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SliderThumbStyle" TargetType="Thumb">
        <Setter Property="SnapsToDevicePixels" Value="true"/>
        <Setter Property="OverridesDefaultStyle" Value="false"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Width" Value="18"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Ellipse  Stroke="Black"
                          StrokeThickness="1"
                          Name="Ellipse" 
                          Fill="OrangeRed" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Ellipse" Property="Fill" Value="Orange"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter TargetName="Ellipse" Property="Fill" Value="Gray"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="stylGreenBtn" TargetType="Button">
        <Setter Property="Background" Value="#14A402"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                        <ContentControl Content="{TemplateBinding Content}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#14A402"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
                
            </Setter.Value>
        </Setter>
        
    </Style>
    <Style x:Key="stl_btnBack" TargetType="Button">
        <Setter Property="BorderBrush" Value="#000000"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource bgclr_lightdark}"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontSize" Value="13"/>
        <!--<Setter Property="FontWeight" Value="Medium"/>-->
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Margin" Value="0 0"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                        <ContentControl Content="{TemplateBinding Content}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="{TemplateBinding FontWeight}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource frgclr_gray}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        
        <Style.Triggers>

            <Trigger Property="IsMouseOver"
                     Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#89898A" Offset="0"/>
                            <GradientStop Color="#E8F0F0" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>


            </Trigger>


        </Style.Triggers>
    </Style>
    <Style x:Key="stl_ViewType_cmbBox" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="#343434" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="Transparent"/>
            </Trigger>

            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Border}}}"
                                                                 Value="True">
                <Setter Property="Background" Value="#4D4D4D" />
            </DataTrigger>
             <!--<Trigger Property="IsPressed" Value="True">
             <Setter Property="Background" Value="#4D4D4D"/>
                                        </Trigger>--> 
        </Style.Triggers>
    </Style>

    <ControlTemplate x:Key="ComboBoxToggleButton_ViewType" 
                      TargetType="{x:Type ToggleButton}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition MinWidth="20" 
                                   MaxWidth="40" />
            </Grid.ColumnDefinitions>
            <Border x:Name="Border" 
                     Grid.ColumnSpan="2" 
                     CornerRadius="3" 
                     Background="#272727" 
                     BorderBrush="#272727" 
                     BorderThickness="0" />
            <Border Grid.Column="0" 
                     CornerRadius="3" 
                     Margin="1" 
                     Background="#272727" 
                     BorderThickness="0,0,0,0" />
            <Border Grid.Column="1" CornerRadius="2" HorizontalAlignment="Right" Margin="0 0 12 15 ">
                <Image Width="auto" 
                        Height="auto" 
                        Stretch="None" 
                         
                        Margin="1 0 0 0"                    
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </ControlTemplate>

    <DataTemplate x:Key="cmbTemplateViewsType">
        <StackPanel VerticalAlignment="Center" Margin="0 0 0 0" HorizontalAlignment="Center" Orientation="Horizontal">
            <Image Stretch="None" 
                        Width="16" 
                        HorizontalAlignment="Center" 
                        Source="{Binding ViewImage}" />
            <TextBlock Text="{Binding ViewName}" 
                            ToolTip="{Binding ViewName}" 
                            Margin="5 5 0 5" 
                            TextAlignment="Center" 
                            TextWrapping="Wrap" 
                            TextTrimming="WordEllipsis" 
                        VerticalAlignment="Bottom"
                       
                        FontSize="{Binding cboFontSize}" 
                        Foreground="#FFFFFF" />
            <!-- <Image Width="auto" 
                        Height="auto" 
                        Stretch="None" 
                        x:Name="imgTick" 
                        Source="/Resources/tick.png" 
                        Margin="3 0 0 0" 
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Center" /> -->
        </StackPanel>
        
        <!-- <DataTemplate.Triggers> 
                 <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type ComboBoxItem}},Path=IsSelected}" Value="True"> 
                     <Setter TargetName="imgTick" Property="Visibility" Value="Visible"/> 
                 </DataTrigger> 
                 <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type ComboBoxItem}},Path=IsSelected}" Value="False"> 
                     <Setter TargetName="imgTick" Property="Visibility" Value="Collapsed"/> 
                 </DataTrigger> 
             </DataTemplate.Triggers> -->
    </DataTemplate>
    
    <Style x:Key="CustomComboViewsType"
           TargetType="{x:Type ComboBox}">
        <Setter Property="SnapsToDevicePixels"
                Value="true" />
        <Setter Property="OverridesDefaultStyle"
                Value="true" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility"
                Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility"
                Value="Auto" />
        <Setter Property="ScrollViewer.CanContentScroll"
                Value="true" />
        <Setter Property="MinWidth"
                Value="20" />
        <Setter Property="MinHeight"
                Value="20" />
        <Setter Property="Foreground"
                Value="White" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid>
                        <ToggleButton Name="ToggleButton"
                                      Template="{StaticResource ComboBoxToggleButton_ViewType}"
                                      Grid.Column="2"
                                      Focusable="false"
                                      IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press" />

                        <ContentPresenter Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          Margin="3,3,3,3"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left" />

                        <TextBox x:Name="PART_EditableTextBox"
                                 Style="{x:Null}"
                                
                                 HorizontalAlignment="Left"
                                 BorderBrush="{TemplateBinding BorderBrush}"
                                 VerticalAlignment="Center"
                                 Focusable="True"
                                 Background="#272727"
                                 Foreground="Green"
                                 Visibility="Hidden"
                                 IsReadOnly="{TemplateBinding IsReadOnly}" />

                        <Popup Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Grid Name="DropDown"
                                  SnapsToDevicePixels="True"
                                  MinWidth="{TemplateBinding ActualWidth}"
                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">

                                <Border x:Name="DropDownBorder"
                                        Background="#2C2C2C"
                                        BorderThickness="1"
                                        BorderBrush="#4C4C4C" />

                                <ScrollViewer Margin="4,6,4,6"
                                              SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasItems"
                                 Value="false">
                            <Setter TargetName="DropDownBorder"
                                    Property="Height"
                                    Value="40" />
                        </Trigger>
                        <Trigger Property="IsEnabled"
                                 Value="false">
                            <Setter Property="Foreground"
                                    Value="#888888" />
                        </Trigger>
                        <Trigger Property="IsGrouping"
                                 Value="true">
                            <Setter Property="ScrollViewer.CanContentScroll"
                                    Value="false" />
                        </Trigger>
                        <Trigger SourceName="Popup"
                                 Property="Popup.AllowsTransparency"
                                 Value="true">
                            <Setter TargetName="DropDownBorder"
                                    Property="CornerRadius"
                                    Value="0" />
                            <Setter TargetName="DropDownBorder"
                                    Property="Margin"
                                    Value="0,2,0,0" />

                        </Trigger>
                        <Trigger Property="IsEditable"
                                 Value="true">
                            <Setter Property="IsTabStop"
                                    Value="false" />
                            <Setter TargetName="PART_EditableTextBox"
                                    Property="Visibility"
                                    Value="Visible" />
                            <Setter TargetName="ContentSite"
                                    Property="Visibility"
                                    Value="Hidden" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
        </Style.Triggers>
    </Style>
    <Style x:Key="CustomComboScanMode"
           TargetType="{x:Type ComboBox}">
        <Setter Property="SnapsToDevicePixels"
                Value="true" />
        <Setter Property="OverridesDefaultStyle"
                Value="true" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility"
                Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility"
                Value="Auto" />
        <Setter Property="ScrollViewer.CanContentScroll"
                Value="true" />
        <Setter Property="MinWidth"
                Value="20" />
        <Setter Property="MinHeight"
                Value="20" />
        <Setter Property="Foreground"
                Value="White" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid>
                        <ToggleButton Name="ToggleButton"
                                      Template="{StaticResource ComboBoxToggleButton}"
                                      Grid.Column="2"
                                      Focusable="false"
                                      IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press" />

                        <ContentPresenter Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          Margin="3,3,23,3"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left" />

                        <TextBox x:Name="PART_EditableTextBox"
                                 Style="{x:Null}"
                                 Template="{StaticResource ComboBoxTextBox}"
                                 HorizontalAlignment="Left"
                                 BorderBrush="{TemplateBinding BorderBrush}"
                                 VerticalAlignment="Center"
                                 Focusable="True"
                                 Background="#272727"
                                 Foreground="Green"
                                 Visibility="Hidden"
                                 IsReadOnly="{TemplateBinding IsReadOnly}" />

                        <Popup Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Grid Name="DropDown"
                                  SnapsToDevicePixels="True"
                                  MinWidth="{TemplateBinding ActualWidth}"
                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">

                                <Border x:Name="DropDownBorder"
                                        Background="#2C2C2C"
                                        BorderThickness="1"
                                        BorderBrush="#4C4C4C" />

                                <ScrollViewer Margin="4,6,4,6"
                                              SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasItems"
                                 Value="false">
                            <Setter TargetName="DropDownBorder"
                                    Property="Height"
                                    Value="40" />
                        </Trigger>
                        <Trigger Property="IsEnabled"
                                 Value="false">
                            <Setter Property="Foreground"
                                    Value="#888888" />
                        </Trigger>
                        <Trigger Property="IsGrouping"
                                 Value="true">
                            <Setter Property="ScrollViewer.CanContentScroll"
                                    Value="false" />
                        </Trigger>
                        <Trigger SourceName="Popup"
                                 Property="Popup.AllowsTransparency"
                                 Value="true">
                            <Setter TargetName="DropDownBorder"
                                    Property="CornerRadius"
                                    Value="0" />
                            <Setter TargetName="DropDownBorder"
                                    Property="Margin"
                                    Value="0,2,0,0" />

                        </Trigger>
                        <Trigger Property="IsEditable"
                                 Value="true">
                            <Setter Property="IsTabStop"
                                    Value="false" />
                            <Setter TargetName="PART_EditableTextBox"
                                    Property="Visibility"
                                    Value="Visible" />
                            <Setter TargetName="ContentSite"
                                    Property="Visibility"
                                    Value="Hidden" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
        </Style.Triggers>
    </Style>



    <Style x:Key="imageButton" 
                TargetType="{x:Type cust:ImageButton}">
        <Setter Property="Background" 
                     Value="Transparent" />
        <Setter Property="Cursor" 
                     Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Border x:Name="Border" 
                                 Width="{TemplateBinding Width}" 
                                 Height="{TemplateBinding Height}" 
                                 HorizontalAlignment="Center" 
                                 VerticalAlignment="Stretch" 
                                 Background="{TemplateBinding Background}" 
                                 BorderBrush="{TemplateBinding BorderBrush}" 
                                 BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid HorizontalAlignment="Stretch" 
                                   VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" 
                                             HorizontalAlignment="Stretch" 
                                             VerticalAlignment="Stretch">
                                <Image x:Name="imgOption" 
                                        SnapsToDevicePixels="False" 
                                        Source="{TemplateBinding Image}" 
                                        Stretch="Uniform" 
                                        HorizontalAlignment="Center" 
                                        VerticalAlignment="Center" 
                                        RenderOptions.BitmapScalingMode="HighQuality" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" 
                                      Value="true">
                            <Setter TargetName="Border" 
                                         Property="BorderThickness" 
                                         Value="0,0,0,0" />
                            <Setter TargetName="Border" 
                                         Property="BorderBrush" 
                                         Value="{DynamicResource ucPdfViewerOptionsHoverForeColor}" />
                            <Setter TargetName="imgOption" 
                                         Property="Image.Source" 
                                         Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=HoverImage}" />

                        </Trigger>
                        <Trigger Property="IsPressed" 
                                      Value="true">
                            <Setter TargetName="Border" 
                                         Property="BorderThickness" 
                                         Value="0,0,0,0" />
                            <Setter TargetName="Border" 
                                         Property="BorderBrush" 
                                         Value="{DynamicResource ucPdfViewerOptionsHoverForeColor}" />
                            <Setter TargetName="imgOption" 
                                         Property="Image.Source" 
                                         Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=HoverImage}" />
                        </Trigger>
                        <Trigger Property="IsFocused" 
                                      Value="true">
                            <Setter TargetName="Border" 
                                         Property="BorderThickness" 
                                         Value="0,0,0,0" />
                            <Setter TargetName="Border" 
                                         Property="BorderBrush" 
                                         Value="{DynamicResource ucPdfViewerOptionsHoverForeColor}" />
                            <Setter TargetName="imgOption" 
                                         Property="Image.Source" 
                                         Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=SelectedImage}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="nodefaultHoverbtn" TargetType="Button">
        <Setter Property="BorderBrush" Value="#000000"/>
        <Setter Property="BorderThickness" Value="1"/>
        <!--<Setter Property="Background" Value="{DynamicResource bgclr_lightdark}"/>-->
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0 0"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentControl Content="{TemplateBinding Content}" VerticalContentAlignment="Bottom" HorizontalAlignment="Center" FontWeight="{TemplateBinding FontWeight}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource frgclr_gray}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>

            <Trigger Property="IsMouseOver"
                     Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#89898A" Offset="0"/>
                            <GradientStop Color="#E8F0F0" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>


            </Trigger>


        </Style.Triggers>
    </Style>
    
    <Style x:Key="imgBtn_TopImageText" TargetType="{x:Type cust:ImageButton}">
        <Setter Property="Background"
                    Value="Transparent" />
        <Setter Property="Cursor"
                    Value="Arrow" />
        <Setter Property="BorderBrush" Value="{DynamicResource clr_darkborder}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Border x:Name="Border"
                            Height="{TemplateBinding Height}"
                                VerticalAlignment="Stretch"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                        <StackPanel Orientation="Vertical" >
                          
                            <Image  x:Name="lnkAutoMark"
                                    Source="{TemplateBinding Image}" 
                                    Width="Auto"
                                    Height="Auto"
                                    Stretch="None"/>
                            <!--<TextBlock FontWeight="SemiBold" FontSize="12" 
                                       x:Name="lnkLblAutoMark"                                                                                   
                                       Foreground="#fff"
                                       Text="{TemplateBinding Content}"
                                       TextWrapping="WrapWithOverflow"/>-->
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                     Value="true">
                            <Setter TargetName="Border"
                                        Property="BorderThickness"
                                        Value="0,0,0,0" />
                            <Setter TargetName="Border"
                                        Property="BorderBrush"
                                        Value="{DynamicResource ucPdfViewerOptionsHoverForeColor}" />
                           
                            <!--<Setter TargetName="imgOption"
                                        Property="Image.Source"
                                        Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=HoverImage}" />-->

                        </Trigger>
                        </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="styleResultHeaderButtons"
               TargetType="{x:Type cust:ImageButton}">
        <Setter Property="Background"
                    Value="{DynamicResource clr_bgr}" />
        <Setter Property="Cursor"
                    Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Border CornerRadius="0"
                                x:Name="Border"
                                Background="{DynamicResource clr_border}">
                        <StackPanel HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center">

                            <Image x:Name="imgMenu"
                                       SnapsToDevicePixels="False"
                                       Source="{TemplateBinding Image}"
                                       Stretch="None"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            <TextBlock x:Name="txtName"
                                           Grid.Row="1"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Foreground="{DynamicResource clr_txt}"
                                       FontWeight="SemiBold"
                                           Text="{TemplateBinding Content}"
                                           TextWrapping="WrapWithOverflow" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                     Value="true">
                            <Setter TargetName="Border"
                                        Property="Background"
                                        Value="{DynamicResource clr_bgr_mediumLight}" />
                            <Setter TargetName="txtName"
                                        Property="Foreground"
                                        Value="{DynamicResource cl_txt_high}" />

                        </Trigger>
                        <Trigger Property="IsPressed"
                                     Value="true">
                            <Setter TargetName="Border"
                                        Property="Background"
                                        Value="#33343B" />
                            <Setter TargetName="txtName"
                                        Property="Foreground"
                                        Value="{DynamicResource cl_txt_high}" />
                            <!-- <Setter TargetName="imgMenu"
                                        Property="Image.Source"
                                        Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=HoverImage}" /> -->
                        </Trigger>
                        <Trigger Property="IsFocused"
                                     Value="true">
                            <Setter TargetName="Border"
                                        Property="Background"
                                        Value="#33343B" />
                            <Setter TargetName="txtName"
                                        Property="Foreground"
                                        Value="{DynamicResource cl_txt_high}" />
                            <!-- <Setter TargetName="imgMenu"
                                        Property="Image.Source"
                                        Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=SelectedImage}" /> -->
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="ComboBoxTextBox"
                     TargetType="{x:Type TextBox}">
        <Border x:Name="PART_ContentHost"
                Focusable="False"
                Background="{TemplateBinding Background}" />
    </ControlTemplate>


    <ControlTemplate x:Key="ComboBoxToggleButton"
                     TargetType="{x:Type ToggleButton}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition MinWidth="20"
                                  MaxWidth="40" />
            </Grid.ColumnDefinitions>
            <Border x:Name="Border"
                    Grid.ColumnSpan="2"
                    CornerRadius="3"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="{TemplateBinding BorderThickness}" />
            <Border Grid.Column="0"
                    CornerRadius="0"
                    Margin="1"
                    Background="Transparent"
                    BorderThickness="0,0,0,0" />
            <Border Grid.Column="1" Background="#003E3E3E" Width="10" Height="20" CornerRadius="2" HorizontalAlignment="Center" Margin="0 0 0 0 " BorderBrush="#BCBCBC" BorderThickness="1 0 0 0">
                <Image Width="auto"
                       Height="auto"
                       Stretch="None"
                       Source="/Resources/dropdown_arrow.png"
                       Margin="1 0 0 0"                   
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center" />
            </Border>
        </Grid>
    </ControlTemplate>

