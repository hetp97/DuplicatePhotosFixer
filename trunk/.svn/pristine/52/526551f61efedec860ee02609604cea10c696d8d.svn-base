    <DrawingImage x:Key="img_uncheckDrawingImage">
        
        <DrawingImage.Drawing>
            <DrawingGroup ClipGeometry="M0,0 V16.6 H16.6 V0 H0 Z">
                <GeometryDrawing Brush="#FF686868" Geometry="F1 M16.6,16.6z M0,0z M16.6,16.6L0,16.6 0,0 16.6,0 16.6,16.6z M1,15.6L15.6,15.6 15.6,1 1,1 1,15.6z" />
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>
    <DrawingImage x:Key="img_checkDrawingImage">
        <DrawingImage.Drawing>
            <DrawingGroup ClipGeometry="M0,0 V16.6 H16.6 V0 H0 Z" >
                <GeometryDrawing  Brush="#FF686868"  Geometry="F1 M16.6,16.6z M0,0z M16.6,16.6L0,16.6 0,0 16.6,0 16.6,16.6z M1,15.6L15.6,15.6 15.6,1 1,1 1,15.6z M12.6,6.7L11.2,5.3 7.5,8.9 5.6,6.8 4.1,8.2 7.4,11.8 12.6,6.7z" />
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>


    <!--  Styles  -->

    <Style x:Key="DataGridContextMenuStyle" TargetType="{x:Type ContextMenu}">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderThickness" Value="0 0 0 1"/>
        <Setter Property="BorderBrush" Value="Gray"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContextMenu}">
                    <Border Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            SnapsToDevicePixels="True">
                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="stl_btnUpgradeNow" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="BorderBrush" Value="#000000"/>
        <Setter Property="BorderThickness" Value="0.8"/>

        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="VerticalContentAlignment" Value="Top"/>
        <!--<Setter Property="HorizontalContentAlignment" Value=""/>-->
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Margin" Value="15 0"/>

        <Setter Property="Background">
            <Setter.Value>
                <!--EndPoint="0.5,1" StartPoint="0.5,0"-->
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5, 1">
                    <GradientStop Color="#FFA341" Offset="0"/>
                    <GradientStop Color="#FF7602" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3"
                            >
                        <ContentControl Content="{TemplateBinding Content}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="{TemplateBinding FontWeight}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver"
                     Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FFD580" Offset="0"/>
                            <GradientStop Color="#FF7602" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="stl_btnScanForDuplicates" TargetType="Button">
        <Setter Property="BorderBrush" Value="#000000"/>
        <Setter Property="BorderThickness" Value="0.8"/>
        <Setter Property="Background" Value="#317AE6"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Margin" Value="0 0"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                        <ContentControl Content="{TemplateBinding Content}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="{TemplateBinding FontWeight}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource frgclr_gray}"/>
                        </Trigger>
                        
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>

            <Trigger Property="IsMouseOver"
                     Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#87CEFA" Offset="0"/>
                            <GradientStop Color="#317AE6" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                      

            </Trigger>

            
        </Style.Triggers>
    </Style>
    <Style x:Key="styl_reset_btn" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="#989898"/>
        
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" >
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver"
                     Value="True">
                <Setter Property="Background" Value="#E3D8D8">
                </Setter>
            </Trigger>
        </Style.Triggers>

    </Style>
    <Style x:Key="ImageTextbtn" TargetType="cust:ImageButton">
        <Setter Property="Background"
                    Value="Transparent" />
        <Setter Property="Cursor"
                    Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Border x:Name="Border"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Stretch">

                                <Image  
                                            Margin="0,2,4,0"
                                           Stretch="None"
                                           x:Name="lnkImageSettings"
                                           SnapsToDevicePixels="False"
                                           Source="{TemplateBinding Image}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock  Padding="3,0,3,0"
                                            Margin="0,0,0,0"
                                            x:Name="lnkLblInstall"
                                           FontSize="13"                                       
                                          Foreground="#fff"
                                            Text="{TemplateBinding Content}"
                                            TextWrapping="WrapWithOverflow"/>


                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="styl_add_excludebtn" TargetType="Button">
        <Setter Property="Background" Value="#1CA2E5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}" >
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver"
                     Value="True">
                <Setter Property="Background" Value="#E3D8D8">
                </Setter>
            </Trigger>
        </Style.Triggers>


    </Style>

    <Style x:Key="stl_btnClose" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True"/>

        <Setter Property="Height" Value="19"/>
        <Setter Property="Width" Value="28"/>

        <Setter Property="Background">
            <Setter.Value>
                <ImageBrush ImageSource="{DynamicResource img_close_normal}"/>
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Height="{TemplateBinding Height}" Width="{TemplateBinding Width}" Background="{TemplateBinding Background}">
                        <ContentControl Content="{TemplateBinding Content}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="{DynamicResource img_close_hover}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>

            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="stl_btnMaximize" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True"/>

        <Setter Property="Height" Value="19"/>
        <Setter Property="Width" Value="28"/>

        <Setter Property="Background">
            <Setter.Value>
                <ImageBrush ImageSource="{DynamicResource img_max_normal}"/>
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Height="{TemplateBinding Height}" Width="{TemplateBinding Width}" Background="{TemplateBinding Background}">
                        <ContentControl Content="{TemplateBinding Content}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="{DynamicResource img_max_hover}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>

            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="stl_btnMinimize" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True"/>

        <Setter Property="Height" Value="19"/>
        <Setter Property="Width" Value="28"/>

        <Setter Property="Background">
            <Setter.Value>
                <ImageBrush ImageSource="{DynamicResource img_min_normal}"/>
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Height="{TemplateBinding Height}" Width="{TemplateBinding Width}" Background="{TemplateBinding Background}">
                        <ContentControl Content="{TemplateBinding Content}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="{DynamicResource img_min_hover}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        
                    </ControlTemplate.Triggers>
                    
                </ControlTemplate>

            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="stl_btnHelpPopup" TargetType="Button">

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border>
                        <ContentControl Content="{TemplateBinding Content}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="stl_btnSettings" TargetType="{x:Type cust:ImageButton}">
        <Setter Property="Background"
                    Value="Transparent" />
        <Setter Property="Cursor"
                    Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Border x:Name="Border"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top">
                                <Image  
                                    Margin="0,2,-5,0"
                                           Width="12"
                                    Height="12"
                                           x:Name="lnkImageSettings"
                                           SnapsToDevicePixels="False"
                                           Source="{TemplateBinding Image}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock  Padding="0,0,0,0"
                                            Margin="-3,0,5,0"
                                            x:Name="lnkLblHelp"
                                           FontSize="13"
                                            VerticalAlignment="Top"
                                          Foreground="#ECECEC"
                                            Text="{TemplateBinding Content}"
                                            TextWrapping="WrapWithOverflow"/>
                              

                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="stl_btnreset" TargetType="{x:Type cust:ImageButton}">
        <Setter Property="Background"
                    Value="Transparent" />
        <Setter Property="Cursor"
                    Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Border x:Name="Border"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#989898"
                                
                                BorderThickness="1">
                        <Grid HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top">
                                <Image  
                                    Margin="0,0,0,0"
                                     Stretch="None"
                                           x:Name="lnkImagereset"
                                           SnapsToDevicePixels="False"
                                           Source="{TemplateBinding Image}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock  Padding="3,0,3,0"
                                            Margin="0,0,0,0"
                                            x:Name="lnkLblHelp"
                                           FontSize="13"
                                            
                                          Foreground="#A8A8A8"
                                            Text="{TemplateBinding Content}"
                                            TextWrapping="WrapWithOverflow"/>


                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="stl_btnfooter" TargetType="{x:Type cust:ImageButton}">

        <Setter Property="Background"
                    Value="Transparent" />
        <Setter Property="Cursor"
                    Value="Hand" />
        <Setter Property="BorderBrush"
                Value="#646464"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Border x:Name="Border"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                HorizontalAlignment="Center"
                               Padding="3 0 0 0"
                                Background="{TemplateBinding Background}"
                              BorderBrush="{TemplateBinding BorderBrush}"
                            VerticalAlignment="Center"
                                BorderThickness="0.8">
                        <Grid HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top">
                                <Image  
                                    Margin="0,5,0,0"
                                      Width="25"
                                    Height="25"
                                           x:Name="img_playbtn"
                                           SnapsToDevicePixels="False"
                                           Source="{TemplateBinding Image}"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock  Padding="5,0,3,0"
                                            Margin="0,5,0,0"
                                            x:Name="lnkwatchtutorial"
                                           FontSize="14"
                                            VerticalAlignment="Center"
                                          Foreground="White"
                                            Text="{TemplateBinding Content}"
                                            TextWrapping="WrapWithOverflow"/>


                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="stl_btnAction" TargetType="{x:Type cust:ImageButton}">

