<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucGeneralSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="352" d:DesignWidth="561" Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition/>
            <RowDefinition Height="Auto" MinHeight="80"/>
        </Grid.RowDefinitions>
        <Label Content="General" x:Name="lblGeneral" Margin="15 3 0 0" />
        <Grid Grid.Row="1" Background="#F1F1F1" Margin="20 3 30 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition  Height="Auto"/>
                <RowDefinition  Height="Auto"/>
            </Grid.RowDefinitions>
            <Border BorderBrush="#A0A0A0" BorderThickness="0 0 0 1"  Margin="5 3 5 0">
                <DockPanel Margin="5 10 0 0">
                    <CheckBox x:Name="chkConfirmdeleteDlg"  Padding="0 0 5 0"  />
                    <TextBlock x:Name="txtConfirmdeleteDlg" Text="Do not show confirmation dialog on delete" Padding="0 0 0 3"/>
                </DockPanel>
            </Border>
            <Border BorderBrush="#A0A0A0" BorderThickness="0 0 0 1" Grid.Row="1" Margin="5 3 5 0">
                <DockPanel Margin="5 10 0 0" Grid.Row="1">
                    <CheckBox x:Name="chkAutoMarkDlg"  Padding="0 0 5 0"  />
                    <TextBlock x:Name="txtAutoMarkDlg" Text="Do not show auto mark dialog on Auto Mark"  Padding="0 0 0 3"/>

                </DockPanel>
            </Border>
            <Border BorderBrush="#A0A0A0" BorderThickness="0 0 0 1" Grid.Row="2" Margin="5 3 5 0">
                <DockPanel Margin="5 10 0 0" Grid.Row="2">
                    <CheckBox x:Name="chkConfirmBackDlg"  Padding="0 0 5 0"  />
                    <TextBlock x:Name="txtConfirmBackDlg" Text="Do not show confirmation window on moving back"  Padding="0 0 0 3"/>

                </DockPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Button x:Name="btn_resetdefault" 
                    Width="118" 
                    Height="30"
                    HorizontalAlignment="Right" 
                    Margin="0 0 30 0"
                    Content="Reset Default">
                <Button.Background>
                    <LinearGradientBrush  StartPoint="0,0" EndPoint="0 ,1">
                        <GradientStop Color="#F1F1F1" Offset="0"/>
                        <GradientStop Color="LightGray" Offset="0.555"/>
                        <GradientStop Color="#F1F1F1" Offset="0.03"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>
                   
        </Grid>
    </Grid>
   
</UserControl>
