using DataGrid = System.Windows.Controls.DataGrid;


namespace DuplicatePhotosFixer.UserControls.Selection_Assistant
{
    /// <summary>
    /// Interaction logic for ucSelectionPriority.xaml
    /// </summary>
    public partial class ucSelectionPriority : System.Windows.Controls.UserControl
    {
        public ucSelectionPriority()
        {
            InitializeComponent();
            LoadStrings();
            loadAutoMark();
            DataContext = this;
        }

        void LoadStrings()
        {
            use_lbl.Header = cResourceManager.LoadString("IDS_MARKFILES_USE");
            priority_lbl.Header = cResourceManager.LoadString("IDS_MARKFILES_PRIORITY");
            name_lbl.Header = cResourceManager.LoadString("IDS_MARKFILES_NAME");
            rule_lbl.Header = cResourceManager.LoadString("IDS_MARKFILES_RULE");


        }

        public void loadAutoMark()
        {
            try
            {
                csPriority.getLastPriorityList();
                objSelectionPriority.ItemsSource = null;
                objSelectionPriority.ItemsSource = cGlobalSettings.listPriority.Values;

                //UpdateAutoMarkList(objSelectionPriorityInfo);


                }
            catch (Exception ex )
            {

                System.Windows.MessageBox.Show(ex.Message);
            }

        }



        public void UpdateAutoMarkList(DataGrid dataGrid)
        {
            try
            {
                //get the list of auto mark preferences collected by user
                if (Program.oMainReference.AutoMarkPreferences == null)
                    Program.oMainReference.AutoMarkPreferences = new List<string>();

                Program.oMainReference.AutoMarkPreferences.Clear();


                cGlobalSettings.listPriority.OrderBy(p => p.Value.priority).All
                    (p =>
                    {
                        if (p.Value.isChecked)
                            Program.oMainReference.AutoMarkPreferences.Add(p.Key.ToString());

                        return true;
                    });
                /*for (int i = 0; i < dataGrid.Rows.Count; i++)
                {
                    if (dataGrid.Rows[i] != null)
                    {
                        if (Convert.ToBoolean((dataGrid.Rows[i].Cells[0] as DataGridViewCheckBoxCell).Value))
                            Program.oMainReference.AutoMarkPreferences.Add(dataGrid.Rows[i].Tag.ToString());
                    }
                }*/
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("ucSelectionPriority:: UpdateAutoMarkList:", ex);
            }
        }
    }
}
