<Window x:Class="DuplicatePhotosFixer.Views.frmUpdateNotification"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        mc:Ignorable="d"
        Title="frmUpdateNotification" Height="182" Width="361" WindowStyle="None" Background="{DynamicResource cl_bg_theme}">
    <Grid>
        <StackPanel>
            <DockPanel VerticalAlignment="Center" Margin="5">
                <Button DockPanel.Dock="Right"  Background="Transparent"                
                    BorderBrush="Transparent"
                    Click="close_btn_click">
                    <Image Source="/Resources/closevpn.png" Stretch="None"/>
                </Button>
                <TextBlock x:Name="dpf_heading" Text="Duplicate Photos Fixer Pro" FontSize="12" Foreground="#cecece" />
            </DockPanel>
            <DockPanel  HorizontalAlignment="Center" Margin="0 40 0 40">
                <Image x:Name="img_info" Source="{DynamicResource img_alert_icon_trans}" Stretch="None" VerticalAlignment="Center" Margin="0 0 5 0"/>
                <TextBlock x:Name="lblinfo" VerticalAlignment="Center"
                            FontWeight="Regular"
                           FontSize="14"
                           Foreground="#fff"
                           Text="Duplicate Photos Fixer Pro is up to date."/>
            </DockPanel>
            <Button x:Name="ok_btn" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="94" Height="31" Margin="0 0 10 0"
                    BorderBrush="#000" Background="#007EED" Content="OK" Foreground="#fff" Click="ok_btn_Click" >
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="White" />
                        <Setter Property="TextBlock.TextAlignment" Value="Center" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bdr_main"  BorderThickness="1" Background="#2B9FD2">
                                        <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"                                                              
                                                              TextElement.FontSize="13"
                                                              TextElement.Foreground="White">
                                        </ContentPresenter>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" TargetName="bdr_main" Value="#3FB3E6">
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="true">
                                            <Setter Property="Background" TargetName="bdr_main" Value="#178BBE">
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                            <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
