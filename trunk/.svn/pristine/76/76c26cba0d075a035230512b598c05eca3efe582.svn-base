<Window x:Class="DuplicatePhotosFixer.Views.frmAfterScan"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        mc:Ignorable="d"
        Title="frmAfterScan" Height="280" Width="630" WindowStyle="None" Background="{DynamicResource bgrclr_solidgray}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <DockPanel>
            <Button DockPanel.Dock="Right"  Margin="0,0,3,0" Background="Transparent">
                <Image Source="{DynamicResource img_close}"/>
            </Button>
            <Label DockPanel.Dock="Left" x:Name="lbl_heading" Content="Duplicate Photo Fixer Pro" Margin="2, 0, 2, 0" Foreground="#C9C9C9" />
        </DockPanel>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Image Source="{DynamicResource img_ucHomedragdrop}" Height="100" Width="105" Margin="27, 35, 3, 3" VerticalAlignment="Top"/>
            <Grid Grid.Column="1">
                <StackPanel>
                <DockPanel>
                        <TextBlock x:Name="label1" Text="Duplicate Photos Found:" Foreground="White" FontSize="24" FontWeight="Bold" Margin="4, 35, 3, 3"/>
                        <TextBlock x:Name="cbtn_totalCount" Text="300" FontSize="24" FontWeight="Bold" Foreground="Orange" Margin="4, 35, 3, 3"/>
                </DockPanel>
                    <TextBlock x:Name="label3" Text="Use Auto Mark to conveniently mark duplicates based on set hierarchy." FontSize="15" FontWeight="Regular" Foreground="#40A5FD" Margin="3, 0, 0, 0"/>
                    <TextBlock x:Name="lbl_tip" Text="We found {0} duplicates occupying {1} space on your computer. It is recommended to delete these unwanted photos immediately to de-cluster your system and recoverextra storage space." TextWrapping="Wrap" Foreground="#C9C9C9" FontSize="14" FontWeight="Regular" Margin="2,4,2,4"/>
                    <DockPanel>
                        <Button x:Name="btn_selectManually" Content="Select Manually" Width="200" Height="50" Foreground="White" FontSize="14" FontWeight="SemiBold" Background="#2B72E6"/>
                        <Button x:Name="btn_autoMark" Content="Auto Mark" Width="200" Height="50" Foreground="White" FontSize="14" FontWeight="SemiBold" Background="#009926"/>

                    </DockPanel>
                </StackPanel>
                

            </Grid>
        </Grid>
    </Grid>
</Window>
