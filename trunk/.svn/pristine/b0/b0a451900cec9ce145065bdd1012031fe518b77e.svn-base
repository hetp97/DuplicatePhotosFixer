<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucSettingsFileFormat"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="464" d:DesignWidth="515" Background="#272727">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="57"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <StackPanel  Margin="10 20">
                <TextBlock x:Name="lbl1" Text="Manage File Formats" FontSize="24" Foreground="#fff"/>
                <TextBlock  x:Name ="lbl2" Text="The settings below allow you to exclude file extensions from being added to scan list."
                       TextWrapping="Wrap" Foreground="#AEAEAE" Margin="0 0 0 0" 
                       FontSize="14"/>
                <!--<ScrollViewer x:Name="gridViewer" Visibility="Visible" CanContentScroll="True">-->
            </StackPanel>
            <DataGrid Grid.Row="1" x:Name="fileformatsgrid"  Background="{DynamicResource bgrclr_lightgray}"   BorderBrush="Transparent"
                          ItemsSource="{Binding}" AutoGenerateColumns="False" IsReadOnly="True" ScrollViewer.CanContentScroll="True"
                              RowBackground="Transparent" Foreground="{DynamicResource frgclr_white}" Margin="0 0 0 20"
                              GridLinesVisibility="None" AlternatingRowBackground="{DynamicResource bgrclr_gray}" 
                                  CanUserResizeColumns="False" CanUserResizeRows="False"  RowHeaderWidth="0" 
                                  Cursor="Hand" CanUserAddRows="False" CanUserReorderColumns="False" HeadersVisibility="Column" >
                
                    <DataGrid.ColumnHeaderStyle>
                        <Style  TargetType="{x:Type DataGridColumnHeader}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type DataGridColumnHeader}">
                                        <Border BorderBrush="#4e4e4e"
                                BorderThickness="1"
                                Background="#272727"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                            <TextBlock Text="{TemplateBinding Content}" Padding="5,5,0,0" Height="28"  Width="{TemplateBinding Width}" TextAlignment="Left"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Center"
                                       Foreground="#8c8c8c"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                    <!--<Style TargetType="DataGridColumnHeader">
                        <Setter Property="Height" Value="32"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="#000"/>
                        <Setter Property="BorderBrush" Value="Red"/>
                        <Setter Property="BorderThickness" Value="0 1 1 1"/>
                    </Style>-->

                </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="{x:Type DataGridCell}">
                        <Setter Property="Background"
                                    Value="Transparent" />
                        <Setter Property="Height"
                                    Value="25"/>
                        
                         
                        <!-- <Setter Property="BorderBrush" Value="Red" />
                            <Setter Property="Foreground" Value="#93A0BE" /> -->
                            <Setter Property="BorderThickness"
                                Value="0" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected"
                                            Value="True">
                                    <Setter Property="Background"
                                     Value="Transparent" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn x:Name="colUse" Width="30" Header="Use" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding isChecked}" VerticalAlignment="Center" Margin="5 0">
                                        <CheckBox.LayoutTransform>
                                            <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                                        </CheckBox.LayoutTransform>
                                    </CheckBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn x:Name="colType" Header="Type Description" Width="*" Binding="{Binding FileDialogFilterItem}"/>
                    </DataGrid.Columns>
                </DataGrid>
                <!--</ScrollViewer>-->
         

        </Grid>
       
        <Grid Grid.Row="1" Background="{DynamicResource bgclr_soliddark}">
            <DockPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <TextBlock x:Name="lblMinSize" Text="Minimum file size included in scan :" VerticalAlignment="Center" Foreground="#E9E9E9" />
                <!--<Border BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1" Width="50" Height="30" Margin="10 0">-->
                    <DockPanel Margin="10 0" >
                    <TextBox x:Name="numericUpDownMinFileSize" Text="50" Padding="5" VerticalAlignment="Center" Background="#fff" Width="30" TextChanged="numericUpDownMinFileSize_TextChanged_1"  />
                    <StackPanel>
                            <Button x:Name="btnMaxSize" Width="13" Height="12" Margin="-1,0,0,-1" MinHeight="15" BorderThickness="1" Click="btnMaxSize_Click"  >
                                <Button.Template>
                                    <ControlTemplate>
                                        <Border>
                                            <Grid>
                                                <Border Name="Mask" BorderBrush="#ADADAD" BorderThickness="1">
                                                    <Border.Background>
                                                        <LinearGradientBrush EndPoint="0.504,1.5" StartPoint="0.504,0.03">
                                                            <GradientStop Color="#ECEBEC" Offset="0" />
                                                            <GradientStop Color="#E1E1E1" Offset="0.567" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                <StackPanel>
                                                    <Image x:Name="imgMoveup" Source="{DynamicResource img_maxsize}" Height="12" Width="12" />

                                                    <StackPanel.OpacityMask>
                                                        <VisualBrush Visual="{Binding ElementName=Mask}" />
                                                    </StackPanel.OpacityMask>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="false">
                                                <!--<Setter TargetName="imgMoveup" Property="Foreground" Value="Gray"/>-->
                                                <Setter TargetName="Mask" Property="Background" Value="#0078D7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        <Button x:Name="btnMoveDown" Width="13" Height="13" Margin="-1,0,0,0" Click="btnMoveDown_Click_1">
                                <Button.Template>
                                    <ControlTemplate>
                                        <Border>
                                            <Grid>
                                                <Border Name="Mask" BorderBrush="#ADADAD" BorderThickness="1">
                                                    <Border.Background>
                                                        <LinearGradientBrush EndPoint="0.504,1.5" StartPoint="0.504,0.03">
                                                            <GradientStop Color="#ECEBEC" Offset="0" />
                                                            <GradientStop Color="#E1E1E1" Offset="0.567" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                <StackPanel>
                                                    <Image x:Name="imgMovedown" Source="{DynamicResource img_minsize}" Height="12" Width="12" />
                                                    <StackPanel.OpacityMask>
                                                        <VisualBrush Visual="{Binding ElementName=Mask}" />
                                                    </StackPanel.OpacityMask>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="false">
                                                <!--<Setter TargetName="imgMoveup" Property="Foreground" Value="Gray"/>-->
                                                <Setter TargetName="Mask" Property="Background" Value="#0078D7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>



                        </StackPanel>


                    </DockPanel>
                <!--</Border>-->
                <!--<Border BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1" Width="50" Height="30">-->
                    <DockPanel >
                    <TextBox  x:Name="domainUpDownFileSize" Text="KB" Padding="5" VerticalAlignment="Center" Background="#fff" Width="30"/>
                    <StackPanel >
                        <Button x:Name="btnMaxSize1"  Width="13" Height="12" Margin="-1,0,0,-1" MinHeight="15" BorderThickness="1"  >
                                <Button.Template>
                                    <ControlTemplate>
                                        <Border>
                                            <Grid>
                                                <Border Name="Mask" BorderBrush="#ADADAD" BorderThickness="1">
                                                    <Border.Background>
                                                        <LinearGradientBrush EndPoint="0.504,1.5" StartPoint="0.504,0.03">
                                                            <GradientStop Color="#ECEBEC" Offset="0" />
                                                            <GradientStop Color="#E1E1E1" Offset="0.567" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                <StackPanel>
                                                <Image x:Name="imgMoveup" Source="{DynamicResource img_maxsize}" Height="12" Width="12" />
                                                <StackPanel.OpacityMask>
                                                        <VisualBrush Visual="{Binding ElementName=Mask}" />
                                                    </StackPanel.OpacityMask>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="false">
                                                <!--<Setter TargetName="imgMoveup" Property="Foreground" Value="Gray"/>-->
                                                <Setter TargetName="Mask" Property="Background" Value="#0078D7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        <Button x:Name="btnMoveDown1" Width="13" Height="13" Margin="-1,0,0,0" >
                            <Button.Template>
                                <ControlTemplate>
                                    <Border>
                                        <Grid>
                                            <Border Name="Mask" BorderBrush="#ADADAD" BorderThickness="1">
                                                <Border.Background>
                                                    <LinearGradientBrush EndPoint="0.504,1.5" StartPoint="0.504,0.03">
                                                        <GradientStop Color="#ECEBEC" Offset="0" />
                                                        <GradientStop Color="#E1E1E1" Offset="0.567" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <StackPanel>
                                                <Image x:Name="imgMovedown" Source="{DynamicResource img_minsize}" Height="12" Width="12" />
                                                <StackPanel.OpacityMask>
                                                    <VisualBrush Visual="{Binding ElementName=Mask}" />
                                                </StackPanel.OpacityMask>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsEnabled" Value="false">
                                            <!--<Setter TargetName="imgMoveup" Property="Foreground" Value="Gray"/>-->
                                            <Setter TargetName="Mask" Property="Background" Value="#0078D7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>


                    </DockPanel>
                <!--</Border>-->

            </DockPanel>
        </Grid>
        
    </Grid>
</UserControl>
