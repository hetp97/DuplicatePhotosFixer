<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucSettingsMove"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="441" d:DesignWidth="482" Background="{DynamicResource  cl_bg_settingsNag}" Loaded="UserControl_Loaded" >
    <UserControl.Resources>
        <Style x:Key="styl_radiobtn_content" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource cl_fg_setCont}"/>
            <Setter Property="Padding" Value="3 0 0 0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Regular"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

        </Style>
        <Style x:Key="styl_textbox" TargetType="TextBox">
            <Setter Property="Foreground" Value="#E9E9E9"/>
            <Setter Property="BorderBrush" Value="#5B5B5B"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Height" Value="33"/>
        </Style>
        <Style TargetType="Button" x:Name="styl_btn">
            <Setter Property="Background" Value="#888888"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>

            </Style.Triggers>
        </Style>

    </UserControl.Resources>
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="70" />
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="57"/>
        </Grid.RowDefinitions>
        <StackPanel Margin="10 10 10 30">
            <TextBlock x:Name="move_heading" Foreground="{DynamicResource cl_fg_setHeading}"
                       FontSize="24" FontWeight="Regular" >
                Manage duplicate photos
            </TextBlock>
            <TextBlock x:Name="heading_info"
                       Foreground="{DynamicResource cl_fg_setCont}" FontSize="14" TextWrapping="Wrap" FontWeight="Regular"
                       >
                This setting will allow you to select which action to perform on duplicate photos
            </TextBlock>
        </StackPanel>
        <Grid Grid.Row="1" Margin="10 0" VerticalAlignment="Center">

            <RadioButton  x:Name="rb_MoveToBin" Margin="5 2 0 0"  Content="Send duplicate photos to recycle bin"
                       IsChecked="{Binding Path=bMoveToRecycleBin}"
                              Style="{StaticResource styl_radiobtn_content}" Click="rb_MoveToBin_Click" />
        </Grid>

        <Grid Grid.Row="2" Margin="10">
            
            <StackPanel>
                <RadioButton x:Name="rb_MoveToLocation" Style="{StaticResource styl_radiobtn_content}"
                              IsChecked="{Binding Path=bMoveToLocation}"
                              Margin="5 2 0 5" Content="Move duplicate photos to selected path" Click="rb_MoveToLocation_Click"  />

                <DockPanel>
                    <Button x:Name="btn_AddFolder" DockPanel.Dock="Right" Content="Browse" 
                        Width="99" 
                        Height="33"                      
                        Foreground="{DynamicResource cl_fg_transbtn}"
                        BorderThickness="1"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        FontWeight="Bold"
                        Margin="0 -10 10 0"
                        Style="{DynamicResource btn_Transparent_style}" Click="btn_AddFolder_Click"/>
                    <TextBox x:Name="rb_MoveToLocationText"  Margin="25 0 10 10" FontWeight="Regular"
                             Text="{Binding bLocationPath}" VerticalAlignment="Center"
                             Foreground="{DynamicResource cl_fg_setCont}"
                               Padding="5" Height="33" Style="{StaticResource styl_textbox}" >
                    </TextBox>
                </DockPanel>
  
                <!--<TextBlock x:Name="txt_moveLocation" Text="C:\\users\\picture\\" Margin="10 0 0 0" Foreground="#565656"/>-->
            </StackPanel>
            
        </Grid>
        <Grid Grid.Row="3" Background="{DynamicResource cl_bg_TabControl}" >
            <Label x:Name="lbl_settingsApplied" Content="Settings Applied" 
                   Foreground="{DynamicResource cl_fg_primary}"
                   FontSize="15"
                   FontWeight="Bold"
                   VerticalContentAlignment="Center"
                   HorizontalAlignment="Center"
                   Visibility="Collapsed"/>
        </Grid>

        <!--<TextBlock Grid.Row="3"  Background="#D5D5D5" VerticalAlignment="Bottom"/>-->
    </Grid>
</UserControl>
