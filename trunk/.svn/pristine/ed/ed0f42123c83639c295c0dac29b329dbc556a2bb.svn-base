<Window x:Class="DuplicatePhotosFixer.Views.frmRegistrationDPF"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        mc:Ignorable="d"
      Title="frmRegistration" Height="582" Width="742" WindowStyle="None" AllowsTransparency="True" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="CustomTextBox"
           TargetType="{x:Type TextBox}"
           BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="border"
                            BorderBrush="{DynamicResource cl_br_WaterMark}"
                            BorderThickness="1 1 1 1"
                            Background="{DynamicResource cl_br_WaterMark}"
                            SnapsToDevicePixels="True">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="false"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden" />

                                <TextBlock Text="{TemplateBinding Tag}"
                                       IsHitTestVisible="False"
                                       Foreground="{DynamicResource cl_fg_WaterMark}"
                                       Margin="15 0 0 0"
                                       FontSize="17"
                                       VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility"
                                                Value="Hidden" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Path=Text, RelativeSource={RelativeSource AncestorType=TextBox}}"
                                                         Value="">
                                                    <Setter Property="Visibility"
                                                        Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                            </Grid>
                        </Border>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--<Style x:Key="MyWaterMarkStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Grid>
                            <Border Background="{DynamicResource cl_br_WaterMark}" BorderBrush="{DynamicResource cl_br_WaterMark}"/>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="5,0,0,0" VerticalAlignment="Center" />
                             <Label Margin="15,0,0,0" x:Name="WaterMarkLabel" Content="{TemplateBinding Tag}" VerticalAlignment="Center"
                               Visibility="Collapsed" Foreground="{DynamicResource cl_fg_WaterMark}" FontSize="15"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text" Value=""/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Visibility" TargetName="WaterMarkLabel" Value="Visible"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="DimGray"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>-->

        <Style TargetType="Button" x:Name="btn_close">
            <Setter Property="Background" Value="#888888"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>

            </Style.Triggers>
        </Style>

    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="41"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="62"/>
        </Grid.RowDefinitions>
        <DockPanel Background="{DynamicResource cl_bg_header}">
          
            <!--<Button DockPanel.Dock="Right"  Background="Transparent"
                    Margin="0 0 20 0" Style="{StaticResource stl_btnClose}"
                    BorderBrush="Transparent"
                    Click="Button_Click">
                <Image Source="/Resources/closevpn.png" Stretch="None"/>
          
            </Button>-->
            <cust:ImageButton
                            x:Name="close_btn"
                            Width="10"
                            Height="10"
                            DockPanel.Dock="Right"
                            Margin="10 0 10 0"
                            Style="{DynamicResource imageButton}"
                            Image="{DynamicResource img_close_plain}"
                            HoverImage="{DynamicResource img_close_plain}"
                            SelectedImage="{DynamicResource img_close_plain}" Click="close_btn_Click"  />

            <Image x:Name="dpf_logo" Source="/Resources/dpf_updateofr_icon.png" DockPanel.Dock="Left" Margin="10 0" Stretch="None"/>

            <TextBlock x:Name="dpf_header" Text="Duplicate Photos Fixer Pro" Foreground="{DynamicResource cl_fg_Heading}"
                       FontSize="15" FontWeight="Regular" 
                       VerticalAlignment="Center" />
            <TextBlock x:Name="dpf_header_Registraionfrm" Text="Register" Foreground="{DynamicResource cl_fg_subHeading}"
                       FontSize="15" FontWeight="Regular" Margin="10 0 0 0"
                       VerticalAlignment="Center" />

        </DockPanel>
        <Grid Grid.Row="1">
            <StackPanel Margin="30">
                <TextBlock x:Name="lbl_heading" Text="Thank you for choosing Duplicate Photos Fixer!" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource clr_darkborder}"/>
                <TextBlock x:Name="lbl_info" Text="To activate the full version of Duplicate Photo Fixer, you need to register the feature using a license key." Foreground="{DynamicResource cl_fg_RegContent}" FontSize="13" Padding="0 " />
                <StackPanel Margin="0 30">
                    <DockPanel>
                        <DockPanel>
                            <Image x:Name="img" Source="{DynamicResource img_clean_duplicate}"  Width="50" Height="50"  Margin="0 0 5 0"/>
                            <StackPanel Margin="10 0">
                                <TextBlock x:Name="feature_heading1" Text="Duplicate Photos Cleaner" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock x:Name="feature_desc1" Text="Find and Delete duplicate photos" Foreground="{DynamicResource cl_fg_RegContent}" FontSize="14" FontWeight="Regular" Padding="0 3"/>
                            </StackPanel>
                        </DockPanel>
                        <DockPanel HorizontalAlignment="Right">
                            <Image x:Name="img1" Source="{DynamicResource img_recover}"  Width="50" Height="50" Margin="0 0 5 0"/>
                            <StackPanel Margin="10 0" >
                                <TextBlock x:Name="feature_heading2" Text="Recover Storage Space" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock x:Name="feature_desc2" Text="Recover amount of storage space" Foreground="{DynamicResource cl_fg_RegContent}" FontSize="14" FontWeight="Regular" Padding="0 3"/>
                            </StackPanel>
                        </DockPanel>

                    </DockPanel>
                    <DockPanel Margin="0 35">
                        <DockPanel>
                            <Image x:Name="img3" Source="{DynamicResource img_auto_mark}"  Width="50" Height="50"/>
                            <StackPanel Margin="10 0">
                                <TextBlock x:Name="feature_heading3" Text="Auto Mark Delete" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock x:Name="feature_desc3" Text="Auto-mark and delete the photos" Foreground="{DynamicResource cl_fg_RegContent}" FontSize="14" FontWeight="Regular" Padding="0 3"/>
                            </StackPanel>
                        </DockPanel>
                        <DockPanel HorizontalAlignment="Right" Margin="0 0 30 0">
                            <Image x:Name="img4" Source="{DynamicResource img_one_click}"  Width="50" Height="50"/>
                            <StackPanel Margin="10 0">
                                <TextBlock x:Name="feature_heading4" Text="One click Scan" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock x:Name="feature_desc4" Text="One click and find duplicates" Foreground="{DynamicResource cl_fg_RegContent}" FontSize="14" FontWeight="Regular" Padding="0 3"/>
                            </StackPanel>
                        </DockPanel>
                    </DockPanel>
                    <TextBlock x:Name="label_key" Text="Already have a license key!" FontSize="16" Foreground="{DynamicResource cl_fg_primary2}" FontWeight="Bold"/>
                    <TextBlock x:Name="label_key_info1" Padding="0 5" Foreground="{DynamicResource cl_fg_info}" FontSize="13" FontWeight="Regular">
                        1. Copy the license key from the order page or confirmation email and paste it into the box below.</TextBlock>
                    <TextBlock x:Name="label_key_info2" Foreground="{DynamicResource cl_fg_info}" FontSize="13" FontWeight="Regular" Padding="0 0 0 5">2. Click on Activate Now button to enjoy full functionality.</TextBlock>
                    <DockPanel Margin="0 10">
                        <Button x:Name="btn_registerNow" Width="158" DockPanel.Dock="Right"
                                Height="42"
                                IsEnabled="{Binding IsActivationBtnEnable}"
                                Content="Activate Now" 
                                FontSize="16" BorderBrush="{DynamicResource cl_bgText-Border}" BorderThickness="0 1 1 1"
                                FontWeight="SemiBold"
                                
                                Foreground="#fff" Click="btn_registerNow_Click" >

                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{DynamicResource cl_bgBtn}" />
                                    <Setter Property="TextBlock.TextAlignment" Value="Center" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bdr_main"  BorderThickness="1" BorderBrush="{DynamicResource cl_bgText}" Background="{DynamicResource cl_bgBtn}">
                                                    <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="White">
                                                    </ContentPresenter>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" TargetName="bdr_main" Value="#494949"></Setter>
                                                        <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                        <Setter Property="Background" TargetName="bdr_main" Value="#494949"></Setter>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="true">
                                                        <Setter Property="BorderBrush" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                        <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                        <Setter Property="Background" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                                        <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>

                        </Button>
                        <TextBox x:Name="txt_reg_key" 
                                 BorderBrush="{DynamicResource cl_bgText-Border}" 
                                 VerticalAlignment="Center" VerticalContentAlignment="Center"
                                 Height="40" Background="{DynamicResource cl_bgWaterMarkText}" 
                                 Style="{StaticResource CustomTextBox}" Tag="XXXX-XXXX-XXXX-XXXX"
                                 
                                  Text="{Binding txtLicenseKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextChanged="txt_reg_key_TextChanged" PreviewKeyDown="txt_reg_key_PreviewKeyDown">
                        </TextBox>
                    </DockPanel>
                    <TextBlock x:Name="hyperlink_text" FontSize="12" FontWeight="Regular" Padding="0 5" PreviewMouseDown="hyperlink_text_PreviewMouseDown" >
                        <Hyperlink Foreground="{DynamicResource cl_fg_hyperLinkText}">Click here to paste the copied license key into the box above.</Hyperlink>
                    </TextBlock>
                </StackPanel>

            </StackPanel>
        </Grid>
        <Grid Grid.Row="2" Background="{DynamicResource bgclr_soliddark}">
            <DockPanel>
                <Button x:Name="btn_Upgrade" 
                        FontWeight="SemiBold" DockPanel.Dock="Right" Width="158" Height="36" Style="{DynamicResource stl_btnUpgradeNow}" Content="Purchase Now" Margin="0 0 10 0" Click="btn_Upgrade_Click"/>
                <Image x:Name="img_mb_icon" Source="{Binding ImgMoneyBack}"
                       
                       Margin="5 5 10 5"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="lbl_moneyBack" Text="No Questions Asked, 60 Days Money Back Guarantee" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource cl_fg_footertext1}"/>
                    <TextBlock x:Name="lbl_noQuestion" Text="If you are not satisfied with our feature , contact us within 60 days for a full refund" Foreground="{DynamicResource cl_fg_footertext2}" FontSize="12" FontWeight="Regular"/>
                </StackPanel>
            </DockPanel>
        </Grid>
    </Grid>
</Window>

