        public override bool ReadAllMessages(object client, object folder, ref List<csImageFileInfo> fileRecordsData0, Callback callback, int PauseCounter, string directoryPath)
        {
            CancellationTokenSource cts = null;
            object lockObj = new object(); // For thread-safe operations

            // Group by content hash for duplicate detection
            var hashGroups = cGlobalSettings.listImageFileInfo.GroupBy(x => x.Value.hash).ToList();

            int nTotalFilesCount = cGlobalSettings.listImageFileInfo.Count;
            int GroupNumber = 0;
            int nFilesProcessed = 0;
            int nTotalDupsFound = 0;
            int progressReportCounter = 0;

            List<csImageFileInfo> newFileRecordsData = new List<csImageFileInfo>();
            List<FileRecord> modifiedFileRecordsData = new List<FileRecord>();
            cts = new CancellationTokenSource();

            try
            {
                // Initial progress report
                OnScanProgressProcess("Starting duplicate analysis...", 0, nTotalFilesCount, 0, 0);

                foreach (var group in hashGroups)
                {
                    cGlobalSettings.oManualReset.WaitOne();
                    if (cGlobalSettings.abortNow)
                    {
                        OnScanCompletedProcess("Scan aborted.", "", true, 100);
                        break;
                    }

                    int nItems = group.Count();
                    var first = group.FirstOrDefault();
                    string currentGroupFile = first.Equals(default(KeyValuePair<int, csImageFileInfo>))
                        ? ""
                        : first.Value.filePath;
                    //string currentGroupFile = group.FirstOrDefault()?.Value?.filePath ?? "";

                    // Process single files (no duplicates)
                    if (nItems == 1)
                    {
                        lock (lockObj)
                        {
                            nFilesProcessed += 1;
                            progressReportCounter++;

                            // Report progress every 50 files for better responsiveness
                            if (progressReportCounter % 50 == 0)
                            {
                                int percentage = Math.Min(99, (nFilesProcessed * 100) / nTotalFilesCount);
                                OnScanProgressProcess(currentGroupFile, percentage, nTotalFilesCount, nFilesProcessed, nTotalDupsFound);
                            }
                        }
                        continue;
                    }

                    // Process duplicate groups
                    var processedItems = new List<csImageFileInfo>();

                    group.AsParallel()
                        .WithDegreeOfParallelism(Environment.ProcessorCount > 4 ? 4 : Environment.ProcessorCount)
                        .WithCancellation(cts.Token)
                        .ForAll(p =>
                        {
                            try
                            {
                                cGlobalSettings.oManualReset.WaitOne();
                                if (cGlobalSettings.abortNow)
                                {
                                    cts.Cancel();
                                    return;
                                }

                                        // Generate thumbnail cache
                                        string thumbPath = GetThumbnailImage(p.Value.filePath, false);
                                p.Value.ThumbnailPath = thumbPath;

                                lock (lockObj)
                                {
                                    processedItems.Add(p.Value);
                                    nFilesProcessed++;
                                    progressReportCounter++;

                                            // Report progress more frequently for better UI responsiveness
                                            if (progressReportCounter % 25 == 0)
                                    {
                                        int percentage = Math.Min(99, (nFilesProcessed * 100) / nTotalFilesCount);

                                                // Use Dispatcher to ensure UI thread safety
                                                System.Windows.Application.Current.Dispatcher.BeginInvoke(
                                                             new Action(() =>
             {
                 OnScanProgressProcess(p.Value.filePath, percentage, nTotalFilesCount, nFilesProcessed, nTotalDupsFound);
             })
);
                                    }
                                }
                            }
                            catch (OperationCanceledException)
                            {
                                        // Expected when cancellation is requested
                                        return;
                            }
                            catch (Exception ex)
                            {
                                cGlobalSettings.oLogger?.WriteLogException($"Error processing file: {p.Value?.filePath}", ex);
                            }
                        });

                    // Check for cancellation after parallel processing
                    if (cts.Token.IsCancellationRequested || cGlobalSettings.abortNow)
                    {
                        OnScanCompletedProcess("Scan aborted", "", true, 100);
                        break;
                    }

                    // Update duplicate group information
                    if (processedItems.Count > 1)
                    {
                        GroupNumber++;
                        nTotalDupsFound += processedItems.Count;

                        // Assign group number to all items in this duplicate group
                        foreach (var item in processedItems)
                        {
                            item.groupNumber = GroupNumber;
                            newFileRecordsData.Add(item);
                        }

                        // Update global counters
                        cGlobalSettings.TotalDuplicateGroups++;
                        cGlobal.TotalDulicateFilesCount += processedItems.Count;
                        cGlobal.TotalDuplicateFileSize += processedItems.Sum(p => p.fileSize);

                        // Report progress after processing each duplicate group
                        int groupPercentage = Math.Min(99, (nFilesProcessed * 100) / nTotalFilesCount);
                        string groupFile = processedItems.FirstOrDefault()?.filePath ?? "";

                        OnScanProgressProcess(
                            $"Found {processedItems.Count} duplicates in: {Path.GetFileName(groupFile)}",
                            groupPercentage,
                            nTotalFilesCount,
                            nFilesProcessed,
                            nTotalDupsFound);
                    }
                }

                // Final progress update
                OnScanProgressProcess("Finalizing duplicate images...", 100, nTotalFilesCount, nFilesProcessed, nTotalDupsFound);
                OnScanCompletedProcess("Scan completed", "", true, 100);

                return true;
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger?.WriteLogException("ReadAllMessages", ex);
                OnScanCompletedProcess($"Scan failed: {ex.Message}", "", true, 100);
                return false;
            }
            finally
            {
                // Cleanup
                cts?.Dispose();

                if (newFileRecordsData.Count > 0)
                {
                    newFileRecordsData.Clear();
                }

                if (modifiedFileRecordsData.Count > 0)
                {
                    modifiedFileRecordsData.Clear();
                }
            }
        }



        public override bool Scan(List<csScanPaths> inputToScan, object filters, SearchOption searchOption, ref List<csImageFileInfo> list, Callback callback, int PauseCounter)
        {
            OnScanStartProcess("Gettings files, please wait", 5, 0);

            if (objSystemScanHelper == null)
                objSystemScanHelper = new SystemScanHelper();

            List<string> searchPatterns = filters as List<string>;

            // Init list
            cGlobalSettings.listImageFileInfo = new ConcurrentDictionary<int, csImageFileInfo>();

            // Search for files and add in list
            bool bAddingFiles = objSystemScanHelper.StartScan(inputToScan, searchPatterns, searchOption, ref list, callback, PauseCounter, OnScanProgressProcess);

            // Adding files complete.
            if (list.Count <= 0)
                return true;

            ConcurrentDictionary<int, csImageFileInfo> dictRecords = new ConcurrentDictionary<int, csImageFileInfo>();

            int nKey = 0;
            foreach (csImageFileInfo record in list)
            {
                nKey += 1;
                dictRecords.TryAdd(nKey, record);
            }

            var groupSize = list.GroupBy(p => p.fileSize);

            Dictionary<string, List<csImageFileInfo>> dictDupsData = new Dictionary<string, List<csImageFileInfo>>();

            int nTotalFilesCount = list.Count;
            int GroupNumber = 0;
            int nFilesProcessed = 0;
            int nTotalDupsFound = 0;

            foreach (var group in groupSize)
            {
                int nItems = group.Count();

                if (nItems == 1)
                {
                    group.All(p =>
                    {
                        p.groupNumber = 0;
                        return true;
                    });

                    nFilesProcessed += 1;
                    continue;
                }

                int progressCounter = 0;
                group.All(p =>
                {
                    //  Calculate file content hash instead of filename hash
                    p.fileID = AppFunctions.GetMD5(p.filePath); // This should calculate file content hash, not filename
                                                                // I Store the hash in the hash property too for consistency
               //  p.hash = p.fileID;

                    nFilesProcessed += 1;

                    progressCounter++;
                    if (progressCounter % 125 == 0)
                    {
                        int percentage1 = (nFilesProcessed * 100) / nTotalFilesCount;
                        OnScanProgressProcess(p.filePath, percentage1, nTotalFilesCount, nFilesProcessed, nTotalDupsFound);
                    }
                    return true;
                });

                //  Filter out empty hashes before grouping
                var dupsGroups = group.GroupBy(p => p.fileID).Where(p => !string.IsNullOrEmpty(p.Key));

                string strCurrentFile = "";
                foreach (var dupsGroup in dupsGroups)
                {
                    int nDupsCount = dupsGroup.Count();

                    if (nDupsCount == 1)
                        continue;

                    GroupNumber += 1;
                    nTotalDupsFound += nDupsCount;
                    dupsGroup.All(p =>
                    {
                        p.groupNumber = GroupNumber;
                        strCurrentFile = p.filePath;
                        return true;
                    });

                    dictDupsData.Add(dupsGroup.Key, dupsGroup.ToList<csImageFileInfo>());
                }

                if (nFilesProcessed % 125 == 0)
                {
                    int percentage = (nFilesProcessed * 100) / list.Count;
                    OnScanProgressProcess(strCurrentFile, percentage, list.Count, nFilesProcessed, nTotalDupsFound);
                }
            }

            return true;
        }

       
    }


