        void checkListSize(List<csScanPaths> lst)
        {
            if (lst.Count >= 1)
            {
                btnScanForDuplicates.IsEnabled = true;
            }
           
            {
                btnScanForDuplicates.IsEnabled = false;
            }
            
        }

