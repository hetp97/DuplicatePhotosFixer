        void OpenFileSystemExplorer()
        {
            FolderSelectDialog folderSelectDialog = null;
         
            try
            {
                //folderSelectDialog = new FolderSelectDialog();
                //folderSelectDialog.InitialDirectory = "c:\\";
                //folderSelectDialog = new FolderSelectDialog();

                //if (folderSelectDialog.ShowDialog())
                //{
                //    string selectedFileName = folderSelectDialog.FileName;

                //    selectedFiles.Add(new Helpers.csSelectedFiles()
                //    {
                //        isSelected = true,
                //        fileIcon = "/Resources/btn_folder.png",
                //        filePath = selectedFileName,
                //        deleteButtonIcon = "/Resources/delete_normal.png",
                //    });

                //    gridFileFolder.ItemsSource = null;
                //    gridFileFolder.ItemsSource = selectedFiles;

                //    checkListSize(selectedFiles);

                //}

                var fsd = new FolderSelectDialog();
                
                //fsd.Title = cResourceManager.LoadString("DPF_HOME_UC_CUSTOM_FOLDER_DIALOG_TITLE");
                //fsd.InitialDirectory = @"c:\";
                if (fsd.ShowDialog())
                {
                    List<csScanPaths> lstScanPath = new List<csScanPaths>();
                    foreach (string strPath in fsd.FileName.Split('|'))
                    {
                        csScanPaths oScanPath = new csScanPaths { 
                            strPath = strPath,
                            fileIcon = "/Resources/btn_folder.png",
                            deleteButtonIcon = "/Resources/delete_normal.png",
                            IncludeSubFolder = true,
                        };
                        lstScanPath.Add(oScanPath);
                    }
                    string statusMessage = addValidScanPath(lstScanPath.ToArray());
                    lstScanPath.Clear();
                    lstScanPath = null;
                    if (!string.IsNullOrEmpty(statusMessage))
                    {
                        //MessageBoxEx.Show(statusMessage, cGlobalSettings.GetProductNameFromAssembly(), MessageBoxButtons.OK, MessageBoxIcon.Information);
                        //MessageBoxEx.Show(this, statusMessage, cGlobalSettings.GetProductName(), MessageBoxButtons.OK, MessageBoxIcon.Information);
                        System.Windows.Forms.MessageBox.Show(statusMessage);
                    }

                    gridFileFolder.ItemsSource = null;
                    gridFileFolder.ItemsSource = cGlobalSettings.listScanPath;

                    //checkListSize(cGlobalSettings.listScanPath);
                }

            }
            catch
            {

            }
            finally
            {
                folderSelectDialog = null;
            }
        }

        void OpenGoogleFolderExplorer()
        {
            System.Windows.MessageBox.Show("Sign In");
        }

        private void btn_deleteCurrentRow_Click(object sender, RoutedEventArgs e)
        {
            if (cGlobalSettings.listScanPath.Contains((csScanPaths)gridFileFolder.SelectedItem))
            {
                cGlobalSettings.listScanPath.Remove((csScanPaths)gridFileFolder.SelectedItem);


                checkListSize(cGlobalSettings.listScanPath);
                //int n = gridFileFolder.SelectedIndex;

                gridFileFolder.ItemsSource = null;

                gridFileFolder.ItemsSource = cGlobalSettings.listScanPath;
                //FileList.RemoveAt(n);

            }
        }

      



        private void btnEmptySelectedFileList_Click(object sender, RoutedEventArgs e)
        {
            gridFileFolder.ItemsSource = null;
            cGlobalSettings.listScanPath.Clear();
            checkListSize(cGlobalSettings.listScanPath);
            gridFileFolder.ItemsSource = cGlobalSettings.listScanPath;
        }

        private void chkbxCheckAll_Click(object sender, RoutedEventArgs e)
        {


            if (cGlobalSettings.isAllChecked == true)
            {
                foreach (var item in cGlobalSettings.listScanPath)
                {
                    item.isSelected = false;
                    cGlobalSettings.isAllChecked = false;
                }
            }
            else
            {
                foreach (var item in cGlobalSettings.listScanPath)
                {
                    item.isSelected = true;
                    cGlobalSettings.isAllChecked = true;
                }
            }
            gridFileFolder.ItemsSource = null;
            gridFileFolder.ItemsSource = cGlobalSettings.listScanPath;
        }


        public static eScanMode scanMode;
        private void cboScanMode_SelectionChanged(object sender, SelectionChangedEventArgs e)
        {


            var index = customComboBox.SelectedIndex;

            if (index == 0)
            {
                scanMode = eScanMode.FileSearch;
                btnAddPhotos.Visibility = Visibility.Visible;
                btnAddPhotos.Width = 120;
            }
            else if (index == 1)
            {
                scanMode = eScanMode.GoogleDrive;
                btnAddPhotos.Visibility = Visibility.Collapsed;
                btnAddPhotos.Width = 0;
            }

            else if(index == 2)
            {
                scanMode = eScanMode.DropBox;
                btnAddPhotos.Visibility = Visibility.Collapsed;
                btnAddPhotos.Width = 0;
            }
            else if (index == 3)
            {
                scanMode = eScanMode.PicasaLibrary;
                btnAddPhotos.Visibility = Visibility.Collapsed;
                btnAddPhotos.Width = 0;
            }
            else if (index == 4)
            {
                scanMode = eScanMode.LightRoomClassic;
                btnAddPhotos.Visibility = Visibility.Collapsed;
                btnAddPhotos.Width = 0;
            }



        }

