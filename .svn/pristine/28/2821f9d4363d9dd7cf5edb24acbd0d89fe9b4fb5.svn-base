<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="471" d:DesignWidth="872" >
    <Grid Background="#F0F0F0">

     
        
        <TabControl
                       
                    Name="tab_main" 
                    TabStripPlacement="Left"
                    Margin="0,0,0,0"
                    Padding="0"
                    BorderThickness="0" 
                    >
            <TabControl.Resources>
                <!--<Style TargetType="{x:Type TabPanel}">
                    <Setter Property="HorizontalAlignment" Value="Center" />
                    <Setter Property="VerticalAlignment" Value="Top" />
                    <Setter Property="Margin" Value="0 0 0 0"/>
                    <Setter Property="Width" Value="150"/>
                </Style>
                <Style x:Key="tabcontrol" TargetType="TabItem">
                    <Setter Property="Margin" Value="0 0"/>
                    <Setter Property="FontSize" Value="13" />
                    <Setter Property="Padding" Value="0 0 0 0" />
                    <Setter Property="IsTabStop" Value="False" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Margin" Value="0 0"/>
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="#707070"/>
                    <Setter Property="FontWeight" Value="Bold"/>


                    <Setter Property="Height" Value="40" />
                   
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border"
                                                Padding="0"
                                        BorderBrush="#DFDFDF"
                                                    BorderThickness="0 0 0 1"
                                                    >
                                    <DockPanel HorizontalAlignment="Left"
                                               LastChildFill="False" VerticalAlignment="Center"
                                                               x:Name="stack" Margin="10 0 0 0">

                                        <TextBlock Name="txt_strHeader" Text="{TemplateBinding Header}" TextWrapping="Wrap" 
                                                   Foreground="#707070" FontWeight="SemiBold" FontSize="13"/>

                                        <DockPanel.ToolTip>
                                            <ContentPresenter x:Name="ContentSites"
                                                                              Margin="5,0"
                                                                              VerticalAlignment="Center"
                                                                              HorizontalAlignment="Center"
                                                                              ContentSource="Header">
                                            </ContentPresenter>
                                        </DockPanel.ToolTip>
                                    </DockPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="txt_strHeader"
                                                Property="Foreground"
                                                Value="#178DC6" />
                                        <Setter TargetName="Border"
                                                Property="Background"
                                                Value="#ffffff" />
                                    </Trigger>
                                   
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition  Property="IsMouseOver"
                                                                    Value="True" />
                                            <Condition Property="IsTabStop"
                                                                   Value="True" />
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="txt_strHeader"
                                                Property="Foreground"
                                                Value="#38A3DA" />
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>-->

                <Style x:Key="stl_mainTabControl" TargetType="{x:Type TabControl}">
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabControl">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border CornerRadius="3 3 0 0" Grid.Row="1">
                                        <Border BorderThickness="{TemplateBinding BorderThickness}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}">
                                            <Border Background="{TemplateBinding Background}">
                                                <ContentPresenter ContentSource="SelectedContent" />
                                            </Border>
                                        </Border>
                                    </Border>
                                    <TabPanel Grid.Row="0" IsItemsHost="true" />
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
                <Style TargetType="{x:Type TabPanel}">
                    <Setter Property="HorizontalAlignment" Value="Left" />
                </Style>

                <Style x:Key="stl_TabItem" TargetType="TabItem">
                    <Setter Property="FontSize" Value="10"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource clr_border}"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Width" Value="150"/>
                  
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                    <Setter Property="VerticalAlignment" Value="Stretch"/>
                    <Setter Property="Margin" Value="0 0 0 0"/>
                    <Setter Property="Background" Value="{DynamicResource clr_bgr}"/>
                    
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Height" Value="40" />

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border"
                                                Padding="0"
                                        BorderBrush="#DFDFDF"
                                                    BorderThickness="0 0 0 1"
                                                    >
                                    <DockPanel HorizontalAlignment="Left"
                                               LastChildFill="False" VerticalAlignment="Center"
                                                               x:Name="stack" Margin="10 0 0 0">

                                        <TextBlock Name="txt_strHeader" Text="{TemplateBinding Header}" TextWrapping="Wrap" 
                                                   Foreground="#707070" FontWeight="SemiBold" FontSize="13"/>

                                        <DockPanel.ToolTip>
                                            <ContentPresenter x:Name="ContentSites"
                                                                              Margin="5,0"
                                                                              VerticalAlignment="Center"
                                                                              HorizontalAlignment="Center"
                                                                              ContentSource="Header">
                                            </ContentPresenter>
                                        </DockPanel.ToolTip>
                                    </DockPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="txt_strHeader"
                                                Property="Foreground"
                                                Value="#178DC6" />
                                        <Setter TargetName="Border"
                                                Property="Background"
                                                Value="#ffffff" />
                                    </Trigger>

                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition  Property="IsMouseOver"
                                                                    Value="True" />
                                            <Condition Property="IsTabStop"
                                                                   Value="True" />
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="txt_strHeader"
                                                Property="Foreground"
                                                Value="#0A71A5" />
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>


                    </Setter>
                </Style>

            </TabControl.Resources>
            <TabItem x:Name="general_settings" Header="General" Style="{StaticResource stl_TabItem}">
                <local:ucGeneral/>
            </TabItem>
            <TabItem x:Name="fileformat_settings" Header="File Formats" Style="{StaticResource stl_TabItem}" >
                <local:ucSettingsFileFormat/>
            </TabItem>

            <TabItem x:Name="excludedfolders_settings" Header="Exclude Folders" Style="{StaticResource stl_TabItem}">
                <local:ucExcludeSettings/>
            </TabItem>
            <TabItem x:Name="scancriteria_settings" Header="Scan Criteria" Style="{StaticResource stl_TabItem}">
                <local:ucExtraSettings/>
            </TabItem>
            <TabItem x:Name="moveduplicates_settings" Header="Move Duplicates" Style="{StaticResource stl_TabItem}">
                <local:ucSettingsMove/>
            </TabItem>


        </TabControl>
        <!--<TabControl
                       
                    Name="tab_main" 
                    TabStripPlacement="Left"
                    Margin="0,0,0,0"
