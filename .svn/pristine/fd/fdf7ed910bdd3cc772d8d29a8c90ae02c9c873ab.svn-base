<Window x:Class="DuplicatePhotosFixer.Views.frmProcessing"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
       xmlns:rpb ="http://schemas.microsoft.com/expression/2010/drawing"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
          xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
        xmlns:cpb="clr-namespace:DuplicatePhotosFixer.CustomExtendClass"
        mc:Ignorable="d" ResizeMode="NoResize"
        Title="frmProcessing" Height="327" Width="630" WindowStyle="None" Background="{DynamicResource cl_br_Nagtheme}" Loaded="frmProcessing_Loaded" >
    <Window.Resources>
        <Style x:Key="CircularProgressBar" TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Ellipse  Width="180" Height="180" Stroke="#2d2d2d" Fill="#454545" StrokeThickness="20" Margin="10 0">
                            <Ellipse.StrokeDashArray>
                                <DoubleCollection>1 0</DoubleCollection>
                            </Ellipse.StrokeDashArray>
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="rotateTransform" CenterX="100" CenterY="100" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="54"/>
        </Grid.RowDefinitions>
        <Border BorderBrush="{DynamicResource cl_br_pgr}"  BorderThickness="0 0 0 1">
            <DockPanel Background="{DynamicResource cl_br_pgr}">
                <Image x:Name="dpf_logo" Source="{DynamicResource img_update_dpf}" DockPanel.Dock="Left" Margin="10 0 5 0" Width="30" VerticalAlignment="Center"/>
                <cust:ImageButton
                            x:Name="btn_close"
                            Width="10"
                            Height="10"
                            DockPanel.Dock="Right"
                            Margin="10 0 10 0"
                            Style="{DynamicResource imageButton}"
                            Image="{DynamicResource img_close_plain}"
                            HoverImage="{DynamicResource img_close_plain}"
                            SelectedImage="{DynamicResource img_close_plain}" Click="btn_close_Click"/>
                <!--<Button DockPanel.Dock="Right" x:Name="btn_close"  Margin="0,0,10,0" Background="Transparent" BorderBrush="Transparent" Click="Button_Click">
                    <Button.Style>
                        <Style TargetType="{x:Type Button}">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="TextBlock.TextAlignment" Value="Center" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <Border x:Name="bdr_main">
                                            <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"                                                              
                                                              TextElement.FontSize="13"
                                                              TextElement.Foreground="White"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" TargetName="bdr_main" Value="Transparent"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="true">
                                                <Setter Property="Background" TargetName="bdr_main" Value="Transparent"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                                <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <Image Source="{DynamicResource img_close_plain}" Stretch="None"  />
                </Button>-->
                <Label DockPanel.Dock="Left" x:Name="lbl_heading" FontSize="15" VerticalAlignment="Center" Content="Duplicate Photo Fixer Pro" Margin="2, 0, 2, 0" Foreground="{DynamicResource cl_fg_setHeading}" />
            </DockPanel >
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!--<crb:CircularProgressBar
            x:Name="progressbar1"         
            Thickness="50" Radius="100"
            Value="{Binding ProgressValue}"
            Style="{StaticResource CircularProgressBarStyle}"
            Background="Black"
            Fill="Transparent"
            Stroke="Blue"
            StrokeThickness="3"
            StrokeMode="Middle"
            EndLineCap="Triangle" />-->

            <ProgressBar x:Name="progressBar1"  Style="{StaticResource CircularProgressBar}"/>
            <StackPanel VerticalAlignment="Center">
                <Label x:Name="lbl_percentage" Margin="0 0 0 -5"
                       Content="100%" FontSize="25" Foreground="{DynamicResource cl_fg_pgrlbl1}" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Label x:Name="label10" FontSize="13" Foreground="{DynamicResource cl_fg_pgrlbl1}"
                       Content="Comparing" Margin="0 -8 0 0"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </StackPanel>

            <!--<rpb:Arc  x:Name="progressBar"
         Fill="Blue"
        Height="150" Width="150"
        Stretch="None"
        ArcThickness="10"
        ArcThicknessUnit="Pixel"
        EndAngle="360" />
            <StackPanel VerticalAlignment="Center">
                <Label x:Name="lbl_percentage" Margin="0 0 0 -5"
                       Content="100%" FontSize="25" Foreground="#fff" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Label x:Name="label10" FontSize="13" Foreground="#fff"
                       Content="Comparing" Margin="0 -8 0 0"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </StackPanel>
            <Slider x:Name="progressBar1" Visibility="Collapsed"  />-->


            <!--<Image Source="{DynamicResource img_circle}" Height="100" Width="105" Margin="27, 35, 3, 3" VerticalAlignment="Top"/>-->
            <Grid Grid.Column="1">
                <StackPanel Margin="0 25 0 0">
                    <TextBlock x:Name="lbl_searchingDuplicates" FontWeight="Bold" FontSize="22" Foreground="{DynamicResource cl_fg_pgrlbl1}" 
                               Text="Searching for Duplicates..."/>
                    <TextBlock x:Name="lbl_progressInfo" FontSize="14" FontWeight="Regular" Foreground="{DynamicResource cl_fg_pgrlbl2}"
                               Text="Please be pateint while we scan your duplicates..."/>
                    <DockPanel Margin="0 20 0 0">
                        <Image x:Name="img1" Source="{DynamicResource img_remaining_photos}" Width="50" Height="40" Margin="0 0 0 0"/>
                        <StackPanel>
                            <TextBlock x:Name="lbl_counter1" FontSize="18"  VerticalAlignment="Center" Foreground="{DynamicResource cl_fg_pgrlbl1}" FontWeight="Bold"><Run Text="100"/></TextBlock>
                            <TextBlock x:Name="lbl_subInfo1" Text="Remaining Photos" Foreground="{DynamicResource cl_fg_pgrCont}" FontWeight="Regular" FontSize="14"/>
                        </StackPanel>
                    </DockPanel>
                    <DockPanel Margin="0 15 0 0 ">
                        <Image x:Name="img2" Source="{DynamicResource img_disk_space}" Width="50" Height="40" Margin="0 0 0 0"/>
                        <StackPanel>
                            <TextBlock x:Name="lbl_counter2" FontSize="18"  VerticalAlignment="Center" Foreground="{DynamicResource cl_fg_pgrlbl1}" FontWeight="Bold"><Run Text="520.28 MB"/></TextBlock>
                            <TextBlock x:Name="lbl_subInfo2" Text="Disk space to free up" Foreground="{DynamicResource cl_fg_pgrCont}" FontWeight="Regular" FontSize="14"/>
                        </StackPanel>
                    </DockPanel>
                </StackPanel>
            </Grid>

        </Grid>
        <Grid Grid.Row="2" Margin="15 0 10 0">
            <DockPanel >
                <DockPanel>
                    <Image x:Name="img_loading" Source="{DynamicResource img_loading}"  Width="18"
                           VerticalAlignment="Top" Height="20" Margin="0 2 5 0"/>
                    <TextBlock x:Name="lbl_scan" Foreground="{DynamicResource cl_fg_pgrlbl1}" FontSize="14" FontWeight="Regular"
                               Text="Scan Path: " Margin="0 0 5 0"/>
                    <TextBlock x:Name="lbl_scanPath" TextWrapping="Wrap" Foreground="{DynamicResource cl_fg_pgrlbl2}"
                               FontSize="14px" Text="C:\Users\admin\Pictures\"/>
                </DockPanel>
                <Button x:Name="btn_cancel" 
                        Style="{DynamicResource btn_Transparent_style}"
                        Foreground="{DynamicResource cl_fg_pgrlbl1}"
                        Background="{DynamicResource cl_bg_cancelbtn}"
                        FontSize="14" FontWeight="Regular"  Width="108" Height="32" 
                        VerticalAlignment="Top" Margin="0 0 10 0" HorizontalAlignment="Right"
                         Content="Cancel" Click="btn_cancel_Click"  >
                   
                </Button>
            </DockPanel>
        </Grid>
       
    </Grid>
</Window>
