        public bool Expired()
        {
            //return oArmadillo.Expired;//modified by anurag jain 2010-07-19 12-05
            //to be modified
            bool bRet = false;
            try
            {
                //bRet = ST_ARM_IsExpired();

              int nRetVal =  ST_XGetRegStatus();

              eSYS_TRIAL_VERSION_STATUS oStatus = (eSYS_TRIAL_VERSION_STATUS)nRetVal;

              switch (oStatus)
              {
                  case eSYS_TRIAL_VERSION_STATUS.STATUS_EVAL_VERSION_EXPIRED:                     
                  case eSYS_TRIAL_VERSION_STATUS.STATUS_SUBSCRIPTION_EXPIRED:
                      bRet = true;
                      break;
                  case eSYS_TRIAL_VERSION_STATUS.STATUS_SUBSCRIPTION_ACTIVATION_FAILED:
                      bRet = false;
                      break;
                  case eSYS_TRIAL_VERSION_STATUS.STATUS_EVAL_PERIOD_REMAINING:                      
                  case eSYS_TRIAL_VERSION_STATUS.STATUS_SUBSCRIPTION_REMAINING:
                      bRet = false;
                      break;
                  default:
                      break;
              }

            }
            catch (Exception oEx)
            {
                cGlobalSettings.oLogger.WriteLogException("Expired ::", oEx);
                //  oUtils.WriteToFile(string.Format("Expired()|error:{0}", oEx.Message));
            }
            return bRet;
        }


        public void ResetKey()
        {
            try
            {

                try
                {

                    string sPath = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.ApplicationData), ProductName);
                    if (Directory.Exists(sPath))
                    {
                        Directory.Delete(sPath, true);
                    }
                }
                catch (System.Exception ex)
                {
                    cGlobalSettings.oLogger.WriteLogException("GetFolderPath - ResetKey ::", ex);
                    //  oUtils.WriteToFile(string.Format("SetExpireKey()|unable to delete files |error:{0}", ex.Message));
                }


                RegistryKey oReg = Registry.LocalMachine.OpenSubKey("software\\k9");
                if (oReg != null)
                {
                    RegistryKey SubKey = Registry.LocalMachine.OpenSubKey("software", true);
                    SubKey.DeleteSubKeyTree("k9");
                    SubKey.Close();
                    oReg.Close();
                }


                oReg = Registry.CurrentUser.OpenSubKey("software\\k9");
                if (oReg != null)
                {
                    RegistryKey SubKey = Registry.CurrentUser.OpenSubKey("software", true);
                    SubKey.DeleteSubKeyTree("k9");
                    SubKey.Close();
                    oReg.Close();
                }
            }
            catch (System.Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("ResetKey ::", ex);
            }
        }
