                    case cClientEnum.eKeyActionToTake.KEY_BAD_EXPIRE_IT_SHOW_MSG_OPEN_BROWSER:
                    case cClientEnum.eKeyActionToTake.KEY_BAD_EXPIRE_IT_OPEN_BROWSER:
                    case cClientEnum.eKeyActionToTake.KEY_BAD_EXPIRE_IT_DOWNLOAD_EXE_AND_EXEC_SILENT:
                    case cClientEnum.eKeyActionToTake.KEY_GOOD_BUT_DO_NOT_ALLOW_REGISTRATION:
                        b_isClientAllowedToRegister = false;
                        break;
                    default:
                        break;
                }
            }
            catch (System.Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException(" cArmadilloHelper :: IsClientAllowedToRegister : ::", ex);
            }
            return b_isClientAllowedToRegister;
        }

        public string GetKeyErrorMessage(cClientEnum.eKeyActionToTake nReturnStatus)
        {
            string strMsg = string.Empty;
            bool b_isStatusGood = true;
            try
            {
                switch (nReturnStatus)
                {
                    case cClientEnum.eKeyActionToTake.KEY_RESERVED:
                    case cClientEnum.eKeyActionToTake.KEY_EVERYTHING_OK:
                    case cClientEnum.eKeyActionToTake.KEY_GOOD_CONTINUE:
                    case cClientEnum.eKeyActionToTake.INSTALL_A_NEW_KEY:
                    case cClientEnum.eKeyActionToTake.SET_DEFAULT_KEY:
                    case cClientEnum.eKeyActionToTake.GET_AND_INSTALL_A_NEW_KEY_ONBASEOF_CURRENT_KEY:
                    case cClientEnum.eKeyActionToTake.EXTEND_KEY_EXPIRY_DAYS:
                        b_isStatusGood = true;
                        break;
                    case cClientEnum.eKeyActionToTake.KEY_BAD_ONLY_OPEN_BROWSER:
                    case cClientEnum.eKeyActionToTake.KEY_BAD_DO_NOTHING:
                    case cClientEnum.eKeyActionToTake.KEY_BAD_ONLY_SHOW_MSG:
                    case cClientEnum.eKeyActionToTake.KEY_BAD_DOWNLOAD_EXE_AND_EXEC_SILENT:
                    case cClientEnum.eKeyActionToTake.KEY_BAD_EXPIRE_IT:
                    case cClientEnum.eKeyActionToTake.KEY_BAD_EXPIRE_IT_SHOW_MSG:
                    case cClientEnum.eKeyActionToTake.KEY_BAD_EXPIRE_IT_SHOW_MSG_OPEN_BROWSER:
                    case cClientEnum.eKeyActionToTake.KEY_BAD_EXPIRE_IT_OPEN_BROWSER:
                    case cClientEnum.eKeyActionToTake.KEY_BAD_EXPIRE_IT_DOWNLOAD_EXE_AND_EXEC_SILENT:
                        //   strMsg = cResourceManager.LoadString("KEY_VERIFICATION_ERROR_MSG2");//_T("Entered Key is not valid");
                        strMsg = "Entered Key is not valid";
                        break;
                    case cClientEnum.eKeyActionToTake.KEY_GOOD_BUT_DO_NOT_ALLOW_REGISTRATION:
                        b_isStatusGood = false;
                        // strMsg = cResourceManager.LoadString("KEY_VERIFICATION_ERROR_MSG3"); // _T("Entered Key is already used");
                        strMsg = "Entered Key is already used";
                        break;
                    default:
                        //strMsg = cResourceManager.LoadString("KEY_VERIFICATION_ERROR_MSG2");//_T("Entered Key is not valid");
                        strMsg = "Entered Key is not valid";
                        break;
                }
            }
            catch (System.Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException(" cArmadilloHelper :: GetKeyErrorMessage : ::", ex);
            }
            return strMsg;
        }


        public string GetActivationMessege(cClientEnum.ACTIVATION_MESSAGES oMsg)
        {
            string strMsg = string.Empty, strINIId = string.Empty;
            bool b_isStatusGood = true;
            try
            {

                switch (oMsg)
                {
                    /////////
                    //THE THREE VALUES BELOW ARE SAME
                    //BUT ARE USED JUST TO COVER SLOPPY PROGRAMMING 
                    case cClientEnum.ACTIVATION_MESSAGES.MSG_KEY_RESERVED:// = -1,
                    case cClientEnum.ACTIVATION_MESSAGES.MSG_KEY_EVERYTHING_OK:// = 0,
                    case cClientEnum.ACTIVATION_MESSAGES.MSG_KEY_GOOD_CONTINUE:// = 1,
                        ////////////////////////////////
                        b_isStatusGood = true;
                        strMsg = string.Empty;
                        break;
                    case cClientEnum.ACTIVATION_MESSAGES.MSG_KEY_PIRATED:// = 2, // Pirated key
                        strINIId = cResourceManager.LoadString("IDS_MSG_KEY_PIRATED");
                        break;
                    case cClientEnum.ACTIVATION_MESSAGES.MSG_KEY_FALSE:// = 3, // Invalid key == > THIS IS THE DEFAULT MESSAGE NOW ON
                        strINIId = cResourceManager.LoadString("IDS_MSG_KEY_FALSE");
                        break;
                    case cClientEnum.ACTIVATION_MESSAGES.MSG_KEY_BLOCKED:// = 4, // key is blocked
                        strINIId = cResourceManager.LoadString("IDS_MSG_KEY_BLOCKED");
                        break;
                    case cClientEnum.ACTIVATION_MESSAGES.MSG_KEY_REFUND:// = 5, // Key refunded
                        strINIId = cResourceManager.LoadString("IDS_MSG_KEY_BLOCKED");
                        break;
                    case cClientEnum.ACTIVATION_MESSAGES.MSG_KEY_EXPIRED:// = 6, // Key expired        
                        strINIId = cResourceManager.LoadString("IDS_MSG_KEY_EXPIRED");
                        break;
                    case cClientEnum.ACTIVATION_MESSAGES.MSG_KEY_LIMIT_EXCEEDED:// = 7, // Key used more than limit
                        strINIId = cResourceManager.LoadString("IDS_MSG_KEY_LIMIT_EXCEEDED");
                        break;
                    case cClientEnum.ACTIVATION_MESSAGES.MSG_KEY_ALREADY_NOT_IN_DB:// = 8, // Key not generated by portal
                        strINIId = cResourceManager.LoadString("IDS_MSG_KEY_FALSE");
                        break;
                    case cClientEnum.ACTIVATION_MESSAGES.MSG_KEY_FOUND_FOR_OTHER_PRODUCT:// = 9, // Key belongs to other product
                        strINIId = cResourceManager.LoadString("IDS_MSG_KEY_FALSE");
                        break;

                    // DeactivateReasons
                    case cClientEnum.ACTIVATION_MESSAGES.MSG_AUTO_EXPIRE_AFTER_TIME:// = 21,
                        strINIId = cResourceManager.LoadString("IDS_MSG_KEY_EXPIRED");
                        break;
                    case cClientEnum.ACTIVATION_MESSAGES.MSG_REFUND:// = 22,
                        strINIId = cResourceManager.LoadString("IDS_MSG_KEY_BLOCKED");
                        break;
                    case cClientEnum.ACTIVATION_MESSAGES.MSG_CHARGEBACK:// = 23,
                        strINIId = cResourceManager.LoadString("IDS_MSG_KEY_BLOCKED");
                        break;
                    case cClientEnum.ACTIVATION_MESSAGES.MSG_EXCEED_DOWNLOAD:// = 24,
                        strINIId = cResourceManager.LoadString("IDS_MSG_KEY_BLOCKED");
                        break;
                    case cClientEnum.ACTIVATION_MESSAGES.MSG_MISUSED:// = 25,
                        strINIId = cResourceManager.LoadString("IDS_MSG_KEY_BLOCKED");
                        break;
                    default:
                        break;
                }

                /*IDS_MSG_KEY_PIRATED = This license key has been blacklisted.
IDS_MSG_KEY_FALSE = Please enter a valid license key.
IDS_MSG_KEY_BLOCKED = This license key has been deactivated. 
IDS_MSG_KEY_EXPIRED = This license key has expired. Please purchase a new key.
IDS_MSG_KEY_LIMIT_EXCEEDED = You have exceeded maximum number of allowed machines for the key.
IDS_PP_REL_ISSUES = Privacy Related Issues
IDS_PP_EXPOS_TRACES = Privacy exposing traces on the PC
IDS_PP_EXPOSING_MALWARE_TOO = Privacy exposing traces which may include malware traces
IDS_MSG_UNREGISTERED_EXPIRE_VERSION = Unregister/Expired version*/


            }
            catch (System.Exception oEx)
            {
                cGlobalSettings.oLogger.WriteLogException("GetActivationMessege()|error:{0}", oEx);
              //  //  oUtils.WriteToFile(string.Format("GetActivationMessege()|error:{0}", oEx.Message));
            }
            return strINIId;
        }

        #endregion




        public bool IsRegistered()
        {
            //return oArmadillo.IsRegistered;//modified by anurag jain 2010-07-19 12-05
