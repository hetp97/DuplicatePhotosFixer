        /// <summary>
        /// return the user string
        /// </summary>
        /// <param name="nIndex">index of string to return</param>
        /// <param name="sUserString">buffer to hold the string</param>
        /// <param name="nLength">length of the string</param>
        /// <returns>true if successfull else false</returns>
        public bool GetUserString(int nIndex, out string sUserString, int nLength)
        {
            bool bRet = false;
            string sTempString = string.Empty;
            try
            {
                byte[] bByte = new byte[nLength];
                bRet = STGetUserString(nIndex, bByte, nLength);
                if (bRet)
                {
                    sTempString = Encoding.Default.GetString(bByte);
                    if (!string.IsNullOrEmpty(sTempString))
                    {
                        sTempString = sTempString.Trim(new char[] { '\0' });
                    }
                }
            }
            catch (Exception oEx)
            {
                cGlobalSettings.oLogger.WriteLogException("GetUserString ::", oEx);
                //  oUtils.WriteToFile(string.Format("GetUserString():error{0}", oEx.Message));
            }
            sUserString = sTempString;
            return bRet;
        }

        /// <summary>
