        /// <summary>
        /// get the value of environment variables
        /// </summary>
        /// <param name="sEnvName">Name of the environment variable whose value we have to retrieve</param>
        /// <returns>returns the value of the variable</returns>
        public string GetEnvironmentVariable(string sEnvName)
        {
            string sRet = string.Empty;
            try
            {
                IntPtr ptrResult = STGetEnvironmentvariable(sEnvName);
                if (ptrResult != IntPtr.Zero)
                {
                    sRet = Marshal.PtrToStringAuto(ptrResult);
                }
            }
            catch (Exception oEx)
            {
                cGlobalSettings.oLogger.WriteLogException("GetEnvironmentVariable ::", oEx);
                //  oUtils.WriteToFile(string.Format("GetEnvironmentVariable()|error:{0}", oEx.Message));
            }
            return sRet;
        }

