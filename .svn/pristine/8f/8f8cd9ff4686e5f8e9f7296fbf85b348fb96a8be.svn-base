        private void btnMinimize_Click(object sender, RoutedEventArgs e)
        {
            var winState = Application.Current.MainWindow.WindowState;
            if (winState == WindowState.Normal)
            {
                Application.Current.MainWindow.WindowState = WindowState.Minimized;
            }
            else
            {
                Application.Current.MainWindow.WindowState = WindowState.Normal;
            }
        }

        private void btnMaximize_Click(object sender, RoutedEventArgs e)
        {
            var winState = Application.Current.MainWindow.WindowState;
            if (winState == WindowState.Normal)
            {
                Application.Current.MainWindow.WindowState = WindowState.Maximized;

            }
            else
            {
                Application.Current.MainWindow.WindowState = WindowState.Normal;
            }
        }

        private void btn_close_Click(object sender, RoutedEventArgs e)
        {

            App.oMainReference = (MainWindow)Window.GetWindow(this);
            App.oMainReference.Close();
        }

        private void LanguageComboBox_SelectionChanged(object sender, SelectionChangedEventArgs e)
        {
            var selectedItem = (LanguageItem)languageComboBox.SelectedItem;

            if (selectedItem != null)
            {
               
                lnkLblLang.Image = new BitmapImage(new Uri(selectedItem.FlagImagePath, UriKind.Relative));

                //flag_img.Source = new BitmapImage(new Uri(selectedItem.FlagImagePath, UriKind.Relative));
            }
        }

        private void linklblSettings_Click(object sender, RoutedEventArgs e)
        {
            App.oSettingsfrm = new Views.frmSettings();
            App.oSettingsfrm.ShowDialog();
        }

