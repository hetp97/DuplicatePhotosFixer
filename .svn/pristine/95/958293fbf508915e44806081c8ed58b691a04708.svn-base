<Window x:Class="DuplicatePhotosFixer.UserControls.ucClearCache"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:cust ="clr-namespace:DuplicatePhotosFixer.CustomControl"
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
            Height="152" Width="409"  WindowStyle="None" AllowsTransparency="True" WindowStartupLocation="CenterScreen"  Background="{DynamicResource bgrclr_solidgray}">
    <Window.Resources>
        <Style TargetType="Button" x:Name="btn_close">
            <Setter Property="Background" Value="#888888"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>

            </Style.Triggers>
        </Style>

    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="44"/>
        </Grid.RowDefinitions>
        <DockPanel VerticalAlignment="Center" Margin="5">
            <Button DockPanel.Dock="Right"  Background="Transparent"                
                    BorderBrush="Transparent"
                    Cursor="Hand"
                    Click="close_btn_click" Style="{StaticResource stl_btnClose}">
                <Image Source="/Resources/closevpn.png" Stretch="None"  >
                    <Image.ToolTip>Close</Image.ToolTip>
                </Image>
            </Button>
            <TextBlock x:Name="dpf_heading" Text="Duplicate Photos Fixer Pro" FontSize="12" Foreground="#cecece" />
        </DockPanel>
        <Grid Grid.Row="1">
            <DockPanel Margin="20 0 0 0">
                <Image x:Name="exclaim_image" Source="{DynamicResource img_alert_icon_trans}" Stretch="None" Margin="0 0 5 0"/>
                <TextBlock x:Name="lblinfo" VerticalAlignment="Center"
                            FontWeight="Regular"
                           FontSize="13"
                           Foreground="#fff" TextWrapping="Wrap">
                    It will clear your scan results and data related to current scan
                    and previous scans. Are you sure you want to do this?
                </TextBlock>
            </DockPanel>
        </Grid>
        <Grid Grid.Row="2" >
            <DockPanel HorizontalAlignment="Right">
                <Button x:Name="btnYes" Width="120" Height="33"  Content="Yes" Margin="0 0 20 0"
                         HorizontalAlignment="Right" VerticalAlignment="Center"  Grid.Column="3" >
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="TextBlock.TextAlignment" Value="Center" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bdr_main"  BorderThickness="1" Background="#2B9FD2">
                                            <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"                                                              
                                                              TextElement.FontSize="13"
                                                              TextElement.Foreground="White">
                                            </ContentPresenter>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" TargetName="bdr_main" Value="#3FB3E6">
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="true">
                                                <Setter Property="Background" TargetName="bdr_main" Value="#178BBE">
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                                <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="btnNo" Content="No" Grid.Column="2" Width="120" Height="33" 
                         HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"  >
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="TextBlock.TextAlignment" Value="Center" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bdr_main"  BorderThickness="1" BorderBrush="#4E4E4E" Background="Transparent">
                                            <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="White">
                                            </ContentPresenter>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" TargetName="bdr_main" Value="#494949"></Setter>
                                                <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                <Setter Property="Background" TargetName="bdr_main" Value="#494949"></Setter>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="true">
                                                <Setter Property="BorderBrush" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                <Setter Property="Background" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                                <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

            </DockPanel>
        </Grid>
    </Grid>
</Window>
