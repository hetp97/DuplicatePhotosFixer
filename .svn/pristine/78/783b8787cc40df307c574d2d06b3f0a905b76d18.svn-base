	//	/// <param name="handle">Handle to wrap</param>
	//	public WindowWrapper(IntPtr handle)
	//	{
	//		_hwnd = handle;
	//	}

	//	/// <summary>
	//	/// Original ptr
	//	/// </summary>
	//	public IntPtr Handle
	//	{
	//		get { return _hwnd; }
	//	}

	//	private IntPtr _hwnd;
	//}

}
