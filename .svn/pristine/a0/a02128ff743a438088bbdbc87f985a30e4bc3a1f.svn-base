using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.IO;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using DuplicatePhotosFixer.App_Code;
using DuplicatePhotosFixer.ClassDictionary;
using DuplicatePhotosFixer.HelperClasses;
using Microsoft.Win32;

namespace DuplicatePhotosFixer.Models
{
   public class vmExtraSettings : INotifyPropertyChanged
    {
        public event PropertyChangedEventHandler PropertyChanged;
        public void OnPropertyChanged(string name)
        {
            PropertyChangedEventHandler handler = PropertyChanged;
            if (handler != null)
            {
                handler(this, new PropertyChangedEventArgs(name));
            }
        }

         int _bConsiderTimeInterval = -1;
        public  bool bConsiderTimeInterval
        {
            get
            {
                if (_bConsiderTimeInterval == -1)
                {
                    _bConsiderTimeInterval = Convert.ToInt32(GetUserAppDataRegistryValue(cRegistrySettings.REGSTR_CONSIDER_TIME_INTERVAL, 1));
                }
                return _bConsiderTimeInterval == 0 ? false : true;
            }
            set
            {
                SetUserAppDataRegistryValue(cRegistrySettings.REGSTR_CONSIDER_TIME_INTERVAL, value ? 1 : 0, RegistryValueKind.DWord);
                _bConsiderTimeInterval = value ? 1 : 0;
                SaveExtraSettings();
                OnPropertyChanged("bConsiderTimeInterval");
            }
        }

        int _bConsiderGPS = -1;
        public  bool bConsiderGPS
        {
            get
            {
                if (_bConsiderGPS == -1)
                {
                    _bConsiderGPS = Convert.ToInt32(GetUserAppDataRegistryValue(cRegistrySettings.REGSTR_CONSIDER_GPS, 1));
                }
                return _bConsiderGPS == 0 ? false : true;
            }
            set
            {
                SetUserAppDataRegistryValue(cRegistrySettings.REGSTR_CONSIDER_GPS, value ? 1 : 0, RegistryValueKind.DWord);
                _bConsiderGPS = value ? 1 : 0;
                SaveExtraSettings();
                OnPropertyChanged("bConsiderGPS");
            }
        }

         int _bConsiderTimeNoCaptureDt = -1;
        /// <summary>
        /// Include time interval settings if capture date is not available.
        /// </summary>
        public  bool bConsiderTimeNoCaptureDt
        {
            get
            {
                if (_bConsiderTimeNoCaptureDt == -1)
                {
                    _bConsiderTimeNoCaptureDt = Convert.ToInt32(GetUserAppDataRegistryValue(cRegistrySettings.REGSTR_CONSIDER_TIME_NO_CAPTURE_DT, 0));
                }
                return _bConsiderTimeNoCaptureDt == 0 ? false : true;
            }
            set
            {
                SetUserAppDataRegistryValue(cRegistrySettings.REGSTR_CONSIDER_TIME_NO_CAPTURE_DT, value ? 1 : 0, RegistryValueKind.DWord);
                _bConsiderTimeNoCaptureDt = value ? 1 : 0;
                SaveExtraSettings();
                OnPropertyChanged("bConsiderTimeNoCaptureDt");
            }
        }


        int _bIncludeRotatedImages = -1;
        public  bool bIncludeRotatedImages
        {
            get
            {
                if (_bIncludeRotatedImages == -1)
                {
                    _bIncludeRotatedImages = Convert.ToInt32(GetUserAppDataRegistryValue(cRegistrySettings.REGSTR_INCLUDE_ROTATED_IMAGES, 1));
                }
                return _bIncludeRotatedImages == 0 ? false : true;
            }
            set
            {
                SetUserAppDataRegistryValue(cRegistrySettings.REGSTR_INCLUDE_ROTATED_IMAGES, value ? 1 : 0, RegistryValueKind.DWord);
                _bIncludeRotatedImages = value ? 1 : 0;
                SaveExtraSettings();
                OnPropertyChanged("bIncludeRotatedImages");
            }
        }

        int  _bIncludeFlippedImages = -1;
        public  bool bIncludeFlippedImages
        {
            get
            {
                if (_bIncludeFlippedImages == -1)
                {
                    _bIncludeFlippedImages = Convert.ToInt32(GetUserAppDataRegistryValue(cRegistrySettings.REGSTR_INCLUDE_FLIPPED_IMAGES, 1));
                }
                return _bIncludeFlippedImages == 0 ? false : true;
            }
            set
            {
                SetUserAppDataRegistryValue(cRegistrySettings.REGSTR_INCLUDE_FLIPPED_IMAGES, value ? 1 : 0, RegistryValueKind.DWord);
                _bIncludeFlippedImages = value ? 1 : 0;
                SaveExtraSettings();
                OnPropertyChanged("bIncludeFlippedImages");
            }

        }

        public vmExtraSettings()
        {
            LoadExtraSettings();
        }

        public void SetUIPropertiesValue()
        {
            if (cGlobalSettings.ExtraSettings == null)
                LoadExtraSettings();

            bConsiderTimeInterval = cGlobalSettings.ExtraSettings.DbConsiderTimeInterval;
            bConsiderGPS = cGlobalSettings.ExtraSettings.DbConsiderGPS;
            bConsiderTimeNoCaptureDt = cGlobalSettings.ExtraSettings.DbConsiderTimeNoCaptureDt;
            bIncludeFlippedImages = cGlobalSettings.ExtraSettings.DbIncludeFlippedImages;
            bIncludeRotatedImages = cGlobalSettings.ExtraSettings.DbIncludeRotatedImages;

        }

        public void LoadExtraSettings(bool bLoadDefaultFocefully = false)
        {
            try
            {
                if (bLoadDefaultFocefully)
                {
                    LoadDefaultSettings();
                    return;
                }
                LoadSavedSettings();

                if (cGlobalSettings.ExtraSettings == null)
                    LoadExtraSettings(true);

            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("vmExtraSettings:: LoadExtraSettings: ", ex);
            }
        }

        void LoadDefaultSettings()
        {
            try
            {
                cGlobalSettings.ExtraSettings = new cExtraSettings()
                {
                    DbConsiderTimeInterval = cExtraSettings.bDConsiderTimeInterval,
                    DbConsiderGPS = cExtraSettings.bDConsiderGPS,
                    DbConsiderTimeNoCaptureDt = cExtraSettings.bDConsiderTimeNoCaptureDt,
                    DbIncludeRotatedImages = cExtraSettings.bDConsiderRotated,
                    DbIncludeFlippedImages = cExtraSettings.bDCondiserFlipped
                  
                };
            }


            catch (Exception ex)
            {

                cGlobalSettings.oLogger.WriteLogException("vmExtraSettings:: LoadDefaultSettings: ", ex);
            }
        }


        void LoadSavedSettings()
        {
            try
            {
                if (File.Exists(cGlobalSettings.xmlExtraSettings))
                {
                    /// Desearlize the strings
                    /// Fill SettingsData
                    /// 
                    cGlobalSettings.ExtraSettings = cSerializer.DeSerializeObject<cExtraSettings>(cGlobalSettings.xmlExtraSettings);
                }
            }
            catch (Exception ex)
            {

            }
        }

        public void SaveExtraSettings()
        {
            try
            {
                /// Save cGlobalSettings.ExtraSettingsData in xml file 
                /// 
                cSerializer.SerializeToXML<cExtraSettings>(cGlobalSettings.ExtraSettings, cGlobalSettings.xmlExtraSettings);
            }
            catch (Exception ex)
            {

            }
        }
        public static string VersionIndependentRegKey
        {
            get
            {
                string versionDependent = System.Windows.Forms.Application.UserAppDataRegistry.Name;
                string versionIndependent =
                       versionDependent.Substring(0, versionDependent.LastIndexOf("\\"));

                //   versionIndependent = string.Format("{0}\\{1}", versionIndependent, cGlobalSettings.nUserMachineId);

                return versionIndependent;
            }
        }

        public static string VersionIndependentRegKeyNoHive
        {
            get
            {
                string versionDependent = System.Windows.Forms.Application.UserAppDataRegistry.Name;
                string versionIndependent =
                       versionDependent.Substring(0, versionDependent.LastIndexOf("\\"));

                versionIndependent = versionIndependent.Substring(versionIndependent.IndexOf("\\") + 1);

                // versionIndependent = string.Format("{0}\\{1}", versionIndependent, cGlobalSettings.nUserMachineId);

                return versionIndependent;
            }
        }

        public static object GetUserAppDataRegistryValue(string name, object defaultValue)
        {
            return Registry.GetValue(VersionIndependentRegKey, name, defaultValue) ?? defaultValue;
        }

        public static string VersionIndependentRootRegKey
        {
            get
            {
                string versionDependent = System.Windows.Forms.Application.UserAppDataRegistry.Name;
                string versionIndependent =
                       versionDependent.Substring(0, versionDependent.LastIndexOf("\\"));

                // versionIndependent = string.Format("{0}\\{1}", versionIndependent, cGlobalSettings.nUserMachineId);

                return versionIndependent;
            }
        }
        public static object GetUserAppDataRegistryValue(string name)
        {
            return GetUserAppDataRegistryValue(name, null);
        }

        public static void SetUserAppDataRootRegistryValue(string name, object value, RegistryValueKind kind)
        {
            if (Registry.CurrentUser.OpenSubKey(VersionIndependentRegKeyNoHive) == null)
            {
                Registry.CurrentUser.CreateSubKey(VersionIndependentRegKeyNoHive);
            }
            Registry.SetValue(VersionIndependentRootRegKey, name, value, kind);
        }


        public static void SetUserAppDataRootRegistryValueNotifier(string name, object value, RegistryValueKind kind)
        {
            string strRegPath = VersionIndependentRegKeyNoHive + "\\" + AppNotifier.Notifier.notifierName;
            if (Registry.CurrentUser.OpenSubKey(strRegPath) == null)
            {
                Registry.CurrentUser.CreateSubKey(strRegPath);
            }
            Registry.SetValue(VersionIndependentRootRegKey + "\\" + AppNotifier.Notifier.notifierName, name, value, kind);
        }

        public static void SetUserAppDataRegistryValue(string name, object value, RegistryValueKind kind)
        {
            if (Registry.CurrentUser.OpenSubKey(VersionIndependentRegKeyNoHive) == null)
            {
                Registry.CurrentUser.CreateSubKey(VersionIndependentRegKeyNoHive);
            }
            Registry.SetValue(VersionIndependentRegKey, name, value, kind);
        }

       

    }
}
