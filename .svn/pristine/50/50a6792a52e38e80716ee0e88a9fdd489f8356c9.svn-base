<Window x:Class="DuplicatePhotosFixer.Nags.nagMessageUpgradeNow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Nags"
        mc:Ignorable="d"
        Title="Duplicate Photo Fixer Pro - Connect with us" Height="379" Width="763">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition MinWidth="80" Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Image x:Name="info_img" Source="/Resources/info-icon.png" Width="53" Height="49" VerticalAlignment="Top"
                   Margin="0 20 0 0"/>
            <Grid Grid.Column="1" Margin="0 20 0 0">
                <StackPanel>
                    <TextBlock x:Name="rtb_totalPhotos" Text="Duplicate Photos found:"
                               FontSize="17"
                               FontWeight="Bold" Foreground="Black" Margin="0 0 0 10"/>
                    <TextBlock x:Name="rtb_totlaSize" Text="Space to be Saved"
                               FontSize="17"
                               FontWeight="Bold" Foreground="Black"
                               Margin="0 10 0 0"/>
                    <TextBlock x:Name="label4" FontSize="13"
                               Margin="0 20 0 20">
                        Thanks you for using Duplicate Photos Fixer. Last scan revealed that duplicates are using significant<LineBreak/> amount of space which can be recovered in few simple clicks.
                    </TextBlock>
                    <TextBlock x:Name="richTextBoxEx1" FontSize="13"
                               Margin="0 10 0 0">
                       and continue removing duplicates and recover your valuable space.
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Grid>
        <Grid Grid.Row="1" Background="#F0F0F0">
            <DockPanel Margin="10 0 10 0">
                <TextBlock x:Name="llNoThanks"
                           DockPanel.Dock="Left"
                           FontSize="13"
                           VerticalAlignment="Center">
                    <Hyperlink>No Thanks</Hyperlink>
                </TextBlock>
                <Button x:Name="btnUpgradeNow" Width="227" Height="41"
                            Content="Upgrade Now"
                            Margin="0 10 20 0"
                        HorizontalAlignment="Right">
                    <Button.Background>
                        <LinearGradientBrush  StartPoint="0,0" EndPoint="0 ,1">
                            <GradientStop Color="#F1F1F1" Offset="0"/>
                            <GradientStop Color="LightGray" Offset="0.555"/>
                            <GradientStop Color="#F1F1F1" Offset="0.03"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

            </DockPanel>


        </Grid>
    </Grid>
</Window>
