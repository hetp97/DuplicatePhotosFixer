            </TabItem>
            <TabItem Header="Scan Criteria" 
                      Padding="3"
                     FontSize="12"
                      Width="145"
                      Height="40" Background="#F5F5F5">
                <uc:ucExtraSettings/>
            </TabItem>
            <TabItem Header="Move Duplicates" 
                      Padding="3"
                     FontSize="12"
                      Width="145"
                      Height="40"
                     Background="#F5F5F5">
                <uc:ucSettingsMove/>
            </TabItem>



        </TabControl>
                    
                </StackPanel>

              
            </Grid>

            <Grid Grid.Column="1">
                
            </Grid>-->

        </Grid>
        <Grid Grid.Row="2" Background="#D5D5D5" HorizontalAlignment="Left">
            <Button Grid.Row="2" x:Name="btnReset" Background="#888888"
                    Foreground="White"
                    FontWeight="SemiBold"
                Content="Reset Settings" Height="30" Width="132" 
                    Margin="10 0" Style="{DynamicResource styl_reset_btn}"
                HorizontalAlignment="Left" Click="btnReset_Click">
            </Button>
        </Grid>
       
