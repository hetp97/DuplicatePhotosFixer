<Window x:Class="DuplicatePhotosFixer.Views.frmSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
         xmlns:uc="clr-namespace:DuplicatePhotosFixer.UserControls"
        mc:Ignorable="d"
        Title="frmSettings" Height="576" Width="665" WindowStyle="None"
        Background="{DynamicResource bgrclr_solidgray}" Visibility="Visible" x:Name="settingsWindow" WindowStartupLocation="CenterScreen">
    <Window.Resources>
       
            <Style TargetType="Button" x:Name="btn_close">
                <Setter Property="Background" Value="#888888"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="Transparent"/>
                    </Trigger>

                </Style.Triggers>
            </Style>
       
    </Window.Resources>
    <Grid Margin="5 0 5 5">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="57"/>

        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Margin="20 5 20 0" >
            <TextBlock Text="Duplicate Photo Fixer Pro" Foreground="{DynamicResource frgclr_white}" VerticalAlignment="Center" FontSize="15"/>

            <Button DockPanel.Dock="Right" Height="20" Width="20" Background="#444445"
                    BorderBrush="{DynamicResource clr_darkborder}" Style="{StaticResource stl_btnClose}"
                    Click="Button_Click">
                <Image Source="{DynamicResource img_close}" />
            </Button>
            <TextBlock Text="Settings" Foreground="{DynamicResource frgclr_gray}" FontSize="15" VerticalAlignment="Center" Padding="10 0"/>
        </DockPanel>
        <Grid Grid.Row="1" Grid.RowSpan="2" Background="{DynamicResource frgclr_white}" >
            <uc:ucSettings Loaded="ucSettings_Loaded_1"  />
            <!--<Grid.ColumnDefinitions>
                <ColumnDefinition Width="141"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="{DynamicResource bgrclr_grayish}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="57"/>
