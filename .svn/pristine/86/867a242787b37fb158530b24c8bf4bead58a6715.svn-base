        void FillScanModes()
        {
            try
            {
                lstScanModeData = new List<ScanModeData>();
                var fontSize = 12.0;
                lstScanModeData.Add(new ScanModeData() { ModeName = cResourceManager.LoadString("DPF_SCAN_COMPUTER"), ModeIcon = @"\Resources\pc.png", IconMargin = "0", ModeType = eScanMode.FileSearch, cboFontSize = fontSize, ItemHeight = 40 });
                lstScanModeData.Add(new ScanModeData() { ModeName = cResourceManager.LoadString("DPF_SCAN_GOOGLE"), ModeIcon = @"\Resources\drive.png", IconMargin = "0", ModeType = eScanMode.GoogleDrive, cboFontSize = fontSize, ItemHeight = 40 });
                lstScanModeData.Add(new ScanModeData() { ModeName = cResourceManager.LoadString("IDS_SCAN_DROPBOX"), ModeIcon = @"\Resources\dropbox_img.png", IconMargin = "0", ModeType = eScanMode.Dropbox, cboFontSize = fontSize, ItemHeight = 40 });
                lstScanModeData.Add(new ScanModeData() { ModeName = cResourceManager.LoadString("DPF_SCAN_Picasa_LIBRARY"), ModeIcon = @"\Resources\picasa15x15.png", IconMargin = "0", ModeType = eScanMode.Dropbox, cboFontSize = fontSize, ItemHeight = 40 });
                lstScanModeData.Add(new ScanModeData() { ModeName = cResourceManager.LoadString("IDS_LIGHTROOM_CLASSIC"), ModeIcon = @"\Resources\Lightroom_15x15.png", IconMargin = "0", ModeType = eScanMode.Dropbox, cboFontSize = fontSize, ItemHeight = 40 });
                lstScanModeData.Add(new ScanModeData() { ModeName = cResourceManager.LoadString("IDS_PHOTOS_ORGANIZER"), ModeIcon = @"\Resources\po_logo_small.png", IconMargin = "0", ModeType = eScanMode.Dropbox, cboFontSize = fontSize, ItemHeight = 40 });

            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("ucHomeViewModel:: FillScanModes: ", ex);
            }
        }

      public  void FillScanPaths(bool bLoadCurrentTypeListOnly)
        {
            try
            {
                /// Get xml files data 
                /// 
                csXmlOperations.LoadScanPathsList();
                if (bLoadCurrentTypeListOnly)
                {
                    switch (cGlobalSettings.CurrentTypeOfInclusion)
                    {
                        case eTypeOfInclusion.Included:
                            lstScanPathsInclude = new ObservableCollection<csScanPaths>();
                            break;

                        case eTypeOfInclusion.Protected:
                            lstScanPathsProtected = new ObservableCollection<csScanPaths>();
                            break;
                        default:
                            break;
                    }
                }

                for (int i = 0; i < cGlobalSettings.listScanPaths.Count; i++)
                {
                    if (bLoadCurrentTypeListOnly && cGlobalSettings.listScanPaths[i].TypeOfInclusion != cGlobalSettings.CurrentTypeOfInclusion)
                        continue;

                    switch (cGlobalSettings.listScanPaths[i].TypeOfInclusion)
                    {
                        case eTypeOfInclusion.Included:
                            lstScanPathsInclude.Add(cGlobalSettings.listScanPaths[i]);
                            break;

                        case eTypeOfInclusion.Protected:
                            lstScanPathsProtected.Add(cGlobalSettings.listScanPaths[i]);
                            break;
                        default:
                            break;
                    }

                    if (cGlobalSettings.listScanPaths[i].TypeOfInclusion != eTypeOfInclusion.Included)
                        continue;
                }
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("ucHomeViewModel:: FilScanPaths: ", ex);
            }
        }

        public bool AddPhotoPaths(bool bShowErrorMsg, eTypeOfInclusion typeOfInclusion)
        {
            bool bAdded = false;
            Nullable<bool> result = false;
            try
            {

                string statusMessage = string.Empty;
                //string[] selectedFile = null;
                csFileTypes.initillizeFileTypes();

                var FileTypesToAdd = cGlobalSettings.listFileType.Where(p => p.Key >= -1);
                foreach (var item in FileTypesToAdd)
                {
                    cGlobalSettings.FileDialogFilterList += item.Value.FileDialogFilterItem;

                }

                ofd = new OpenFileDialog();
                ofd.Filter = cGlobalSettings.GetFileDialogFileFilter + "|\n";
                ofd.Multiselect = true;
                ofd.FileName = "";
                string InitDir = cGlobalSettings.GetInitialDirectory;
                if (!string.IsNullOrEmpty(InitDir))
                    ofd.InitialDirectory = InitDir;
                //selectedFile = HelperClasses.cSelectFilesFolders.ShowFile_System(App.oMainReference);

                //if (selectedFile == null || selectedFile.Length <= 0)
                //    return false;

                /// Validate Path and add in a scan path list
                /// 

                bool isListUpdated = false;
                result = ofd.ShowDialog();

                if (result == true)
                {
                    foreach (string strPath in ofd.FileNames)
                    {

                        csScanPaths scanPathData = new csScanPaths()
                        {
                            myVisibility = Visibility.Collapsed,
                            IsCheckboxEnabled = false,
                            IsSelected = true,
                            PathType = cClientEnum.ePathType.file,
                            ScanPath = strPath,
                            //TypeOfInclusion = typeOfInclusion,
                            IncludeSubfolder = false,
                            ImageIcon = "/Resources/btn_pic.png"

                        };

                        if (objMainScanHelper.DValidatePath(strPath, ref statusMessage))
                        {
                            cGlobalSettings.listScanPaths.Add(scanPathData);
                            isListUpdated = true;
                        }

                    }

                    if (!string.IsNullOrEmpty(statusMessage))
                    {
                        App.oMainReference.showMessage(statusMessage, "");
                    }


                    /// Save path in xml
                    /// 
                    if (isListUpdated)
                    {
                        csXmlOperations.SaveScanPathsList(cGlobalSettings.listScanPaths);
                        FillScanPaths(true);
                        bAdded = true;
                    }


                }
            }
            catch (Exception ex)
            {


            }

            return bAdded;
        }

        public bool AddScanPaths(bool bShowErrorMsg, eTypeOfInclusion typeOfInclusion)
        {
            bool bAdded = false;
            try
            {
                string statusMessage = string.Empty;
                string[] selectedPaths = null;
                if (!cGlobalSettings.objScanner.Browse(out selectedPaths))
                    return false;

                if (selectedPaths == null || selectedPaths.Length <= 0)
                    return false;

                /// Validate Path and add in a scan path list
                /// 
                bool isListUpdated = false;
                for (int i = 0; i < selectedPaths.Length; i++)
                {

                    csScanPaths scanPathData = new csScanPaths()
                    {
                        myVisibility = Visibility.Visible,
                        IsSelected = true,
                        IsCheckboxEnabled = true,
                        PathType = cClientEnum.ePathType.folder,
                        ScanPath = selectedPaths[i],
                        TypeOfInclusion = typeOfInclusion,
                        IncludeSubfolder = true,
                        ImageIcon = @"/Resources/btn_folder.png"

                    };

                    if (objMainScanHelper.DValidatePath(selectedPaths[i], ref statusMessage))
                    {
                        cGlobalSettings.listScanPaths.Add(scanPathData);
                        isListUpdated = true;
                    }

                }

                if (!string.IsNullOrEmpty(statusMessage))
                {
                    App.oMainReference.showMessage(statusMessage,"");
                }


                /// Save path in xml
                /// 
                if (isListUpdated)
                {
                    csXmlOperations.SaveScanPathsList(cGlobalSettings.listScanPaths);
                    FillScanPaths(true);
                    bAdded = true;
                }
            }
            catch (Exception ex)
            {

            }
            return bAdded;
        }

