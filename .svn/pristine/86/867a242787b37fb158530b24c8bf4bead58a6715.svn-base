        public void RemoveItemFromScanList(object sender)
        {
            try
            {
                // Close context Menu
                //CloseMenu(sender, e);

                eTypeOfInclusion SelectedTabForLocations = cGlobalSettings.CurrentTypeOfInclusion;

                if (App.oMainReference.UiWait)
                {
                    return;
                }
                //Cursor = Cursors.Wait;
              App.oMainReference.UiWait = true;

                string strPath = Convert.ToString(((TextBlock)sender).Tag);

                if (string.IsNullOrEmpty(strPath))
                    return;

               
                            csScanPaths selectedpath = lstScanPathsInclude.FirstOrDefault(x => string.Compare(x.ScanPath, strPath, true) == 0);

                            // ---------------- Update Scan Path list ----------------
                            removePathFromList(strPath, SelectedTabForLocations);

                            // ---------------- Change in XML document ----------------
                            csXmlOperations.removeXmlElement(strPath, SelectedTabForLocations);

                            /// Remove from Binding list
                            lstScanPathsInclude.Remove(selectedpath);
                      
            }
            catch (Exception ex)
            {

            }
            finally
            {
                //Cursor = Cursors.Arrow;
                App.oMainReference.UiWait = false;
            }
        }

        public void RemoveAllItemScanList(object sender)
        {
            try
            {
                // Close context Menu
                //CloseMenu(sender, e);

                eTypeOfInclusion SelectedTabForLocations = cGlobalSettings.CurrentTypeOfInclusion;

                if (App.oMainReference.UiWait)
                {
                    return;
                }
                //Cursor = Cursors.Wait;
                App.oMainReference.UiWait = true;


                foreach (csScanPaths str in lstScanPathsInclude)
                {
                    // ---------------- Update Scan Path list ----------------
                    removePathFromList(str.ScanPath, SelectedTabForLocations);

                    /// ---------------- Change in XML document ----------------
                    /// Check if path is included both in Included and Excluded list
                    /// 
                    csXmlOperations.removeXmlElement(str.ScanPath, SelectedTabForLocations);
                }

                /// Remove from Binding list
                lstScanPathsInclude.Clear();
            
                
            }
            catch (Exception ex)
            {

            }
            finally
            {
                //Cursor = Cursors.Arrow;
                App.oMainReference.UiWait = false;
            }
        }
    }
