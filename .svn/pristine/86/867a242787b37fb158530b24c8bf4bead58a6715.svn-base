        public void doDragDrop(DragEventArgs e)
        {

            string statusMessage = string.Empty;
          
            if (e.Data.GetDataPresent(DataFormats.FileDrop) && (cGlobalSettings.CurrentScanMode == eScanMode.FileSearch ||
                cGlobalSettings.CurrentScanMode == eScanMode.PicasaLibrary || cGlobalSettings.CurrentScanMode == eScanMode.Lightroom || cGlobalSettings.CurrentScanMode == eScanMode.BoxCloud))
            {             

                /// Validate Path and add in a scan path list
                /// 
                bool isListUpdated = false;
                foreach(string strPath in (string[])e.Data.GetData(DataFormats.FileDrop, false))
                {
                    bool isFolder = File.GetAttributes(strPath).HasFlag(FileAttributes.Directory);
                    if(isFolder == true) {

                        csScanPaths scanPathData = new csScanPaths
                        {
                            myVisibility = Visibility.Visible,
                            IsSelected = true,
                            IsCheckboxEnabled = true,
                            PathType = cClientEnum.ePathType.folder,
                            ScanPath = strPath,                      
                            IncludeSubfolder = true,
                            ImageIcon = @"/Resources/btn_folder.png"


                        };
                        if (objMainScanHelper.DValidatePath(strPath, ref statusMessage))
                        {
                            cGlobalSettings.listScanPaths.Add(scanPathData);
                            isListUpdated = true;
                        }
                    }

                    else if (isFolder == false)
                    {
                        csScanPaths scanPathData = new csScanPaths
                        {
                            myVisibility = Visibility.Collapsed,
                            IsCheckboxEnabled = false,
                            IsSelected = true,
                            PathType = cClientEnum.ePathType.file,
                            ScanPath = strPath,
                            //TypeOfInclusion = typeOfInclusion,
                            IncludeSubfolder = false,
                            ImageIcon = "/Resources/btn_pic.png"

                        };
                        if (objMainScanHelper.DValidatePath(strPath, ref statusMessage))
                        {
                            cGlobalSettings.listScanPaths.Add(scanPathData);
                            isListUpdated = true;
                        }
                    }
                   
                  
                   

                }

                if (!string.IsNullOrEmpty(statusMessage))
                {
                    App.oMainReference.showMessage(statusMessage ,"");
                }


                /// Save path in xml
                /// 
                if (isListUpdated)
                {
                    csXmlOperations.SaveScanPathsList(cGlobalSettings.listScanPaths);
                    FillScanPaths(true);
                   
                }
            }
        }

        public bool RemoveScanPath(csScanPaths RemoveScanPath)
        {
            try
            {
                cGlobalSettings.listScanPaths.Remove(RemoveScanPath);
                csXmlOperations.SaveScanPathsList(cGlobalSettings.listScanPaths);
                FillScanPaths(true);
                return true;
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("ucHomeViewModel:: RemoveScanPath: ", ex);
            }
            return false;
        }
        public void alterListScanPath(string SelectedPath, bool newSelectedstatus, string RememberMe, eTypeOfInclusion inclusionType, bool IncludeSubFolder = true, bool ScanIncludeSubFolder = true)
        {
            try
            {
            

                cGlobalSettings.listScanPaths = cGlobalSettings.listScanPaths.Select(p =>
                {
                    if (p.ScanPath.AddBackSlash().ToLower() == SelectedPath.Trim().ToLower().AddBackSlash() && p.TypeOfInclusion == inclusionType)
                    {
                        p.IsSelected = newSelectedstatus;
                    }
                    return p;
                }).ToList();

                csXmlOperations.SaveScanPathsList(cGlobalSettings.listScanPaths);
                FillScanPaths(true);
              

            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("ucHomeViewModel ::alterListScanPath::", ex);
            }
        }

        internal void removePathFromList(string selectedPath, eTypeOfInclusion SelectedTab)
        {
            object isPathAlreadyAdded = null;
            try
            {
                if (SelectedTab == eTypeOfInclusion.Included)
                {
                    isPathAlreadyAdded = cGlobalSettings.listScanPaths.Where(x => x.TypeOfInclusion == eTypeOfInclusion.Included && x.ScanPath.RemoveEndBackSlash().ToLower().Trim() == selectedPath.RemoveEndBackSlash().ToLower().Trim()).FirstOrDefault();
                }
                else
                {
                    isPathAlreadyAdded = cGlobalSettings.listScanPaths.Where(x => x.TypeOfInclusion != eTypeOfInclusion.Included && x.ScanPath.RemoveEndBackSlash().ToLower().Trim() == selectedPath.RemoveEndBackSlash().ToLower().Trim()).FirstOrDefault();/*.Single(p => p.Path.AddBackSlash().ToLower() == selectedPath.AddBackSlash().ToLower().Trim());*/
                }

                if (isPathAlreadyAdded != null)
                {
                    cGlobalSettings.listScanPaths.Remove((csScanPaths)isPathAlreadyAdded);
                    isPathAlreadyAdded = null;
                }
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("ucHomeViewModel :: removePathFromList", ex);
            }
        }


        public void RevealExplorer(object sender)
        {
            ProcessStartInfo showExplorer = null;
            try
            {
                // Close context Menu
                //CloseMenu(sender, e);

                if (App.oMainReference.UiWait)
                {
                    return;
                }

                string strPath = Convert.ToString(((TextBlock)sender).Tag);


                if (string.IsNullOrEmpty(strPath))
                    return;

                //VG220322 - based on current scan mode open the required folder

                switch (cGlobalSettings.CurrentScanMode)
                {

                    case eScanMode.FileSearch:
                        if (System.IO.File.Exists(strPath) || Directory.Exists(strPath))
                        {
                            string finalArgs = string.Format("/Select, \"" + strPath + "\"");
                            showExplorer = new ProcessStartInfo("Explorer.exe", finalArgs);
                            Process.Start(showExplorer);
                        }
                        else
                        {
                            /* SelectedPath = Environment.GetFolderPath(Environment.SpecialFolder.Desktop);*/
                            string finalArgs = string.Format("/Select, \"" + /*SelectedPath*/Environment.GetFolderPath(Environment.SpecialFolder.Desktop) + "\"");
                            showExplorer = new ProcessStartInfo("Explorer.exe", finalArgs);
                            Process.Start(showExplorer);
                        }
                        break;



                    case eScanMode.Dropbox:
                        break;

                    case eScanMode.GoogleDrive:
                        {
                            //open folder explorer dialog box for Google drive here
                            //OpenGoogleFolderExplorer();
                        }
                        break;
                }

            }
            catch (Exception ex)
            {
                if (showExplorer != null) showExplorer = null;
            }
        }





