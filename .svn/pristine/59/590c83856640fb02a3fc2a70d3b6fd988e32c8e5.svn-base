        public static void getLastFileTypesList()
        {
            if (cGlobalSettings.listFileType == null)
                initillizeFileTypes();
            try
            {
                string order = RegistryTool.fileTypes;
                if (order != null)
                {
                    string[] fileTypesStatus = order.Split(new char[] { ',' }, StringSplitOptions.RemoveEmptyEntries);

                    for (int i = 0; i < fileTypesStatus.Length; i++)
                    {
                        bool isCheck = fileTypesStatus[i].Trim()[0] == '0' ? false : true;
                        Int16 key = Convert.ToInt16(fileTypesStatus[i].Trim().Substring(1).ToString());

                        cGlobalSettings.listFileType[key].isChecked = isCheck;
                    }
                }
                setRegistryValue();
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("getLastPriorityList ::", ex);
            }
        }

        public static void updateCheckedStatus(int key, bool isChecked)
        {
            try
            {
                cGlobalSettings.listFileType[key].isChecked = isChecked;
                setRegistryValue();
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("updateCheckedStatus :: key:" + key, ex);
            }
        }

        public static void setRegistryValue()
        {
            try
            {
                // Build a registry value
                StringBuilder builder = new StringBuilder();
                foreach (var dictionary in cGlobalSettings.listFileType)
                {
                    builder.Append(dictionary.Value.isChecked ? "1" : "0").Append(dictionary.Key).Append(",");
                }

                RegistryTool.fileTypes = builder.ToString(); // Update registry key value.
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("setRegistryValue :", ex);
            }

        }



        public static decimal getMinimumSize()
        {
            cGlobalSettings.MinFileSize = RegistryTool.minFileSize;
            return cGlobalSettings.MinFileSize;
        }




    }
