        static string[] arrThemes = new string[]  {
           
            "Themes/ThemeDark.xaml",
          
            "Themes/ThemeLight.xaml",
         
            };

        public static void ApplySkin(cClientEnum.eThemeMode theme)
        {
            try
            {
                //theme = cClientEnum.eThemeMode.Blue;
                Uri skinDictionaryUri = new Uri(@"..\Themes\DarkTheme.xaml", UriKind.Relative);
                
                switch (theme)
                {
                    
                    case cClientEnum.eThemeMode.Dark:
                    default:
                        skinDictionaryUri = new Uri(@"..\Themes\DarkTheme.xaml", UriKind.Relative);
                        break;
                    case cClientEnum.eThemeMode.Light:                 
                        skinDictionaryUri = new Uri(@"..\Themes\LightTheme.xaml", UriKind.Relative);
                        break;
                }

                // Load the ResourceDictionary into memory.
                ResourceDictionary skinDict = Application.LoadComponent(skinDictionaryUri) as ResourceDictionary;
                skinDict.Source = skinDictionaryUri;

                Collection<ResourceDictionary> mergedDicts = Current.Resources.MergedDictionaries;
                /*mergedDicts.Add(skinDictExt);*/
                //int nIndex = Array.IndexOf(mergedDicts.Select(p => p.Source.OriginalString).ToArray(), "");

                int[] indicesOf2In1 = arrThemes.Select(s => Array.IndexOf(mergedDicts.Select(p => p.Source.OriginalString).ToArray(), s)).ToArray(); // (0,5)

                foreach (int nIndex in indicesOf2In1)
                {
                    try
                    {
                        if (nIndex < 0)
                            continue;

                        mergedDicts.RemoveAt(nIndex);
                    }
                    catch (Exception ex)
                    {
                        continue;
                    }
                }
                //Remove the existing skin dictionary, if one exists.
                //NOTE: In a real application, this logic might need
                //to be more complex, because there might be dictionaries
                //which should not be removed.
                /*if (mergedDicts.Count > 0)
                    mergedDicts.Clear();*/

                 //Apply the selected skin so that all elements in the
                 //application will honor the new look and feel.
                mergedDicts.Add(skinDict);
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("ApplySkin:: ", ex);
            }
        }

        //public static UserControls.ucHomeComparisonMethod OucHomeComparisonMethod = null;
    }
