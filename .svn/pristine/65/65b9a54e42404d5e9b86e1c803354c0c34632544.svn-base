<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucImageInfo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="336">
    <Grid Background="{DynamicResource bgclr_lightdark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="47"/>
            <RowDefinition Height="27"/>
            <RowDefinition Height="210"/>
            <RowDefinition Height="27"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <DockPanel Grid.Row="0" Margin="18 0" VerticalAlignment="Center">
            <TextBlock Text="Matching Level : " Padding="0 0 5 0" Foreground="{DynamicResource frgclr_white}"/>
            <Slider Margin="0 0 0 0"/>
        </DockPanel>
        <Border Grid.Row="1" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1" 
                Background="{DynamicResource bgclr_soliddark}">
            <TextBlock Text="Preview" Foreground="{DynamicResource frgclr_white}" VerticalAlignment="Center" Padding="10 0"/>
        </Border>
        <Image Grid.Row="2"/>
        <Border Grid.Row="3" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1" 
                Background="{DynamicResource bgclr_soliddark}">
            <TextBlock Text="Metadata" Foreground="{DynamicResource frgclr_white}" VerticalAlignment="Center" Padding="10 0"/>
        </Border>
        <ScrollViewer Grid.Row="4">
            <StackPanel Margin="0">
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="File Name: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="File Size: "  FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---"  FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="File Label: "  FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---"  FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="File Created: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="File Modified: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Folder Name: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Rating: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Keywords: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Image Size: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Image DPI: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Bit Depth: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Orientation: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Digital Zoom Ratio: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Capture Date: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Editing Software: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Exposure: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Focal Length: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Exposure Bias: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="ISO Speed Rating: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Exposure Mode: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Exposure Program: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Metering Mode: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Light Source: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Sensing Method: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Scence Capture Type: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Camera Maker: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Camera Model: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Camera Lens Model: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Camera Firmware: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Color Model: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Color Space: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="Profile Name: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="GPS Altitude: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="GPS Latitude: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock Text="GPS Longitude: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
    
</UserControl>
