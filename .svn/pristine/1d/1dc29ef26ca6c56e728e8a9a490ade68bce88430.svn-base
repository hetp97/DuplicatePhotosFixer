        public static void LoadStringsFromINI()
        {
            #region "Language Settings"
            try
            {
                LoadLanguageDetails();

                //get selected Language from database                
                cGlobalSettings.oScanSettings.GetLanguageFromRegistry();


                if (String.IsNullOrEmpty(cGlobalSettings.oScanSettings.LanguageCode))
                {
                    cGlobalSettings.oScanSettings.CurrentLangSettings = cGlobalSettings.oScanSettings.LanguageDetails.Where(x => x.LangIdentifier == (cClientEnum.LanguageIdentifier)Enum.Parse(typeof(cClientEnum.LanguageIdentifier), cGlobalSettings.oScanSettings.LanguagePref.ToString())).FirstOrDefault();
                }
                else
                {
                    cGlobalSettings.oScanSettings.CurrentLangSettings = cGlobalSettings.oScanSettings.LanguageDetails.Where(x => x.NameAbbv.ToLower() == cGlobalSettings.oScanSettings.LanguageCode.ToLower()).FirstOrDefault();

                }

                /// this is done, so that always english is loaded if other lang ini is not available.                        
                if (cGlobalSettings.oScanSettings.CurrentLangSettings == null)
                {
                    cGlobalSettings.oScanSettings.CurrentLangSettings = cGlobalSettings.oScanSettings.LanguageDetails.Where(x => x.NameAbbv.ToLower() == "en").FirstOrDefault();
                }
                else
                {
                    /// if other lang ini is not available, load english as default ini
                    string LangIniFilePath = PathEx.Combine(Path.GetDirectoryName(Process.GetCurrentProcess().MainModule.FileName), cGlobalSettings.oScanSettings.CurrentLangSettings.IniName); ;
                    if (!File.Exists(LangIniFilePath))
                    {
                        cGlobalSettings.oScanSettings.CurrentLangSettings = cGlobalSettings.oScanSettings.LanguageDetails.Where(x => x.NameAbbv.ToLower() == "en").FirstOrDefault();
                    }
                }
                //Load INI file                
                cResourceManager.LoadStringsFromIni(oScanSettings.CurrentLangSettings);
                cResourceManager.findDuplicates();
            }
            catch (Exception ex)
            {

            }

            #endregion
        }

        public static uint GetTimeInterval()
        {
            return GetTimeIntervalEx((enumClass.eTimeInterval)cGlobalSettings.timeInterval);
        }


        public static uint GetTimeIntervalEx(enumClass.eTimeInterval timeInterval)
        {
            switch (timeInterval)
            {
                case enumClass.eTimeInterval._24_hours_and_less:
                    return 86400; // 60 * 60 * 24
                case enumClass.eTimeInterval._12_hours_and_less:
                    return 43200;
                case enumClass.eTimeInterval._6_hours_and_less:
                    return 21600;
                case enumClass.eTimeInterval._3_hours_and_less:
                    return 10800;
                case enumClass.eTimeInterval._2_hours_and_less:
                    return 7200;
                case enumClass.eTimeInterval._1_hours_and_less:
                    return 3600;
                case enumClass.eTimeInterval._30_minutes_and_less:
                    return 1800;
                case enumClass.eTimeInterval._10_minutes_and_less:
                    return 600;
                case enumClass.eTimeInterval._5_minutes_and_less:
                    return 300;
                case enumClass.eTimeInterval._3_minutes_and_less:
                    return 180;
                case enumClass.eTimeInterval._2_minutes_and_less:
                    return 120;
                case enumClass.eTimeInterval._1_minutes_and_less:
                    return 60;
                case enumClass.eTimeInterval._10_seconds_and_less:
                    return 10;
                case enumClass.eTimeInterval._5_seconds_and_less:
                    return 5;
                case enumClass.eTimeInterval._3_seconds_and_less:
                    return 3;
                case enumClass.eTimeInterval._2_seconds_and_less:
                    return 2;
                case enumClass.eTimeInterval._1_second_and_less:
                    return 1;
                case enumClass.eTimeInterval._30_seconds_and_less:
                default:
                    return 30;
            }
        }

        public static uint GetGPS()
        {
            return GetGPSEx((enumClass.eGPS)cGlobalSettings.gpsValue);
        }
        public static uint GetGPSEx(enumClass.eGPS gps)
        {
            switch (gps)
            {
                case enumClass.eGPS._1_Meter:
                    return 1;
                case enumClass.eGPS._2_Meters:
                    return 2;
                case enumClass.eGPS._10_Meters:
                    return 10;
                case enumClass.eGPS._20_Meters:
                    return 20;
                case enumClass.eGPS._50_Meters:
                    return 50;
                case enumClass.eGPS._100_Meters:
                    return 100;
                case enumClass.eGPS._5_Meters:
                default:
                    return 5;
            }
        }

        public static uint GetBitmapSize()
        {
            return GetBitmapSizeEx((enumClass.eBitmapSize)cGlobalSettings.gpsValue);
        }

        public static uint GetBitmapSizeEx(enumClass.eBitmapSize bmpSize)
        {
            switch (bmpSize)
            {
                case enumClass.eBitmapSize._48x48_pixels:
                    return 48;
                case enumClass.eBitmapSize._56x56_pixels:
                    return 56;
                case enumClass.eBitmapSize._72x72_pixels:
                    return 72;
                case enumClass.eBitmapSize._80x80_pixels:
                    return 80;
                case enumClass.eBitmapSize._88x88_pixels:
                    return 88;
                case enumClass.eBitmapSize._96x96_pixels:
                    return 96;
                case enumClass.eBitmapSize._64x64_pixels:
                default:
                    return 64;
            }

        }

        public static float GetMatchingLevel()
        {
            return GetMatchingLevelEx((enumClass.eMatchingLevel)cGlobalSettings.matchingLevel);
        }
        public static float GetMatchingLevelEx(enumClass.eMatchingLevel matchingLevel)
        {
            switch (matchingLevel)
            {
                case enumClass.eMatchingLevel._85:
                    return 0.85f;
                case enumClass.eMatchingLevel._88:
                    return 0.88f;
                case enumClass.eMatchingLevel._90:
                    return 0.90f;
                case enumClass.eMatchingLevel._92:
                    return 0.92f;
                case enumClass.eMatchingLevel._94:
                    return 0.94f;
                case enumClass.eMatchingLevel._96:
                    return 0.96f;
                case enumClass.eMatchingLevel._98:
                    return 0.98f;
                case enumClass.eMatchingLevel._100:
                default:
                    return 0.99f;
            }
        }

