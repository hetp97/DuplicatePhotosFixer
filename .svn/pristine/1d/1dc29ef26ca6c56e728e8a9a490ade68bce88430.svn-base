        public static string GetFileDialogFileFilter
        {
            get
            {
                switch (CurrentScanMode)
                {
                    case eScanMode.FileSearch:
                        return FileDialogFilterList;
                    case eScanMode.GoogleDrive:
                        break;
                    //case eScanMode.PicasaLibrary:
                    //    //Digital Negative and ProRaw RAW Image File (*.dng)|*.dn
                    //    return cResourceManager.LoadString("IDS_PICASA_LIB_FORMAT") + @" (thumbindex.db)|thumbindex.db";
                    //case eScanMode.Dropbox:
                    //    break;
                    //case eScanMode.DeleteEmptyFolder:
                    //    break;
                }
                return "";
            }
        }
        static eScanMode? _CurrentScanMode;
        public static eScanMode CurrentScanMode
        {
            get
            {
                if (_CurrentScanMode == null)
                {
                    _CurrentScanMode = eScanMode.FileSearch;
                }

                return (eScanMode)_CurrentScanMode;
            }
            set
            {
                _CurrentScanMode = value;
                //SetUserAppDataRegistryValue(cRegistrySettings.REGSTR_APP_SCAN_MODE, (int)_CurrentScanMode, RegistryValueKind.DWord);
            }
        }


        public static string GetProductNameFromDesc()
        {
            return ((AssemblyProductAttribute)System.Reflection.Assembly.GetExecutingAssembly().GetCustomAttributes(typeof(AssemblyProductAttribute), true)[0]).Product;
            // return ((AssemblyDescriptionAttribute)System.Reflection.Assembly.GetExecutingAssembly().GetCustomAttributes(typeof(AssemblyDescriptionAttribute), true)[0]).Description;
        }


        public static string GetImageFileExtensionsList
        {
            get
            {
                switch (CurrentScanMode)
                {
                    case eScanMode.FileSearch:
                        return ImageFileExtensionsList;
                    //case eScanMode.GoogleDrive:
                    //case eScanMode.Dropbox:
                    //    break;
                    //case eScanMode.PicasaLibrary:
                    //    return @"(thumbindex.db)";
                    //case eScanMode.DeleteEmptyFolder:
                    //    break;
                }
                return ImageFileExtensionsList;
            }
        }

        public static string GetInitialDirectory
        {
            get
            {
                switch (CurrentScanMode)
                {
                    case eScanMode.PicasaLibrary:
                        {
                            string DBPath = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData), @"Google\Picasa2\db3");
                            if (!Directory.Exists(DBPath))
                            {
                                DBPath = Environment.GetFolderPath(Environment.SpecialFolder.MyDocuments);
                            }
                            return DBPath;
                        }
                    default:
                        return null;
                }
                return null;
            }
        }

        public static object GetCommonAppDataRegistryValue(string name, object defaultValue)
        {
            try
            {
                return null;
                //return Registry.GetValue(VersionIndependentCommonRegKey, name, defaultValue) ?? defaultValue;
            }
            catch (System.Exception ex)
            {
                oLogger.WriteLog(string.Format("cGlobal|GetCommonAppDataRegistryValue|{0}", ex.Message));
                return string.Empty;
            }

        }

        public static string VersionIndependentCommonRootRegKeyNoHive
        {
            get
            {
                string versionDependent = System.Windows.Forms.Application.UserAppDataRegistry.Name; // not need to find the key from LM as whole key is version independent
                //string versionDependent = System.Windows.Forms.Application.CommonAppDataRegistry.Name;
                string versionIndependent =
                       versionDependent.Substring(0, versionDependent.LastIndexOf("\\"));

                versionIndependent = versionIndependent.Substring(versionIndependent.IndexOf("\\") + 1);

                // versionIndependent = string.Format("{0}\\{1}", versionIndependent, cGlobalSettings.nUserMachineId);
                return versionIndependent;


            }
        }


        public static string VersionIndependentCommonRegKeyNoHive
        {
            get
            {
                string versionDependent = System.Windows.Forms.Application.UserAppDataRegistry.Name; // not need to find the key from LM as whole key is version independent
                //string versionDependent = System.Windows.Forms.Application.CommonAppDataRegistry.Name;
                string versionIndependent =
                       versionDependent.Substring(0, versionDependent.LastIndexOf("\\"));

                versionIndependent = versionIndependent.Substring(versionIndependent.IndexOf("\\") + 1);

                //  versionIndependent = string.Format("{0}\\{1}", versionIndependent, cGlobalSettings.nUserMachineId);
                return versionIndependent;
            }
        }
        public static object GetCommonAppDataRegistryValue(string name)
        {
            return GetCommonAppDataRegistryValue(name, null);
        }

    }
