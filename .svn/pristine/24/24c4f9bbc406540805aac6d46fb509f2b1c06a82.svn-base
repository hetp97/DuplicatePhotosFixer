<Window x:Class="DuplicatePhotosFixer.Nags.nagUpdateOfferTweakshot"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Nags"
        mc:Ignorable="d"
        Title="nagUpdateOfferTweakshot" Height="596" Width="929" WindowStyle="None" Background="#191E33">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition/>
            <RowDefinition Height="74"/>
            <RowDefinition Height="37"/>
        </Grid.RowDefinitions>
        <DockPanel Margin="10 0 10 0">
            <Button x:Name="pb_Close" Width="15" Height="14"
                        Background="Transparent" BorderBrush="Transparent"
                        DockPanel.Dock="Right">
                <Image  Source="/Resources/closevpn.png"/>
            </Button>
            <Image x:Name="pb_Icon" Width="36" Height="33" Source="{DynamicResource img_dpf_updatelogo}"/>
            <TextBlock x:Name="label_heading"
                           Foreground="#FAFAFA"
                           FontSize="14"
                           FontWeight="SemiBold"
                       Padding="5 0 0 0"
                           VerticalAlignment="Center">
                  Duplicate Photo Fixer Pro has been updated sucessfully.
            </TextBlock>
        </DockPanel>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="334"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Image x:Name="pb_Image" Width="229" Height="177" VerticalAlignment="Top"
                   Margin="0 15 0 0" Source="/Resources/tweakshot.png"/>
            </Grid>
            <Grid Grid.Column="1">
                <StackPanel Margin="0 15 0 0">
                    <TextBlock x:Name="lblProdName" FontSize="29" Padding="0 0 0 10"
                               FontWeight="SemiBold" Foreground="#F1F1F2">
                        Tweak Shot Screen Capture
                    </TextBlock>
                    <StackPanel Margin="0 0 0 10" >
                        <DockPanel>
                            <Image x:Name="pbBullet" Width="9" Height="9" Source="{DynamicResource img_plus_btn}"/>

                            <TextBlock x:Name="lblDes1" Padding="15 0 0 5"
                                       FontSize="16" Foreground="#D7D7D8">
                                Capture Video and Audio
                            </TextBlock>
                        </DockPanel>
                        <TextBlock x:Name="lblDescInfo1" Padding="22 0 0 15"
                                       Foreground="#C8C8C8" FontSize="13">
                                Record screen activities including online classes, live streaming events, online webinars and <LineBreak/> in just a click.
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Margin="0 0 0 10">
                        <DockPanel>
                            <Image x:Name="pbBullet1" Width="9" Height="9" Source="{DynamicResource img_plus_btn}"/>

                            <TextBlock x:Name="lblDes2" Padding="15 0 0 5"
                                       FontSize="16" Foreground="#D7D7D8">
                                Capture Video and Audio
                            </TextBlock>
                        </DockPanel>
                        <TextBlock x:Name="lblDescInfo2" Padding="22 0 0 15"
                                       Foreground="#C8C8C8" FontSize="13">
                                Record screen activities including online classes, live streaming events, online webinars and <LineBreak/> in just a click.
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Margin="0 0 0 10"> 
                        <DockPanel>
                            <Image x:Name="pbBullet2" Width="9" Height="9" Source="{DynamicResource img_plus_btn}"/>

                            <TextBlock x:Name="lblDes3" Padding="15 0 0 5"
                                       FontSize="16" Foreground="#D7D7D8">
                                Capture Video and Audio
                            </TextBlock>
                        </DockPanel>
                        <TextBlock x:Name="lblDescInfo3" Padding="22 0 0 15"
                                       Foreground="#C8C8C8" FontSize="13">
                                Record screen activities including online classes, live streaming events, online webinars and <LineBreak/> in just a click.
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Margin="0 0 0 10" >
                        <DockPanel>
                            <Image x:Name="pbBullet3" Width="9" Height="9" Source="{DynamicResource img_plus_btn}"/>

                            <TextBlock x:Name="lblDes4" Padding="15 0 0 5"
                                       FontSize="16" Foreground="#D7D7D8">
                                Capture Video and Audio
                            </TextBlock>
                        </DockPanel>
                        <TextBlock x:Name="lblDescInfo4" Padding="22 0 0 15"
                                       Foreground="#C8C8C8" FontSize="13">
                                Record screen activities including online classes, live streaming events, online webinars and <LineBreak/> in just a click.
                        </TextBlock>
                    </StackPanel>

                </StackPanel>
            </Grid>
        </Grid>
        <Grid Grid.Row="2">
            <DockPanel HorizontalAlignment="Center">
                <Button x:Name="btn_buynow" Style="{DynamicResource stl_btnScanForDuplicates}" 
                        Width="333" Height="42"
                        FontSize="16"
                        FontWeight="SemiBold" Margin="0 0 25 0">
                    Buy Now at Flat 20% Off
                </Button>
                <Button x:Name="btn_install" Style="{DynamicResource stl_btnScanForDuplicates}" 
                        Width="333" Height="42"
                        FontSize="16" Margin="25 0 0 0"
                        FontWeight="SemiBold">
                    Install
                </Button>
            </DockPanel>
        </Grid>
        <Grid Grid.Row="3">
            <DockPanel Margin="5 5 5 0">
                <TextBlock x:Name="lblLinksInfo"
                           Foreground="#6C7881"
                           FontSize="14"
                           FontWeight="SemiBold">
                   By clicking Install, you agree to install Tweak Shot Screen Capture and accept its
                </TextBlock>
                <TextBlock Width="180"/>
                <TextBlock x:Name="lblEula" FontSize="14" Padding="0 0 10 0">
                    <Hyperlink> EULA </Hyperlink>
                </TextBlock>
                <TextBlock x:Name="txt" FontSize="14" Padding="0 0 10 0"  Foreground="#6C7881" Text="and"/>
                <TextBlock x:Name="lblPP" FontSize="14" Padding="0 0 10 0" >
                    <Hyperlink> Privacy Policy </Hyperlink>
                </TextBlock>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
