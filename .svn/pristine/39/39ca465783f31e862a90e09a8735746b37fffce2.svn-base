<Window x:Class="DuplicatePhotosFixer.Nags.nagCooldown"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Nags"
        mc:Ignorable="d"
        Title="nagCooldown" Height="455" Width="784" WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>
        <StackPanel Margin="10 20">
            <DockPanel>
                <Button x:Name="btn_close" Background="#3E3E3E" Width="20"
                        Height="25"
                        Foreground="White"
                        FontSize="15"
                        FontWeight="SemiBold"
                        DockPanel.Dock="Right"
                        Margin="0 2 5 0"
                        VerticalAlignment="Top"
                       >X
                </Button>
                <TextBlock x:Name="lbl_attention"
                           FontSize="23"
                           FontWeight="Bold"
                           Foreground="#404040">
                    Duplicates cleaning cooldown limit!
                </TextBlock>
            </DockPanel>
            <TextBlock x:Name="linklabel1"
                       Margin="4 7 4 0"
                       Foreground="#5C5C5C"
                       Height="Auto"
                       MinHeight="74">
                You are running the free version of Duplicate Photos Fixer Pro. Is allows you to delete duplicates in 1 group every 5<LineBreak/> minutes. To clean all dulicate photos at once, upgrade to full version now.
            </TextBlock>
            <DockPanel Background="#FEF6E7"
                       Height="Auto" MinHeight="106">
                <Image x:Name="clock_img" Width="60" Height="55" Source="/Resources/clock_cooldown.png" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="lbl_dupsCount" Foreground="#5C5C5C" FontSize="13">
                        Duplicate removal cooldown period
                    </TextBlock>
                    <DockPanel>
                        <TextBlock x:Name="lbl_counter" FontSize="20" FontWeight="Bold"
                               Foreground="#FF5D15">52
                        </TextBlock>
                        <TextBlock x:Name="lbl_totalSpace" FontSize="13" 
                               Foreground="#FF5D15" VerticalAlignment="Center"> seconds remaining
                        </TextBlock>
                    </DockPanel>
                </StackPanel>

                <Button x:Name="btn_removeLimit" Width="200" Height="39" 
                        Background="#01AF50" Foreground="White"
                        HorizontalAlignment="Right"
                        Margin="0 0 20 0"
                        >Remove this limit</Button>
            </DockPanel>
            <DockPanel Margin="0 20 0 0">
                <Image x:Name="img_mbc" Source="/Resources/mbc_icon.png"
                       Width="85"
                       Height="79"   />
                <StackPanel VerticalAlignment="Center" Margin="0 20 0 0">
                    <TextBlock x:Name="lbl_upgradeNow" Foreground="#5C5C5C">
                        Upgrade now to remove all duplicate photos from your PC and recover tons of space.
                    </TextBlock>
                    <TextBlock x:Name="lbl1" Foreground="#5C5C5C" FontWeight="Bold">
                        Backup by our 60 days money back guarantee.
                    </TextBlock>
                </StackPanel>


            </DockPanel>
        </StackPanel>
        <Grid Grid.Row="1" Background="#404040" >
            <DockPanel Margin="10 0 20 0">
                <StackPanel 
                            VerticalAlignment="Center">
                    <TextBlock x:Name="lbl_haveLicenceKey"
                               Foreground="White"
                               >
                        Already purchased?
                    </TextBlock>
                    <TextBlock x:Name="llink_haveKey">                                                       
                        <Hyperlink  Foreground="White">Click here to enter your key</Hyperlink>
                    </TextBlock>
                </StackPanel>
                <Button x:Name="btn_upgradeNow" Width="200" Height="39" 
                        Background="#01AF50" Foreground="White"
                        HorizontalAlignment="Right"
                        >Upgrade Now</Button>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
