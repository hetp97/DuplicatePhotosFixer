<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucExtraSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="441" d:DesignWidth="482" Background="{DynamicResource cl_bg_settingsNag}" Loaded="UserControl_Loaded" >
    <UserControl.Resources>
        <Style TargetType="CheckBox" x:Key="styl_chkbox_content">
            <Setter Property="FontSize" Value ="14"/>
            <Setter Property="Foreground" Value="{DynamicResource cl_fg_setCont}"/>
            <Setter Property="Margin" Value="5 10 0 10"/>
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="styl_txtblock_content">
            <Setter Property="FontSize" Value ="14"/>
            <Setter Property="FontWeight" Value="Regular"/>
            <Setter Property="Foreground" Value="{DynamicResource cl_fg_setCont}"/>
            <Setter Property="Margin" Value="20 5 0 20"/>
            <Setter Property="FontWeight" Value="Regular"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="57"/>
        </Grid.RowDefinitions>
       
            <!--<CheckBox x:Name="chk_TimeInterval"
                                  VerticalAlignment="Center"
                                  Style="{DynamicResource SettingsCheckBoxStyle}"
                                Background="{DynamicResource frgclr_whitish}"
                      Content="Include Time Interval while scan"
                      Foreground="Black" 
                      FontSize="14"
                                 
                                  Width="17"
                                  Height="17"
                                  />-->
        <StackPanel Margin="12 10 10 0">
                <TextBlock x:Name="scan_heading" Foreground="{DynamicResource cl_fg_setHeading}"
                       FontSize="24" FontWeight="Regular">
                Manage scan criteria
                </TextBlock>
            <TextBlock x:Name="heading_info"
                           FontSize="14" FontWeight="Regular"
                       Foreground="{DynamicResource cl_fg_setCont}">
                       
                The settings will allow you to customize scan options</TextBlock>
            </StackPanel>
            <Grid Grid.Row="1">
            <ScrollViewer>
                <StackPanel Margin="5 10 10 0">
                    <CheckBox x:Name="chk_TimeInterval" Content="Include Time Interval while scan" 
                              IsChecked="{Binding Path=ConsiderTimeInterval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource styl_chkbox_content}"
                               Padding="5 -3 0 0" Click="chkSettingsChange_Click">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                        </CheckBox.LayoutTransform>
                    </CheckBox>
                    <TextBlock x:Name="lbl_TimeIntervalInfo" Text="Time Interval determines a time gap between photos ranging from less than a second to 24 hours. Choose an interval of your choice for preferred results." TextWrapping="Wrap"
                      Style="{StaticResource styl_txtblock_content}"/>
                    <CheckBox x:Name="chk_GPS" Content="Include GPS while scan" 
                               IsChecked="{Binding Path=ConsiderGPS, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource styl_chkbox_content}"
                               Padding="5 -3 0 0" Click="chkSettingsChange_Click">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                        </CheckBox.LayoutTransform>
                    </CheckBox>
                    <TextBlock x:Name="lbl_GPSInfo" Text="GPS checks the embedded coordinates of photos. Location coordinates between photos should fall within the range of 0 to 100 meters" TextWrapping="Wrap"
                      Style="{StaticResource styl_txtblock_content}"/>
                    <CheckBox x:Name="chk_captureDate"  Content="Use Time Interval Settings if Capture Data is not available " 
                               IsChecked="{Binding Path=ConsiderTimeNoCaptureDt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource styl_chkbox_content}" 
                               Padding="5 -3 0 0" Click="chkSettingsChange_Click" >
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                        </CheckBox.LayoutTransform>
                    </CheckBox>
                    <TextBlock x:Name="lbl_CaptureDateInfo" Text="If Capture Date is missing in exif data of photo, then Creation Date will be used instead" TextWrapping="Wrap"
                      Style="{StaticResource styl_txtblock_content}"/>
                    <CheckBox x:Name="chk_rotatedImages" Content="Include Rotated Images" 
                               IsChecked="{Binding Path=ImageRotatedChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource styl_chkbox_content}" 
                               Padding="5 -3 0 0" Click="chkSettingsChange_Click">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="0.95" ScaleY="0.95" />
                        </CheckBox.LayoutTransform>
                    </CheckBox>
                    <CheckBox x:Name="chk_flippedImages" Content="Include Flipped Images"
                               IsChecked="{Binding Path=ImageFlippedChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource styl_chkbox_content}" 
                               Padding="5 -3 0 0" Click="chkSettingsChange_Click">
                    </CheckBox>

                </StackPanel>
            </ScrollViewer>
                </Grid>

        <Grid Grid.Row="2" Background="{DynamicResource cl_bg_TabControl}" >
            <Label x:Name="lbl_settingsApplied" Content="Settings Applied" 
                   Foreground="#fff"
                   FontSize="15"
                   FontWeight="Bold"
                   VerticalContentAlignment="Center"
                   HorizontalAlignment="Center"
                   Visibility="Collapsed"/>
        </Grid>
    </Grid>
</UserControl>
