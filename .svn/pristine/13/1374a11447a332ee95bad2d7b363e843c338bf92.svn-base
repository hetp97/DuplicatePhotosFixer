<Window x:Class="DuplicatePhotosFixer.Nags.nagTrialExpire"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Nags"
        mc:Ignorable="d"
        Title="nagTrialExpire" Height="604" Width="1031" WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition MinHeight="73" Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="105"/>
        </Grid.RowDefinitions>
        <DockPanel>
            <Button x:Name="btn_close"
                    Width="20"
                    Height="18"
                    Background="Transparent"
                    BorderBrush="Transparent"  Margin="0 5 10 0"
                    DockPanel.Dock="Right"
                    VerticalAlignment="Top">
                <Image Source="{DynamicResource img_close_black}"/>
            </Button>
            <TextBlock x:Name="lblExpire"
                       Foreground="#1F5EA7"                       
                       FontSize="26"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                Your <Bold>24 Hours</Bold> free trial version has expired.
            </TextBlock>
        </DockPanel>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" MinHeight="74"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="text_registration"
                       FontSize="21"
                       FontWeight="Bold"
                       HorizontalAlignment="Center">
                Register now to keep your PC running at peak Performance
            </TextBlock>
            
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto" MinWidth="296"/>
                </Grid.ColumnDefinitions>
              
                    <StackPanel Margin="30 0 0 0">
                       
                        <DockPanel Margin="0 10 0 0">
                            <Image x:Name="img_tick1" Width="21" Height="18" 
                          Margin="0 0 8 0" Source="{DynamicResource blue_tick}"/>
                        <TextBlock x:Name="txt1" Text="Search for Duplicates"
                                       FontSize="17"/>
                        </DockPanel>
                        <DockPanel Margin="0 10 0 0">
                            <Image x:Name="img_tick2" Width="21" Height="18" 
                          Margin="0 0 8 0" Source="{DynamicResource blue_tick}"/>
                        <TextBlock x:Name="txt2" FontSize="17" Text="Detect Exact &amp; Similar Images"/>
                        </DockPanel>
                        <DockPanel Margin="0 10 0 0">
                            <Image x:Name="img_tick3" Width="21" Height="18" 
                          Margin="0 0 8 0" Source="{DynamicResource blue_tick}"/>
                        <TextBlock x:Name="txt3" FontSize="17" Text="Auto-Mark Duplicates"/>
                        </DockPanel>
                        <DockPanel Margin="0 10 0 0">
                            <Image x:Name="img_tick4" Width="21" Height="18" 
                          Margin="0 0 8 0" Source="{DynamicResource blue_tick}"/>
                        <TextBlock x:Name="txt4"  FontSize="17" Text="Recover Wasted Disk Space"/>
                        </DockPanel>
                    <DockPanel Margin="0 10 0 0">
                        <Image x:Name="img_tick5" Width="21" Height="18" 
                          Margin="0 0 8 0" Source="{DynamicResource blue_tick}"/>
                        <TextBlock x:Name="txt5"  FontSize="17" Text="Works with External Devices"/>
                    </DockPanel>
                </StackPanel>
                <Grid Grid.Column="1" Margin="0 0 30 0">
                    <Image x:Name="limited_offer_img" Source="{DynamicResource img_limited_offer}" Width="227"
                           HorizontalAlignment="Left"
                           Height="200"/>
                </Grid>
            </Grid>
        </Grid>
        <Grid Grid.Row="3">
            <DockPanel>
                <Image x:Name="img_mb" Source="/Resources/mbc_icon.png" Width="67"
                       Height="66" Margin="5 0 5 0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="txt6"
                              >
                      100% money back Guarantee.
                    </TextBlock>
                    <TextBlock x:Name="txt7"
                               Padding="0 10 0 0">
                              
                       Rest assured guranteed improved system performance or your money back.Rest assured guranteed improved system performance or<LineBreak/> your money back.Rest assured guranteed improved system performance or your money back.
                    </TextBlock>
                </StackPanel>
               
            </DockPanel>
        </Grid>
    </Grid>
</Window>
