            //    }

            //}

            return DiscountPercentage;
        }
        
        
        /// <summary>
        /// Reference: 
        /// http://social.msdn.microsoft.com/Forums/windows/en-US/35c91bff-234c-40b9-a239-7addae75b393/borderless-form-hiding-taskbar-on-maximize?forum=winforms
        /// </summary>
        /// <param name="e"></param>
        cTaskbar taskbar = new cTaskbar();
        cTaskbar.TaskbarPosition oTaskBarPosition = cTaskbar.TaskbarPosition.Unknown;
        protected override void OnLoad(EventArgs e)
        {

            try
            {
                if (!AnimateWindow)
                {
                    base.OnLoad(e);
                    return;
                }

                //LoadStrings();
                this.Refresh();
                this.Invalidate();
                int nTaskBarHeight = 0;
                oTaskBarPosition = taskbar.Position;
                if ((oTaskBarPosition == cTaskbar.TaskbarPosition.Bottom) || (oTaskBarPosition == cTaskbar.TaskbarPosition.Top))
                {
                    nTaskBarHeight = taskbar.Bounds.Height;
                    if (oTaskBarPosition == cTaskbar.TaskbarPosition.Top)
                    {
                        this.Location = new System.Drawing.Point(taskbar.Bounds.Width - this.Width, nTaskBarHeight);
                    }
                    else
                    {
                        this.Location = new System.Drawing.Point(taskbar.Bounds.Width - this.Width, (taskbar.Bounds.Y + taskbar.Bounds.Height) - this.Height - nTaskBarHeight);
                    }
                }
                else if ((oTaskBarPosition == cTaskbar.TaskbarPosition.Left) || (oTaskBarPosition == cTaskbar.TaskbarPosition.Right))
                {
                    nTaskBarHeight = taskbar.Bounds.Width;

                    if (oTaskBarPosition == cTaskbar.TaskbarPosition.Right)
                    {
                        this.Location = new System.Drawing.Point((taskbar.Bounds.X + taskbar.Bounds.Width) - this.Width - nTaskBarHeight, taskbar.Bounds.Height - this.Height);
                    }
                    else
                    {
                        this.Location = new System.Drawing.Point(nTaskBarHeight, taskbar.Bounds.Height - this.Height);
                    }

                }


                this.Hide();
                
                this.FormBorderStyle = FormBorderStyle.None;
                
                this.TopMost = true;
                this.Invalidate();
                this.Refresh();
                base.OnLoad(e);
                cWin32APIs.AnimateWindow(this.Handle, 1500, (int)(AnimateWindowFlags.AW_ACTIVATE | AnimateWindowFlags.AW_VER_NEGATIVE | AnimateWindowFlags.AW_SLIDE));
                this.Invalidate();
                this.Refresh();

            }
            catch (Exception oEx)
            {
                // MessageBox.Show(ex.ToString());
                cGlobalSettings.oLogger.WriteLogException("cNageDialogue OnLoad()|Error:{0}", oEx);
            }
            finally
            {
                System.Drawing.Rectangle rect = Screen.GetWorkingArea(this);
                this.MaximizedBounds = Screen.GetWorkingArea(this);
            }

        }
    }
}
