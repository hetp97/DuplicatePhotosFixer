    [PermissionSet(SecurityAction.Demand, Name = "FullTrust")]
    [System.Runtime.InteropServices.ComVisibleAttribute(true)]
    public class cNagDialogue :Form
    {
       

        public eNagResult NagResult { get; set; }
        public int DiscountPercentage { get; set; }
        public eUTM_BTN_TYPE UTM_BTN_CLICK_TYPE { get; set; }
        public bool ShowDiscount { get; set; }

        public bool AnimateWindow { get; set; }
        public bool ShowBorder { get; set; }

        public int AutoCloseFormDelay { get; set; }

        public cNagDialogue()
        {
            ShowDiscount = true; // as now each nag will show discount
            DiscountPercentage = (int)eDiscountOffers.None;
            UTM_BTN_CLICK_TYPE = eUTM_BTN_TYPE.None;
            DiscountPercentage = (int)SetDiscountPercent();
        }

        public void onAlreadyUpgraded()
        {
            try
            {
                this.NagResult = eNagResult.AlreadyUpgraded;
                this.Close();
            }
            catch (Exception oEx)
            {
                cGlobalSettings.oLogger.WriteLog(string.Format("{1}|onAlreadyUpgraded()|{0}", oEx.Message, this));
            }
        }

        //go on web
        public void onClickBtnUpgradeNow(string btnId = "")
        {
            try
            {
                this.NagResult = eNagResult.UpgradeNow;
                


                //cGlobal.BuyNow(/*ShowDiscount ?*/ (eDiscountOffers)DiscountPercentage /*: eDiscountOffers.None*/, UTM_BTN_CLICK_TYPE, btnId);
                
                this.Close();
            }
            catch (Exception oEx)
            {
                cGlobalSettings.oLogger.WriteLogVerbose(string.Format("{1}|onClickBtnUpgradeNow()|{0}", oEx.Message,this));
            }
        }

        //go on web
        public void UpgradeNow(string btnId = "")
        {
            try
            {
                onClickBtnUpgradeNow(btnId);
            }
            catch (Exception oEx)
            {
                cGlobalSettings.oLogger.WriteLogVerbose(string.Format("{1}|onClickBtnUpgradeNow()|{0}", oEx.Message, this));
            }
        }

        public void LearnMore()
        {
            try
            {
                //cGlobal.LearnMore();

                //PCBackupUI.Program.oMainFormReference.FireEventTrackingPixelInThread(eUTM_BTN_TYPE.NagLearnMore.ToString());
            }
            catch (Exception oEx)
            {
                cGlobalSettings.oLogger.WriteLogVerbose(string.Format("{1}|onClickBtnUpgradeNow()|{0}", oEx.Message, this));
            }
        }


        public void SwitchToCustom()
        {
            try
            {
                this.NagResult = eNagResult.SwitchToCustom;
                //cGlobal.LearnMore();
            }
            catch (Exception oEx)
            {
                cGlobalSettings.oLogger.WriteLogVerbose(string.Format("{1}|onClickBtnUpgradeNow()|{0}", oEx.Message, this));
            }
        }

