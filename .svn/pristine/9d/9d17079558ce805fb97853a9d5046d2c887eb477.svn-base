<Window x:Class="DuplicatePhotosFixer.Nags.frmLimitedTimeOffer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Nags"
        mc:Ignorable="d"
        Title="frmLimitedTimeOffer" Height="350" Width="325" WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="33"/>
            <RowDefinition/>
            <RowDefinition Height="44"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#262626">
            <DockPanel>
                <Button x:Name="btn_close" Background="#3E3E3E" Width="20"
                        Height="25"
                        Foreground="White"
                        FontSize="15"
                        FontWeight="SemiBold"
                        DockPanel.Dock="Right"
                        Margin="0 2 5 0"
                        VerticalAlignment="Top"
                        HorizontalContentAlignment="Center">X
                </Button>
                <TextBlock x:Name="lbl_title"
                           FontSize="13"
                           Foreground="White"
                           FontWeight="Bold"
                           VerticalAlignment="Center">
                    Duplicate Photos Fixer Pro
                </TextBlock>
                <TextBlock x:Name= "lbl_limitedOffer"
                           FontSize="12"
                           Foreground="White"
                            VerticalAlignment="Center"
                           Margin="10 0 0 0"
                           >
                     *Limited time offer
                </TextBlock>
            </DockPanel>
        </Grid>
        <Grid Grid.Row="1">
            <StackPanel>
                <DockPanel>
                    <Image x:Name="img_logo" Source="{DynamicResource nag_dpf_logo}" 
                           Width="55" Height="55" Margin="3, 3, 3, 3"/>
                    <TextBlock x:Name="lbl_updateSuccess"
                               Foreground="#006CD5"
                               FontSize="14"
                               FontWeight="Bold"
                               Margin="3, 8, 3, 0">
                        IDS_DU_APP_NAME has been <LineBreak/> updated successfully.
                        
                    </TextBlock>
                </DockPanel>
                <TextBlock x:Name="cLabel1"
                           Margin="3, 0, 3, 0"
                           Foreground="Black">
                    Duplicate Photos Fixer Pro can remove all duplicate <LineBreak/> from your PC with a single click and recover<LineBreak/> tons of disk space.
                </TextBlock>
                <DockPanel HorizontalAlignment="Center">
                    <Image x:Name="img_mbc" Source="/Resources/mbc_icon.png"
                       Width="64"
                       Height="64"                                          
                       DockPanel.Dock="Right"/>
                    <TextBlock x:Name="lbl_discValue" 
                           Foreground="#ED2F3C"
                           FontSize="45"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                            Margin="3 0 3 0">
                    50%
                    </TextBlock>
                    <TextBlock x:Name="lbl_discount"
                           FontSize="16"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="#111111"
                           Margin="3 5 3 0">
                    DISCOUNT <LineBreak/>
                    Only for You
                    </TextBlock>
                   
                </DockPanel>
                <Button x:Name="btn_claimOffer"
                        Width="259"
                        Height="50"
                        Style="{DynamicResource stylGreenBtn}"
                        FontSize="15"
                        FontWeight="Bold"
                        Margin="0 0 20 0"
                        >
                    Claim Offer - 50% OFF

                </Button>
                <TextBlock x:Name="llbl_removeAll"
                       HorizontalAlignment="Center"
                       FontSize="12"
                     Margin="0 5 0 5"                      >
                <Hyperlink>I want to claim offer now</Hyperlink>
                </TextBlock>
               
            </StackPanel>
        </Grid>
        <Grid Grid.Row="2">
            <Grid.Background>
                <LinearGradientBrush  StartPoint="0,0" EndPoint="0 ,1">
                    <GradientStop Color="#F2F2F2" Offset="0.200"/>
                    <GradientStop Color="#F1F1F1" Offset="0"/>
                    <GradientStop Color="#F1F1F1" Offset="0"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Image x:Name="ms_logo" Source="{DynamicResource img_ms_logo_small}"
                   HorizontalAlignment="Right"/>
        </Grid>
    </Grid>
</Window>
