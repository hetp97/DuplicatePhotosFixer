    public partial class ucResultObjectListView : UserControl
    {
        public ucResultObjectListView()
        {
            InitializeComponent();
            LoadStrings();
        }
        void LoadStrings()
        {

            lblGroup.Header = cResourceManager.LoadString("DPF_RESULT_OLV_GROUP");
            //ObjectListView1.Columns["olvColumnKey"].Text = cResourceManager.LoadString("");
            lblFileName.Header = cResourceManager.LoadString("DPF_RESULT_OLV_FILENAME");
            lblPath.Header = cResourceManager.LoadString("DPF_RESULT_OLV_PATH");
            lblSize.Header = cResourceManager.LoadString("DPF_RESULT_OLV_SIZE");
            lblCreated.Header = cResourceManager.LoadString("DPF_RESULT_OLV_CREATED");
            lblModified.Header = cResourceManager.LoadString("DPF_RESULT_OLV_MODIFIED");
            lblFileType.Header = cResourceManager.LoadString("DPF_RESULT_OLV_FILETYPE");
            lblImgWidth.Header = cResourceManager.LoadString("DPF_RESULT_OLV_IMAGEWIDTH");
            lblImgHeight.Header = cResourceManager.LoadString("DPF_RESULT_OLV_IMAGEHEIGHT");

        }

    }
}
