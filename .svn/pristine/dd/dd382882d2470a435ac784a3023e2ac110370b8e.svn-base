        public static Tuple<int, string> getMatchingLevel(int val)
        {
            string compareImagePath = null;
            int matcgLevel = 0;

            switch (val)
            {
                case 0:
                    compareImagePath = "/HelpingFiles/Compare/campare.png";
                    break;
                case 1:
                    compareImagePath = "/HelpingFiles/Compare/campare1.png";
                    break;
                case 2:
                    compareImagePath = "/HelpingFiles/Compare/campare2.png";
                    break;
                case 3:
                    compareImagePath = "/HelpingFiles/Compare/campare3.png";
                    break;
