<UserControl x:Class="DuplicatePhotosFixer.UserControls.Selection_Assistant.ucSelectionPriority"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls.Selection_Assistant"
             mc:Ignorable="d" 
             d:DesignHeight="260" d:DesignWidth="643" Background="#2F2F2F">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="51"/>
        </Grid.ColumnDefinitions>
      
        <Grid Grid.Column="0" Margin="10 10 10 20">
            <DockPanel>
                <DataGrid x:Name="objSelectionPriority"  Background="Transparent"   BorderBrush="#4e4e4e"
                          ItemsSource="{Binding}" AutoGenerateColumns="False"  ScrollViewer.CanContentScroll="True"
                              RowBackground="Transparent" Foreground="{DynamicResource frgclr_white}" Margin="0 0 0 20"
                              GridLinesVisibility="None" AlternatingRowBackground="{DynamicResource bgrclr_gray}" 
                                  CanUserResizeColumns="False" CanUserResizeRows="False"  RowHeaderWidth="0" 
                                  Cursor="Hand" CanUserAddRows="False" CanUserReorderColumns="False" HeadersVisibility="Column">
                <DataGrid.ColumnHeaderStyle>
                    <Style  TargetType="{x:Type DataGridColumnHeader}">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type DataGridColumnHeader}">
                                    <Border BorderBrush="#4e4e4e"
                                    BorderThickness=" 0.5 0 0.6 0.6"
                                Background="#272727"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <TextBlock Text="{TemplateBinding Content}" Padding="5,5,0,0" Height="28"  Width="{TemplateBinding Width}" TextAlignment="Left"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Center" 
                                       Foreground="#8c8c8c"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="{x:Type DataGridCell}">
                            <Setter Property="Background"
                                    Value="Transparent" />
                            <Setter Property="Height"
                                    Value="25"/>
                            <Setter Property="VerticalAlignment"
                                    Value="Center"/>
                            
                            <!-- <Setter Property="BorderBrush" Value="Red" />
                            <Setter Property="Foreground" Value="#93A0BE" /> -->
                            <Setter Property="BorderThickness"
                                Value="0" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected"
                                            Value="True">
                                    <Setter Property="Background"
                                     Value="Transparent" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                   
                    <DataGrid.Columns>

                    <!--<DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox>
                                <CheckBox.LayoutTransform>
                                    <ScaleTransform ScaleX="0.9" ScaleY="0."/>
                                </CheckBox.LayoutTransform>
                            </CheckBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>-->
                        <DataGridTemplateColumn  x:Name="use_lbl" Width="40" Header="Use" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding isChecked}" VerticalAlignment="Center" Margin="5 0">
                                        <CheckBox.LayoutTransform>
                                            <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                                        </CheckBox.LayoutTransform>
                                    </CheckBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--<DataGridTextColumn x:Name="use_lbl" Header="Use" MinWidth="40" Binding="{Binding isChecked}"   >
                    
                    </DataGridTextColumn>-->

                        <DataGridTextColumn x:Name="priority_lbl" Header="Priority" MinWidth="80" Binding="{Binding priority}"/>


                        <DataGridTextColumn x:Name="name_lbl" Header="Name" MinWidth="120" Binding="{Binding name}"/>

                        <!--<DataGridTextColumn x:Name="rule_lbl" Header="Rule" MinWidth="50" Width="*" Binding="{Binding rule}"/>-->


                        <DataGridTemplateColumn x:Name="rule_lbl" Header="Rule" MinWidth="50" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding rule}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox  x:Name="rule_cb"
                            ItemsSource="{Binding DataContext.cGlobalSettings.listPriority.rule, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding rule}"
                                  SelectedValuePath="rule">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding ID}"
                                                   Foreground="Blue" />
                                                    <TextBlock Text="{Binding Name}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                            <!--<DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox x:Name="rule_cb" SelectedItem="{Binding rule}" ItemsSource="{Binding cGlobalSettings.listPriority.Values}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>-->
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
            </DataGrid>
                <!--<DataGrid x:Name="objSelectionPriorityInfo" AutoGenerateColumns="False" Background="{DynamicResource bgrclr_lightgray}"  BorderBrush="#4e4e4e"
                           IsReadOnly="True" CanUserAddRows="False" CanUserReorderColumns="False" 
                             RowBackground="Transparent" Foreground="{DynamicResource frgclr_white}"  Margin="0"
                              GridLinesVisibility="None" AlternatingRowBackground="{DynamicResource bgrclr_gray}" CanUserResizeRows="False" CanUserResizeColumns="False" 
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="22">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox x:Name="chkbxCheckAllgrid" VerticalAlignment="Center" IsChecked="True"
                                  Margin="0 1 0 0" 
                                  HorizontalAlignment="Center" >
                                        <CheckBox.LayoutTransform>
                                            <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                        </CheckBox.LayoutTransform>
                                    </CheckBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="30">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    --><!--<DataGridTextColumn Width="*" Binding="{Binding strPath}"/>--><!--
                                    <TextBlock x:Name="priority_no" Text="{Binding priority_no}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    --><!--<DataGridTextColumn Width="*" Binding="{Binding strPath}"/>--><!--
                                    <TextBlock x:Name="rule_name" Text="{Binding rule_name}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    --><!--<DataGridTextColumn Width="*" Binding="{Binding strPath}"/>--><!--
                                    <TextBlock x:Name="rule_desc" Text="{Binding rule_desc}" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
            </DataGrid>-->

            </DockPanel>
        </Grid>
       
        <Grid Grid.Column="1">
            <StackPanel Grid.Column="1" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="top" Orientation="Vertical" Margin="0,19,0,0">
                <Button x:Name="btnMoveUp" Width="34" Height="34" Margin="0,1,0,7" MinHeight="15" BorderBrush="Transparent" 
                         Style="{DynamicResource stl_btnBack}">
                    <Button.Background>
                        <ImageBrush x:Name="btnUpArrow" ImageSource="{DynamicResource img_arrowUp}"/>
                    </Button.Background>
                </Button>
                <Button x:Name="btnMoveDown" Width="34" Height="34" Margin="0,3,0,7" BorderBrush="Transparent" 
                         Style="{DynamicResource stl_btnBack}">
                    <Button.Background>
                        <ImageBrush x:Name="btnDownArrow" ImageSource="{DynamicResource img_arrowDown}"/>
                    </Button.Background>
                 
                </Button>

            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
