<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucHomeMain"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             xmlns:cust ="clr-namespace:DuplicatePhotosFixer.CustomControl"
             xmlns:UserControls="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="684" d:DesignWidth="998">
    
    <UserControl.Resources>
        <Style x:Key="FooterButtonDesign"
               TargetType="{x:Type cust:ImageButton}">
            <Setter Property="Background"
                    Value="{DynamicResource bgrclr_whitish}" />
            <Setter Property="BorderBrush" Value="{DynamicResource clr_darkborder}" />
            <Setter Property="Foreground" Value="{DynamicResource clr_darkborder}" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                        <Border x:Name="Border"
                                Width="120"
                                Height="33"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                            <Grid HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Image Grid.Column="0"
                                       x:Name="imgMenu"
                                       Width="15"
                                       Height="15"
                                       SnapsToDevicePixels="False"
                                       Source="{TemplateBinding Image}"
                                       Stretch="None"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock Grid.Column="1"
                                           Padding="10 0"
                                           x:Name="txtName"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource bgclr_soliddark}"
                                           Text="{TemplateBinding Content}"
                                           FontWeight="Bold"
                                           TextWrapping="WrapWithOverflow" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="true">
                                <Setter TargetName="txtName"
                                        Property="Foreground"
                                        Value="{DynamicResource ClearListFontColor}" />
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="{DynamicResource pnlLeftTabHoverColor}" />
                                <Setter TargetName="imgMenu"
                                        Property="Image.Source"
                                        Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=HoverImage}" />

                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="true">
                                <Setter TargetName="txtName"
                                        Property="Foreground"
                                        Value="{DynamicResource ClearListFontColor}" />
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="{DynamicResource pnlLeftTabHoverColor}" />
                                <Setter TargetName="imgMenu"
                                        Property="Image.Source"
                                        Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=HoverImage}" />
                            </Trigger>
                            <Trigger Property="IsFocused"
                                     Value="true">
                                <Setter TargetName="txtName"
                                        Property="Foreground"
                                        Value="{DynamicResource ClearListFontColor}" />
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="{DynamicResource pnlLeftTabHoverColor}" />
                                <Setter TargetName="imgMenu"
                                        Property="Image.Source"
                                        Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=SelectedImage}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>
    
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="51"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="335"/>
            </Grid.ColumnDefinitions>

            <Grid Background="#545454" Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="47"/>
                    <RowDefinition Height="210"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="78"/>
                    <!--<RowDefinition Height="0"/>-->
                </Grid.RowDefinitions>
                <Border Grid.Row="0" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="0 0 0 1">
                    <TextBlock Background="{DynamicResource bgclr_lightdark}"/>
                </Border>

                <UserControls:ucDragAndDrop Grid.Row="1" Margin="0" Height="170" Width="588" HorizontalAlignment="Center"/>
                <Grid Grid.Row="2" Margin="15 15 13 0" Background="{DynamicResource bgrclr_lightgray}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="25"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Background="{DynamicResource bgclr_soliddark}">
                        <CheckBox x:Name="chkbxCheckAll" VerticalAlignment="Center" Margin="10 0" HorizontalAlignment="Center" Click="chkbxCheckAll_Click" >
                            <CheckBox.LayoutTransform>
                                <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                            </CheckBox.LayoutTransform>
                        </CheckBox>
                        <DockPanel DockPanel.Dock="Right" Margin="10 0">
                            <Button x:Name="btnEmptySelectedFileList" 
                                  HorizontalAlignment="Center"
                            Style="{DynamicResource stl_btnEmptySelectedFileList}" Click="btnEmptySelectedFileList_Click">

                                <Image Source="{DynamicResource img_deleteselectedfilefolder}" Stretch="None"/>

                            </Button>
                        </DockPanel>
                        
                        <!--<Button x:Name="btndeleteAllSelectedFiles" Width="15" Height="15" DockPanel.Dock="Right" Margin="10 0" 
                                BorderThickness="0"
                                Style="{DynamicResource stl_btndeleteAllRow}"
                                Click="btndeleteAllSelectedFiles_Click">
                            <Button.Background>
                                <ImageBrush ImageSource="{DynamicResource img_deleteselectedfilefolder}"/>
                            </Button.Background>
                            
                        </Button>-->
                        
                        <TextBlock Text="Scan the following files/folders for duplicates" Foreground="{DynamicResource frgclr_whitish}" 
                               VerticalAlignment="Center" Padding="0 0" DockPanel.Dock="Right"/>

                    </DockPanel>

                    <DataGrid x:Name="gridFileFolder" Grid.Row="1" Background="{DynamicResource bgrclr_lightgray}"  BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1 0 1 1"
                          HeadersVisibility="None" ItemsSource="{Binding}" AutoGenerateColumns="False" IsReadOnly="True"
                              RowBackground="Transparent" Foreground="{DynamicResource frgclr_white}" Margin="0"
                              GridLinesVisibility="None" AlternatingRowBackground="{DynamicResource bgrclr_gray}"
                              MinRowHeight="15" Padding="8 5" 
                              >

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="15">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding isSelected}" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <CheckBox.LayoutTransform>
                                                <ScaleTransform ScaleX="1" ScaleY="1" />
                                            </CheckBox.LayoutTransform>
                                        </CheckBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="25">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Height="15" Width="15" Source="{Binding fileIcon}" Margin="5 0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Width="*" Binding="{Binding strPath}"/>

                            <DataGridTemplateColumn Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button x:Name="btn_deleteCurrentRow" Width="10" Height="10" HorizontalAlignment="Right" BorderThickness="0" Click="btn_deleteCurrentRow_Click"
                                                Style="{DynamicResource stl_btndeleteCurrentRow}">
                                            <Button.Background>
                                                <ImageBrush ImageSource="{Binding deleteButtonIcon}"/>
                                            </Button.Background>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>

              


                <DockPanel Grid.Row="3" Margin="15 0 13 0" >

                    <cust:ImageButton x:Name="btnAddPhotos"                                
                                  Margin="10"
                                  Image="{DynamicResource img_btnpic}"
                                  Style="{DynamicResource StyleImageTextButton}"
                                  HoverImage="{DynamicResource img_btnpic}"
                                  SelectedImage="{DynamicResource img_btnpic}"
                                  Content="Add Photos" FontWeight="Bold"
                                      Click="btnAddPhotos_Click">

                    </cust:ImageButton>

                    <cust:ImageButton  x:Name="btnAddfolders"                                
                                   Margin="10"
                                  Image="{DynamicResource img_btnfolder}"
                                  HoverImage="{DynamicResource img_btnfolder}"
                                  SelectedImage="{DynamicResource img_btnfolder}"
                                  Style="{DynamicResource StyleImageTextButton}"
                                  Content="Add Folders" FontWeight="Bold"
                                       Click="btnAddFolder_Click">

                    </cust:ImageButton>

                    <!--<Button x:Name="btnAddPhotos" Click="btnAddPhotos_Click"
                            Style="{DynamicResource stl_btnAddPhotos}">
                        <DockPanel Margin="0 0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image Source="{DynamicResource img_btnpic}" Height="15" Width="15" />
                            <TextBlock Text="Add Photos" Padding="5 0" FontSize="13" FontWeight="Bold"/>
                        </DockPanel>
                    </Button>-->

                    <!--<Button x:Name="btnAddFolder" Margin="19 0" 
                            Style="{DynamicResource stl_btnAddFolders}" Click="btnAddFolder_Click">
                        <DockPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Image Source="{DynamicResource img_btnfolder}" Height="15" Width="15"/>
                            <TextBlock Text="Add Folder" Padding="5 0" FontSize="13" FontWeight="Bold"/>
                        </DockPanel>
                    </Button>-->

                    <Button Height="33" Width="205" DockPanel.Dock="Right" Cursor="Hand">
                        <ComboBox x:Name="cboScanMode" Height="28" Width="200" SelectedIndex="0" SelectionChanged="cboScanMode_SelectionChanged">
                            <ComboBoxItem>
                                <WrapPanel>
                                    <Image Source="{DynamicResource img_pc}" Height="15" Width="15" Margin="5"/>
                                    <TextBlock Text="Scan Computer" VerticalAlignment="Center" FontSize="13" FontWeight="Medium"  Margin="0"/>
                                </WrapPanel>
                            </ComboBoxItem>

                            <ComboBoxItem>
                                <WrapPanel>
                                    <Image Source="{DynamicResource img_drive}" Height="15" Width="15" Margin="5"/>
                                    <TextBlock Text="Google drive" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" />
                                </WrapPanel>
                                
                            </ComboBoxItem>
                            <ComboBoxItem>
                                <WrapPanel>
                                    <Image Source="{DynamicResource img_db}" Height="15" Width="15" Margin="5"/>
                                    <TextBlock Text="DropBox" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" />
                                </WrapPanel>

                            </ComboBoxItem>
                            <ComboBoxItem>
                                <WrapPanel>
                                    <Image Source="{DynamicResource img_picasa}" Height="15" Width="15" Margin="5"/>
                                    <TextBlock Text="Picasa Library" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" />
                                </WrapPanel>

                            </ComboBoxItem>
                            <ComboBoxItem>
                                <WrapPanel>
                                    <Image Source="{DynamicResource img_lr}" Height="15" Width="15" Margin="5"/>
                                    <TextBlock Text="LightRoom Classic" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" />
                                </WrapPanel>

                            </ComboBoxItem>
                            <ComboBoxItem>
                                <WrapPanel>
                                    <Image Source="{DynamicResource img_photo}" Height="15" Width="15" Margin="5"/>
                                    <TextBlock Text="Photo Organizer" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" />
                                </WrapPanel>

                            </ComboBoxItem>
                            <ComboBoxItem>
                                <DockPanel>
                                    <Image Source="{DynamicResource img_db}" Height="15" Width="15" Margin="5"/>
                                    <TextBlock Text="BoxCloud" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" />
                                </DockPanel>

                            </ComboBoxItem>
                            <ComboBoxItem>
                                <DockPanel>
                                    <Image Source="{DynamicResource img_db}" Height="15" Width="15" Margin="5"/>
                                    <TextBlock Text="Amazon S3" VerticalAlignment="Center" FontSize="13" FontWeight="Medium" />
                                </DockPanel>

                            </ComboBoxItem>
                        </ComboBox>
                    </Button>
                    <TextBlock DockPanel.Dock="Right"/>

                </DockPanel>

            </Grid>

            <UserControls:ucHomeComparisonMethod Grid.Column="1" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1 0 0 0"/>
        </Grid>
        <Grid Grid.Row="1" Height="51" Background="{DynamicResource bgrclr_solidgray}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="btnUpgradeNow" Height="32" Width="148" Content="Upgrade Now" Style="{DynamicResource stl_btnUpgradeNow}" />
            <Button Grid.Column="1" x:Name="btnScanForDuplicates" Height="32" Width="235" Content="Scan for Duplicates" Style="{DynamicResource stl_btnScanForDuplicates}"
                    HorizontalAlignment="Center" IsEnabled="True" Click="btnScanForDuplicates_Click"/>
        </Grid>
        <Border Grid.Row="1" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="0 1 0 0"/>
    </Grid>
</UserControl>
