        public static int getBitmapValue(int val)
        {
            int bitmapSize = 48;
            cGloballEnum.enmBitmapSize enumval;
            if (val == 1)
            {
                enumval = cGloballEnum.enmBitmapSize.one;
            }
            else if (val == 2)
            {
                enumval = cGloballEnum.enmBitmapSize.two;
            }
            else if (val == 3)
            {
                enumval = cGloballEnum.enmBitmapSize.three;
            }
            else if (val == 4)
            {
                enumval = cGloballEnum.enmBitmapSize.four;
            }
            else if (val == 5)
            {
                enumval = cGloballEnum.enmBitmapSize.five;
            }
            else if (val == 6)
            {
                enumval = cGloballEnum.enmBitmapSize.six;
            }
            else if (val == 7)
            {
                enumval = cGloballEnum.enmBitmapSize.seven;
            }
            else
            {
                enumval = cGloballEnum.enmBitmapSize.defaultval;

            }


            switch (enumval)
            {
                case cGloballEnum.enmBitmapSize.one:
                    bitmapSize = 48;
                    break;

                case cGloballEnum.enmBitmapSize.two:
                    bitmapSize = 56;
                    break;

                case cGloballEnum.enmBitmapSize.three:
                    bitmapSize = 64;
                    break;

                case cGloballEnum.enmBitmapSize.four:
                    bitmapSize = 72;
                    break;

                case cGloballEnum.enmBitmapSize.five:
                    bitmapSize = 80;
                    break;

                case cGloballEnum.enmBitmapSize.six:
                    bitmapSize = 88;
                    break;

                case cGloballEnum.enmBitmapSize.seven:
                    bitmapSize = 96;
                    break;
            }

            return bitmapSize;
        }


