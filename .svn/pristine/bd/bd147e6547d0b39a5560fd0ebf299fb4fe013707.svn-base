        #region public functions
        public static bool InternalCheckIsWow64()
        {
            Process p = null;
            try
            {
                if ((Environment.OSVersion.Version.Major == OS_VERSION_MAJOR && Environment.OSVersion.Version.Minor >= OS_VERSION_MINOR) ||
                Environment.OSVersion.Version.Major >= OS_VERSION_MAJOR_UP)
                {
                    p = Process.GetCurrentProcess();

                    bool retVal;
                    if (!IsWow64Process(p.Handle, out retVal))
                    {
                        return false;
                    }
                    return retVal;

                }
                else
                {
                    return false;
                }
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("Utility:InternalCheckIsWow64", ex);
            }
            finally
            {
                p = null;
            }
            return false;
        }

        static SP_CLASSIMAGELIST_DATA m_ImageListData = new SP_CLASSIMAGELIST_DATA();
        public static uint Geticonindex(string strGuid)
        {
            //-------------------------------------------------------------------------------

            bool success = false;
            int ClassImage = 0;

            try
            {

                if (!string.IsNullOrEmpty(strGuid))
                {
                    Guid ClassGuid = new Guid(strGuid);

                    m_ImageListData.cbSize = (UInt32)Marshal.SizeOf(typeof(SP_CLASSIMAGELIST_DATA));
                    SetupDiGetClassImageList(out m_ImageListData);

                    success = SetupDiGetClassImageIndex(ref m_ImageListData, ref ClassGuid, out ClassImage);

#if DEBUG
                   // uint err = NativeMethodsExtensions.GetLastError(); not referncing GetLastError method
                    string errorMessage = new Win32Exception(Marshal.GetLastWin32Error()).Message;
                   // Console.WriteLine(string.Format("ErrorCode:{0},ErrorDescription{1}", err, errorMessage));
#endif
                    //-------------------------------------------------------------------------------
                }
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLog(strGuid);
                cGlobalSettings.oLogger.WriteLogException("Utility.cs:Geticonindex()", ex);
            }
            return (uint)ClassImage;
        }

        public static string Geticon(string strGuid)
        {
            //-------------------------------------------------------------------------------

            bool success = false;
            int ClassImage = 0;
            System.Drawing.Icon smallIcon = null;
            string icoPath = string.Empty;
            try
            {


                Guid ClassGuid = new Guid(strGuid);

                m_ImageListData.cbSize = (UInt32)Marshal.SizeOf(typeof(SP_CLASSIMAGELIST_DATA));
                SetupDiGetClassImageList(out m_ImageListData);

                success = SetupDiGetClassImageIndex(ref m_ImageListData, ref ClassGuid, out ClassImage);

                IntPtr smallIconHandle = ImageList_GetIcon(m_ImageListData.HIMAGELIST, ClassImage, 1);

                smallIcon = System.Drawing.Icon.FromHandle(smallIconHandle);

                icoPath = GetIconPath(smallIcon, ClassImage.ToString());

#if DEBUG
               // uint err = NativeMethodsExtensions.GetLastError();
                string errorMessage = new Win32Exception(Marshal.GetLastWin32Error()).Message;
               // Console.WriteLine(string.Format("ErrorCode:{0},ErrorDescription{1}", err, errorMessage));
#endif
                //-------------------------------------------------------------------------------
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("Utility.cs:Geticon()", ex);
            }
            return icoPath;
        }
        const string IconPath = "DeviceIcons";
        private static string GetIconPath(System.Drawing.Icon deviceIcon, string sGuid)
        {
            string completePath = string.Empty;
            try
            {
                if (deviceIcon != null)
                {
                    string imagePath = Path.Combine(Path.GetDirectoryName(System.Windows.Forms.Application.ExecutablePath), IconPath);
                    if (!Directory.Exists(imagePath))
                    {
                        Directory.CreateDirectory(imagePath);
                    }
                    completePath = Path.Combine(imagePath, string.Concat(sGuid, ".Png"));
                    if (!File.Exists(completePath))
                    {
                        using (FileStream fs = new FileStream(completePath, FileMode.Create))
                            deviceIcon.ToBitmap().Save(fs, System.Drawing.Imaging.ImageFormat.Png);
                    }
                    return completePath;
                }
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("Utility.cs:GetIconPath()", ex);
            }
            return completePath;
        }

