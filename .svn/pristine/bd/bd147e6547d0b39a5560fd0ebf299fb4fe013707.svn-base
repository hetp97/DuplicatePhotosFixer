                long fileSize
                , [MarshalAs(UnmanagedType.LPTStr)] StringBuilder buffer
                , int bufferSize);


        /// <summary>
        /// Converts a numeric value into a string that represents the number expressed as a size value in bytes, kilobytes, megabytes, or gigabytes, depending on the size.
        /// </summary>
        /// <param name="filelength">The numeric value to be converted.</param>
        /// <returns>the converted string</returns>
        public static string StrFormatByteSize(long filesize)
        {
            StringBuilder sb = new StringBuilder(11);
            StrFormatByteSize(filesize, sb, sb.Capacity);
            return sb.ToString();
        }


        /// <summary>
        /// Calculate MD5 hash for a given file path.
        /// </summary>
        /// <param name="files"> FilePath whose MD5 is to calculate.</param>
        /// <returns>MD5 hash</returns>
        public static string calcMD5(string files)
        {
            MD5 md5 = null;
            Stream stream = null;
            try
            {
                using (md5 = MD5.Create())
                {
                    using (stream = File.OpenRead(files))
                    {
                        //string tempvalue = BitConverter.ToString(md5.ComputeHash(stream)).Replace("-", "").ToLower();
                        return BitConverter.ToString(md5.ComputeHash(stream)).Replace("-", "").ToLower();
                    }
                }
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("calcMD5() :: file:" + files, ex);
            }
            finally
            {
                if (stream != null)
                {
                    stream.Close();
                    stream.Dispose();
                    stream = null;
                }


                if (md5 != null)
                {
                    md5.Clear();
                    md5 = null;
                }
            }

            return null;
        }

