        public static string GetMD5(string filename)
        {
            string Md5 = string.Empty;
            try
            {
                using (var md5 = MD5.Create())
                {
                    using (var stream = File.OpenRead(filename))
                    {
                        var hash = md5.ComputeHash(stream);
                        Md5 = System.BitConverter.ToString(hash).Replace("-", "");
                        hash = null;
                        return Md5;
                    }
                }
            }
            catch (System.Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException(string.Format("GetMD5 of {0} :- ", filename), ex);
            }
            return Md5;
        }

        public static DateTime GetDateTimeInGlobalFormat(string sDateTime)
        {
            return GetDateTimeInGlobalFormat(sDateTime, false, true);
        }

        public static DateTime GetLocalTimeZoneDateFromUTC(DateTime oDTUtc)
        {
            return TimeZoneInfo.ConvertTimeFromUtc(oDTUtc, TimeZoneInfo.Local);
        }

        public static DateTime GetDateTimeInGlobalFormat(string sDateTime, bool ConvertTimeOnly, bool ConvertToLocalTimeZone)
        {
            DateTime dtDate = DateTime.UtcNow;
            try
            {

                if (!string.IsNullOrEmpty(sDateTime))
                {

                    System.Globalization.DateTimeFormatInfo MyDateTimeFormatInfo = new System.Globalization.DateTimeFormatInfo();
                    MyDateTimeFormatInfo.ShortDatePattern = "M/d/yyyy";
                    if (!DateTime.TryParse(sDateTime, MyDateTimeFormatInfo, System.Globalization.DateTimeStyles.AdjustToUniversal, out dtDate))
                    {
                        if (cGlobalSettings.oLogger != null) cGlobalSettings.oLogger.WriteLogVerbose("unable to type cast server date value: " + sDateTime);
                        dtDate = DateTime.UtcNow;
                    }

                    //dtDate = GetLocalTimeZoneDateFromUTC(dtDate);
                }

                if (ConvertToLocalTimeZone)
                {
                    dtDate = GetLocalTimeZoneDateFromUTC(dtDate);
                }


            }
            catch (System.Exception ex)
            {
                cGlobalSettings.oLogger.WriteLog("GetDateTimeInGlobalFormat::Unable to Type Cast Date : " + ex.Message + " | value | " + sDateTime);
            }
            return dtDate;
        }

        public static string GetUTCDateString(string fmt = "")
        {
            return (string.IsNullOrEmpty(fmt)) ? DateTime.UtcNow.ToString() : DateTime.UtcNow.ToString(fmt/*"M/d/yyyy hh:mm:ss tttt"*/);
        }

        public static double degreeToRadian(double degree)
        {
            return degree * Math.PI / 180.0;
        }

        public static double radianToDegree(double Radian)
        {
            return (Radian / Math.PI * 180.0);
        }


        public static bool IsValidEmail(string strIn)
        {
            invalid = false;
            if (String.IsNullOrEmpty(strIn))
                return false;

            // Use IdnMapping class to convert Unicode domain names.
            try
            {
                strIn = Regex.Replace(strIn, @"(@)(.+)$", DomainMapper,
                                      RegexOptions.None);
            }
            catch /*(RegexMatchTimeoutException)*/
            {
                return false;
            }

            if (invalid)
                return false;

            // Return true if strIn is in valid e-mail format.
            try
            {
                return Regex.IsMatch(strIn,
                      @"^(?("")("".+?(?<!\\)""@)|(([0-9a-z]((\.(?!\.))|[-!#\$%&'\*\+/=\?\^`\{\}\|~\w])*)(?<=[0-9a-z])@))" +
                      @"(?(\[)(\[(\d{1,3}\.){3}\d{1,3}\])|(([0-9a-z][-\w]*[0-9a-z]*\.)+[a-z0-9][\-a-z0-9]{0,22}[a-z0-9]))$",
                      RegexOptions.IgnoreCase);
            }
            catch /*(RegexMatchTimeoutException)*/
            {
                return false;
            }
        }

        /// <summary>
        /// 
        /// </summary>
        /// <param name="BytesSize"></param>
        /// <returns></returns>
        public static string getSizeFormat(double BytesSize)
        {
            string sizeFormat = string.Empty;

            if (BytesSize >= 1024)
            {
                BytesSize = BytesSize / 1024.0;
                if (BytesSize >= 1024)
                {
                    BytesSize = BytesSize / 1024;
                    if (BytesSize >= 1024)
                    {
                        BytesSize = BytesSize / 1024;
                        sizeFormat = Math.Ceiling(BytesSize).ToString("0.00") + " GB";
                    }
                    else
                    {
                        sizeFormat = Math.Ceiling(BytesSize).ToString("0") + " MB";
                    }
                }
                else
                {
                    sizeFormat = Math.Ceiling(BytesSize).ToString("0") + " KB";
                }
            }
            else
            {
                sizeFormat = Math.Ceiling(BytesSize).ToString() + " Bytes";
            }
            return sizeFormat;
        }


