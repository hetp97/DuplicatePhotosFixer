            }
            return string.Empty;

        }

        #region Serilize XML Data
        public static T DeSerilizeXML<T>(string xmlPath)
        {
            T data = default(T);
            try
            {
                if (File.Exists(xmlPath))
                {
                    var xml = System.IO.File.ReadAllText(xmlPath);
                    using (MemoryStream stream = new MemoryStream(Encoding.UTF8.GetBytes(xml)))
                    {
                        XmlSerializer serializer = new XmlSerializer(typeof(T));
                        data = (T)serializer.Deserialize(stream);
                        return (T)data;
                    }
                }
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("Utility.cs:DeSerilizeXMLData()", ex);
            }
            return (T)data;
        }

        public static T DeSerilizeXMLData<T>(string xmlData)
        {
            T data = default(T);
            try
            {
                if (!string.IsNullOrEmpty(xmlData))
                {
                    //var xml = System.IO.File.ReadAllText(xmlPath);
                    using (MemoryStream stream = new MemoryStream(Encoding.UTF8.GetBytes(xmlData)))
                    {
                        XmlSerializer serializer = new XmlSerializer(typeof(T));
                        data = (T)serializer.Deserialize(stream);
                        return (T)data;
                    }
                }
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("Utility.cs:DeSerilizeXMLData()", ex);
            }
            return (T)data;
        }
        #endregion




        public static System.Runtime.InteropServices.ComTypes.FILETIME FileTimeFromDateTime(DateTime date)
        {
            long ftime = date.ToFileTime();

            System.Runtime.InteropServices.ComTypes.FILETIME ft = new System.Runtime.InteropServices.ComTypes.FILETIME();
            ft.dwHighDateTime = (int)(ftime >> 32);
            ft.dwLowDateTime = (int)ftime;

            return ft;
        }

        public static DateTime DateTimeFromFileTime(System.Runtime.InteropServices.ComTypes.FILETIME ft)
        {
            return DateTime.FromFileTime(
                ((long)ft.dwHighDateTime << 32)
                + (long)ft.dwLowDateTime);
        }

        public static string GetTemporaryDirectory()
        {
            string tempDirectory = string.Empty;
            try
            {
                tempDirectory = Path.Combine(Path.GetTempPath(), Path.GetRandomFileName());
                Directory.CreateDirectory(tempDirectory);
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("Utility.cs:GetTemporaryDirectory()", ex);
            }

            return tempDirectory;
        }
        public static string ConvertISO8601Date(string value)
        {
            string rvalue = string.Empty;
            try
            {
                DateTime outputDateTimeValue = DateTime.Parse(System.Convert.ToString(value), null, System.Globalization.DateTimeStyles.RoundtripKind);
                rvalue = outputDateTimeValue.ToString(@"MM/dd/yyyy");
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("Utility.cs:ConvertISO8601Date()", ex);
            }
            return rvalue;
        }

        const string ApplicationNameStringTag = "PKS_DU_APP_NAME";
        const string CompanyNameStringTag = "PKS_DU_COMPANY_NAME";
        public static string UpdateProductName(string description, string productString)
        {
            string rvalue = string.Empty;
            try
            {
                if (description != null && description.Length > 0 && productString != null && productString.Length > 0)
                {
                    if (description.IndexOf(ApplicationNameStringTag) != -1)
                    {
                        rvalue = description.Replace(ApplicationNameStringTag, cGlobalSettings.GetProductName());
                    }
                }
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("Utility.cs:UpdateProductName()", ex);
            }
            return rvalue;
        }

        public static string UpdateCompanyName(string description, string CompanyString)
        {
            string rvalue = string.Empty;
            try
            {
                if (description != null && description.Length > 0 && CompanyString != null && CompanyString.Length > 0)
                {
                    if (description.IndexOf(CompanyNameStringTag) != -1)
                    {
                        rvalue = description.Replace(CompanyNameStringTag, cGlobalSettings.GetCompanyName());
                    }
                }
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("Utility.cs:UpdateProductName()", ex);
            }
            return rvalue;
        }

        public static List<string> ExtractStringFromTag(string description, string tag)
        {
            string rvalue = string.Empty;
            string startTag = string.Empty;
            string endTag = string.Empty;
            List<string> destList = new List<string>();

            //foreach (Match match in Regex.Matches(source, "<m>(.*?)</m>"))
            //    destList.Add(match.Groups[1].Value);
            try
            {
                startTag = string.Format("<{0}>", tag);
                endTag = string.Format("</{0}>", tag);
                foreach (Match match in Regex.Matches(description, string.Format("{0}(.*?){1}", startTag, endTag)))
                    destList.Add(match.Groups[1].Value);
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("Utility.cs:ExtractStringFromTag()", ex);
            }
            return destList;
        }



