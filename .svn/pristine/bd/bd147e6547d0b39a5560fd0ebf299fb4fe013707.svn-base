        public static long GetSizes(long sourcesize, cClientEnum.SizeIN sourceunit)
        {
            long size = 0;
            long convertedsize = 0;
            try
            {
                cClientEnum.SizeIN MINSIZEIN = sourceunit;// (cClientEnum.SizeIN)RegistryVariables.MinSizeIn;
                //_minfilesizeunit =  (cClientEnum.SizeIN)RegistryVariables.MinSizeIn;
                size = sourcesize;
                switch (MINSIZEIN)
                {
                    case cClientEnum.SizeIN.Bytes:
                        {
                            convertedsize = (long)Convert.ToDecimal(size);
                        }
                        break;
                    case cClientEnum.SizeIN.KBytes:
                        {
                            convertedsize = (long)Convert.ToDecimal(size / 1024);
                        }
                        break;
                    case cClientEnum.SizeIN.MBytes:
                        {
                            convertedsize = (long)Convert.ToDecimal(size / 1048576);

                        }
                        break;
                    case cClientEnum.SizeIN.GBytes:
                        {
                            convertedsize = (long)Convert.ToDecimal(size / 1073741824);

                        }
                        break;
                    default:
                        break;
                }
                //CheckSettingChanged();
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("AppFunctions : GetSizes() :: ", ex);
            }
            return convertedsize;
        }

        private static void StringToByteArrayCaseInsensitiveW(string rawdata, ref byte[] strBuff, ref uint dwBuffLen)
        {
            try
            {

                strBuff = Encoding.UTF8.GetBytes(rawdata);
                if (strBuff != null && strBuff.Length > 0)
                {
                    dwBuffLen = (uint)strBuff.Length;
                }
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("RCPSSExports.cs|StringToByteArrayCaseInsensitiveW()", ex);
            }
        }

        public static void FireUrlInBrowser(string UrlToOpen)
        {
            try
            {
                Process.Start(UrlToOpen);
            }
            catch (Exception ex)
            {
                try
                {
                    if (!String.IsNullOrEmpty(UrlToOpen))
                        Process.Start("IExplore.exe", UrlToOpen);
                }
                catch (Exception)
                {
                    cGlobalSettings.oLogger.WriteLogException("FireUrlInBrowser:: Not able to open IE also.", ex);
                }
            }
        }

        public static string RemoveXmlDefinition(string xml)
        {
            string resultValue = string.Empty;
            XDocument xdoc = null;
            try
            {
                xdoc = XDocument.Parse(xml);
                xdoc.Declaration = null;
                resultValue = xdoc.ToString();
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("CHelper.cs|RemoveXmlDefinition()", ex);
            }
            finally
            {
                xdoc = null;
            }
            return resultValue;
        }

