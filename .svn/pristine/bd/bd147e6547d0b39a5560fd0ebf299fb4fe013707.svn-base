        public static bool isChildFolder(string folderToCheck, string folderCheckWith)
        {
            bool isChild = false;

            try
            {
                string _folderToCheck = folderToCheck.Replace("/", "\\");
                string folderPath = folderCheckWith.Replace("/", "\\"); ;
                int folderToCheckLength = _folderToCheck.Length;

                while (!string.IsNullOrEmpty(folderPath))
                {
                    if (folderToCheckLength > folderPath.Length)
                        break;

                    if (string.Compare(_folderToCheck, folderPath, true) == 0)
                    {
                        isChild = true;
                        break;
                    }
                    else
                    {
                        folderPath = Path.GetDirectoryName(folderPath);
                    }
                }
            }
            catch
            {
                ;
            }


            return isChild;
        }
