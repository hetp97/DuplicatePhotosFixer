        const string versionFormat = "{0}.{1}.{2}.{3}";
        /// <summary>
        /// the application return the current version of the application
        /// </summary>
        /// <returns></returns>
        public static string GetApplicationVersion()
        {
            string appVersion = string.Empty;
            Version version = null;
            try
            {
                version = Assembly.GetExecutingAssembly().GetName().Version;
                appVersion = String.Format(versionFormat, version.Major, version.Minor, version.Build, version.Revision);
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("Utility:GetApplicationVersion()", ex);
            }
            finally
            {
                version = null;
            }
            return appVersion;
        }
        /// <summary>
        /// the function remove all the white spaces from XML
        /// and returned the cleaned data
        /// </summary>
        /// <param name="xmlPath"></param>
        /// <returns></returns>
        public static string RemoveWhiteSpacesFromXML(string xmlPath)
        {
            string cleanedXml = string.Empty;
            try
            {
                string xmlData = File.ReadAllText(xmlPath);
                Regex regex = new Regex(@">\s*<");
                cleanedXml = regex.Replace(xmlData, "><");
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("Utility:RemoveWhiteSpacesFromXML()", ex);
            }
            return cleanedXml;
        }

        const string pathVariableName = "path";
        /// <summary>
        /// it is a custom implimentation of PathFindOnPath
        /// If no directories are specified in searchDirectory, 
        /// it attempts to find the file by searching standard directories such as System32 and the directories specified in the PATH environment variable.
        /// </summary>
        /// <param name="fileToSearch"></param>
        /// <param name="searchDirectory"></param>
        /// <returns></returns>
        ///  
        [DllImport("shlwapi.dll", CharSet = CharSet.Auto, SetLastError = false)]
        static extern bool PathFindOnPath([MarshalAs(UnmanagedType.LPTStr)] StringBuilder pszFile, IntPtr unused);

        public static bool FindInPath(string fileName)
        {
            const int MAX_PATH = 260;
            StringBuilder sb = null;
            bool found = false;
            try
            {
                sb = new StringBuilder(fileName, MAX_PATH);
                found = PathFindOnPath(sb, IntPtr.Zero);
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("Utility:FindInPath()", ex);
            }
            finally
            {
                sb = null;
            }
            return found;
        }
        public static bool PathFindOnPath(ref string fileToSearch, string searchDirectory = "")
        {
            string fullFilePath = string.Empty;
            string tmpFile = fileToSearch;
            List<string> fileList = null;
            List<string> directoryList = null;

            try
            {
                fileList = new List<string>();
                directoryList = new List<string>();
                if (FilePathHasInvalidChars(fileToSearch))
                {
                    fileToSearch = string.Empty;
                    return false;
                }

                if (!string.IsNullOrEmpty(searchDirectory.Trim()))
                {
                    fileList = Directory.GetFiles(searchDirectory, fileToSearch).ToList();
                    if (fileList != null && fileList.Count > 0)
                    {
                        fullFilePath = fileList[0];
                    }
                }
                else
                {
                    string systemDirectory = Environment.GetFolderPath(Environment.SpecialFolder.System);
                    fileList = Directory.GetFiles(systemDirectory, fileToSearch).ToList();
                    if (fileList != null && fileList.Count > 0)
                    {
                        fullFilePath = fileList[0];
                    }
                    else
                    {
                        string paths = Environment.GetEnvironmentVariable(pathVariableName);
                        directoryList = paths.Split(new char[] { ';' }).ToList();

                        foreach (var searchDir in directoryList)
                        {
                            try
                            {
                                if (Directory.Exists(searchDir))
                                {
                                    fileList = Directory.GetFiles(searchDir, fileToSearch).ToList();
                                    if (fileList != null && fileList.Count > 0)
                                    {
                                        fullFilePath = fileList[0];
                                        break;
                                    }
                                }
                            }
                            catch (Exception ex)
                            {
                                cGlobalSettings.oLogger.WriteLogException("Utility.cs:PathFindOnPath() Loop in Directory", ex);
                            }
                            finally
                            {
                                fileList = null;
                            }

                        }
                    }

                }


            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLog(string.Format("Utility.cs:PathFindOnPath() {0}", ex.Message));
            }
            finally
            {
                fileList = null;
                directoryList = null;
                if (!string.IsNullOrEmpty(fullFilePath.Trim()))
                    fileToSearch = fullFilePath;
                else
                    fileToSearch = tmpFile;
            }

            return string.IsNullOrEmpty(fullFilePath.Trim()) ? false : true;
        }

        public static bool FilePathHasInvalidChars(string path)
        {
            bool response = false;
            try
            {
                response = (!string.IsNullOrEmpty(path)
                    && path.IndexOfAny(System.IO.Path.GetInvalidFileNameChars()) >= 0);
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("Utility.cs:FilePathHasInvalidChars()", ex);
            }
            return response;

        }

        public static bool PathHasInvalidChars(string path)
        {
            bool response = false;
            try
            {
                response = (!string.IsNullOrEmpty(path)
                    && path.IndexOfAny(System.IO.Path.GetInvalidPathChars()) >= 0);
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("Utility.cs:FilePathHasInvalidChars()", ex);
            }
            return response;

        }

