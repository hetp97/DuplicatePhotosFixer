        /// Open property dialog
        /// http://stackoverflow.com/questions/1936682/how-do-i-display-a-files-properties-dialog-from-c

        [DllImport("shell32.dll", CharSet = CharSet.Auto)]
        static extern bool ShellExecuteEx(ref SHELLEXECUTEINFO lpExecInfo);

        [StructLayout(LayoutKind.Sequential, CharSet = CharSet.Auto)]
        public struct SHELLEXECUTEINFO
        {
            public int cbSize;
            public uint fMask;
            public IntPtr hwnd;
            [MarshalAs(UnmanagedType.LPTStr)]
            public string lpVerb;
            [MarshalAs(UnmanagedType.LPTStr)]
            public string lpFile;
            [MarshalAs(UnmanagedType.LPTStr)]
            public string lpParameters;
            [MarshalAs(UnmanagedType.LPTStr)]
            public string lpDirectory;
            public int nShow;
            public IntPtr hInstApp;
            public IntPtr lpIDList;
            [MarshalAs(UnmanagedType.LPTStr)]
            public string lpClass;
            public IntPtr hkeyClass;
            public uint dwHotKey;
            public IntPtr hIcon;
            public IntPtr hProcess;
        }

        private const int SW_SHOW = 5;
        private const uint SEE_MASK_INVOKEIDLIST = 12;
        public static bool ShowFileProperties(string Filename)
        {
            /*try
            {*/
            SHELLEXECUTEINFO info = new SHELLEXECUTEINFO();
            info.cbSize = System.Runtime.InteropServices.Marshal.SizeOf(info);
            info.lpVerb = "properties";
            info.lpFile = Filename;
            info.nShow = SW_SHOW;
            info.fMask = SEE_MASK_INVOKEIDLIST;
            return ShellExecuteEx(ref info);
            /*}
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException(" AppFunctions :: ShowFileProperties : ", ex);
            }*/

        }

        /// <summary>
        /// Convert DataTime in long to string datetime
        /// </summary>
        /// <param name="ulDateTimeQuadPart"></param>
        /// <returns></returns>
        public static string GetDateString(Int64 ulDateTimeQuadPart, string strFormat = null)
        {
            if (ulDateTimeQuadPart == 0)
            {
                return "Not Available";
            }
            else
            {
                if (strFormat == null)
                    return DateTime.FromFileTimeUtc(ulDateTimeQuadPart).ToShortDateString().ToString(CultureInfo.CurrentCulture.DateTimeFormat);
                else
                    return DateTime.FromFileTimeUtc(ulDateTimeQuadPart).ToString(strFormat);
            }
        }

        public static string GetDateString(DateTime dateTime)
        {
            return dateTime.ToString(CultureInfo.CurrentCulture.DateTimeFormat);
        }

        public static Int64 GetUnixEpoch(this DateTime dateTime)
        {
            System.TimeSpan timeDifference = dateTime - new DateTime(1970, 1, 1, 0, 0, 0, DateTimeKind.Utc);
            Int64 epoch = System.Convert.ToInt64(timeDifference.TotalSeconds);
            return epoch;
        }

        public static DateTime UnixTimeStampToDateTime(double unixTimeStamp)
        {
            // Unix timestamp is seconds past epoch
            System.DateTime dtDateTime = new DateTime(1970, 1, 1, 0, 0, 0, 0, DateTimeKind.Utc);
            dtDateTime = dtDateTime.AddSeconds(unixTimeStamp);
            return dtDateTime;
        }

        public static int ExecuteProcess(string sProcName, string ProcArgs, bool shellExecute, bool CreateNoWindow, bool WaitForExit)
        {

            int PROCESS_EXIT_CODE = 0;

            Process pUnrar = new Process();
            pUnrar.StartInfo.FileName = sProcName;
            pUnrar.StartInfo.Arguments = ProcArgs;
            pUnrar.StartInfo.UseShellExecute = shellExecute;
            pUnrar.StartInfo.CreateNoWindow = CreateNoWindow;
            pUnrar.StartInfo.WindowStyle = ProcessWindowStyle.Hidden;
            pUnrar.StartInfo.RedirectStandardOutput = false;
            pUnrar.StartInfo.ErrorDialog = false;

            pUnrar.Start();
            if (WaitForExit)
            {
                pUnrar.WaitForExit();
                PROCESS_EXIT_CODE = pUnrar.ExitCode;
                pUnrar.Close();
                pUnrar.Dispose();
            }
            return PROCESS_EXIT_CODE;
        }

        public static void KillProcessByName(string processName)
        {

            foreach (var process in Process.GetProcessesByName(processName))
            {
                process.Kill();
            }

        }


        public static void FormatTextBlockText(this System.Windows.Controls.TextBlock myTextBlock, string strText)
        {
            try
            {
                myTextBlock.Inlines.Clear();
                //string s = "<b>This</b> is <b>bold</b> text <b>bold</b> again."; // Sample text
                var parts = strText.Split(new[] { "<Bold>", "</Bold>", "<b>", "</b>", "<bold>", "</bold>", "<B>", "</B>" }, StringSplitOptions.None | StringSplitOptions.RemoveEmptyEntries);
                bool isbold = false; // Start in normal mode
                if (strText.StartsWith("<Bold>", true, CultureInfo.CurrentCulture) || strText.StartsWith("<b>", true, CultureInfo.CurrentCulture))
                {
                    isbold = true;
                }

                foreach (var part in parts)
                {
                    if (isbold)
                        myTextBlock.Inlines.Add(new System.Windows.Documents.Bold(new System.Windows.Documents.Run(part)));
                    else
                        myTextBlock.Inlines.Add(new System.Windows.Documents.Run(part));

                    isbold = !isbold; // toggle between bold and not bold
                }

            }
            catch (Exception ex)
            {

            }
        }


        public static void FormatTextBlockTextColor(this System.Windows.Controls.TextBlock myTextBlock, string strText, System.Windows.Media.Brush highlishtBrush, bool bUnderLine = false, bool bBold = false, double? fontsize = null)
        {
            try
            {
                SolidColorBrush fontBrush = (SolidColorBrush)myTextBlock.Foreground;

                myTextBlock.Text = "";
                myTextBlock.Inlines.Clear();

                var parts = strText.Split(new[] { "<Color>", "</Color>", "<c>", "</c>", "<color>", "</color>", "<COLOR>", "</COLOR>", "<C>", "</C>" }, StringSplitOptions.None | StringSplitOptions.RemoveEmptyEntries);
                bool iscolor = false; // Start in normal mode 
                if (strText.StartsWith("<Color>", true, CultureInfo.CurrentCulture) || strText.StartsWith("<c>", true, CultureInfo.CurrentCulture))
                {
                    iscolor = true;
                }

                foreach (var part in parts)
                {
                    if (iscolor)
                    {
                        Run sRun = new Run(part);
                        sRun.Foreground = highlishtBrush;

                        if (fontsize != null && fontsize > 0)
                            sRun.FontSize = (double)fontsize;

                        if (bUnderLine)
                        {
                            sRun.TextDecorations = System.Windows.TextDecorations.Underline;
                            sRun.Cursor = System.Windows.Input.Cursors.Hand;

                            if (bBold)
                            {
                                myTextBlock.Inlines.Add(new Bold(sRun));
                            }
                            else
                            {
                                myTextBlock.Inlines.Add(sRun);
                            }
                        }
                        else if (bBold)
                        {
                            myTextBlock.Inlines.Add(new Bold(sRun));
                        }
                        else
                        {
                            myTextBlock.Inlines.Add(sRun);
                        }
                    }
                    else
                    {
                        Run sRun = new Run(part);
                        sRun.Foreground = fontBrush;
                        myTextBlock.Inlines.Add(sRun);
                    }

                    iscolor = !iscolor; // toggle between bold and not bold 
                }
            }
            catch (Exception ex)
            {

            }
        }

        public static void FormatRichTextBoxTextColor(this System.Windows.Controls.RichTextBox myRichTextBox, string strText)
        {
            try
            {
                SolidColorBrush fontBrush = (SolidColorBrush)myRichTextBox.Foreground;

                myRichTextBox.Document.Blocks.Clear();

                //string s = "<b>This</b> is <b>bold</b> text <b>bold</b> again."; // Sample text
                var parts = strText.Split(new[] { "<Color>", "</Color>", "<c>", "</c>", "<color>", "</color>", "<COLOR>", "</COLOR>", "<C>", "</C>" }, StringSplitOptions.None | StringSplitOptions.RemoveEmptyEntries);
                bool iscolor = false; // Start in normal mode
                if (strText.StartsWith("<Color>", true, CultureInfo.CurrentCulture) || strText.StartsWith("<c>", true, CultureInfo.CurrentCulture))
                {
                    iscolor = true;
                }

                foreach (var part in parts)
                {
                    if (iscolor)
                    {
                        HighlightWordInRichTextBox(myRichTextBox, part, new SolidColorBrush(System.Windows.Media.Color.FromArgb((byte)255, (byte)255, (byte)0, (byte)0)));
                        //myRichTextBox.Inlines.Add(new System.Windows.Documents.Bold(new System.Windows.Documents.Run(part)));
                    }
                    else
                    {
                        HighlightWordInRichTextBox(myRichTextBox, part, fontBrush);
                    }
                    //myRichTextBox.AppendText(part);// Inlines.Add(new System.Windows.Documents.Run(part));

                    iscolor = !iscolor; // toggle between bold and not bold
                }

            }
            catch (Exception ex)
            {

            }
        }

        public static void HighlightWordInRichTextBox(System.Windows.Controls.RichTextBox richTextBox, String word, SolidColorBrush color)
        {
            //Current word at the pointer
            TextRange tr = new System.Windows.Documents.TextRange(richTextBox.Document.ContentEnd, richTextBox.Document.ContentEnd);
            tr.Text = word;
            tr.ApplyPropertyValue(TextElement.ForegroundProperty, color);
        }


        public static void RestartSystem(UInt16 delay = 0)
        {
            try
            {
                ProcessStartInfo proc = new ProcessStartInfo();
                proc.FileName = "cmd";
                proc.WindowStyle = ProcessWindowStyle.Hidden;
                proc.Arguments = "/C shutdown /r -t " + delay;
                Process.Start(proc);
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("RestartSystem:: ", ex);
            }
        }


        /// <summary>
        /// Check if form is inside the user screen or not
        /// </summary>
        /// <returns></returns>
        public static bool isFormFullyOnScreen(this Form frm)
        {
            try
            {
                Screen[] screens = Screen.AllScreens;
                foreach (Screen screen in screens)
                {
                    Rectangle formRectangle = new Rectangle(frm.Left, frm.Top, frm.Width, frm.Height);

                    if (screen.WorkingArea.Contains(formRectangle))
                    {
                        return true;
                    }
                }
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("isFormFullyOnScreen:: ", ex);
            }
            return false;
        }



        public static bool extIsFormDisposed(this System.Windows.Window window)
        {
            if (window == null || System.Windows.PresentationSource.FromVisual(window) == null || System.Windows.PresentationSource.FromVisual(window).IsDisposed)
            {
                return true;
            }
            return false;
        }

        public static bool extIsUCCtrlDisposed(this System.Windows.Controls.UserControl ucControl)
        {
            if (ucControl == null || System.Windows.PresentationSource.FromVisual(ucControl) == null || System.Windows.PresentationSource.FromVisual(ucControl).IsDisposed)
            {
                return true;
            }

            return false;
        }


        public static void CreateScheduleAtStartup(bool bCreate)
        {
            try
            {
                string strAppPath = Application.ExecutablePath;
                if (Environment.OSVersion.Version.Major < 6)
                {
                    RegistryKey regKey = Registry.CurrentUser.OpenSubKey(@"Software\Microsoft\Windows\CurrentVersion\Run", true);

                    if (regKey == null)
                    {
                        //Registry.CurrentUser.CreateSubKey(VersionIndependentRegKeyNoHive);
                        return;
                    }
                    else
                    {
                        if (bCreate)
                        {
                            Console.WriteLine("\"" + strAppPath + "\" /autoscan");

                            regKey.SetValue(cGlobalSettings.GetProductName() + "_startup", "\"" + strAppPath + "\" /autoscan", RegistryValueKind.String);

                        }
                        else /*if (bDelete)*/
                        {
                            regKey.DeleteValue(cGlobalSettings.GetProductName() + "_startup");
                        }
                    }
                }
                else
                {
                    string processArgs = string.Empty;

                    if (bCreate)
                    {
                        processArgs = "/C schtasks.exe /create /tn \"" + cGlobalSettings.GetProductName() + "_startup\" /tr \"'" + strAppPath + "' /autoscan\" /sc onlogon /RL HIGHEST /F";
                    }
                    else/*if(bDelete)*/
                    {
                        processArgs = "/C schtasks.exe /delete /tn \"" + cGlobalSettings.GetProductName() + "_startup\" /F";
                    }

                    System.Diagnostics.Process process = new System.Diagnostics.Process();

                    process.StartInfo.FileName = "cmd.exe";
                    process.StartInfo.Arguments = processArgs;
                    process.StartInfo.CreateNoWindow = true;
                    process.StartInfo.WindowStyle = System.Diagnostics.ProcessWindowStyle.Hidden;
                    process.Start();

                }
            }
            catch (Exception ex)
            {
                //Console.WriteLine(ex.Message);
            }
        }

        public static void LoadUrlForTrackingSilently(string url)
        {
            try
            {
                //enable BHO logs only when scanned for the first time 
                WebBrowser oBrowser = new WebBrowser();
                oBrowser.DocumentCompleted += new WebBrowserDocumentCompletedEventHandler(oBrowser_DocumentCompleted);
                oBrowser.ScriptErrorsSuppressed = true;
                oBrowser.Navigate(url);
                System.Threading.Thread.Sleep(500); // (1000); 
            }
            catch (System.Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("frmMain:: LoadUrlForTrackingSilently: ", ex);
                //oUtils.WriteToFile(string.Format("{0}|LoadUrlForTrackingSilently()|exception:{1}", this, ex.Message));
            }
        }

        public static T GetChildOfType<T>(this System.Windows.DependencyObject depObj)
    where T : System.Windows.DependencyObject
        {
            if (depObj == null) return null;

            for (int i = 0; i < VisualTreeHelper.GetChildrenCount(depObj); i++)
            {
                var child = VisualTreeHelper.GetChild(depObj, i);

                var result = (child as T) ?? GetChildOfType<T>(child);
                if (result != null) return result;
            }
            return null;
        }

        static void oBrowser_DocumentCompleted(object sender, WebBrowserDocumentCompletedEventArgs e)
        {
            try
            {
                (sender as WebBrowser).Dispose();
                sender = null;
            }
            catch (System.Exception ex)
            {
                cGlobalSettings.oLogger.WriteLog(string.Format("oBrowser_DocumentCompleted()|exception:{0}", ex.Message));
            }
        }

