        public static string getElapsedTime(this System.Diagnostics.Stopwatch watch)
        {
            return "\tDays:" + watch.Elapsed.Days + "\tHours:" + watch.Elapsed.Hours + "\tminutes:" + watch.Elapsed.Minutes + "\tseconds:" + watch.Elapsed.Seconds;
        }

        //check if complete form is visible on screen
        public static bool IsOnScreen(Form form)
        {
            Screen[] screens = Screen.AllScreens;
            foreach (Screen screen in screens)
            {
                Rectangle formRectangle = new Rectangle(form.Left, form.Top, form.Width, form.Height);

                if (screen.WorkingArea.Contains(formRectangle))
                {
                    return true;
                }
            }

            return false;
        }

        public static Size getAspectRatioSize(int width, int height, int requiredWidth, int requiredHeight)
        {
            Size size = new Size(requiredWidth, requiredHeight);
            try
            {

                double ratioX = (double)requiredWidth / (double)width;
                double ratioY = (double)requiredHeight / (double)height;
                // use whichever multiplier is smaller
                double ratio = ratioX < ratioY ? ratioX : ratioY;

                // now we can get the new height and width
                int newHeight = Convert.ToInt32(height * ratio);
                int newWidth = Convert.ToInt32(width * ratio);




                /*int biggerValue = width > height ? width : height;
                float percentWidth = requiredWidth / (float)biggerValue;

                float percent_Height = requiredHeight / (float)biggerValue;

                Int16 newWidth = Convert.ToInt16(width * percentWidth);
                Int16 newHeight = Convert.ToInt16(height * percent_Height);*/
                size = new Size(newWidth, newHeight);
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("getAspectRatioSize()", ex);
            }
            return size;
        }

