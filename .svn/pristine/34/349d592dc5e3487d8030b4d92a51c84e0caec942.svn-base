<Window x:Class="DuplicatePhotosFixer.Nags.nagMessageEmailNoScanPerform"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Nags"
        mc:Ignorable="d"
        Title="Duplicate Photo Fixer Pro - Connect with us" Height="408" Width="654">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition MinWidth="80" Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Image x:Name="info_img" Source="{DynamicResource img_alert_yellow}" Width="53" Height="49" VerticalAlignment="Top"
                   Margin="0 20 0 0"/>
            <Grid Grid.Column="1" Margin="0 20 0 0">
                <StackPanel>
                    <TextBlock x:Name="label2" Text="No scan performed yet!"
                               FontSize="17"
                               FontWeight="Bold" Foreground="Black" Margin="0 0 0 10"/>
                    <!--<TextBlock x:Name="rtb_totlaSize" Text="Space to be Saved"
                               FontSize="17"
                               FontWeight="Bold" Foreground="Black"
                               Margin="0 10 0 0"/>-->
                    <TextBlock x:Name="label4" FontSize="13"
                               Margin="0 20 0 20">
                        It seems you have not scanned your PC for dupicate and similar looking photos. They<LineBreak/> may be taking up a huge amount of storage space.
                    </TextBlock>
                    <TextBlock x:Name="label3" FontSize="13"
                               Margin="0 20 0 20">
                      To help you get started, we would like to offer you a FREE license key to scan and<LineBreak/> remove duplicates.
                    </TextBlock>
                    <TextBlock x:Name="label5" FontSize="13"
                               Margin="0 10 0 0">
                        To get your FREE license key, please enter your email address below:
                    </TextBlock>
                    <Border   BorderThickness="1"  
                                  Height="46" Width="647"
                                   HorizontalAlignment="Left"
                                   Margin="0 5 10 5">
                        <Border.BorderBrush>
                            <DrawingBrush Viewport="0,0,8,8" ViewportUnits="Absolute" TileMode="Tile">
                                <DrawingBrush.Drawing>
                                    <DrawingGroup>
                                        <GeometryDrawing Brush="#525252">
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup>
                                                    <RectangleGeometry Rect="0,0,50,50" />
                                                    <RectangleGeometry Rect="50,50,50,50" />
                                                </GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingGroup>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Border.BorderBrush>
                        <TextBlock x:Name="pnl_name"
                                           VerticalAlignment="Center"
                                       >
                            <TextBox x:Name="txt_email"
                                     Height="18"
                                     Width="157"
                                       IsHitTestVisible="False" 
                                     Text="Please enter your emai address"  
                                     HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="DarkGray"
                                     BorderBrush="Transparent"
                                     VerticalAlignment="Center"
                                     >
                                
                            </TextBox>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
        <Grid Grid.Row="1" Background="#F0F0F0">
            <DockPanel Margin="10 0 10 0">
                <TextBlock x:Name="llNoThanks"
                           DockPanel.Dock="Right"
                           FontSize="13"
                           VerticalAlignment="Center">
                    <Hyperlink>No Thanks</Hyperlink>
                </TextBlock>
                <Button x:Name="btnFreeLic" Width="252" Height="41"
                    Content="Request FREE License Key"
                    Background="White"
                    BorderBrush="#3399FF"
                    BorderThickness="1.5"
                        HorizontalAlignment="Left"/>

            </DockPanel>


        </Grid>
    </Grid>
</Window>
