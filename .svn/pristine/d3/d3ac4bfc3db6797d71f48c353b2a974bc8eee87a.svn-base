    <BitmapImage x:Key="img_flags" UriSource="/Resources/flags_strip.jpg"/>
    <BitmapImage x:Key="img_bg" UriSource="/Resources/bg.png" />
    <BitmapImage x:Key="img_play_icon" UriSource="/Resources/play_icon.png"/>
    <BitmapImage x:Key="img_Alert" UriSource="/Resources/alert.png"/>
    <BitmapImage x:Key="img_close_flat" UriSource="/Resources/close_btn_flat.jpg"/>
