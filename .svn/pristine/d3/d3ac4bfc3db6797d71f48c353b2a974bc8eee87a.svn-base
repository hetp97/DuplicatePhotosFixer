                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:cust ="clr-namespace:DuplicatePhotosFixer.CustomControl">


    
    
    <!-- Foreground colors  -->
    <SolidColorBrush x:Key="frgclr_white" Color="#FFFFFF"/>
    
    <SolidColorBrush x:Key="frgclr_gray" Color="#707070"/>
    <SolidColorBrush x:Key="frgclr_solidgray" Color="#4E4E4E"/>
    <SolidColorBrush x:Key="frgclr_whitish" Color="#D2D2D2"/>
    <SolidColorBrush x:Key="frg_clr_dragdropbox" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="frg_clr_blue" Color="#1B67F2"/>
    <SolidColorBrush x:Key="frg_clr_red" Color="#E00000"/>

    <!-- Background colors  -->
    <SolidColorBrush x:Key="bgclr_dark" Color="#2F2F2F"/>
    <SolidColorBrush x:Key="bgclr_lightdark" Color="#343434"/>
    <SolidColorBrush x:Key="bgclr_soliddark" Color="#232323"/>

    <SolidColorBrush x:Key="bgrclr_gray" Color="#545454"/>
    <SolidColorBrush x:Key="bgrclr_lightgray" Color="#5E5D5F"/>
    <SolidColorBrush x:Key="bgrclr_solidgray" Color="#414141"/>
    <SolidColorBrush x:Key="bgrclr_ucHomeDragDrop" Color="#3D3D3D"/>
    <SolidColorBrush x:Key="bgrclr_menuitemstackpanel" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="bgrclr_grayish" Color="#D5D5D5"/>
    <SolidColorBrush x:Key="bgrclr_white" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="bgrclr_whitish" Color="#F0F1F4"/>

    <!--  Border color  -->
    <SolidColorBrush x:Key="clr_darkborder" Color="#000000"/>
    <SolidColorBrush x:Key="clr_grayborder" Color="#545454"/>

    <!--   Image Resources -->

