    <BitmapImage x:Key="img_selection_assistant_A_icon_hover" UriSource="/Resources/selection_assistant_A_icon_hover.png"/>
    <BitmapImage x:Key="img_selection_assistant_B_icon" UriSource="/Resources/selection_assistant_B_icon.png"/>
