    <Style TargetType="{x:Type CheckBox}"
           x:Key="SettingsCheckBoxStyle">
        <Setter Property="Width"
                Value="16" />
        <Setter Property="Height"
                Value="16" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <Image x:Name="checkBoxImage"
                           Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="Unspecified"
                           Source="{DynamicResource img_uncheckDrawingImage}"></Image>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked"
                                 Value="True">
                            <Setter TargetName="checkBoxImage"
                                    Property="Source"
                                    Value="{DynamicResource img_checkDrawingImage}" />
                        </Trigger>
                        <Trigger Property="IsChecked"
                                 Value="False">
                            <Setter TargetName="checkBoxImage"
                                    Property="Source"
                                    Value="{DynamicResource img_uncheckDrawingImage}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>