using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.IO;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using DuplicatePhotosFixer.App_Code;
using DuplicatePhotosFixer.ClassDictionary;
using DuplicatePhotosFixer.HelperClasses;

namespace DuplicatePhotosFixer.Models
{
    public class vmGeneralSettings : INotifyPropertyChanged
    {
        public event PropertyChangedEventHandler PropertyChanged;
        public void OnPropertyChanged(string name)
        {
            PropertyChangedEventHandler handler = PropertyChanged;
            if (handler != null)
            {
                handler(this, new PropertyChangedEventArgs(name));
            }
        }

        bool _OpenAssistantChecked;
        public bool OpenAssistantChecked
        {
            get
            {
                return _OpenAssistantChecked;
            }
            set
            {
                _OpenAssistantChecked = value;

                if (value)
                {
                    cGlobalSettings.GeneralSettingsData.bNotOpenAssistantConfirmation = false;

                    SaveGeneralSettings();

                }
                OnPropertyChanged("OpenAssistantChecked");
            }
        }
        bool _BackbtnChecked;
        public bool BackbtnChecked
        {
            get
            {
                return _BackbtnChecked;
            }
            set
            {
                _BackbtnChecked = value;

                if (value)
                {
                    cGlobalSettings.GeneralSettingsData.bNotShowBackConfirmation = false;

                    SaveGeneralSettings();

                }
                OnPropertyChanged("BackbtnChecked");
            }
        }
        bool _SysStartupChecked;
        public bool SysStartupChecked
        {
            get
            {
                return _SysStartupChecked;
            }
            set
            {
                _SysStartupChecked = value;

                if (value)
                {
                    cGlobalSettings.GeneralSettingsData.StartScanSystemStartup = false;

                    SaveGeneralSettings();

                }
                OnPropertyChanged("SysStartupChecked");
            }
        }
        bool _ProductMesChecked;
        public bool ProductMesChecked
        {
            get
            {
                return _ProductMesChecked;
            }
            set
            {
                _ProductMesChecked = value;

                if (value)
                {
                    cGlobalSettings.GeneralSettingsData.bShowProductMessages = true;

                    SaveGeneralSettings();

                }
                OnPropertyChanged("ProductMesChecked");
            }
        }
        bool _OtherProductMesChecked;
        public bool OtherProductMesChecked
        {
            get
            {
                return _OtherProductMesChecked;
            }
            set
            {
                _OtherProductMesChecked = value;

                if (value)
                {
                    cGlobalSettings.GeneralSettingsData.bShowOtherProductMessages = true;

                    SaveGeneralSettings();

                }
                OnPropertyChanged("OtherProductMesChecked");
            }
        }
        bool _PeriodicMesChecked;
        public bool PeriodicMesChecked
        {
            get
            {
                return _PeriodicMesChecked;
            }
            set
            {
                _PeriodicMesChecked = value;

                if (value)
                {
                    cGlobalSettings.GeneralSettingsData.bShowPeriodicMessages = true;

                    SaveGeneralSettings();

                }
                OnPropertyChanged("PeriodicMesChecked");
            }
        }


        public vmGeneralSettings()
        {
            LoadGeneralMethodSettings();
        }

        public void SetUIPropertiesValue()
        {
            if (cGlobalSettings.GeneralSettingsData == null)
            {
                LoadGeneralMethodSettings();
            }
                OpenAssistantChecked = cGlobalSettings.GeneralSettingsData.bNotOpenAssistantConfirmation;
                BackbtnChecked = cGlobalSettings.GeneralSettingsData.bNotShowBackConfirmation;
                SysStartupChecked = cGlobalSettings.GeneralSettingsData.StartScanSystemStartup;
                ProductMesChecked = cGlobalSettings.GeneralSettingsData.bShowProductMessages;
                OtherProductMesChecked = cGlobalSettings.GeneralSettingsData.bShowOtherProductMessages;
                PeriodicMesChecked = cGlobalSettings.GeneralSettingsData.bShowPeriodicMessages;
            
            

        }
        public void LoadGeneralMethodSettings(bool bLoadDefaultFocefully = false)
        {
            try
            {
                if (bLoadDefaultFocefully)
                {
                    LoadDefaultSettings();
                    return;
                }
                LoadSavedSettings();

                if (cGlobalSettings.GeneralSettingsData == null)
                    LoadGeneralMethodSettings(true);

            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("vmGeneralSettings:: LoadGeneralMethodSettings: ", ex);
            }
        }

        void LoadDefaultSettings()
        {
            try
            {
                cGlobalSettings.GeneralSettingsData = new cGeneralSettings()
                {

                    bNotShowDeleteConfirmation = RegistryTool.notShowDeleteConfirmation > 0 ? true : false,
                    bNotOpenAssistantConfirmation = RegistryTool.notShowAutoMarkConfirmation > 0 ? true : false,
                    bNotShowBackConfirmation = RegistryTool.notShowBackConfirmation > 0 ? true : false,
                    StartScanSystemStartup = RegistryTool.ScanSystemStartup > 0 ? true : false,
                    // bCheckUpdates = RegistryTool.CheckAutoUpdates > 0 ? true : false,
                    bShowOtherProductMessages = RegistryTool.ShowOtherProductMessages > 0 ? true : false,
                    bShowProductMessages = RegistryTool.ShowProductMessages > 0 ? true : false,
                    bShowPeriodicMessages = true
                };
            }
                
            
            catch (Exception ex)
            {

                cGlobalSettings.oLogger.WriteLogException("vmGeneralSettings:: LoadDefaultSettings: ", ex);
            }
        }

        void LoadSavedSettings()
        {
            try
            {
                if (File.Exists(cGlobalSettings.xmlGeneralSettings))
                {
                    /// Desearlize the strings
                    /// Fill MatchSettingsData
                    /// 
                    cGlobalSettings.GeneralSettingsData = cSerializer.DeSerializeObject<cGeneralSettings>(cGlobalSettings.xmlGeneralSettings); ;
                }
            }
            catch (Exception ex)
            {

            }
        }

        public void SaveGeneralSettings()
        {
            try
            {
                /// Save cGlobalSettings.GeneralSettingsData in xml file 
                /// 
                cSerializer.SerializeToXML<cGeneralSettings>(cGlobalSettings.GeneralSettingsData, cGlobalSettings.xmlGeneralSettings);
            }
            catch (Exception ex)
            {

            }
        }
    }

    
}
