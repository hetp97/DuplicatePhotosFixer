<Window x:Class="DuplicatePhotosFixer.Views.frmProcessing"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        mc:Ignorable="d"
        Title="frmProcessing" Height="229" Width="513" WindowStyle="None" Background="{DynamicResource bgrclr_solidgray}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" VerticalAlignment="Center" Margin="0 0" Background="{DynamicResource bgrclr_solidgray}">
            <Image Source="{DynamicResource img_applicationIcon}" Margin="5"/>
            <DockPanel DockPanel.Dock="Right" VerticalAlignment="Top" Margin="5 0">
                <Button Height="20" Width="30" BorderThickness="0" Style="{DynamicResource stl_btnMinimize}">
                    <Button.Background>
                        <ImageBrush ImageSource="{DynamicResource img_min_normal}"/>
                    </Button.Background>
                </Button>
                <Button Height="20" Width="30" BorderThickness="0" Style="{DynamicResource stl_btnClose}">
                    <Button.Background>
                        <ImageBrush ImageSource="{DynamicResource img_close_normal}"/>
                    </Button.Background>
                </Button>
            </DockPanel>
            <TextBlock Text="Duplicate Photos Fixer Pro" VerticalAlignment="Center" FontSize="15" Padding="10 0" 
                       Foreground="{DynamicResource frgclr_white}" DockPanel.Dock="Right"/>
            
        </DockPanel>

        <Grid Grid.Row="1" Background="{DynamicResource bgrclr_white}" Margin="3">
            <StackPanel VerticalAlignment="Center" Margin="25">
                <DockPanel>
                    <TextBlock Text="Searching for duplicates ..." FontSize="15" FontWeight="Medium"/>
                    <TextBlock Text="0/0 processed" HorizontalAlignment="Right"/>
                </DockPanel>
                <Image Height="20" Margin="5" />
                <TextBlock Text="Please be patient while we scan your photos for duplicates..."/>
                <Button Height="30" Width="100" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="10 15" Content="Cancel"/>
            </StackPanel>
            
        </Grid>
        
    </Grid>
</Window>
