<Window x:Class="DuplicatePhotosFixer.Nags.nagUpdateOfferTp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Nags"
        mc:Ignorable="d"
        Title="nagUpdateOfferTp" Height="596" Width="929" WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="44"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#F2F2F2">
            <DockPanel Margin="10 0 10 0">
                <Button x:Name="pb_Close" Width="15" Height="14"
                        Background="Transparent" BorderBrush="Transparent"
                        DockPanel.Dock="Right">
                    <Image  Source="/Resources/closevpn.png"/>
                </Button>
                <Image x:Name="pb_Icon" Width="36" Height="33" Source="{DynamicResource img_dpf_updatelogo}"/>
                <TextBlock x:Name="label_heading"
                           Foreground="#333333"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center">
                    Duplicate Photo Fixer Pro has been updated sucessfully.
                </TextBlock>
            </DockPanel>
        </Grid>
        <Grid Grid.Row="1">
            <DockPanel Margin="10 0 10 0"  VerticalAlignment="Center">
                <TextBlock x:Name="label1" FontSize="14"
                          >
                    Recommended Product: by Systweak:
                </TextBlock>
                <TextBlock Width="50"/>
                <TextBlock x:Name="label2" FontSize="14"
                            Foreground="#1188D8">TweakPass</TextBlock>
            </DockPanel>
        </Grid>
        <Grid Grid.Row="2" Margin="0 0 0 20">
            <StackPanel>
                <Image x:Name="pbLogo"  Width="51" Height="54" Source="/Resources/tp.png" Margin="0 5 0 20"/>
                <TextBlock x:Name="lblDes"
                           FontSize="28" HorizontalAlignment="Center"
                           Foreground="#454545">Never Forget A Password Again With TweakPass</TextBlock>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="3" Margin="0 20 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="295"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Image x:Name="pb_Image" Width="229" Height="177" Source="/Resources/lap.png" VerticalAlignment="Top"/>
            <Grid Grid.Column="1">
                <StackPanel>
                    <TextBlock x:Name="lblDesHeader" FontSize="24" Foreground="Black"
                           Padding="10 0 0 15">
                    Start securing your passwords today
                    </TextBlock>
                    <DockPanel Margin="10 0 0 10">
                        <Image x:Name="pbBullet" Width="7" Height="6" Source="/Resources/bullet.png"/>
                        <TextBlock x:Name="lblDes1" Padding="5 0 0 5"
                                       FontSize="13" Foreground="#7D878C">
                               Master Password to secure all valuable information
                            </TextBlock>
                        </DockPanel>
                    <DockPanel Margin="10 0 0 10">
                        <Image x:Name="pbBullet1" Width="7" Height="6" Source="/Resources/bullet.png"/>
                        <TextBlock x:Name="lblDes2" Padding="5 0 0 5"
                                       FontSize="13" Foreground="#7D878C">
                              AutoFill all your online forms swiftly with the saved information
                        </TextBlock>
                    </DockPanel>
                    <DockPanel Margin="10 0 0 10">
                        <Image x:Name="pbBullet2" Width="7" Height="6" Source="/Resources/bullet.png"/>
                        <TextBlock x:Name="lblDes3" Padding="5 0 0 5"
                                       FontSize="13" Foreground="#7D878C">
                              Generate unique passwords instantly
                        </TextBlock>
                    </DockPanel>
                    <DockPanel Margin="10 0 0 10">
                        <Image x:Name="pbBullet3" Width="7" Height="6" Source="/Resources/bullet.png"/>
                        <TextBlock x:Name="lblDes4" Padding="5 0 0 5"
                                       FontSize="13" Foreground="#7D878C">
                              Stores all passwords in a single location, accessible only to you
                        </TextBlock>
                    </DockPanel>
                    <DockPanel Margin="20 20 0 0">

                        <TextBlock x:Name="lblFooter1"
                               Foreground="DimGray"
                               Padding="0 0 20 0">
                        By installing Systweak VPN agree to
                        </TextBlock>
                        <TextBlock x:Name="lblFooter2">
                        <Hyperlink x:Name="lblEula"> EULA </Hyperlink> and 
                        <Hyperlink x:Name="lblPP"> Privacy Policy </Hyperlink>
                        </TextBlock>
                    </DockPanel>
                    <Button x:Name="btn_Install" Width="341" Height="55" Background="#4285F4" HorizontalAlignment="Left"
                            Foreground="White" FontWeight="SemiBold" FontSize="20" Margin="0 20 0 0">
                        Secure Your Passwords
                    </Button>
                </StackPanel>
                
            </Grid>
        </Grid>
        <Grid Grid.Row="4" Margin="10 0 10 0">
            <TextBlock x:Name="lblClose"
                       Foreground="#A4A4A4" FontSize="14">
                <Underline>Close</Underline>
            </TextBlock>
        </Grid>
    </Grid>
</Window>
