<Window x:Class="DuplicatePhotosFixer.Views.frmImageViewer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        mc:Ignorable="d"
        Title="frmImageViewer" Height="261" Width="284" WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition MinHeight="30" Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="#3F3F3F">
            <DockPanel>
                <Button x:Name="btn_close"
                        Width="48"
                        Height="28"
                        DockPanel.Dock="Right"
                        Background="Transparent">
                    <Image x:Name="img_close" Source="/Resources/close_btn_modified.png"/>

                </Button>
                <TextBlock x:Name="pnl_ImageViewerTitleBar"/>
                
            </DockPanel>
            
        </Grid>

        <Grid Grid.Row="1" Background="#F0F0F0">
            
        </Grid>
    </Grid>
</Window>
