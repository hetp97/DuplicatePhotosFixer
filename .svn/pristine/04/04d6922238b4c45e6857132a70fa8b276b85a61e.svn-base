        void objScanPhotos_OnScanProgress(cClientEnum.eScanPhase scanPhaseType, string message, int percentageCompleted, string counterMsg, string subMsg, bool showScanBar = false, bool bConfirmationBox = false)

        {
            this.Dispatcher.Invoke(() =>
            {
                if (bConfirmationBox)
                {
                    App.oMainReference.LaunchAndRefresh();

                    frmProcessing oProgress = null;
                    try
                    {
                        cGlobal.frmNagReturnCode = FORM_RETURN_CODES.DO_NOTHING;
                        oProgress = new frmProcessing();
                        if (App.oMainReference.fProgress == null)
                        {
                            oProgress.Owner = App.oMainReference.fProgress;
                        }
                        else
                        {
                            oProgress.Owner = App.oMainReference;
                        }
                        oProgress.bConfirmationBox = bConfirmationBox;
                        oProgress.ScanProgress(cClientEnum.eScanPhase.Search,message, percentageCompleted, counterMsg, subMsg, showScanBar);
                        Thread.Sleep(0);
                        if (bConfirmationBox)
                        {
                           //oProgress.LoadAsConfirmationBox();
                            oProgress.ShowDialog();
                        }
                    }
                    catch (Exception ex)
                    {

                    }
                    finally
                    {
                        //if (oProgress != null)
                        //    oProgress.Dispose();
                        //oProgress = null;
                    }
                }
                else
                {
                    if (App.oMainReference.fProgress == null)
                        App.oMainReference.fProgress = new frmProcessing();

                    App.oMainReference.fProgress.ScanProgress(scanPhaseType, message, percentageCompleted, counterMsg, subMsg, showScanBar);
                }
            });
        }

       
        bool bNagShownAfterCmdSLNT = false;
        void objScanPhotos_OnScanCompleted(string messageHeader, string messageDesc, bool bMoveToResultsTab, int percentageCompleted)
        {

            this.Dispatcher.Invoke(() =>
            {

#if TrayScan
                    if (Program.oMainReference.bTrayScan && Program.bAutoscan)
                    {
                        // Show taskbar notification
                        Program.oMainReference.bTrayScan = false;
                        Program.oMainReference.ShowTaskbarNotification(1800000);
                    }
                    else
#endif
                {
                    if (Program.bSilentScanNLaunch && !bNagShownAfterCmdSLNT)
                    {
                        App.oMainReference.DisplayTaskbarNotification();
                        bNagShownAfterCmdSLNT = true;
                    }
                    else if (!(Program.bSilentScan))
                    {
                        App.oMainReference.LaunchAndRefresh();
                    }

                    cGlobalSettings.b_SCAN_STARTED = false;

                    //App.oMainReference.ShowSystemTrayNagsAfterScan();
                }


                if (App.oMainReference.fProgress != null)
                {
                    App.oMainReference.Progress_Close(Program.oMainReference.fProgress);
                }

                if (!bMoveToResultsTab)
                {
                    App.oMainReference.footer_showScanDuplicateButton((int)enumClass.eBtnVisableStatus.Active, true, true);
                    //Program.oMainReference.footer_showScanDuplicateButton((int)enumClass.eBtnVisableStatus.Disable, false, false);
                }


                Thread.Sleep(64);

                if (!string.IsNullOrEmpty(messageHeader))
                {
                    if (!Program.bSilentScan)
                        App.oMainReference.showMessage(messageHeader, messageDesc);
                }
            });
            //Program.oMainReference.footer_showScanDuplicateButton((int)enumClass.eBtnVisableStatus.Active, true, true);



            //new Thread(() =>
            //{
            //    Thread.Sleep(64/*1008*/);

            //    this.UIThread(() =>
            //    {
            //        //Program.oMainReference.ucResult_showCurrentDuplicateCount(true);

            //        if (Program.oMainReference.fProgress != null && !Program.oMainReference.fProgress.IsDisposed)
            //        {
            //            Program.oMainReference.Progress_Close(Program.oMainReference.fProgress);
            //        }
            //    });

            //}).Start();


#if _to_fix_
            this.UIThread(() =>
                {
                    if (Program.oMainReference.fProgress != null)
                    {
                        Program.oMainReference.fProgress.percentage = 100;
                        Program.oMainReference.fProgress.Close();

                        Program.oMainReference.fProgress.Dispose();
                        Program.oMainReference.fProgress = null;

                        Program.oMainReference.CloseDarkBackGround();
                        Program.oMainReference.Activate();
                    }
                    //Program.oMainReference.Enabled = true;
                }); 
#endif
        }


