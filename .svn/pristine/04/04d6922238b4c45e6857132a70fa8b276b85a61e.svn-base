        void scanner_OnScanProgress(string startMsg, int percentageCompleted, int TotalFiles, string counterMsg, string progressInfo, bool showScanBar = false, bool bConfirmationBox = false)
        {

            this.Dispatcher.Invoke(() =>
            {
                if (bConfirmationBox)
                {
                    App.oMainReference.LaunchAndRefresh();

                    frmProcessing oProgress = null;
                    try
                    {
                        cGlobal.frmNagReturnCode = FORM_RETURN_CODES.DO_NOTHING;
                        oProgress = new frmProcessing();
                        oProgress.bConfirmationBox = true;
                        oProgress.ScanProgress(cClientEnum.eScanPhase.Search, startMsg, percentageCompleted, counterMsg, progressInfo, showScanBar);
                        //oProgress.LoadAsConfirmationBox();
                        Thread.Sleep(0);
                        oProgress.ShowDialog();
                    }
                    catch (Exception ex)
                    {

                    }
                    finally
                    {
                        if (oProgress != null)
                            //oProgress.Dispose();
                            oProgress = null;
                    }
                }
                else
                {
                    if (App.oMainReference.fProgress == null)
                        App.oMainReference.fProgress = new frmProcessing();

                    App.oMainReference.fProgress.ScanProgress(cClientEnum.eScanPhase.Search, startMsg, percentageCompleted, counterMsg, progressInfo, showScanBar);
                }
            });
        }


        void scanner_OnScanCompleted(string messageHeader, string messageDesc, bool bMoveToResultsTab, int percentageCompleted)
        {

            Dispatcher.Invoke(() =>
            {
                Dispatcher.Invoke(() =>
                {
                    {
                        if (Program.bSilentScanNLaunch && !bNagShownAfterCmdSLNT)
                        {
                            Program.oMainReference.DisplayTaskbarNotification();
                            bNagShownAfterCmdSLNT = true;
                        }
                        else if (!(Program.bSilentScan))
                        {
                            App.oMainReference.LaunchAndRefresh();
                        }

                        cGlobalSettings.b_SCAN_STARTED = false;

                       // App.oMainReference.ShowSystemTrayNagsAfterScan();
                    }



                    if (App.oMainReference.fProgress != null )
                    {
                        App.oMainReference.Progress_Close(Program.oMainReference.fProgress);
                    }

                    if (!bMoveToResultsTab)
                    {
                        App.oMainReference.footer_showScanDuplicateButton((int)enumClass.eBtnVisableStatus.Active, true, true);
                        //Program.oMainReference.footer_showScanDuplicateButton((int)enumClass.eBtnVisableStatus.Disable, false, false);
                    }


                    Thread.Sleep(64);

                    if (!string.IsNullOrEmpty(messageHeader))
                    {
                        if (!Program.bSilentScan)
                            Program.oMainReference.showMessage(messageHeader, messageDesc);
                    }
                });

            });

        }

     
        public void startCompare()
        {
            try
            {
                if (!ScanLock.TryEnterWriteLock(0))
                {
                    return;
                }


                try
                {
                    Init();

                    //if (Environment.OSVersion.Version.Major >= 6)
                    //    Microsoft.WindowsAPICodePack.Taskbar.TaskbarManager.Instance.SetProgressState((Microsoft.WindowsAPICodePack.Taskbar.TaskbarProgressBarState.Normal));

                    App.oMainReference.fProgress.progressType = ProgressType.Scan;
                    App.oMainReference.fProgress.LoadStringsForScan();

#if TrayScan
                    if (Program.oMainReference.bTrayScan && Program.bAutoscan)
                    {
                        Program.oMainReference.fProgress.Opacity = 0;
                    }
                    else
                    {
                        Program.oMainReference.fProgress.Opacity = 100;
                    }
#endif

                    App.oMainReference.Progress_Show(App.oMainReference.fProgress,null, true);
                    if (Program.bIsFirstInstall)
                    {
                        switch (cGlobal.setupType)
                        {
                            case eSetupType.SCAN_DEFAULT:
                            case eSetupType.SCAN_ALL:
                                //case eSetupType.ADD_All:
                                //App.oMainReference.MinimizeAppToTray(false);
                                break;
                            default:
                                break;
                        }
                    }
                }
                finally
                {
                    ScanLock.SafeExitWriteLock();
                }
            }
            catch (System.Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("SearchDuplicates", ex);
            }
        }

