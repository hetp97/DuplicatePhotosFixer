<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucActionCentre"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
              d:DesignHeight="685" d:DesignWidth="1000" Background="{DynamicResource cl_bg_actioncenter}"  x:Name="objActionCentre" >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition MinHeight="49" Height="Auto"/>
            <RowDefinition MinHeight="70" Height="Auto"/>
            <RowDefinition Height="*"/>
           
            <RowDefinition MinHeight="60" Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="pnl_imageCount" Background="{DynamicResource cl_bg_Header_ac}" />
        <Grid Grid.Row="1"  Background="{DynamicResource cl_bg_Header2_ac}" >
            <StackPanel VerticalAlignment="Center" Margin="20 0">
                <TextBlock x:Name="lblHeader" Text="Recommended Applications By Systweak"                    
                       Foreground="{DynamicResource cl_fg_Header_ac}"
                       FontSize="18"
                           FontWeight="SemiBold"/>

                <TextBlock x:Name="lblHeadermsg"
                           FontSize="14"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource cl_fg_ContInfo_ac}">
                      Organize your photos, secure it from threats and boost PC's performance with these recommended apps for your PC.
                </TextBlock>

            </StackPanel>
            
        </Grid>
        <Grid Grid.Row="2" Margin="5 0 5 0">
            <!--<local:ucRecommendedApp/>-->

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                      
                      Grid.Row="1"
                      
                      Background="Transparent">
                <DataGrid x:Name="utilityAppsListView"
                           IsTabStop="False"
                           Background="{DynamicResource cl_bg_actioncenter}"
                           HeadersVisibility="Column"
                           RowHeight="78"
                           RowHeaderWidth="0"
                           BorderThickness="0"
                           VerticalAlignment="Top"                           
                           ScrollViewer.CanContentScroll="True"
                           AlternationCount="2"
                           AutoGenerateColumns="False"
                           CanUserAddRows="false"
                           GridLinesVisibility="None"
                           SelectionMode="Single"
                           SelectionUnit="FullRow"
                           HorizontalAlignment="Stretch"
                           CanUserResizeColumns="False"
                           CanUserReorderColumns="False"
                           VirtualizingStackPanel.IsVirtualizing="True">

                    <!--<data:DataGrid.Style>
                    <Style TargetType="data:DataGrid">
                        <Setter Property="MaxHeight"
                                            Value="430" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}"
                                                     Value="Maximized">
                                <Setter Property="MaxHeight"
                                                    Value="740" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </data:DataGrid.Style>-->
                    <DataGrid.Resources>
                        <!--<con:BindingProxy x:Key="proxy"
                                      Data="{Binding RelativeSource={RelativeSource AncestorType=UserControl}}" />-->
                    </DataGrid.Resources>
                    <DataGrid.ItemContainerStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="FontSize"
                                Value="15" />
                            <Setter Property="SnapsToDevicePixels"
                                Value="true" />
                            <Setter Property="HorizontalAlignment"
                                Value="Left" />
                            <Setter Property="VerticalAlignment"
                                Value="Center" />
                            <Setter Property="FontWeight"
                                Value="Normal" />
                            <Setter Property="Height"
                                Value="76" />
                            <Setter Property="Background"
                                Value="{DynamicResource cl_bg_AppDes}"></Setter>
                            <Setter Property="Margin"
                                Value="0 0 0 10"></Setter>
                            <!--<Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate>
                                        <Border CornerRadius="3 3 3 3" Height="80" Background="#313131">
                                            <ContentPresenter></ContentPresenter>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>-->
                        </Style>
                    </DataGrid.ItemContainerStyle>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="{x:Type  DataGridColumnHeader}">
                            <Setter Property="HorizontalContentAlignment"
                                Value="Left" />
                            <!--<Setter Property="Margin"
                                Value="20,0,0,0" />
                            <Setter Property="BorderBrush"
                                Value="#080E17" />-->
                            <Setter Property="BorderThickness"
                                Value="0,0,0,1" />
                            <Setter Property="Height"
                                Value="0" />
                            <Setter Property="FontWeight"
                                Value="SemiBold" />
                            <Setter Property="FontSize"
                                Value="14" />
                            <Setter Property="Foreground"
                                Value="{DynamicResource cl_fg_AppName_ac}" />
                            <Setter Property="Background"
                                Value="{DynamicResource cl_bg_actioncenter}" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="{x:Type DataGridCell}">
                            <Setter Property="BorderThickness"
                                Value="0" />
                            <Setter Property="FocusVisualStyle"
                                Value="{x:Null}" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected"
                                     Value="True">
                                    <Setter Property="Background"
                                        Value="{x:Null}" />
                                    <Setter Property="BorderBrush"
                                        Value="{x:Null}" />

                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>

                        <!--Startup Items-->
                        <DataGridTemplateColumn Width="0.45*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Image  x:Name="img_product"
                                            Margin="20 0 0 0"
                                            Width="38"
                                            Height="38"
                                            Stretch="Uniform"
                                            VerticalAlignment="Center"
                                            Source="{Binding imgProductLogo}" />


                                        <StackPanel Orientation="Vertical"
                                                VerticalAlignment="Center">
                                            <TextBlock Name="txt_product"
                                                   Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource cl_fg_AppName_ac}"
                                                   Text="{Binding ProductName}"
                                                   Margin="10 0 10 0"
                                                  
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />

                                            <TextBlock Name="txt_Summary"
                                                   Foreground="{DynamicResource cl_fg_AppInfo_ac}"
                                                   
                                                   Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   FontStyle="Italic"
                                                   Width="165"
                                                   HorizontalAlignment="Left"
                                                   Margin="0,0,0,0"
                                                   Text="{Binding Summary}"
                                                   TextWrapping="WrapWithOverflow"
                                                   />
                                        </StackPanel>


                                    </StackPanel>
                                    <!--<DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Path=isTrending}"
                                                             Value="False">
                                            <Setter Property="Visibility"
                                                            Value="Collapsed"
                                                            TargetName="lbl_trending" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>-->
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>


                        <DataGridTemplateColumn Width="0.4*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Grid.Column="4"
                                           Margin="20,0,0,0"
                                           FontSize="13"
                                           FontWeight="DemiBold"
                                           Foreground="{DynamicResource cl_fg_AppDes_ac}"
                                           Text="{Binding Description}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="0.15*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Button Name="btn_InstallNow"
                                            Cursor="Hand"
                                            Margin="0 0 0 0"
                                            Tag="{Binding}"
                                            
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <StackPanel x:Name="pnlInstallNow"
                                                            Orientation="Horizontal">
                                                        <Image Stretch="None"
                                                           Width="17"
                                                           Height="17">
                                                            <Image.Style>
                                                                <Style TargetType="{x:Type Image}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding nInstallSatus}"
                                                                                 Value="1">
                                                                            <Setter Property="Source"
                                                                                Value="{DynamicResource img_download}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding nInstallSatus}"
                                                                                 Value="0">
                                                                            <Setter Property="Source"
                                                                                Value="{DynamicResource launch_img}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Image.Style>
                                                        </Image>

                                                      

                                                    </StackPanel>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>
        </Grid>
       
        <Grid Grid.Row="3" Margin="5 0 5 0">
            <DockPanel Background="{DynamicResource cl_bg_AppDes}">
                <Button x:Name="btnBack" Content="Back" 
                        Foreground="{DynamicResource cl_fg_homeprimary}" 
                        BorderBrush="Transparent"
                        Width="75" 
                      Style="{DynamicResource stl_btnBack}"
                        Height="35" HorizontalAlignment="Left" Click="btnBack_Click">
                    <Button.Background>
                        <ImageBrush ImageSource="/Resources/back_n.png" />
                    </Button.Background>
                </Button>
                <DockPanel VerticalAlignment="Center" Margin="100 0 0 0">
                    <Image x:Name="info_icon2" Source="{DynamicResource info_icon_grey}" Stretch="None"/>
                    <TextBlock x:Name="upgrade_text"
                               Padding="5 0"
                               Foreground="{DynamicResource cl_fg_ContInfo_ac}"
                               FontSize="14"
                               Text="Upgrade Now to remove all duplicate photos from your PC and recover tons of space"/>
                </DockPanel>
                <Button x:Name="btn_Upgrade" Content="Upgrade Now"
                      Height="35" Width="143" 
                        Style="{DynamicResource stl_btnUpgradeNow}"
                        HorizontalAlignment="Right">
                </Button>
                
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
