<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucImageInfo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="336">
    <UserControl.Resources>
       
    </UserControl.Resources>

    <Grid Background="{DynamicResource bgclr_lightdark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="47"/>
            <RowDefinition Height="27"/>
            <RowDefinition Height="210"/>
            <RowDefinition Height="27"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <DockPanel Grid.Row="0" Margin="18 0" VerticalAlignment="Center">
            <TextBlock x:Name="lbl_matchingLevel" Text="Matching Level : " Padding="0 0 5 0" Foreground="{DynamicResource frgclr_white}"/>
            <Slider x:Name="matchLevelSlider"   Margin="0" ValueChanged="matchLevelSlider_ValueChanged" TickPlacement="BottomRight"
                TickFrequency="0">
            </Slider>
            
        </DockPanel>
        <Border Grid.Row="1" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1" 
                Background="{DynamicResource bgclr_soliddark}">
            <TextBlock x:Name="lblPreview" Text="Preview" Foreground="{DynamicResource frgclr_white}" VerticalAlignment="Center" Padding="10 0" FontWeight="SemiBold"/>
        </Border>
        <Image x:Name="previewimg" Grid.Row="2"/>
        <Border Grid.Row="3" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1 0 1 1" 
                Background="{DynamicResource bgclr_soliddark}">
            <TextBlock x:Name="lbl_metadata" Text="Metadata"
                       FontWeight="SemiBold" Foreground="{DynamicResource frgclr_white}" VerticalAlignment="Center" Padding="10 0"/>
        </Border>
        <ScrollViewer Grid.Row="4" Padding="0 0 2 0">
            <StackPanel Margin="0" HorizontalAlignment="Left">
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_fileName" Text="File Name: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_fileSize" Text="File Size: "  FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---"  FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_fileLabel" Text="File Label: "  FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---"  FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_fileCreated" Text="File created: "  FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock  Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_fileModified" Text="File Modified: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_folderName" Text="Folder Name: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_rating" Text="Rating: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_keywords" Text="Keywords: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_imageSize" Text="Image Size: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_imageDPI" Text="Image DPI: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_bitDepth" Text="Bit Depth: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_orientation" Text="Orientation: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_digitalZoomRatio" Text="Digital Zoom Ratio: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_captureDate" Text="Capture Date: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_editingSoftware" Text="Editing Software: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_exposure" Text="Exposure: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_focalLength" Text="Focal Length: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_exposureBias" Text="Exposure Bias: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_ISOSpeedRating" Text="ISO Speed Rating: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_exposureMode" Text="Exposure Mode: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_exposureProgram" Text="Exposure Program: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_meteringMode" Text="Metering Mode: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_lightSource" Text="Light Source: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_sensingMethod" Text="Sensing Method: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_scenceCaptureType" Text="Scence Capture Type: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_cameraMaker" Text="Camera Maker: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_cameraModel" Text="Camera Model: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_cameraLensModel" Text="Camera Lens Model: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock  x:Name="lbl_cameraFirmware" Text="Camera Firmware: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_colorModel" Text="Color Model: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_colorSpace" Text="Color Space: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_profileName" Text="Profile Name: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_GPSAltitude" Text="GPS Altitude: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_GPSLatitude" Text="GPS Latitude: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
                <DockPanel HorizontalAlignment="Center" Margin="2">
                    <TextBlock x:Name="lbl_GPSLongitude" Text="GPS Longitude: " FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                    <TextBlock Text="---" FontSize="11" FontWeight="Light" Foreground="{DynamicResource frgclr_white}"/>
                </DockPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
    
</UserControl>
