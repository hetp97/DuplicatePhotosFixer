        /// <summary>
        /// old 1 time usage code
        /// </summary>
        public void WriteNewINI()
        {
            string[] allAllSections = oIniReader.GetSectionNames();

            foreach (KeyValuePair<string, string> sSection in cGlobalSettings.dResStrings)
            {
                cWin32APIs.IniWriteValue(allAllSections[0], sSection.Key, sSection.Value, PathEx.Combine(Application.StartupPath, "eng_asp.ini"));
            }
        }





        public static string LoadString(string sKey)
        {



            /*foreach (KeyValuePair<string, string> sSection in cGlobalSettings.dResStrings)
            {
                cGlobalSettings.oLogger1.WriteLog(sSection.Key + "=" + sSection.Value);
            }*/



            sKey = sKey.ToUpper();
            if (cGlobalSettings.dResStrings.ContainsKey(sKey))
            {

                string sRes = cGlobalSettings.dResStrings[sKey];
                if (sRes.IndexOf("IDS_DU_APP_NAME") != -1)
                {
                    sRes = sRes.Replace("IDS_DU_APP_NAME", cGlobalSettings.GetProductNameFromDesc());
                }
                if (sRes.IndexOf("IDS_PB_APP_NAME") != -1)
                {
                    sRes = sRes.Replace("IDS_PB_APP_NAME", ""/*"Power Bundle"*/);
                }

                if (sRes.IndexOf("\\r\\n") != -1)
                {
                    sRes = sRes.Replace("\\r\\n", "\r\n");
                }
                if (sRes.IndexOf("\\t") != -1)
                {
                    sRes = sRes.Replace("\\t", "\t");
                }
                if (sRes.IndexOf("IDS_LIVE_INTERNATIONAL_PHONE") != -1)
                {
                    sRes = sRes.Replace("IDS_LIVE_INTERNATIONAL_PHONE", cGlobalSettings.dResStrings["IDS_LIVE_INTERNATIONAL_PHONE"]);
                }
                if (sRes.IndexOf("IDS_LIVE_PHONE") != -1)
                {
                    sRes = sRes.Replace("IDS_LIVE_PHONE", cGlobalSettings.dResStrings["IDS_LIVE_PHONE"]);
                }
                if (sRes.IndexOf("IDS_OS_DETECTED") != -1)
                {
                    sRes = sRes.Replace("IDS_OS_DETECTED", cGlobalSettings.dResStrings["IDS_OS_DETECTED"]);
                }

                //if (sRes.IndexOf("IDS_RB_USER") != -1)
                //{
                //    sRes = sRes.Replace("IDS_RB_USER", cGlobal.GetLoginNameTrimmed(cGlobal.sUserLoginName));
                //}
#if DEBUG
                //  sRes += "#";
#endif
                return sRes;
                //return "*" + sRes + "*";
            }
            else
            {
                // #if DEBUG
                //                 //if not found in new ini search in old and add in new 
                //                 if (UniqueStrings.ContainsKey(sKey))
                //                 {
                //                     cGlobalSettings.dResStrings.Add(sKey, UniqueStrings[sKey]);
                //                     //UniqueStrings.Add(sKey, cGlobalSettings.dResStrings[sKey]);
                //                     cWin32APIs.IniWriteValue("RESOURCESTRING", sKey, UniqueStrings[sKey], PathEx.Combine(Application.StartupPath, "eng_asp.ini"));
                //                 }
                // #endif
                //Trace.WriteLine(sKey);
                return "N/A";
            }
        }



