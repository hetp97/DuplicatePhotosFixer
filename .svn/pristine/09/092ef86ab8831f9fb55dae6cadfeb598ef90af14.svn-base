        public static void findDuplicates()
        {
            StringBuilder sAllStrings = new StringBuilder();
            var lookup = cGlobalSettings.dResStrings.ToLookup(x => x.Value, x => x.Key).Where(x => x.Count() > 1);
            foreach (var item in lookup)
            {
                var keys = item.Aggregate("", (s, v) => s + ", " + v);
                var message = "Key " + keys + "\tvalue: " + item.Key;
                //Trace.WriteLine(message);
                sAllStrings.AppendLine(message);
            }
            //Trace.WriteLine(sAllStrings.ToString());
        }


        public void CreateOtherLanguageFROMRCP_INI()
        {
            string[] allAllSections = oIniReader.GetSectionNames();

            Dictionary<string, string> dtEnglang = new Dictionary<string, string>();
            foreach (string sSection in allAllSections)
            {
                if (sSection == "rc_strings"/* || sSection == "du_strings"*/)
                //gets the distinct strings
                dtEnglang = dtEnglang.Union(oIniReader.GetSectionValuesAsList(sSection).GroupBy(x => x.Key).Select(y => y.First())).ToDictionary(item => item.Key, item => item.Value);
                
            }

            //loop through all ini files load thier strings and 
            foreach (string sLangIniFile  in  Directory.GetFiles(@"C:\Users\abhinav.SYSDEVORG\Desktop\asp_strings","*.ini"))
            {
                string sLangName = Path.GetFileNameWithoutExtension(sLangIniFile);
                sLangName = sLangName.Substring(0,sLangName.IndexOf("_"));

                string sFileName = Directory.GetFiles(@"C:\Users\abhinav.SYSDEVORG\Desktop\rcp_ini", sLangName + "_rcp*.ini").First();
                cIniFile oIniReadernew2 = new cIniFile(sFileName);
                string[] allAllSectionsADU = oIniReadernew2.GetSectionNames();

                Dictionary<string, string> lsADUStrings = new Dictionary<string, string>();
                foreach (string sSection in allAllSectionsADU)
                {
                    //gets the distinct strings
                    lsADUStrings = lsADUStrings.Distinct().Union(oIniReadernew2.GetSectionValuesAsList(sSection).GroupBy(x => x.Key).Select(y => y.First())).ToDictionary(item => item.Key, item => item.Value);

                }
                Dictionary<string, string> lsResultCommonStrings = new Dictionary<string, string>();
                dtEnglang.All(x=> 
                    {
                        if(lsADUStrings.ContainsKey(x.Key))
                        {
                            lsResultCommonStrings.Add(x.Key, lsADUStrings[x.Key]);
                        }
                        return true;
                    });


                string snewResFile = sLangIniFile.Replace(@"\asp_strings\", @"\asp_strings\result\");
                if (!File.Exists(snewResFile))
                {
                    File.Copy(sLangIniFile, snewResFile);         
                }
                foreach (KeyValuePair<string, string> sSection in lsResultCommonStrings)
                {
                    cWin32APIs.IniWriteValue("rc_strings", sSection.Key, sSection.Value, snewResFile);
                }

            }
             
        }

        public void CreateOtherLanguageFROMADU_INI()
        {
            string[] allAllSections = oIniReader.GetSectionNames();

            Dictionary<string, string> dtEnglang = new Dictionary<string, string>();
            foreach (string sSection in allAllSections)
            {
                if ( sSection == "du_strings")
                    //gets the distinct strings
                    dtEnglang = dtEnglang.Union(oIniReader.GetSectionValuesAsList(sSection).GroupBy(x => x.Key).Select(y => y.First())).ToDictionary(item => item.Key, item => item.Value);

            }

            //loop through all ini files load thier strings and 
            foreach (string sLangIniFile in Directory.GetFiles(@"C:\Users\abhinav.SYSDEVORG\Desktop\asp_strings", "*.ini"))
            {
                string sLangName = Path.GetFileNameWithoutExtension(sLangIniFile);
                sLangName = sLangName.Substring(0, sLangName.IndexOf("_"));


                string sFileName = Directory.GetFiles(@"C:\Users\abhinav.SYSDEVORG\Desktop\du_ini", sLangName + "_rcp*.ini").First();
                cIniFile oIniReadernew2 = new cIniFile(sFileName);
                string[] allAllSectionsADU = oIniReadernew2.GetSectionNames();

                Dictionary<string, string> lsADUStrings = new Dictionary<string, string>();
                foreach (string sSection in allAllSectionsADU)
                {
                    //gets the distinct strings
                    lsADUStrings = lsADUStrings.Distinct().Union(oIniReadernew2.GetSectionValuesAsList(sSection).GroupBy(x => x.Key).Select(y => y.First())).ToDictionary(item => item.Key, item => item.Value);

                }
                Dictionary<string, string> lsResultCommonStrings = new Dictionary<string, string>();
                dtEnglang.All(x =>
                {
                    if (lsADUStrings.ContainsKey(x.Key))
                    {
                        lsResultCommonStrings.Add(x.Key, lsADUStrings[x.Key]);
                    }
                    return true;
                });


                string snewResFile = sLangIniFile.Replace(@"\asp_strings\", @"\asp_strings\result\");
                if (!File.Exists(snewResFile))
                {
                    File.Copy(sLangIniFile, snewResFile);
                }
                foreach (KeyValuePair<string, string> sSection in lsResultCommonStrings)
                {
                    cWin32APIs.IniWriteValue("du_strings", sSection.Key, sSection.Value, snewResFile);
                }

            }

        }


        public void CreateOtherLanguageFROMPB_INI()
        {
            string[] allAllSections = oIniReader.GetSectionNames();

            Dictionary<string, string> dtEnglang = new Dictionary<string, string>();
            foreach (string sSection in allAllSections)
            {
                if (sSection == "pb_strings")
                    //gets the distinct strings
                    dtEnglang = dtEnglang.Union(oIniReader.GetSectionValuesAsList(sSection).GroupBy(x => x.Key).Select(y => y.First())).ToDictionary(item => item.Key, item => item.Value);

            }

            //loop through all ini files load their strings and 
            foreach (string sLangIniFile in Directory.GetFiles(@"C:\Users\abhinav.SYSDEVORG\Desktop\asp_strings", "*.ini"))
            {
                string sLangName = Path.GetFileNameWithoutExtension(sLangIniFile);
                sLangName = sLangName.Substring(0, sLangName.IndexOf("_"));

                string sFileName = Directory.GetFiles(@"C:\Users\abhinav.SYSDEVORG\Desktop\pb_ini", sLangName + "_pb*.ini").First();

                cIniFile oIniReadernew2 = new cIniFile(sFileName);
                string[] allAllSectionsADU = oIniReadernew2.GetSectionNames();

                Dictionary<string, string> lsADUStrings = new Dictionary<string, string>();
                foreach (string sSection in allAllSectionsADU)
                {
                    //gets the distinct strings
                    lsADUStrings = lsADUStrings.Distinct().Union(oIniReadernew2.GetSectionValuesAsList(sSection).GroupBy(x => x.Key).Select(y => y.First())).ToDictionary(item => item.Key, item => item.Value);

                }
                Dictionary<string, string> lsResultCommonStrings = new Dictionary<string, string>();
                dtEnglang.All(x =>
                {
                    if (lsADUStrings.ContainsKey(x.Key))
                    {
                        lsResultCommonStrings.Add(x.Key, lsADUStrings[x.Key]);
                    }
                    return true;
                });

                dtEnglang.All(x=>
                    {
                        if(!lsResultCommonStrings.ContainsKey(x.Key))
                        {
                            lsResultCommonStrings.Add(x.Key,x.Value);
                        }
                    return true;}
                    );
                

                string snewResFile = sLangIniFile.Replace(@"\asp_strings\", @"\asp_strings\result\");
                if (!File.Exists(snewResFile))
                {
                    File.Copy(sLangIniFile, snewResFile);
                }
                foreach (KeyValuePair<string, string> sSection in lsResultCommonStrings)
                {
                    cWin32APIs.IniWriteValue("pb_strings", sSection.Key, sSection.Value, snewResFile);
                }

            }

        }


