        static string GetEnglishLangIniPath() 
        { 
            return PathEx.Combine(Application.StartupPath, "eng_dpf_en.ini"); 
        }

        static string GetCurrentLangIniPath(cLanguageSettings oLanguageSettings) 
        { 
            return PathEx.Combine(Application.StartupPath, oLanguageSettings.IniName); 
        }

        public cResourceManager()
        {
            oIniReader = new cIniFile(GetEnglishLangIniPath());
        }


        public cResourceManager(cLanguageSettings oLanguageSettings)
        {

            oIniReader = new cIniFile(GetCurrentLangIniPath(oLanguageSettings));

        }




        public void ShiftString()
        {
            cIniFile oIniReadernew = new cIniFile(PathEx.Combine(Application.StartupPath, "old_eng_asp.ini"));
            string[] allAllSections = oIniReadernew.GetSectionNames();


            foreach (string sSection in allAllSections)
            {
                //gets the distinct strings
                UniqueStrings = UniqueStrings.Union(oIniReadernew.GetSectionValuesAsList(sSection).GroupBy(x => x.Key).Select(y => y.First())).ToDictionary(item => item.Key, item => item.Value);
                //cGlobalSettings.dResStrings = oIniReader.GetSectionValuesAsList(sSection).ToDictionary(item => item.Key, item => item.Value);
            }
        }

        public static bool LoadStringsFromIni(cLanguageSettings oLanguageSettings)
        {
            try
            {
                oIniReader = new cIniFile(PathEx.Combine(Application.StartupPath, oLanguageSettings.IniName));
                string[] allAllSections = oIniReader.GetSectionNames();

               
                foreach (string sSection in allAllSections)
                {     
                    try
                    {
                        cGlobalSettings.dResStrings = cGlobalSettings.dResStrings.Union(oIniReader.GetSectionValuesAsList(sSection).GroupBy(x => x.Key).Select(y => y.First())).ToDictionary(item => item.Key.ToUpper(), item => item.Value); 
                        
                    }
                    catch (System.Exception ex)
                    {
                        cGlobalSettings.oLogger.WriteLogException("LoadStringsFromIni:: While add strings from sections: ", ex);
                        //oUtils.WriteToFile(string.Format("LoadStringsFromIni()|{0}", ex.Message)); 
                    }
                    //gets the distinct strings
                    
                    //cGlobalSettings.dResStrings = oIniReader.GetSectionValuesAsList(sSection).ToDictionary(item => item.Key, item => item.Value);
                }




                /*foreach (var data in cGlobalSettings.dResStrings)
                {
                    cGlobalSettings.oLogger1.WriteLogVerbose("{0}={1}", data.Key, data.Value);
                }*/


                //SetPhoneNo();
                //SetOS();
                //SetUserName();



            }
            catch (System.Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("LoadStringsFromIni:: ", ex);
                //oUtils.WriteToFile(string.Format("LoadStringsFromIni()", ex.Message)); 
            }
            return true;
        }

