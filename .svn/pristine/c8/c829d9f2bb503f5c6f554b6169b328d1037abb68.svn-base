<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucSettingsMove"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="441" d:DesignWidth="482" Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <RadioButton x:Name="rb_MoveToBin" Margin="0 5 0 5" VerticalAlignment="Center" Content="Send duplicate photos to Recycle Bin." Style="{DynamicResource stl_MoveSettingsRadiobtn}" />
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <RadioButton x:Name="rb_MoveToLocation" Content="Move duplicate photos to selected path" IsChecked="False" Style="{DynamicResource stl_MoveSettingsRadiobtn}"/>
                <TextBlock x:Name="txt_moveLocation" Text="C:\\users\\picture\\" Margin="10 0 0 0" Foreground="#565656"/>
            </StackPanel>
            <Grid Grid.Column="1">
                <Button x:Name="btn_AddFolder" Content="Browse" 
                        Width="99" 
                        Height="33" 
                        HorizontalAlignment="Right"
                        Background="#E3E6EC"
                        FontWeight="Bold"
                        Margin="0 0 10 0"
                        />
            </Grid>
        </Grid>
    
            
    </Grid>
</UserControl>
