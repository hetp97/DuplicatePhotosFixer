<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucSettingsFileFormat"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
             mc:Ignorable="d" 
             d:DesignHeight="464" d:DesignWidth="515" Background="#272727" Loaded="UserControl_Loaded" >
    <UserControl.Resources>
        <!--<Style x:Key="DataGridCustomStyle" TargetType="{x:Type DataGrid}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                </Trigger>
            </Style.Triggers>
        </Style>-->
        <Style TargetType="xctk:IntegerUpDown" x:Key="styl_updown">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource frgclr_whitish}"/>
            <Setter Property="BorderBrush" Value="#ABADB3"/>
            <Setter Property="BorderThickness" Value="1"/>
      
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                </Trigger>
              
            </Style.Triggers>
        </Style>
       
       
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition />
            <RowDefinition Height="57"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">

            <StackPanel  Margin="10 20">
                <TextBlock x:Name="lbl1" Text="Manage File Formats" FontSize="24" Foreground="#fff"/>
                <TextBlock  x:Name ="lbl2" Text="The settings below allow you to exclude file extensions from being added to scan list."
                       TextWrapping="Wrap" Foreground="#AEAEAE" Margin="0 0 0 0" 
                       FontSize="14"/>

            </StackPanel>
        </Grid>
        <Grid Grid.Row="1">
            <DataGrid  x:Name="fileformatsgrid"  Background="#2F2F2F" BorderThickness="0" IsReadOnly="True" 
                                  CanUserResizeColumns="False" CanUserResizeRows="False" GridLinesVisibility="None" RowHeaderWidth="0" RowBackground="Transparent"
                                  Cursor="Hand" CanUserAddRows="False" AutoGenerateColumns="False" CanUserReorderColumns="False" 
                              HeadersVisibility="Column"   UseLayoutRounding="True" SelectionMode="Extended" BorderBrush="Transparent" MinRowHeight="15" >


                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Height" Value="28"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{DynamicResource frgclr_white}"/>
                        <Setter Property="Background" Value="{DynamicResource clr_darkborder}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource clr_darkborder}"/>
                            <Setter Property="BorderThickness" Value="0 "/>
                            <Setter Property="FontSize" Value="14"/>

                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.ItemContainerStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="FontSize"
                                                                Value="13" />
                            <Setter Property="HorizontalAlignment"
                                                                Value="Left" />
                            <Setter Property="VerticalAlignment"
                                                                Value="Center" />
                            <Setter Property="VerticalContentAlignment"
                                                                Value="Center" />
                            <Setter Property="HorizontalContentAlignment"
                                                                Value="Center" />
                            <Setter Property="FontWeight"
                                                                Value="Regular" />
                            <Setter Property="Height"
                                                                Value="20"/>
                            <Setter Property="Foreground"
                                                                Value="{DynamicResource frgclr_white}" />
                            <Setter Property="Background"
                                                                Value="Transparent" />

                            <Setter Property="IsHitTestVisible"
                                                                Value="True" />

                        </Style>
                    </DataGrid.ItemContainerStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="{x:Type DataGridCell}">
                            <Setter Property="Background"
                                  Value="Transparent" />
                            <Setter Property="BorderThickness"
                                         Value="0" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected"
                                             Value="True">
                                    <Setter Property="Background"
                                              Value="Transparent" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="40">
                            <DataGridTemplateColumn.Header>
                                <Border Padding="5 0">
                                    <TextBlock x:Name="colUse" Text="Use" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding Path=isChecked , Mode=TwoWay , UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" Click="CheckBox_Click" >
                                        <CheckBox.LayoutTransform>
                                            <ScaleTransform ScaleX="0.90" ScaleY="0.90"/>
                                        </CheckBox.LayoutTransform>
                                    </CheckBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="*">
                            <DataGridTemplateColumn.Header>
                                <Border Padding="3 0">
                                    <TextBlock x:Name="colTypedes" Text="Type Description" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Border>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Name="file_types"
                                          Text="{Binding fileTypeText}" 
                                          ToolTip="{Binding fileTypeText}"                                                                
                                          Tag="{Binding}" Margin="3 0"/>
                                </DataTemplate>

                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
   
       
        <Grid Grid.Row="2" Background="{DynamicResource bgclr_soliddark}">
            <DockPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Label x:Name="lbl_settingsApplied" Content="Settings Applied" 
                   Foreground="#fff"
                   FontSize="15"
                   FontWeight="Bold"
                   VerticalContentAlignment="Center"                
                   Visibility="Collapsed"/>
                <TextBlock x:Name="lblMinSize" Text="Minimum file size included in scan :" VerticalAlignment="Center" Foreground="#E9E9E9" />
                <!--<Border BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1" Width="50" Height="30" Margin="10 0">-->
                    <DockPanel Margin="5 0" >
                    <xctk:IntegerUpDown  x:Name="numericUpDownMinFileSize" 
                                         Value="{Binding Path=sMinSizeValue , Mode=TwoWay}"
                                         Style="{StaticResource styl_updown}"/>
                    <xctk:IntegerUpDown x:Name="domainUpDownMinFileSize"
                                         Value="{Binding Path=sMinSize , Mode=TwoWay}"
                                         Style="{StaticResource styl_updown}"/>

                    <!--<TextBox x:Name="numericUpDownMinFileSize" Style="{StaticResource styl_txtbox}"
                             Text="50" TextChanged="numericUpDownMinFileSize_TextChanged_1"  />
                    <StackPanel  VerticalAlignment="Center">
                      
                        <cust:ImageButton x:Name="btnMaxSize"
                                          Style="{DynamicResource imgNumericButton}"
                                          Image="{DynamicResource img_maxsize}"
                                          HoverImage="{DynamicResource img_max_hover}"
                                          SelectedImage="{DynamicResource img_max_normal}"
                                          Height="11" Width="10"
                                          BorderBrush="#ABADB3"
                                          BorderThickness="1"
                                          Click="btnMaxSize_Click">


                        </cust:ImageButton>
                        <cust:ImageButton x:Name="btnMinSize"
                                          Style="{DynamicResource imgNumericButton}"
                                          Image="{DynamicResource img_minsize}"
                                          HoverImage="{DynamicResource img_min_hover}"
                                          SelectedImage="{DynamicResource img_min_normal}"
                                          Height="11" Width="10"
                                           BorderBrush="#ABADB3"
                                          BorderThickness="1"
                                          Click="btnMoveDown_Click_1">
                        </cust:ImageButton>

                    </StackPanel>-->


                    </DockPanel>
             

            </DockPanel>
        </Grid>
        
    </Grid>
</UserControl>
