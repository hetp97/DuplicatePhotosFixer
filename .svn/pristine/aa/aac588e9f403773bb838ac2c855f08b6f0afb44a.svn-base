<Window x:Class="DuplicatePhotosFixer.UserControls.ucClearCache"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:cust ="clr-namespace:DuplicatePhotosFixer.CustomControl"
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
            Height="176" Width="548"  WindowStyle="None" AllowsTransparency="True" WindowStartupLocation="CenterScreen"  Background="{DynamicResource cl_bg_cache}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="44"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="{DynamicResource cl_bg_header}">
            <Border BorderBrush="{DynamicResource cl_br_afterHeading}" BorderThickness="0 0 0 1">
                <DockPanel VerticalAlignment="Center" Margin="5" >
                    <Image x:Name="dpf_logo" Source="/Resources/dpf_updateofr_icon.png" DockPanel.Dock="Left" Margin="10 0" Stretch="None"/>
                    <cust:ImageButton
                            x:Name="close_btn"
                            Width="10"
                            Height="10"
                            DockPanel.Dock="Right"
                            Margin="10 0 10 0"
                            Style="{DynamicResource imageButton}"
                            Image="{DynamicResource img_close_plain}"
                            HoverImage="{DynamicResource img_close_plain}"
                            SelectedImage="{DynamicResource img_close_plain}" 
                Click="close_btn_click"/>

                    <TextBlock x:Name="dpf_heading" 
                       Text="Duplicate Photos Fixer Pro" VerticalAlignment="Center"
                       FontSize="14" Foreground="{DynamicResource cl_fg_heading}"/>


                </DockPanel>
            </Border>
        </Grid>
      
        <Grid Grid.Row="1">
            <DockPanel Margin="20 0 0 0">
                <Image x:Name="exclaim_image" Source="{DynamicResource img_alert_icon_trans}" Stretch="None" Margin="0 0 5 0"/>
                <TextBlock x:Name="lblinfo" VerticalAlignment="Center"
                            FontWeight="Regular"
                           FontSize="13"
                           Foreground="{DynamicResource cl_fg_cachecontent}" TextWrapping="Wrap">
                    It will clear your scan results and data related to current scan
                    and previous scans. Are you sure you want to do this?
                </TextBlock>
            </DockPanel>
        </Grid>
        <Grid Grid.Row="2" >
            
            <DockPanel HorizontalAlignment="Right">
                <Button x:Name="btnNo" Content="No" Grid.Column="2" Width="120" Height="33" Foreground="{DynamicResource cl_fg_transbtn}"
                         HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" 
                        Style="{DynamicResource btn_Transparent_style}">
                   
                </Button>
                <Button x:Name="btnYes" Width="120" Height="33"  Content="Yes" Margin="0 0 20 0"
                         HorizontalAlignment="Right" VerticalAlignment="Center"  Grid.Column="3" Style="{DynamicResource btn_contrastTransparent}" >
                
                </Button>

               

            </DockPanel>
        </Grid>
    </Grid>
</Window>
