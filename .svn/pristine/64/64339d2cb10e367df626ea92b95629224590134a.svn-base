        public static void getLastPriorityList(bool useUserSettings = true)
        {
            if (cGlobalSettings.listPriority == null)
                initillizePriorityList();
            try
            {
                if (!useUserSettings)
                    RegistryTool.priorityOrder = cGlobalSettings.DefaultAutoMarkPirority;
                string order = RegistryTool.priorityOrder;
                if (order != null)
                {
                    string[] priorityOrder = order.Split(new char[] { ',' }, StringSplitOptions.RemoveEmptyEntries);

                    for (int i = 0; i < priorityOrder.Length; i++)
                    {
                        bool isCheck = priorityOrder[i].Trim()[0] == '0' ? false : true;
                        Int16 key = Convert.ToInt16(priorityOrder[i].Trim().Substring(1, 1).ToString());
                        int indexSelected = 0;
                        if (priorityOrder[i].Length > 2)
                            indexSelected = Convert.ToInt16(priorityOrder[i].Trim().Substring(2).ToString());

                        cGlobalSettings.listPriority[key].isChecked = isCheck;

                        cGlobalSettings.listPriority[key].priority = (Int16)(i + 1);

                        cGlobalSettings.listPriority[key].indexSelectedInMultiOptions = indexSelected;

                        /*cGlobalSettings.listPriority[i].isChecked = priorityOrder[i].Trim()[0] == '0' ? false : true;

                        string ddfb = priorityOrder[i].Trim()[1].ToString();

                        cGlobalSettings.listPriority[i].priority = Convert.ToInt16(priorityOrder[i].Trim()[1].ToString());*/
                    }
                }
            }
            catch(Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("getLastPriorityList ::", ex);
            }
        }

        public static void updateCheckedStatus(int key, bool isChecked)
        {
            //if (cGlobalSettings.listPriority[key].isChecked != isChecked)
            {
                cGlobalSettings.listPriority[key].isChecked = isChecked;
                updateRegistryValue();
            }
        }

        public static void updateRegistryValue()
        {
            StringBuilder builder = new StringBuilder();

            foreach (var item in cGlobalSettings.listPriority.OrderBy(p=>p.Value.priority))
            {
                // Saving Style : 1st char: Is Priority checked |2nd: Priority key |3rd: Index selected (if multi value)  |and their order is their priority
                builder.Append(item.Value.isChecked ? "1" : "0").Append(item.Key).Append(item.Value.indexSelectedInMultiOptions).Append(",");
            }

            RegistryTool.priorityOrder = builder.ToString(); // Update registry key value.
        }
    }

