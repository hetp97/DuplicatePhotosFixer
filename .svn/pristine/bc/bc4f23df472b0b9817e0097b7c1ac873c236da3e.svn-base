        public static void resetTotalDuplicatesParams()
        {
            TotalDuplicatePhotos = 0;
            TotalDuplicatePhotosSelected = 0;
            TotalDuplicateGroups = 0;
            TotalDuplicateMarkPhotos = 0;
            TotalDuplicateMarkPhotosSize = 0;
            TotalCleanDuplicatePhotosCount = 0;
            TotalCleanDuplicatePhotosSize = 0;
            //ListDuplicateMarkPhotos = new List<String>();

            abortNow = false;
            arrAllFilesGrouping = null;

            currentItemsList = null;
            previousItemsList = null;

            if (itemsList != null) itemsList.Clear();
            isImageListViewLoaded = true;

            if (folderPaths != null)
            {
                folderPaths = null;
            }

            if (fileFormats != null)
            {
                fileFormats = null;
            }
        }


        public static string EncryptString(string input)
        {
            List<byte> encodedBytes = null;
            try
            {
                encodedBytes = new List<byte>();
                foreach (byte item in Encoding.UTF8.GetBytes(input))
                {
                    encodedBytes.Add((byte)~item);
                }
                string encodedString = System.Convert.ToBase64String(encodedBytes.ToArray());
                return encodedString;
            }
            catch (Exception ex)
            {
                ////Trace.WriteLine(ex.ToString());
            }
            finally
            {
                if (encodedBytes != null) encodedBytes.Clear();
                encodedBytes = null;
            }

            return "";

        }

        public static string DecryptString(string input)
        {
            List<byte> decodedBytes = null;
            try
            {
                decodedBytes = new List<byte>();
                foreach (byte item in System.Convert.FromBase64String(input))
                {
                    decodedBytes.Add((byte)~item);
                }
                string decryptedString = Encoding.UTF8.GetString(decodedBytes.ToArray());
                return decryptedString;
            }
            catch (Exception ex)
            {
                ////Trace.WriteLine(ex.ToString());
            }
            finally
            {
                if (decodedBytes != null) decodedBytes.Clear();
                decodedBytes = null;
            }

            return "";
        }
        static int _bMoveToLocation = -1;

        public static bool bMoveToLocation
        {
            get
            {
                if (_bMoveToLocation == -1)
                {
                    _bMoveToLocation = Convert.ToInt32(GetUserAppDataRegistryValue(cRegistrySettings.REGSTR_MOVE_TO_LOCATION, 0));
                }
                return _bMoveToLocation == 0 ? false : true;
            }
            set
            {
                SetUserAppDataRegistryValue(cRegistrySettings.REGSTR_MOVE_TO_LOCATION, value ? 1 : 0, RegistryValueKind.DWord);
                _bMoveToLocation = value ? 1 : 0;
            }
        }
        public static string strMoveLocation
        {
            get
            {
                string strLoc = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.Desktop), "DeletedPhotos");

                try
                {
                    strLoc = Convert.ToString(GetUserAppDataRegistryValue(cRegistrySettings.REGSTR_MOVE_LOCATION, ""));

                    if (string.IsNullOrEmpty(strLoc))
                    {
                        strLoc = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.Desktop), "DeletedPhotos");
                    }
                    strMoveLocation = strLoc;

                    /*if (Directory.Exists(strLoc))
                    {
                        return strLoc;
                    }
                    else
                    {
                        Directory.CreateDirectory(strLoc);
                    }
                    if (Directory.Exists(strLoc))
                    {
                        return strLoc;
                    }
                    else
                    {
                        strLoc = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.Desktop), "DeletedPhotos");
                        strMoveLocation = strLoc;
                        return strMoveLocation;
                    }*/
                }
                catch
                {
                    strLoc = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.Desktop), "DeletedPhotos");
                    strMoveLocation = strLoc;
                }
                return strLoc;
            }
            set
            {
                SetUserAppDataRegistryValue(cRegistrySettings.REGSTR_MOVE_LOCATION, value, RegistryValueKind.String);
            }
        }

        public static string GetApplicationVersion()
        {
            return ((AssemblyFileVersionAttribute)System.Reflection.Assembly.GetExecutingAssembly().GetCustomAttributes(typeof(AssemblyFileVersionAttribute), true)[0]).Version;

        }

        public static string getAppDataApplicationPath()
        {


            string sPath = Application.UserAppDataPath;
            sPath = sPath.Substring(0, sPath.LastIndexOf("\\"));

            if (!Directory.Exists(sPath))
            {
                Directory.CreateDirectory(sPath);
            }
            return sPath;

        }

