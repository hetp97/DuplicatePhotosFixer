        public static void LoadStringsFromINI()
        {
            #region "Language Settings"
            try
            {
                LoadLanguageDetails();

                //get selected Language from database                
                cGlobalSettings.oScanSettings.GetLanguageFromRegistry();


                if (String.IsNullOrEmpty(cGlobalSettings.oScanSettings.LanguageCode))
                {
                    cGlobalSettings.oScanSettings.CurrentLangSettings = cGlobalSettings.oScanSettings.LanguageDetails.Where(x => x.LangIdentifier == (cClientEnum.LanguageIdentifier)Enum.Parse(typeof(cClientEnum.LanguageIdentifier), cGlobalSettings.oScanSettings.LanguagePref.ToString())).FirstOrDefault();
                }
                else
                {
                    cGlobalSettings.oScanSettings.CurrentLangSettings = cGlobalSettings.oScanSettings.LanguageDetails.Where(x => x.NameAbbv.ToLower() == cGlobalSettings.oScanSettings.LanguageCode.ToLower()).FirstOrDefault();

                }

                /// this is done, so that always english is loaded if other lang ini is not available.                        
                if (cGlobalSettings.oScanSettings.CurrentLangSettings == null)
                {
                    cGlobalSettings.oScanSettings.CurrentLangSettings = cGlobalSettings.oScanSettings.LanguageDetails.Where(x => x.NameAbbv.ToLower() == "en").FirstOrDefault();
                }
                else
                {
                    /// if other lang ini is not available, load english as default ini
                    string LangIniFilePath = PathEx.Combine(Path.GetDirectoryName(Process.GetCurrentProcess().MainModule.FileName), cGlobalSettings.oScanSettings.CurrentLangSettings.IniName); ;
                    if (!File.Exists(LangIniFilePath))
                    {
                        cGlobalSettings.oScanSettings.CurrentLangSettings = cGlobalSettings.oScanSettings.LanguageDetails.Where(x => x.NameAbbv.ToLower() == "en").FirstOrDefault();
                    }
                }
                //Load INI file                
                cResourceManager.LoadStringsFromIni(oScanSettings.CurrentLangSettings);
                cResourceManager.findDuplicates();
            }
            catch (Exception ex)
            {

            }

            #endregion
        }

