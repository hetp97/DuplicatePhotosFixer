<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucHomeMain"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             xmlns:cust ="clr-namespace:DuplicatePhotosFixer.CustomControl"
             xmlns:UserControls="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="684" d:DesignWidth="998"  Name="objMainHome">

    <UserControl.Resources>
        <DataTemplate x:Key="cmbScanModeTemplate">
            <DockPanel VerticalAlignment="Center" Height="Auto" MinHeight="28">
                <Image Width="auto"
                       Height="auto"
                       Stretch="None"
                       Source="{Binding ModeIcon}"
                        Margin="0 4 8 5"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ModeName}"
                           ToolTip="{Binding ModeName}"
                           Margin="3 0"
                           TextWrapping="NoWrap"
                           TextTrimming="WordEllipsis"
                           FontWeight="SemiBold"
                           FontSize="14"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           
                           Foreground="#000" />
            </DockPanel>
            <!--<DataTemplate.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type ComboBoxItem}},Path=IsSelected}" Value="True">
                    <Setter TargetName="imgTick" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type ComboBoxItem}},Path=IsSelected}" Value="False">
                    <Setter TargetName="imgTick" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </DataTemplate.Triggers>-->
        </DataTemplate>
        <Style x:Key="DataGridCustomStyle" TargetType="{x:Type DataGrid}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FooterButtonDesign"
               TargetType="{x:Type cust:ImageButton}">
            <Setter Property="Background"
                    Value="{DynamicResource bgrclr_whitish}" />
            <Setter Property="BorderBrush" Value="{DynamicResource clr_darkborder}" />
            <Setter Property="Foreground" Value="{DynamicResource clr_darkborder}" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                        <Border x:Name="Border"
                                Width="120"
                                Height="33"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                            <Grid HorizontalAlignment="Center"
                                  VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Image Grid.Column="0"
                                       x:Name="imgMenu"
                                       Width="15"
                                       Height="15"
                                       SnapsToDevicePixels="False"
                                       Source="{TemplateBinding Image}"
                                       Stretch="None"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"                                      
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock Grid.Column="1"
                                           Padding="10 0"
                                           x:Name="txtName"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource bgclr_soliddark}"
                                           Text="{TemplateBinding Content}"
                                           FontWeight="Bold"
                                           TextWrapping="WrapWithOverflow" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="true">
                                <Setter TargetName="txtName"
                                        Property="Foreground"
                                        Value="{DynamicResource ClearListFontColor}" />
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="{DynamicResource pnlLeftTabHoverColor}" />
                                <Setter TargetName="imgMenu"
                                        Property="Image.Source"
                                        Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=HoverImage}" />

                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="true">
                                <Setter TargetName="txtName"
                                        Property="Foreground"
                                        Value="{DynamicResource ClearListFontColor}" />
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="{DynamicResource pnlLeftTabHoverColor}" />
                                <Setter TargetName="imgMenu"
                                        Property="Image.Source"
                                        Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=HoverImage}" />
                            </Trigger>
                            <Trigger Property="IsFocused"
                                     Value="true">
                                <Setter TargetName="txtName"
                                        Property="Foreground"
                                        Value="{DynamicResource ClearListFontColor}" />
                                <Setter TargetName="Border"
                                        Property="Background"
                                        Value="{DynamicResource pnlLeftTabHoverColor}" />
                                <Setter TargetName="imgMenu"
                                        Property="Image.Source"
                                        Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=SelectedImage}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate x:Key="cbmTemplate">
            <StackPanel Orientation="Horizontal" >
                <Image Source="{Binding ImagePath}" Height="15" Width="15" Margin="5"/>
                <TextBlock Text="{Binding Text}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="51"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="335"/>
            </Grid.ColumnDefinitions>

            <Grid Background="#545454" Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="210"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="78"/>
                    <!--<RowDefinition Height="0"/>-->
                </Grid.RowDefinitions>
                <Border Grid.Row="0" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="0 1 0 1">
                    <Border.Background>
                        <ImageBrush ImageSource="{DynamicResource img_top_header}"/>
                    </Border.Background>  
                </Border>
             
                <UserControls:ucDragAndDrop Grid.Row="1" Margin="0" Height="170" Width="588" HorizontalAlignment="Center"/>
                <Grid Grid.Row="2" Margin="15 15 13 0" Background="#00FF00">
                    <!--<Grid.RowDefinitions>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>-->

                    <DataGrid Name="grid_file_folder" Background="{DynamicResource bgrclr_lightgray}" BorderThickness="0" IsReadOnly="True" Style="{DynamicResource DataGridCustomStyle}"
                              VerticalAlignment="Stretch"
                              MinHeight="150"
                                  CanUserResizeColumns="False" CanUserResizeRows="False" GridLinesVisibility="None" RowHeaderWidth="0" RowBackground="Transparent"
                                  Cursor="Hand" CanUserAddRows="False" AutoGenerateColumns="False" CanUserReorderColumns="False" AlternatingRowBackground="{DynamicResource bgrclr_gray}"
                              HeadersVisibility="Column"   UseLayoutRounding="True" SelectionMode="Extended" BorderBrush="Transparent" MinRowHeight="15">


                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Height" Value="32"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="{DynamicResource cl_fg_primary}"/>
                                <Setter Property="Background" Value="{DynamicResource bgclr_dark}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource clr_darkborder}"/>
                                <Setter Property="BorderThickness" Value="0 "/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.ItemContainerStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="FontSize"
                                                                Value="13" />
                                <Setter Property="HorizontalAlignment"
                                                                Value="Left" />
                                <Setter Property="VerticalAlignment"
                                                                Value="Center" />
                                <Setter Property="VerticalContentAlignment"
                                                                Value="Center" />
                                <Setter Property="HorizontalContentAlignment"
                                                                Value="Center" />
                                <Setter Property="FontWeight"
                                                                Value="Regular" />
                                <Setter Property="Height"
                                                                Value="20"/>
                                <Setter Property="Foreground"
                                                                Value="{DynamicResource cl_fg_primary}" />
                                <Setter Property="Background"
                                                                Value="Transparent" />

                                <Setter Property="IsHitTestVisible"
                                                                Value="True" />
                                <!--<Setter Property="BorderBrush"
                                                                Value="{DynamicResource clr_border}" />
                                <Setter Property="BorderThickness"
                                                                Value="0,0,0,1" />
                                <Style.Triggers>
                                    <Trigger Property="ItemsControl.AlternationIndex"
                                                                     Value="0">
                                        <Setter Property="Background"
                                                                        Value="{DynamicResource clr_bg_row0}"></Setter>
                                    </Trigger>
                                    <Trigger Property="ItemsControl.AlternationIndex"
                                                                     Value="1">
                                        <Setter Property="Background"
                                                                        Value="{DynamicResource clr_bg_row1}"></Setter>
                                    </Trigger>
                                    <Trigger Property="ItemsControl.IsMouseOver"
                                                                     Value="True">
                                        <Setter Property="Foreground"
                                                                        Value="{DynamicResource clr_txt_bright}"></Setter>
                                    </Trigger>
                                </Style.Triggers>-->
                            </Style>
                        </DataGrid.ItemContainerStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="{x:Type DataGridCell}">
                                <Setter Property="Background"
                                                                Value="Transparent" />
                                <Setter Property="BorderThickness"
                                                                Value="0" />
                                <Style.Triggers>
                                    <Trigger Property="IsSelected"
                                                                     Value="True">
                                        <Setter Property="Background"
                                                                        Value="Transparent" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn>
                                <DataGridTemplateColumn.Header>

                                    <CheckBox x:Name="chkbxCheckAllgrid"  VerticalAlignment="Center" 
                                  Margin="7 1 0 0" IsEnabled="True"                                               
                                  HorizontalAlignment="Center" >
                                        <CheckBox.LayoutTransform>
                                            <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                        </CheckBox.LayoutTransform>
                                    </CheckBox>

                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox Name="chk_selected"
                                                                  DockPanel.Dock="Left" 
                                                  VerticalAlignment="Center" 
                                                    Margin="6 1 0 0" 
                                                                  Tag="{Binding}"
                                                                  IsChecked="{Binding Path=IsSelected,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"  Width="25">
                                            <CheckBox.LayoutTransform>
                                                <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                            </CheckBox.LayoutTransform>

                                        </CheckBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="*" >
                                <DataGridTemplateColumn.Header>
                                    <Border Padding="5 0">
                                        <TextBlock x:Name="scan_heading" Text="Scans the following files/folders for duplicates" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </DataGridTemplateColumn.Header>

                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <DockPanel Background="Transparent" Margin="3 0" 
                                                               VerticalAlignment="Center">

                                            <!--<Image Name="img_PathType"
                                                               DockPanel.Dock="Left"
                                                               Source="{DynamicResource img_btnfolder}"
                                                               Width="20" Height="15" Stretch="Uniform" Margin="0 0"/>-->
                                            <TextBlock Name="txt_path"
                                                                   Text="{Binding ScanPath}" 
                                                                   ToolTip="{Binding ScanPath}" 
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Tag="{Binding}" Margin="0 0"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="200" >
                                <DataGridTemplateColumn.Header>
                                    <Border Width="182">
                                        <TextBlock Text="Include Sub Folder" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox Name="chk_includeSubFolders" 
                                                  VerticalAlignment="Center" 
                                                        Margin="8 1 0 0" 
                                                        HorizontalAlignment="Center"
                                                              Tag="{Binding}"
                                                              IsEnabled="{Binding IsSelected}"
                                                              IsChecked="{Binding IncludeSubfolder,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <CheckBox.LayoutTransform>
                                                <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                            </CheckBox.LayoutTransform>

                                        </CheckBox>
                                        <!--<DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="False">
                                                            <Setter Property="IsEnabled" Value="False" TargetName="chk_includeSubFolders" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="IsEnabled" Value="True" TargetName="chk_includeSubFolders"/>
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>-->
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="80" x:Name="col_includeAction">
                                <DataGridTemplateColumn.Header>
                                    <Border HorizontalAlignment="Center" Width="80">
                                        <TextBlock Text="Action" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </DataGridTemplateColumn.Header>

                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button x:Name="btn_deleteCurrentRow" Width="10" Height="14" HorizontalAlignment="Center"
                                                BorderThickness="0" Click="btn_deleteCurrentRow_Click"
                                                 Tag="{Binding}" Margin="0 0 0 0"
                                                Style="{DynamicResource stl_btndeleteCurrentRow}">
                                            <Image Source="{DynamicResource img_deleteselectedfilefolder}" HorizontalAlignment="Center" 
                                                               VerticalAlignment="Center"
                                                                Height="15" Width="15" Stretch="None"/>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>

                    <DockPanel Grid.Row="3" Margin="5 0 13 0" >
                    
                    <cust:ImageButton x:Name="btnAddPhotos"                                
                                  Margin="10"
                                  Image="{DynamicResource img_btnpic}"
                                  Style="{DynamicResource stl_ImgTextButton}"
                                  HoverImage="{DynamicResource img_btnpic}"
                                  SelectedImage="{DynamicResource img_btnpic}"
                                  Content="Add Photos" FontWeight="Bold"
                                      Height="33" MinWidth="120"
                                       Background="{DynamicResource bgrclr_whitish}"
                                       Padding="6 0 0 0"
                                       FontSize="13"
                                       Foreground="{DynamicResource cl_fg_primary2}"
                                       BorderBrush="{DynamicResource cl_br_mainHomegrid}" BorderThickness="1"
                                      Click="btnAddPhotos_Click">

                    </cust:ImageButton>

                    <cust:ImageButton  x:Name="btnAddfolders"   
                                       Margin="10"
                                      Image="{DynamicResource img_btnfolder}"
                                  HoverImage="{DynamicResource img_btnfolder}"
                                  SelectedImage="{DynamicResource img_btnfolder}"
                                       Height="33" MinWidth="120"
                                       Background="{DynamicResource bgrclr_whitish}"
                                       Padding="6 0 0 0"
                                       FontSize="13"
                                       Foreground="{DynamicResource cl_fg_primary2}"
                                       BorderBrush="{DynamicResource cl_br_mainHomegrid}" BorderThickness="1"
                                  Style="{DynamicResource stl_ImgTextButton}"
                                  Content="Add Folders" FontWeight="Bold"
                                       Click="btnAddFolder_Click">

                    </cust:ImageButton>

                    <!--<Button x:Name="btnAddPhotos" Click="btnAddPhotos_Click"
                            Style="{DynamicResource stl_btnAddPhotos}">
                        <DockPanel Margin="0 0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image Source="{DynamicResource img_btnpic}" Height="15" Width="15" />
                            <TextBlock Text="Add Photos" Padding="5 0" FontSize="13" FontWeight="Bold"/>
                        </DockPanel>
                    </Button>-->

                    <!--<Button x:Name="btnAddFolder" Margin="19 0" 
                            Style="{DynamicResource stl_btnAddFolders}" Click="btnAddFolder_Click">
                        <DockPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Image Source="{DynamicResource img_btnfolder}" Height="15" Width="15"/>
                            <TextBlock Text="Add Folder" Padding="5 0" FontSize="13" FontWeight="Bold"/>
                        </DockPanel>
                    </Button>-->
                    <Border DockPanel.Dock="Right" Cursor="Hand" Margin="1 1"
                             Width="216" Height="30" Background="{DynamicResource bgrclr_white}" BorderThickness="0" >
                        <ComboBox x:Name="cboScanModes" 
                                                              Padding="2"                                                                                    
                                                              Foreground="{DynamicResource cl_fg_primary2}"
                                                              FontWeight="Normal"
                                                                                    
                                                              Margin="0,0,0,0"
                                                              Width="216" Height="30"
                                                              ItemTemplate="{DynamicResource cmbScanModeTemplate}"
                                                              Style="{DynamicResource ComboBoxFlatStyle}"
                                              ItemsSource="{Binding lstScanModeData}"
                                              SelectionChanged="cboScanModes_SelectionChanged">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ItemHeight}"
                                                                         Value="0">
                                            <Setter Property="Visibility"
                                                                            Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>

                    </Border>
                    <!--<ComboBox x:Name="cboScanModes" Width="216" Height="30"                            
                              BorderBrush="Transparent"
                              DockPanel.Dock="Right"   
                              SelectedIndex="0"
                              SelectionChanged="cboScanMode_SelectionChanged">
                        <DockPanel VerticalAlignment="Center">
                            <Image Source="{DynamicResource img_pc}" Height="15" Width="15" Margin="0 4 8 5"/>
                            <TextBlock Text="Scan Computer"  FontSize="14" FontWeight="SemiBold"  Margin="0 0 0 0 " HorizontalAlignment="Center"/>
                        </DockPanel>
                        <ComboBoxItem Width="200" >
                           

                        </ComboBoxItem>

                        <ComboBoxItem>
                            <DockPanel>
                                <Image Source="{DynamicResource img_drive}" Height="15" Width="15" Margin="0 5 8 5"/>
                                <TextBlock Text="Scan Google Drive" VerticalAlignment="Center" FontSize="13.5" FontWeight="Medium" />
                            </DockPanel>

                        </ComboBoxItem>
                        <ComboBoxItem>
                            <DockPanel>
                                <Image Source="{DynamicResource img_db}" Height="15" Width="15" Margin="0 5 8 5"/>
                                <TextBlock Text="Scan DropBox" VerticalAlignment="Center" FontSize="13.5" FontWeight="Medium" />
                            </DockPanel>

                        </ComboBoxItem>
                        <ComboBoxItem>
                            <DockPanel>
                                <Image Source="{DynamicResource img_picasa}" Height="15" Width="15" Margin="0 5 8 5"/>
                                <TextBlock Text="Picasa Library" VerticalAlignment="Center" FontSize="13.5" FontWeight="Medium" />
                            </DockPanel>

                        </ComboBoxItem>
                        <ComboBoxItem>
                            <DockPanel>
                                <Image Source="{DynamicResource img_lr}" Height="15" Width="15" Margin="0 5 8 5"/>
                                <TextBlock Text="LightRoom Classic" VerticalAlignment="Center" FontSize="13.5" FontWeight="Medium" />
                            </DockPanel>
                        </ComboBoxItem>
                        <ComboBoxItem>
                            <DockPanel>
                                <Image Source="{DynamicResource img_photo}" Height="15" Width="15" Margin="0 5 8 5"/>
                                <TextBlock Text="Photo Organizer" VerticalAlignment="Center" FontSize="13.5" FontWeight="Medium" />
                            </DockPanel>

                        </ComboBoxItem>
                        <ComboBoxItem>
                            <DockPanel>
                                <Image Source="{DynamicResource img_db}" Height="15" Width="15" Margin="0 5 8 5"/>
                                <TextBlock Text="BoxCloud" VerticalAlignment="Center" FontSize="13.5" FontWeight="Medium" />
                            </DockPanel>
                        </ComboBoxItem>
                        <ComboBoxItem>
                            <DockPanel>
                                <Image Source="{DynamicResource img_db}" Height="15" Width="15" Margin="0 5 8 5"/>
                                <TextBlock Text="Amazon S3" VerticalAlignment="Center" FontSize="13.5" FontWeight="Medium" />
                            </DockPanel>

                        </ComboBoxItem>
                        --><!--<ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" >
                                    <Image Source="{Binding ImagePath}" Height="15" Width="15" Margin="5"/>
                                    <TextBlock Text="{Binding Text}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>--><!--
                      
                    </ComboBox>-->


                    <!--<Button Height="33" Width="205" DockPanel.Dock="Right" Cursor="Hand" Background="White"  >

                        <ComboBox  
                            x:Name="cboScanMode" 
                            Height="33" 
                            Width="205" 
                            DockPanel.Dock="Right"
                         
                            Style="{DynamicResource CustomComboBoxStyle}"                           
                            SelectedIndex="0" 
                            SelectionChanged="cboScanMode_SelectionChanged" >
                            
                            <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <DockPanel>
                                                <Image x:Name="icon" Source="{Binding ScanPath}" Width="20" Height="20" Margin="0 0 5 0"/>
                                                <TextBlock Text="{Binding}"/>
                                            </DockPanel>
                                           
                                        </Grid>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>


                        </ComboBox>
                    </Button>-->
                    <TextBlock DockPanel.Dock="Right"/>

                </DockPanel>

            </Grid>
            <UserControls:ucHomeComparisonMethod Grid.Column="1" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1 1 0 0" />


        </Grid>
        <!--<Grid Grid.Row="1">
            <local:ucHomeFooter/>
        </Grid>-->
         <Border Grid.Row="1" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="0 1 0 0">
                    <Border.Background>
                        <ImageBrush ImageSource="{DynamicResource img_top_header}"/>
                    </Border.Background>
            <Grid Grid.Row="1" Height="51" Background="#424242">
                <local:ucHomeFooter/>
                

            </Grid>
        </Border>
    </Grid>
</UserControl>
