<Window x:Class="DuplicatePhotosFixer.Views.frmExitNag"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        mc:Ignorable="d"
        Title="frmExitNag" Height="311" Width="511" WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <DockPanel>
                <Button x:Name="btn_close" Background="#3E3E3E" Width="20"
                        Height="20"
                        Foreground="White"
                        FontSize="15"
                        FontWeight="SemiBold"
                        DockPanel.Dock="Right"
                        Margin="0 2 5 0"
                        VerticalAlignment="Top">X
                </Button>
                <TextBlock x:Name="clblPlsWait" Text="Before Closing"
                           Foreground="Black"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="5 10 0 0"/>
               
            </DockPanel>

            <TextBlock x:Name="lbl1" TextWrapping="Wrap" 
                       Margin="5 5 0 0"
                       FontSize="13"
                       Foreground="Black">
                Duplicate Photos Fixer Pro can remove all duplicate photos from your PC with<LineBreak/> a single click and recover tons of disk space.
            </TextBlock>

            <DockPanel HorizontalAlignment="Center">
                <TextBlock x:Name="lbl_discValue" 
                           Foreground="#ED2F3C"
                           FontSize="55"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                            Margin="3 0 3 0">
                    50%
                </TextBlock>
                <TextBlock x:Name="lbl_discount"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="#111111"
                           Margin="3 5 3 0">
                    DISCOUNT <LineBreak/>
                    Only for You
                </TextBlock>
            </DockPanel>
            <TextBlock x:Name="llbl_removeAll"
                       HorizontalAlignment="Center"
                       FontSize="14"
                     
                      >
                <Hyperlink>linkLabel</Hyperlink>
            </TextBlock>
            <DockPanel HorizontalAlignment="Right">
               

                <Button x:Name="btn_claimOffer"
                        Width="259"
                        Height="50"
                        Style="{DynamicResource stylGreenBtn}"
                        FontSize="15"
                        FontWeight="Bold"
                        Margin="0 0 20 0"
                        >
                    Claim Offer - 50% OFF
                    
                </Button>
                <Image x:Name="img_mbc" Source="/Resources/mbc_icon.png"
                       Width="64"
                       Height="64"
                      
                      Margin="0 0 20 0"
                       VerticalAlignment="Center"/>

            </DockPanel>
        </StackPanel>
        <Grid Grid.Row="1" Background="#262626">
            <Button x:Name="btn_cancel" 
                        Width="109"
                        Height="30"
                        Content="Quit" 
                        HorizontalAlignment="Right"
                    FontWeight="Bold"
                    Margin="0 0 20 0"/>
            <StackPanel Orientation="Horizontal">
                <Image x:Name="ms_logo" Source="{DynamicResource img_ms_logo}"
                       Width="128"
                       Height="47"
                       HorizontalAlignment="Left"/>
               

            </StackPanel>
        </Grid>
    </Grid>
</Window>
