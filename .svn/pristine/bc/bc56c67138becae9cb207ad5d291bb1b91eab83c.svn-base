<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="471" d:DesignWidth="872"   Background="#F5F5F5">
    <Grid>
        <TabControl
                       
                    Name="tab_main" 
                    TabStripPlacement="Left"
                    Margin="0,0,0,0"
                    Padding="0"        
                    Height="470"
          
                    BorderThickness="0" 
            Background="White"
           
                    >
            <TabItem Header="General"
                     Padding="3"
                     FontSize="12"
                    Width="145"
                      Height="40"
                     Background="#F5F5F5"
                     >
                <local:ucGeneral/>

            </TabItem>
            <TabItem Header="File Formats"
                      Padding="3"
                     FontSize="12"
                      Width="145"
                     Height="40" Background="#F5F5F5">
                <local:ucSettingsFileFormat/>
            </TabItem>

            <TabItem Header="Exclude Folder" 
                      Padding="3"
                     FontSize="12"
                      Width="145"
                      Height="40" Background="#F5F5F5">
                <local:ucExcludeSettings/>
            </TabItem>
            <TabItem Header="Scan Criteria" 
                      Padding="3"
                     FontSize="12"
                      Width="145"
                      Height="40" Background="#F5F5F5">
                <local:ucExtraSettings/>
            </TabItem>
            <TabItem Header="Move Duplicates" 
                      Padding="3"
                     FontSize="12"
                      Width="145"
                      Height="40"
                     Background="#F5F5F5">
                <local:ucSettingsMove/>
            </TabItem>



        </TabControl>
    </Grid>
</UserControl>
