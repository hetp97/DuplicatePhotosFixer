<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucNagSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="441" d:DesignWidth="482" Background="#272727">
    <UserControl.Resources>
        <Style x:Key="styl_radiobtn_content" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#E9E9E9"/>
            <Setter Property="Padding" Value="3 0 0 0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="70" />
            <RowDefinition Height="Auto"/>
           
            <RowDefinition Height="57"/>
        </Grid.RowDefinitions>
        <StackPanel Margin="10">
            <TextBlock x:Name="move_heading" Foreground="#fff"
                       FontSize="22" >
                Nag Theme
            </TextBlock>
            <TextBlock x:Name="heading_info"
                       Foreground="#AEAEAE" FontSize="14" TextWrapping="Wrap" FontWeight="Regular">
                       
                Select notification nag Theme Mode
            </TextBlock>
        </StackPanel>
        <Grid Grid.Row="1" Margin="10 15 0 0">
            <StackPanel Grid.Row="1" VerticalAlignment="Center" >
                <RadioButton  x:Name="rb_MoveToBin" Margin="5 2 0 5"  
                              Style="{StaticResource styl_radiobtn_content}" Content="Dark" />
                <RadioButton x:Name="rb_MoveToLocation" Style="{StaticResource styl_radiobtn_content}"
                              Margin="5 2 0 5"  IsChecked="False" Content="Light" />
                
            </StackPanel>
        </Grid>



        

        <!--<TextBlock Grid.Row="3"  Background="#D5D5D5" VerticalAlignment="Bottom"/>-->
    </Grid>
</UserControl>
