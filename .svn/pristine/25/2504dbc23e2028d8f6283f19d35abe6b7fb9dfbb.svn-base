<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucSettingsFileFormat"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="464" d:DesignWidth="515" Background="{DynamicResource bgrclr_white}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="57"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10 20">
            <TextBlock Text="Manage File Formats" FontSize="22" Foreground="{DynamicResource frgclr_solidgray}"/>
            <TextBlock Text="The settings below allow you to exclude file extensions from being added to scan list."
                       TextWrapping="Wrap" Foreground="{DynamicResource frgclr_solidgray}" Margin="0 0 0 30" 
                       FontSize="14"/>
            <ScrollViewer x:Name="gridViewer">

                <DataGrid x:Name="fileformatsgrid"  AutoGenerateColumns="False" ItemsSource="{Binding}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="30" Header="Use">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding isSelected}">
                                        <CheckBox.LayoutTransform>
                                            <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                                        </CheckBox.LayoutTransform>
                                    </CheckBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Type Description" Width="*" Binding="{Binding formatType}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>
        </StackPanel>

        <Grid Grid.Row="1" Background="{DynamicResource  bgrclr_grayish}">
            <DockPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Minimum file size included in scan :" VerticalAlignment="Center"/>
                <Border BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1" Width="50" Height="30" Margin="10 0">
                    <DockPanel >
                        <TextBlock Text="0" Padding="5" VerticalAlignment="Center" Background="{DynamicResource bgrclr_whitish}"/>

                        <StackPanel>
                            <Button Height="15">

                            </Button>
                            <Button Height="15">

                            </Button>
                        </StackPanel>


                    </DockPanel>
                </Border>
                <Border BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="1" Width="50" Height="30">
                    <DockPanel >
                        <TextBlock Text="0" Padding="5" VerticalAlignment="Center" Background="{DynamicResource bgrclr_whitish}"/>

                        <StackPanel >
                            <Button Height="15">

                            </Button>
                            <Button Height="15">

                            </Button>
                        </StackPanel>


                    </DockPanel>
                </Border>

            </DockPanel>
        </Grid>
        
    </Grid>
</UserControl>
