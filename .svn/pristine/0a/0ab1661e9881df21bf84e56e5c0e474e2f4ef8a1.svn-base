<Window x:Class="DuplicatePhotosFixer.Views.Cloud.frmAmazonLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views.Cloud"
        mc:Ignorable="d"
        Title="frmAmazonLogin" Height="402" Width="659" WindowStyle="None" Background="{DynamicResource bgrclr_solidgray}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition/>
            <RowDefinition Height="61"/>
        </Grid.RowDefinitions>
        <DockPanel Background="Black">
            <Button DockPanel.Dock="Right"  Margin="3,3,3,3" Background="Transparent"  Width="24" Height="24">
                <Image Source="{DynamicResource img_close}"/>
            </Button>
            <Label x:Name="lbl_heading" Content="label1" Margin="2, 0, 2, 0" Foreground="White" />
        </DockPanel>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Image Source="{DynamicResource img_nag}" Width="80" Height="80" VerticalAlignment="Top" Margin="15"/>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <StackPanel Margin="0 18 15 0">
                    <Label x:Name="txtSignin" Content="Please fill the below details" Foreground="White" FontSize="20" FontWeight="Regular" Margin="0,0,0,10"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock x:Name="label1" Text="1." Foreground="White" FontSize="14" Padding="3,0,0,0" />
                                <TextBlock x:Name="txtPoint1" Text="Bucket Name:" Foreground="#A8A8A8" FontSize="14" Padding="3,0,0,0"/>
                            </DockPanel>
                            <DockPanel  Margin="0,0,0,10">
                                <TextBlock x:Name="label2" Text="2." Foreground="White" FontSize="14" Padding="3,0,0,0" />
                                <TextBlock x:Name="txtPoint2" Text="Access Key:" Foreground="#A8A8A8" FontSize="14" Padding="3,0,0,0" />
                            </DockPanel>
                            <DockPanel>
                                <TextBlock x:Name="label3" Text="3." Foreground="White" FontSize="14" Padding="3,0,0,0" />
                                <TextBlock x:Name="txtPoint3" Text="Secret Key:" Foreground="#A8A8A8" FontSize="14" Padding="3,0,0,0"/>
                            </DockPanel>
                        </StackPanel>
                        <Grid Grid.Column="1">
                            <StackPanel Margin="10,0,0,0">
                                <TextBox x:Name="txtbcktname" Text="" Background="Transparent" Foreground="White" FontSize="14" Margin="0,0,0,10" BorderBrush="#A8A8A8"/>
                                <TextBox x:Name="txtacesskey" Text="" Background="Transparent" Foreground="White" FontSize="14" Margin="0,0,0,10" BorderBrush="#A8A8A8"/>
                                <TextBox x:Name="txtsecretidkey" Text="" Background="Transparent" Foreground="White" FontSize="14" BorderBrush="#A8A8A8" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
        <Grid Grid.Row="2">
            <DockPanel  HorizontalAlignment="Right">
                <Button x:Name="btnCancel" Content="Cancel" Foreground="Black" Width="124" Height="32" Margin="0 0 25 0" FontWeight="SemiBold" FontSize="14" Background="#E3E6EC"/>
                <Button x:Name="btnContinue" Content="Continue" Foreground="White"  Width="124" Height="32" Margin="0 0 25 0" FontWeight="SemiBold" FontSize="14" Background="#0283C1"/>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
