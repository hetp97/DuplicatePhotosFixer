        public static string VersionIndependentRootRegKey
        {
            get
            {
                string versionDependent = System.Windows.Forms.Application.UserAppDataRegistry.Name;
                string versionIndependent =
                       versionDependent.Substring(0, versionDependent.LastIndexOf("\\"));

                // versionIndependent = string.Format("{0}\\{1}", versionIndependent, cGlobalSettings.nUserMachineId);

                return versionIndependent;
            }
        }
        public static void SetUserAppDataRootRegistryValue(string name, object value, RegistryValueKind kind)
        {
            if (Registry.CurrentUser.OpenSubKey(VersionIndependentRegKeyNoHive) == null)
            {
                Registry.CurrentUser.CreateSubKey(VersionIndependentRegKeyNoHive);
            }
            Registry.SetValue(VersionIndependentRootRegKey, name, value, kind);
        }

        public static object GetUserAppDataRootRegistryValue(string name, object defaultValue)
        {
            return Registry.GetValue(VersionIndependentRootRegKey, name, defaultValue) ?? defaultValue;
        }

        public static object GetCommonAppDataRootRegistryValue(string name, object defaultValue)
        {
            try
            {
                return Registry.GetValue(VersionIndependentRegKey/*VersionIndependentCommonRootRegKey*/, name, defaultValue) ?? defaultValue;
            }
            catch (System.Exception ex)
            {
                oLogger.WriteLog(string.Format("cGlobal|GetCommonAppDataRootRegistryValue|{0}", ex.Message));
                return string.Empty;
            }

        }

        public static void SetCommonAppDataRootRegistryValue(string name, object value, RegistryValueKind kind)
        {
            try
            {
                Registry.SetValue(VersionIndependentRegKey/*VersionIndependentCommonRootRegKey*/, name, value, kind);
            }
            catch (System.Exception ex)
            {
                oLogger.WriteLog(string.Format("cGlobal|SetCommonAppDataRegistryValue|{0}", ex.Message));

            }
        }
        public static string GetUpdatePath()
        {
            string sDbPath = Path.Combine(getCommonAppDataApplicationPath(), UPDATE_FOLDERNAME);
            if (!Directory.Exists(sDbPath))
            {
                Directory.CreateDirectory(sDbPath);
            }
            return sDbPath;
        }


        public static string m_DownloadPath = string.Empty;
        public static string GetDownloadPath
        {
            get
            {
                if (string.IsNullOrEmpty(m_DownloadPath))
                {
                    string sDownloadPath = Path.Combine(getCommonAppDataApplicationPath(), DOWNLOAD_FOLDERNAME);
                    if (!Directory.Exists(sDownloadPath))
                    {
                        Directory.CreateDirectory(sDownloadPath);
                    }
                    m_DownloadPath = sDownloadPath;
                }
                return m_DownloadPath;
            }
            set
            {
                m_DownloadPath = value;
            }
        }

        public static List<string> GetUpdateUrlCollection(cClientEnum.eCheckForUpdateType oCheckForUpdateType)
        {
            List<string> lsUpdateUrls = new List<string>();
            try
            {
                switch (oCheckForUpdateType)
                {
                    case cClientEnum.eCheckForUpdateType.Check_All_Servers:
                        int nCountUrls = Convert.ToInt32(ConfigurationManager.AppSettings["UPDATE_URL_COUNT"]);
                        for (int i = 1; i <= nCountUrls; i++)
                        {
                            lsUpdateUrls.Add(Convert.ToString(ConfigurationManager.AppSettings["UPDATE_URL" + i]));
                        }
                        break;
                    case cClientEnum.eCheckForUpdateType.Check_Primary_Server:
                        lsUpdateUrls.Add(Convert.ToString(ConfigurationManager.AppSettings["UPDATE_URL" + (int)cClientEnum.eCheckForUpdateType.Check_Primary_Server]));

                        break;
                    case cClientEnum.eCheckForUpdateType.Check_Alternate_Server_1:
                        lsUpdateUrls.Add(Convert.ToString(ConfigurationManager.AppSettings["UPDATE_URL" + (int)cClientEnum.eCheckForUpdateType.Check_Alternate_Server_1]));
                        break;
                    default:
                        break;
                }
                //string sConfigName = GetBuildConfiguration();

                //switch (oCheckForUpdateType)
                //{
                //    case cClientEnum.eCheckForUpdateType.Check_All_Servers:
                //        int nCountUrls = Convert.ToInt32(ConfigurationManager.AppSettings["UPDATE_URL_COUNT"]);
                //        for (int i = 1; i <= nCountUrls; i++)
                //        {
                //            lsUpdateUrls.Add(Convert.ToString(ConfigurationManager.AppSettings["UPDATE_URL_" + sConfigName + i]));
                //        }
                //        break;
                //    case cClientEnum.eCheckForUpdateType.Check_Primary_Server:
                //        lsUpdateUrls.Add(Convert.ToString(ConfigurationManager.AppSettings["UPDATE_URL" + sConfigName + (int)cClientEnum.eCheckForUpdateType.Check_Primary_Server]));

                //        break;
                //    case cClientEnum.eCheckForUpdateType.Check_Alternate_Server_1:
                //        lsUpdateUrls.Add(Convert.ToString(ConfigurationManager.AppSettings["UPDATE_URL" + sConfigName + (int)cClientEnum.eCheckForUpdateType.Check_Alternate_Server_1]));
                //        break;
                //    default:
                //        break;
                //}


            }
            catch (System.Exception ex)
            {
                oLogger.WriteLogException("|GetUpdateUrlCollection()|", ex);
            }
            return lsUpdateUrls;
        }

        public static cClientEnum.eCheckForUpdateType GetUrlServerType(string sUrl)
        {
            cClientEnum.eCheckForUpdateType oRetType = cClientEnum.eCheckForUpdateType.Check_Primary_Server;
            try
            {
                List<string> lsAllUrls = GetUpdateUrlCollection(cClientEnum.eCheckForUpdateType.Check_All_Servers);

                int index = lsAllUrls.FindIndex(x => x.ToLower() == sUrl);

                if (index == 0)
                {
                    oRetType = cClientEnum.eCheckForUpdateType.Check_Primary_Server;
                }
                else
                {
                    oRetType = cClientEnum.eCheckForUpdateType.Check_Alternate_Server_1;
                }
            }
            catch (System.Exception ex)
            {
                oLogger.WriteLogException("|GetUrlServerType()|", ex);
            }
            return oRetType;
        }

        internal static string CombineUrlAppTracking(string sInput, string action, string productname, int reminderoffertype, int remindereventtype, string extraparam)
        {
            try
            {
                string sFinalUrl = string.Empty;
                if (!sInput.EndsWith("?") && !sInput.EndsWith("&"))
                {
                    if (!sInput.Contains("="))
                    {
                        sInput += "?";
                    }
                    else
                    {
                        sInput += "&";
                    }
                }
                if (string.IsNullOrEmpty(X_AT))
                {
                    sFinalUrl = string.Format(
                        "{0}&nagaction={2}&nagname={3}&productid={4}&utm_source={5}&utm_medium={6}&utm_campaign={7}&affiliate={8}&utm_cid={9}&utm_updt={10}&utm_updatedate={11}&utm_days={12}&isreg={13}&isexpired={14}&pcname={15}&productversion={16}&override={17}&langcode={18}&nagshowndate={19}&remindereventtype={20}&reminderoffertype={21}&isvm={22}&nagparent={23}"
                        , sInput, 1, action, productname, cGlobalSettings._ProductId, UTM_SOURCE, UTM_MEDIUM, UTM_CAMPAIGN, UTM_AFFILIATE, UTM_CID, UTM_UPDT, UTM_UPDATEDATE, UTM_DAYS, cGlobalSettings.cRegDetails.IsRegistered, cGlobalSettings.cRegDetails.IsExpired, PC_NAME, APP_VERSION, 1, langApplied.FirstOrDefault(), DateTime.Now.ToString("dd-MM-yy_hh-mm-ss"), remindereventtype, reminderoffertype, cGlobal.IsVirtualMachine, cGlobal.NagParentStr);
                }
                else
                {
                    sFinalUrl = string.Format(
                        "{0}&nagaction={2}&nagname={3}&productid={4}&utm_source={5}&utm_medium={6}&utm_campaign={7}&affiliate={8}&utm_cid={9}&utm_updt={10}&utm_updatedate={11}&utm_days={12}&x-at={13}&isreg={14}&isexpired={15}&pcname={16}&productversion={17}&override={18}&langcode={19}&nagshowndate={20}&remindereventtype={21}&reminderoffertype={22}&isvm={23}&nagparent={24}"
                        , sInput, 1, action, productname, cGlobalSettings.ProductId, UTM_SOURCE, UTM_MEDIUM, UTM_CAMPAIGN, UTM_AFFILIATE, UTM_CID, UTM_UPDT, UTM_UPDATEDATE, UTM_DAYS, X_AT, cGlobalSettings.cRegDetails.IsRegistered, cGlobalSettings.cRegDetails.IsExpired, PC_NAME, APP_VERSION, 1, langApplied.FirstOrDefault(), DateTime.Now.ToString("dd-MM-yy_hh-mm-ss"), remindereventtype, reminderoffertype, cGlobal.IsVirtualMachine, cGlobal.NagParentStr);
                }

                //if (!string.IsNullOrEmpty(cGlobal.NagParentStr))
                //{
                //    cGlobal.NagParentStr = string.Empty;
                //}

                sFinalUrl = sFinalUrl + cGlobalSettings.FINAL_PARAMS + extraparam;
                sFinalUrl = RemoveQueryStringDuplicates(sFinalUrl);

                return sFinalUrl;
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("CombineUrlAppTracking:: ", ex);
                return sInput; // keep compiler happy     
            }
        }

        public static string RemoveQueryStringDuplicates(string strUri)
        {
            string FinalLink = strUri;
            try
            {
                Uri uriLink = new Uri(FinalLink);
                string newQueryString = uriLink.Query;
                string strlink = uriLink.GetLeftPart(UriPartial.Path);

                /*var nameValueList = HttpUtility.ParseQueryString(newQueryString); 

                IEnumerable<string> distKeys = nameValueList.AllKeys.Distinct(); 

                FinalLink = newQueryString.Count() > 0 
                       ? String.Format("{0}?{1}", strlink, newQueryString) 
                       : strlink;*/


                if (string.IsNullOrEmpty(newQueryString))
                {
                    /// No query string found for given link. 
                    ///  
                    return FinalLink;
                }

                newQueryString = newQueryString.TrimStart(new char[] { '?' }).TrimEnd(new char[] { '&' }).ToLower();

                string[] queryParams = newQueryString.Split(new string[] { "&", "&amp;" }, StringSplitOptions.RemoveEmptyEntries);

                Dictionary<string, string> dictUniqueKeyValues = new Dictionary<string, string>();
                if (queryParams.Length > 0)
                {
                    for (int i = 0; i < queryParams.Length; i++)
                    {
                        string[] strKeyValue = queryParams[i].Split(new char[] { '=' });
                        if (!dictUniqueKeyValues.ContainsKey(strKeyValue[0]))
                        {
                            if (strKeyValue.Length == 0)
                                continue;
                            if (strKeyValue.Length == 1)
                            {
                                dictUniqueKeyValues.Add(strKeyValue[0], "");
                            }
                            if (strKeyValue.Length >= 2)
                                dictUniqueKeyValues.Add(strKeyValue[0], strKeyValue[1]);
                        }
                    }
                }

                FinalLink = dictUniqueKeyValues.Count > 0
                       ? String.Format("{0}?{1}", strlink, string.Join("&", dictUniqueKeyValues.Select(x => x.Key + "=" + x.Value).ToArray()))
                       : strlink;

            }
            catch (Exception ex)
            {

            }

            return FinalLink;
        }

