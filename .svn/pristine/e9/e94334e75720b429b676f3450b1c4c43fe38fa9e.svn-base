        public static string GetFileDialogFileFilter
        {
            get
            {
                switch (CurrentScanMode)
                {
                    case eScanMode.FileSearch:
                        {
                            //var FileTypesToAdd = cGlobalSettings.listFileType;
                            cGlobalSettings.FileDialogFilterList = string.Empty;
                            foreach (var item in cGlobalSettings.listFileType.Where(p => p.Value.isChecked))
                            {
                                cGlobalSettings.FileDialogFilterList += item.Value.FileDialogFilterItem;
                            }

                            if (cGlobalSettings.FileDialogFilterList != "")
                                cGlobalSettings.FileDialogFilterList = cGlobalSettings.FileDialogFilterList.TrimEnd(new char[] { '|' });
                        }
                        return FileDialogFilterList;
                    case eScanMode.GoogleDrive:
                        break;
                    //case eScanMode.PicasaLibrary:
                    //    //Digital Negative and ProRaw RAW Image File (*.dng)|*.dn
                    //    return cResourceManager.LoadString("IDS_PICASA_LIB_FORMAT") + @" (thumbindex.db)|thumbindex.db";
                    //case eScanMode.Dropbox:
                    //    break;
                    //case eScanMode.DeleteEmptyFolder:
                    //    break;
                }
                return "";
            }
        }
