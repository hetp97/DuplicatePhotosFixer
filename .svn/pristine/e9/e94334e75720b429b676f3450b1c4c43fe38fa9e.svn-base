        /// <summary>
        /// Get download link of Duplicate Files Fixer (DFF)
        /// </summary>
        /// <returns></returns>
        public static string GetFileFixerDownloadUrl(bool bSetParamsInLink = false)
        {
            string link = Convert.ToString(ConfigurationManager.AppSettings["FIX_FILES_URL1"]);
            if (bSetParamsInLink)
            {
                return GetParameterisedLink(link);
            }
            else
                return link;
        }

        static string GetParameterisedLink(string link)
        {
            string newLink = link; // http://cdn.systweak.com/downloads/dffw/dffsetupadg_dpfw-adg1.exe?of=dffsetupadg_.exe
            try
            {
                string fileName = cGlobal.GetFileNameFromUrl(link);

                string fileNameWithoutExtension = Path.GetFileNameWithoutExtension(fileName);

                int nName = fileNameWithoutExtension.IndexOf('_');

                if (nName < 0)
                {
                    return link;
                }
                string setupname = fileNameWithoutExtension.Substring(0, nName);

                string newName = string.Format("{0}_{1}-{2}", setupname, cGlobal.UTM_SOURCE, cGlobal.UTM_CAMPAIGN);

                newLink = link.Replace(fileNameWithoutExtension, newName);
            }
            catch (Exception ex)
            {
                oLogger.WriteLogException("cGlobalSettings:: GetParameterisedLink: ", ex);
            }
            return newLink;
        }

        public static Version GetOSVersion()
        {
            Version oVersion = null;

            System.Management.ManagementObjectSearcher searcher = new System.Management.ManagementObjectSearcher("SELECT Version FROM Win32_OperatingSystem");
            try
            {
                foreach (var os in searcher.Get())
                {
                    oVersion = new Version(os["Version"].ToString());
                }
            }
            catch (Exception ex)
            {
                oVersion = Environment.OSVersion.Version;
            }
            return oVersion;
        }

