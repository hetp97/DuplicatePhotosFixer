        public static void DownloadNInstallRecommandedSetup(string pName, string DownloadSetupLink, bool showProgress, out cClientEnum.eDownloadStatus status)
        {
            status = cClientEnum.eDownloadStatus.DownloadError;
            try
            {
                string param = "/verysilent /aftinsts";

                //param for Systweak VPN
                if (pName.Trim().ToLower() == UtilityKitBuyNow.GetEnumDescription(UtilityKitBuyNow.eUtlKitProduct.SVPN).Trim().ToLower())
                    param = "/verysilent /components=\"\"";

                //param for Right Backup
                if (pName.Trim().ToLower() == UtilityKitBuyNow.GetEnumDescription(UtilityKitBuyNow.eUtlKitProduct.RB).Trim().ToLower())
                    param = "/aftinsts";

                csDownloadFile oDownload = null;

                System.Diagnostics.Process proc = null;
                try
                {
                    if (oDownload == null)
                    {
                        oDownload = new csDownloadFile();
                        /*if (showProgress)
                        {
                            oDownload.OnProgress += (percentage, strMsg) => Program.oMainReference.oDownload_OnProgress(0, "");
                        }*/
                    }

                    string fullDownloadedPath = string.Empty;
                    try
                    {

                        status = oDownload.DownloadFile(DownloadSetupLink, GetFileNameFromUrl(DownloadSetupLink)/*Path.GetFileName(DownloadSetupLink)*/, cGlobalSettings.GetUtilDownloadPath(), out fullDownloadedPath);

                        if (status != cClientEnum.eDownloadStatus.DownloadSucessFull)
                        {
                            cGlobalSettings.oLogger.WriteLogVerbose("DownloadNInstallRBSetup:: Not able to download setup successfully");
                            return;
                        }
                        if (!File.Exists(fullDownloadedPath))
                        {
                            cGlobalSettings.oLogger.WriteLogVerbose("DownloadNInstallRBSetup:: Downloaded setup not found on system");
                            return;
                        }
                    }
                    catch (Exception ex)
                    {
                        cGlobalSettings.oLogger.WriteLogException("DownloadNInstallRBSetup:: While Downloading setup, :: ", ex);
                    }
                    finally
                    {

                    }

                    /*if (showProgress)
                        Program.oMainReference.oDownload_OnProgress(100, cResourceManager.LoadString("SCANTAB4"));*/

                    using (proc = new System.Diagnostics.Process())
                    {
                        proc.EnableRaisingEvents = false;
                        proc.StartInfo.FileName = fullDownloadedPath;
                        proc.StartInfo.Arguments = param;

                        proc.Start();
                        proc.WaitForExit();
                    }

                }
                catch (Exception ex)
                {
                    cGlobalSettings.oLogger.WriteLogException("DownloadNInstallRBSetup:: Thread- ThreadRBInstall, :: ", ex);
                }
                finally
                {
                    /*if (showProgress)
                    {
                        Program.oMainReference.UIThread(() =>
                        {
                            if (Program.oMainReference.oCustomProgress != null || !Program.oMainReference.oCustomProgress.IsDisposed)
                            {
                                Program.oMainReference.oCustomProgress.Close();
                            }
                                //CloseForm();
                            });
                    }*/
                    if (proc != null)
                    {
                        proc.Close();
                        proc.Dispose();
                        proc = null;
                    }
                }
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("DownloadNInstallRBSetup:: ", ex);
            }
        }


        #endregion

    }
}
