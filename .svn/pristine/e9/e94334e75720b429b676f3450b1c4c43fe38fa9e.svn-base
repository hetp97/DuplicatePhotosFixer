        public static DateTime ProductRegisterDate
        {
            get
            {
                DateTime dt = DateTime.MinValue;
                string strProductRegisterDate = Convert.ToString(GetUserAppDataRegistryValue(cRegistrySettings.REGSTR_PRODUCT_REGISTER_DATE, ""));
                if (string.IsNullOrEmpty(strProductRegisterDate))
                    return dt;

                if (!DateTime.TryParseExact(strProductRegisterDate, strInstallDateFormat, CultureInfo.InvariantCulture, DateTimeStyles.None, out dt))
                {
                    dt = DateTime.MinValue;
                }
                return dt;
            }
            set
            {
                SetUserAppDataRegistryValue(cRegistrySettings.REGSTR_PRODUCT_REGISTER_DATE, value.ToString(strInstallDateFormat, CultureInfo.InvariantCulture), RegistryValueKind.String);
            }
        }

