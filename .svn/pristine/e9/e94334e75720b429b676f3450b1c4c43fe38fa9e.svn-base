        public static void SetCommonAppDataRegistryValue(string name, object value, RegistryValueKind kind)
        {
            try
            {
                if (Registry.LocalMachine.OpenSubKey(VersionIndependentCommonRegKeyNoHive) == null)
                {
                    Registry.LocalMachine.CreateSubKey(VersionIndependentCommonRegKeyNoHive);
                }
                Registry.SetValue(VersionIndependentCommonRegKey, name, value, kind);
            }
            catch (System.Exception ex)
            {
                oLogger.WriteLog(string.Format("cGlobal|SetCommonAppDataRegistryValue|{0}", ex.Message));

            }
        }

        public static string VersionIndependentCommonRegKey
        {
            get
