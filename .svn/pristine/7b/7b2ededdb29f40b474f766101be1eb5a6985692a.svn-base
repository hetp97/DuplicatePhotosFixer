        public void updateSelectedExtensionsItems()
        {
            try
            {
                StringBuilder builder = new StringBuilder();
                // Update cGlobalSettings constants 
                //cGlobalSettings.ImageFileExtensionsList = "(";
                cGlobalSettings.FileDialogFilterList = "";

                // Add all image types to File Dialog Filter list
                //builder.Append(cGlobalSettings.listFileType[-1].ImageFileExtension);
                cGlobalSettings.FileDialogFilterList += cGlobalSettings.listFileType[-1].FileDialogFilterItem;


                for (int i = 0; i < fileformatsgrid.Items.Count; i++)
                {
                    if (fileformatsgrid.Items[i] != null)
                    {
                        if (Convert.ToBoolean((fileformatsgrid.Items[i] as DataGridViewCheckBoxCell).Value))
                        {
                            _ = builder.Append(cGlobalSettings.listFileType[(int)fileformatsgrid.Items[i]].ImageFileExtension);
                            cGlobalSettings.FileDialogFilterList += cGlobalSettings.listFileType[(int)fileformatsgrid.Items[i]].FileDialogFilterItem;
                            //cGlobalSettings.ImageFileExtensionsList += cGlobalSettings.listFileType[(int)listFileTypes.Items[i].Tag].ImageFileExtension;
                        }
                    }
                }
                if (cGlobalSettings.FileDialogFilterList != "")
                    cGlobalSettings.FileDialogFilterList = cGlobalSettings.FileDialogFilterList.Substring(0, cGlobalSettings.FileDialogFilterList.Length - 2);

                cGlobalSettings.ImageFileExtensionsList = "(" + builder.ToString().TrimStart('|') + ")";

                builder = null;
                //cGlobalSettings.ImageFileExtensionsList += ")";
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("updateSelectedExtensionsItems", ex);
            }
        }

        private void fileformatsgrid_CurrentCellChanged(object sender, EventArgs e)
        {
            try
            {
                if (fileformatsgrid.Items.Count < 1)
                    return;

                int key = (int)fileformatsgrid.Items[0];
                bool isChecked = Convert.ToBoolean((fileformatsgrid.Items[0] as DataGridViewCheckBoxCell).Value);

                //int key = (int)e.Item.Tag;
                //bool isChecked = e.Item.Checked;

                if (cGlobalSettings.listFileType[key].isChecked != isChecked)
                {
                    // Update Dictionary values
                   // csFileTypes.updateCheckedStatus(key, isChecked);


                    if (cGlobalSettings.listFileType.Where(p => p.Value.isChecked == true && p.Key > -1).Count() == 0)
                    {
                        (fileformatsgrid.Items[0] as DataGridViewCheckBoxCell).Value = true;
                        cGlobalSettings.listFileType[key].isChecked = true;
                        if (!cGlobalSettings.isFileTypesSettingLoadFirstTime)
                        {
                            //Program.oMainReference.showMessage(cResourceManager.LoadString("DPF_PREFERENCES_FILTER_SORT_ATLEAST_ONE_EXTENSION_REQUIRED"), "");
                        }
                        cGlobalSettings.isFileTypesSettingLoadFirstTime = false;
                    }
                    // Update cGlobalSettings constants 
                    updateSelectedExtensionsItems();
                }
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("listFileTypes_ItemChecked :: ", ex);
            }
        }

       
    }
