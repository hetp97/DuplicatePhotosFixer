    <DrawingImage x:Key="img_uncheckDrawingImage">
        
        <DrawingImage.Drawing>
            <DrawingGroup ClipGeometry="M0,0 V16.6 H16.6 V0 H0 Z">
                <GeometryDrawing Brush="#FF686868" Geometry="F1 M16.6,16.6z M0,0z M16.6,16.6L0,16.6 0,0 16.6,0 16.6,16.6z M1,15.6L15.6,15.6 15.6,1 1,1 1,15.6z" />
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>
    <DrawingImage x:Key="img_checkDrawingImage">
        <DrawingImage.Drawing>
            <DrawingGroup ClipGeometry="M0,0 V16.6 H16.6 V0 H0 Z" >
                <GeometryDrawing  Brush="#FF686868"  Geometry="F1 M16.6,16.6z M0,0z M16.6,16.6L0,16.6 0,0 16.6,0 16.6,16.6z M1,15.6L15.6,15.6 15.6,1 1,1 1,15.6z M12.6,6.7L11.2,5.3 7.5,8.9 5.6,6.8 4.1,8.2 7.4,11.8 12.6,6.7z" />
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>


    <!--  Styles  -->

  
    
    
    <Style x:Key="stl_btnUpgradeNow" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="BorderBrush" Value="#000000"/>
        <Setter Property="BorderThickness" Value="0.8"/>

        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="VerticalContentAlignment" Value="Top"/>
        <!--<Setter Property="HorizontalContentAlignment" Value=""/>-->
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Margin" Value="15 0"/>

        <Setter Property="Background">
            <Setter.Value>
                <!--EndPoint="0.5,1" StartPoint="0.5,0"-->
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5, 1">
                    <GradientStop Color="#FFA341" Offset="0"/>
                    <GradientStop Color="#FF7602" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3"
                            >
                        <ContentControl Content="{TemplateBinding Content}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="{TemplateBinding FontWeight}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>

            <Trigger Property="IsMouseOver"
                     Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FFD580" Offset="0"/>
                            <GradientStop Color="#FF7602" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>



            </Trigger>


        </Style.Triggers>
    </Style>

    <Style x:Key="stl_btnScanForDuplicates" TargetType="Button">
        <Setter Property="BorderBrush" Value="#000000"/>
        <Setter Property="BorderThickness" Value="0.8"/>
        <Setter Property="Background" Value="#317AE6"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Margin" Value="0 0"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                        <ContentControl Content="{TemplateBinding Content}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="{TemplateBinding FontWeight}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource frgclr_gray}"/>
                        </Trigger>
                        
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>

            <Trigger Property="IsMouseOver"
                     Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#87CEFA" Offset="0"/>
                            <GradientStop Color="#317AE6" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
               
              

            </Trigger>

            
        </Style.Triggers>
    </Style>

    <Style x:Key="stl_btnClose" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True"/>

        <Setter Property="Height" Value="19"/>
        <Setter Property="Width" Value="28"/>

        <Setter Property="Background">
            <Setter.Value>
                <ImageBrush ImageSource="{DynamicResource img_close_normal}"/>
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Height="{TemplateBinding Height}" Width="{TemplateBinding Width}" Background="{TemplateBinding Background}">
                        <ContentControl Content="{TemplateBinding Content}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="{DynamicResource img_close_hover}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>

            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="stl_btnMaximize" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True"/>

        <Setter Property="Height" Value="19"/>
        <Setter Property="Width" Value="28"/>

        <Setter Property="Background">
            <Setter.Value>
                <ImageBrush ImageSource="{DynamicResource img_max_normal}"/>
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Height="{TemplateBinding Height}" Width="{TemplateBinding Width}" Background="{TemplateBinding Background}">
                        <ContentControl Content="{TemplateBinding Content}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="{DynamicResource img_max_hover}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>

            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="stl_btnMinimize" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True"/>

        <Setter Property="Height" Value="19"/>
        <Setter Property="Width" Value="28"/>

        <Setter Property="Background">
            <Setter.Value>
                <ImageBrush ImageSource="{DynamicResource img_min_normal}"/>
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Height="{TemplateBinding Height}" Width="{TemplateBinding Width}" Background="{TemplateBinding Background}">
                        <ContentControl Content="{TemplateBinding Content}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="{DynamicResource img_min_hover}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        
                    </ControlTemplate.Triggers>
                    
                </ControlTemplate>

            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="stl_btnHelpPopup" TargetType="Button">

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border>
                        <ContentControl Content="{TemplateBinding Content}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="stl_btnSettings" TargetType="{x:Type cust:ImageButton}">
        <Setter Property="Background"
                    Value="Transparent" />
        <Setter Property="Cursor"
                    Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Border x:Name="Border"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top">
                                <Image  
                                    Margin="0,0,0,0"
                                           Width="12"
                                    Height="12"
                                           x:Name="lnkImageSettings"
                                           SnapsToDevicePixels="False"
                                           Source="{TemplateBinding Image}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock  Padding="3,0,3,0"
                                            Margin="0,0,0,0"
                                            x:Name="lnkLblHelp"
                                           FontSize="13"
                                            VerticalAlignment="Top"
                                          Foreground="#ECECEC"
                                            Text="{TemplateBinding Content}"
                                            TextWrapping="WrapWithOverflow"/>
                              

                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="stl_btnfooter" TargetType="{x:Type cust:ImageButton}">

        <Setter Property="Background"
                    Value="Transparent" />
        <Setter Property="Cursor"
                    Value="Hand" />
        <Setter Property="BorderBrush"
                Value="#646464"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Border x:Name="Border"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                HorizontalAlignment="Center"
                               Padding="3 0 0 0"
                                Background="{TemplateBinding Background}"
                              BorderBrush="{TemplateBinding BorderBrush}"
                            VerticalAlignment="Center"
                                BorderThickness="0.8">
                        <Grid HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top">
                                <Image  
                                    Margin="0,5,0,0"
                                      Width="25"
                                    Height="25"
                                           x:Name="img_playbtn"
                                           SnapsToDevicePixels="False"
                                           Source="{TemplateBinding Image}"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock  Padding="5,0,3,0"
                                            Margin="0,5,0,0"
                                            x:Name="lnkwatchtutorial"
                                           FontSize="14"
                                            VerticalAlignment="Center"
                                          Foreground="White"
                                            Text="{TemplateBinding Content}"
                                            TextWrapping="WrapWithOverflow"/>


                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="stl_btnAction" TargetType="{x:Type cust:ImageButton}">

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Image x:Name="btnActionCenter"
                                Width="22"
                                Height="22"
                          Margin="0,5,0,0"
                          Source="{TemplateBinding Image}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"  
                           Stretch="Uniform"
                              />

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="stl_btnCart" TargetType="{x:Type cust:ImageButton}">

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Image x:Name="btnCart"
                                Width="15"
                                Height="15"
                          Margin="0,7,10,0"
                          Source="{TemplateBinding Image}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"  
                           Stretch="Uniform"
                              />

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="stl_btnLanguageArrow" TargetType="{x:Type cust:ImageButton}">

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">


                    <Image x:Name="btnlangarrow"
                                Width="8"
                                Height="5"
                          Margin="0,0,10,10"
                                        SnapsToDevicePixels="False"
                                           Source="{TemplateBinding Image}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality"                                     
                              />

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="stl_btnLanguage" TargetType="{x:Type cust:ImageButton}">

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                  
                        <Image x:Name="btnLanguage"
                                Width="15"
                                Height="15"
                          Margin="0,0,5,10"
                          Source="{TemplateBinding Image}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"  
                           Stretch="Uniform"
                              />
                        
                        
                   
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StyleMainBorderHelpButton"
           TargetType="{x:Type cust:ImageButton}">
        
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Cursor"
                    Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Border x:Name="Border"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top">
                                <!--<Image   Width="8"
                                          Height="5"
                                           x:Name="lnkImageHelp"
                                           SnapsToDevicePixels="False"
                                           Source="{TemplateBinding Image}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />-->
                                <TextBlock  Padding="5,0,3,0"
                                            x:Name="lnkLblHelp"
                                           FontSize="13"
                                            Margin="0,0,0,0"
                                            VerticalAlignment="Top"
                                          Foreground="#ECECEC"
                                            Text="{TemplateBinding Content}"
                                            TextWrapping="WrapWithOverflow"/>
                                <Image   Width="8"
                                          Height="5"
                                         Margin="0,0,0,0"
                                           x:Name="lnkddImage"
                                           SnapsToDevicePixels="False"
                                           Source="{TemplateBinding Image}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                               
                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

        <Style x:Key="StyleMainBorderButtons"
        TargetType="{x:Type cust:ImageButton}">
        <!--<Setter Property="Background"
                Value="Transparent"/>-->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Image x:Name="btn_close"
                                Width="28"
                                Height="26"
                          
                          Source="{TemplateBinding Image}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"  
                           Stretch="Uniform"
                              />


                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>

    <Style x:Key="StyleComboboxTextButton"
        TargetType="{x:Type cust:ImageButton}">
        <Setter Property="Background"
                    Value="White" />
        
        <Setter Property="Foreground" Value="{DynamicResource clr_darkborder}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Border x:Name="Border"
                                Width="200"
                                Height="28"
                          
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                        <Grid HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch">
                                <Image 
                                       Width="15"
                                       Height="15"
                                        Margin="10,0,0,0"
                                           x:Name="imgOption"
                                           SnapsToDevicePixels="False"
                                           Source="{TemplateBinding Image}"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock  Padding="5,0,0,0"
                                            x:Name="txtName"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                           
                                            Text="{TemplateBinding Content}"
                                            TextWrapping="WrapWithOverflow" />
                            </StackPanel>
                        </Grid>
                    </Border>
                 
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style x:Key="StyleImageTextButton"
               TargetType="{x:Type cust:ImageButton}">
        <Setter Property="Background"
                    Value="{DynamicResource bgrclr_whitish}" />
        <Setter Property="BorderBrush" Value="{DynamicResource clr_darkborder}" />
        <Setter Property="Foreground" Value="{DynamicResource clr_darkborder}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Border x:Name="Border"
                                Width="120"
                                Height="33"
                          
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0.5">
                        <Grid HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch">
                                <Image 
                                       Width="15"
                                       Height="15"
                                        Margin="5,0,0,0"
                                           x:Name="imgOption"
                                           SnapsToDevicePixels="False"
                                           Source="{TemplateBinding Image}"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock  Padding="5,0,0,0"
                                            x:Name="txtName"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            FontSize="13.5"
                                            FontWeight="Bold"
                                            Text="{TemplateBinding Content}"
                                            TextWrapping="WrapWithOverflow" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver"
                                     Value="true">
                            <Setter TargetName="Border"
                                        Property="BorderThickness"
                                        Value="0,0,0,0" />
                            <Setter TargetName="Border"
                                        Property="BorderBrush"
                                        Value="{DynamicResource ucPdfViewerOptionsHoverForeColor}" />
                            <Setter TargetName="txtName"
                                        Property="Foreground"
                                        Value="{DynamicResource ucPdfViewerOptionsHoverForeColor}" />
                            <Setter TargetName="imgOption"
                                        Property="Image.Source"
                                        Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=HoverImage}" />

                        </Trigger>
                        <Trigger Property="IsPressed"
                                     Value="true">
                            <Setter TargetName="Border"
                                        Property="BorderThickness"
                                        Value="0,0,0,0" />
                            <Setter TargetName="Border"
                                        Property="BorderBrush"
                                        Value="{DynamicResource ucPdfViewerOptionsHoverForeColor}" />
                            <Setter TargetName="txtName"
                                        Property="Foreground"
                                        Value="{DynamicResource ucPdfViewerOptionsHoverForeColor}" />
                            <Setter TargetName="imgOption"
                                        Property="Image.Source"
                                        Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=HoverImage}" />
                        </Trigger>
                        <Trigger Property="IsFocused"
                                     Value="true">
                            <Setter TargetName="Border"
                                        Property="BorderThickness"
                                        Value="0,0,0,0" />
                            <Setter TargetName="Border"
                                        Property="BorderBrush"
                                        Value="{DynamicResource ucPdfViewerOptionsHoverForeColor}" />
                            <Setter TargetName="txtName"
                                        Property="Foreground"
                                        Value="{DynamicResource ucPdfViewerOptionsHoverForeColor}" />
                            <Setter TargetName="imgOption"
                                        Property="Image.Source"
                                        Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=SelectedImage}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="stl_btnAddPhotos" TargetType="Button">

        <Setter Property="Background" Value="{DynamicResource bgrclr_whitish}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource clr_darkborder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Height" Value="33"/>
        <Setter Property="Width" Value="120"/>
        
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                        BorderThickness="{TemplateBinding BorderThickness}" Height="{TemplateBinding Height}"
                                        Width="{TemplateBinding Width}">
                        <ContentControl Content="{TemplateBinding Content}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource frgclr_white}">
                                
                            </Setter>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
                
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="stl_btnAddFolders" TargetType="Button">

        <Setter Property="Background" Value="{DynamicResource bgrclr_whitish}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource clr_darkborder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Height" Value="33"/>
        <Setter Property="Width" Value="120"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                        BorderThickness="{TemplateBinding BorderThickness}" Height="{TemplateBinding Height}"
                                        Width="{TemplateBinding Width}">
                        <ContentControl Content="{TemplateBinding Content}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource frgclr_white}">

                            </Setter>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>

            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="stl_MoveSettingsRadiobtn" TargetType="RadioButton">
        <Setter Property="Foreground" Value="#565656"/>
        
        <!--<Setter Property="Width" Value="244"/>
        <Setter Property="Height" Value="27"/>-->
        <Setter Property="IsChecked" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <RadioButton Foreground="{TemplateBinding Foreground}"
                                
                                 Padding="{TemplateBinding Padding}"
                                 IsChecked="{TemplateBinding IsChecked}">
                        <ContentControl Content="{TemplateBinding Content}"/>
                    </RadioButton>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="stl_btndeleteCurrentRow" TargetType="Button">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                        Height="{TemplateBinding Height}" Width="{TemplateBinding Width}"
                            Margin="{TemplateBinding Margin}" Padding="{TemplateBinding Padding}">
                        <ContentControl Content="{TemplateBinding Content}" HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers >
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <ImageBrush ImageSource="{DynamicResource img_deleteselectedfilefolder}" AlignmentX="Center"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>

            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="stl_btnEmptySelectedFileList" TargetType="Button">

        <Setter Property="Background" Value="{DynamicResource bgclr_soliddark}"/>

        <Setter Property="Height" Value="15"/>
        <Setter Property="Width" Value="15"/>
        <Setter Property="Padding" Value="0 0"/>
        <Setter Property="Margin" Value="0 0"/>
        <!--<Setter Property="BorderThickness" Value="0"/>-->

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                        Height="{TemplateBinding Height}" Width="{TemplateBinding Width}"
                            Margin="{TemplateBinding Margin}" Padding="{TemplateBinding Padding}">
                        <ContentControl Content="{TemplateBinding Content}" HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers >
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource bgclr_soliddark}">
                                
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>

            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="stl_btnRefresh" TargetType="cust:ImageButton">
        <Setter Property="Background" Value="#888888"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Width" Value="125"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Border x:Name="Border"
                                Width="125"
                                Height="32"
                              HorizontalAlignment="Left"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                        <Grid HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch">
                                <Image 
                                       Width="15"
                                       Height="15"
                                        Margin="10,0,0,0"
                                           x:Name="imgOption"
                                           SnapsToDevicePixels="False"
                                           Source="{TemplateBinding Image}"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock  Padding="5,0,0,0"
                                            x:Name="txtName"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                           
                                            Text="{TemplateBinding Content}"
                                            TextWrapping="WrapWithOverflow" />
                            </StackPanel>
                        </Grid>
                    </Border>
                            
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="stl_btnScanDeleteMarked" TargetType="Button">
        <Setter Property="BorderBrush" Value="#000000"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="#317AE6"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Margin" Value="0 0"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                        <ContentControl Content="{TemplateBinding Content}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="{TemplateBinding FontWeight}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

