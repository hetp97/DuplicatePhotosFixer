<Window x:Class="DuplicatePhotosFixer.Views.frmProcessing"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        mc:Ignorable="d"
        Title="frmProcessing" Height="327" Width="630" WindowStyle="None" Background="{DynamicResource bgrclr_solidgray}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="54"/>
        </Grid.RowDefinitions>
        <Border BorderBrush="#404040" BorderThickness="0 0 0 1">
            <DockPanel>
                <Image x:Name="dpf_logo" Source="/Resources/dpf_updateofr_icon.png" DockPanel.Dock="Left" Margin="10 0" Stretch="None" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right"  Margin="0,0,10,0" Background="Transparent" BorderBrush="Transparent" Click="Button_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="TextBlock.TextAlignment" Value="Center" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bdr_main">
                                            <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"                                                              
                                                              TextElement.FontSize="13"
                                                              TextElement.Foreground="White">
                                            </ContentPresenter>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" TargetName="bdr_main" Value="#3FB3E6">
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="true">
                                                <Setter Property="Background" TargetName="bdr_main" Value="#178BBE">
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                                <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>

                    <Image Source="{DynamicResource img_close_plain}" Stretch="None"/>
                </Button>
                <Label DockPanel.Dock="Left" x:Name="lbl_heading" FontSize="15" VerticalAlignment="Center" Content="Duplicate Photo Fixer Pro" Margin="2, 0, 2, 0" Foreground="#f9f9f9" />
            </DockPanel>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Source="{DynamicResource img_circle}" Height="100" Width="105" Margin="27, 35, 3, 3" VerticalAlignment="Top"/>
            <Grid Grid.Column="1">
                <StackPanel Margin="0 25 0 0">
                    <TextBlock x:Name="search_heading" FontWeight="Bold" FontSize="22" Foreground="#fff" 
                               Text="Searching for Duplicates..."/>
                    <TextBlock x:Name="infotxt" FontSize="14" FontWeight="Regular" Foreground="#B0B0B0"
                               Text="Please be pateint while we scan your duplicates..."/>
                    <DockPanel Margin="0 20 0 0">
                        <Image x:Name="img1" Source="{DynamicResource img_remaining_photos}" Width="50" Height="40" Margin="0 0 20 0"/>
                        <StackPanel>
                            <TextBlock x:Name="no_of_duplicates" FontSize="18"  VerticalAlignment="Center" Foreground="#fff" FontWeight="Bold">
                            {0}
                            </TextBlock>
                            <TextBlock x:Name="lbl1" Text="Remaining Photos" Foreground="#DcDCDc" FontWeight="Regular" FontSize="14"/>
                        </StackPanel>
                    </DockPanel>
                    <DockPanel Margin="0 15 0 0 ">
                        <Image x:Name="img2" Source="{DynamicResource img_disk_space}" Width="50" Height="40" Margin="0 0 20 0"/>
                        <StackPanel>
                            <TextBlock x:Name="storage_txt" FontSize="18"  VerticalAlignment="Center" Foreground="#fff" FontWeight="Bold">
                            {0} GB
                            </TextBlock>
                            <TextBlock x:Name="lbl2" Text="Disk space to free up" Foreground="#DcDCDc" FontWeight="Regular" FontSize="14"/>
                        </StackPanel>
                    </DockPanel>



                </StackPanel>
            </Grid>
        </Grid>
        <Grid Grid.Row="2" Margin="15 0 10 0">
            <DockPanel >
                <DockPanel>
                    <TextBlock x:Name="scan_path_lbl" Foreground="#fff" FontSize="14" FontWeight="Regular"
                               Text="Scan Path: "/>
                    <TextBlock x:Name="scan_path" TextWrapping="Wrap" Foreground="#B0B0B0"
                               FontSize="14px" Text="C:\Users\admin\Pictures\"/>
                </DockPanel>
                <Button x:Name="stop_btn" Foreground="#8C8C8C" FontSize="14" FontWeight="Regular" Background="Transparent" Width="108" Height="32" 
                        VerticalAlignment="Top" Margin="0 10 10 0" HorizontalAlignment="Right"
                        BorderBrush="#989898" >
                    Stop
                </Button>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
