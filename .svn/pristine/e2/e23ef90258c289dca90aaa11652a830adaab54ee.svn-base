        public void showExactDuplicates()
        {
            try
            {
                var groupsOfFilesWithSize = cGlobalSettings.listImageFileInfo.GroupBy(s => s.Value.fileSize).Where(s => s.Count() > 1);

                if (groupsOfFilesWithSize.Count() > 0)
                {
                    int GroupCounter = 0;

                    List<GroupUserControl> listGroupUserControl = new List<GroupUserControl>();
                    for (int i = 0; i < groupsOfFilesWithSize.Count(); i++)
                    {
                        OnScanProgress("Comparing for duplicates", (int)((((double)i + 1) / groupsOfFilesWithSize.Count()) * 100), i);

                        var groupsOfFilesWithSameHash = groupsOfFilesWithSize.ElementAt(i).GroupBy(f => AppFunctions.calcMD5(f.Value.filePath)).Where(g => g.Count() > 1);
                        if (groupsOfFilesWithSameHash.Count() > 0)
                        {
                            for (int HashGroupIndex = 0; HashGroupIndex < groupsOfFilesWithSameHash.Count(); HashGroupIndex++)
                            {
                                GroupCounter += 1;

                                List<ImageCheckBox> listImageCheckBox = new List<ImageCheckBox>();
                                // Grouping duplicate photos and assign group number.
                                foreach (KeyValuePair<int, csImageFileInfo> gp in groupsOfFilesWithSameHash.ElementAt(HashGroupIndex))
                                {
                                    var gpVal = gp.Value;
//                                     gpVal.groupNumber = GroupCounter;
//                                     ModifyImageFileInfoList.updateListImageFileInfo(gp.Key, gpVal);

                                    ImageCheckBox objImageCheckBox = new ImageCheckBox(gpVal.filePath);

                                    objImageCheckBox.Tag = gp.Key;
                                    listImageCheckBox.Add(objImageCheckBox);

                                    objImageCheckBox = null;
                                }

                                GroupUserControl objGroupUserControl = new GroupUserControl("Group " + GroupCounter, groupsOfFilesWithSameHash.ElementAt(HashGroupIndex).Count(), listImageCheckBox);
                                objGroupUserControl.Anchor = (AnchorStyles.Top | AnchorStyles.Left | AnchorStyles.Right);

                                //objGroupUserControl.Dock = DockStyle.Fill;

                                listGroupUserControl.Add(objGroupUserControl);
                                objGroupUserControl = null;
                                listImageCheckBox.Clear();
                                listImageCheckBox = null;
                            }
                        }
                        groupsOfFilesWithSameHash = null;
                    }

                    Program.oMainReference.ucResult_showCurrentDuplicateCount(true);
                    if (GroupCounter <= 0)
                    {
                        // Show No Duplicate photos found message.
                        /*OnNoDuplicateFound(cResourceManager.LoadString("DPF_cGlobalSettings_HEADINGS_NO_DUPLICATE"), cResourceManager.LoadString("DPF_cGlobalSettings_HINT_NO_DUPLICATE"));*/
                        Program.oMainReference.footer_showScanDuplicateButton((int)enumClass.eBtnVisableStatus.Active, true, true);
                    }
                    else
                    {
                        if (listGroupUserControl.Count > 0)
                            onGroupCreated(listGroupUserControl);
                        //listGroupUserControl.Clear();
                        listGroupUserControl = null;
                        Program.oMainReference.footer_showScanDuplicateButton((int)enumClass.eBtnVisableStatus.Active, false, false);
                    }
                    groupsOfFilesWithSize = null;
                }
                else
                {
                    // Show No Duplicate photos found message.
                    /*OnNoDuplicateFound(cResourceManager.LoadString("DPF_cGlobalSettings_HEADINGS_NO_DUPLICATE"), cResourceManager.LoadString("DPF_cGlobalSettings_HINT_NO_DUPLICATE"));*/
                    Program.oMainReference.footer_showScanDuplicateButton((int)enumClass.eBtnVisableStatus.Active, true, true);
                }

                OnScanCompleted("Scanning complete", 100);

            }
            catch
            {

            }
            finally
            {

            }
            
        }
#endif
