                // Update folderIndex 
                cGlobalSettings.oManualReset.WaitOne();
                if (cGlobalSettings.abortNow)
                {
                    cGlobalSettings.oLogger.WriteLogVerbose("\tScanning aborted");
                    return;
                }

                imgProcessor = new ImageProcessor();
                imgProcessor.OnScanProgress += new ImageProcessor.OnScanProgressProcess(imgProcessor_OnScanProgress);


                ///// Check if RAW image formats are there in SCAN list.
                // Download component to process RAW images.

                if (isRawFormatFound)
                {
                    string dwnLink = cGetString.GetMagickDwnUrl();
                    string fullDownloadedPath = Path.Combine(Application.StartupPath, cGlobal.GetFileNameFromUrl(dwnLink));

                    if (!File.Exists(fullDownloadedPath))
                    {
                        /// No confirmation box is shown now, 
                        /// consider as true and proceed.
                        /// 
                        OnScanProgress(cClientEnum.eScanPhase.ComponentDownload, cResourceManager.LoadString("IDS_INSTALL_COMPONENT"), 10, "", cResourceManager.LoadString("IDS_CONFIRM_DOWNLOAD_COMPONENT"), true, false);
                        cGlobal.frmNagReturnCode = FORM_RETURN_CODES.YES_PROCEED;

                        //if (cGlobal.frmNagReturnCode == FORM_RETURN_CODES.YES_PROCEED)
                        //{
                        //    cGlobalSettings.b_COMPONENT_INSTALL_STARTED = true;
                        //    OnScanProgress(cClientEnum.eScanPhase.ComponentDownload, cResourceManager.LoadString("IDS_INSTALL_COMPONENT"), 10, "", cResourceManager.LoadString("IDS_CONFIRM_DOWNLOAD_COMPONENT"), true);
                        //    cClientEnum.eDownloadStatus status = imgProcessor.DownloadComponents();
                        //    switch (status)
                        //    {
                        //        case cClientEnum.eDownloadStatus.DownloadSucessFull:
                        //            break;
                        //        case cClientEnum.eDownloadStatus.AccessDenied:
                        //            /// User Denied to download component.
                        //            break;
                        //        case cClientEnum.eDownloadStatus.NoInternetConnection:
                        //            Program.oMainReference.showMessage(cResourceManager.LoadString("IDS_ERROR_CONNECTING_INTERNET"), "");
                        //            break;
                        //        case cClientEnum.eDownloadStatus.DownloadError:
                        //        default:
                        //            Program.oMainReference.showMessage(cResourceManager.LoadString("IDS_FREETRIALKEYSTATUS_PRODUCTID_INVALID"), "");
                        //            break;
                        //    }
                        //    cGlobalSettings.b_COMPONENT_INSTALL_STARTED = false;
                        //}
                    }
                }

                float matchingLevel = 0.99f;

                uint MaxImageTimeTakenDifference = vmHomeComparisonMethod.GetTimeIntervalEx((enumClass.eTimeInterval)cGlobalSettings.DefaultTimeInterval);
                uint userSelectedGpsValue = vmHomeComparisonMethod.GetGPSEx((enumClass.eGPS)cGlobalSettings.DefaultGpsValue);

                ////===================== Searching simillar photos  =====================
                //cGlobalSettings.oLogger.WriteLogVerbose("\tStart : Searching similar photos");                                        
                try
                {
#if false
                        try
                        {
                            bool flag;
                            if (Boolean.TryParse(System.Configuration.ConfigurationManager.AppSettings["createThumbnails"], out flag))
                                cGlobalSettings.bCreateThumbnail = flag;
                        }
                        catch (Exception)
                        {
                            ;
                        }
#endif


#if true

                    if (cGlobalSettings.MatchSettingsData.MatchMethod == enumClass.eMatchMethod.Similar)
                    {
                        if (Program.IsCommandLine)
                            matchingLevel = vmHomeComparisonMethod.GetMatchingLevelEx((enumClass.eMatchingLevel)Program.MatchingLevel);
                        else
                            matchingLevel = vmHomeComparisonMethod.GetMatchingLevel();

                        // Get filter params
                        MaxImageTimeTakenDifference = vmHomeComparisonMethod.GetTimeInterval();
                        userSelectedGpsValue = vmHomeComparisonMethod.GetGPS();
                    }
                    else
                    {
                       // imgProcessor.compareForExactPhotos();
                    }

                    /// start getting hash for all the files
                    /// ==== calculating all hashes
                  //  imgProcessor.ReadAllHashes();

                    watchProcessDuration.Stop();
                    cGlobalSettings.oLogger.WriteLogVerbose("\tTotal Photos:\t{0}, \tDuration-Current:\t{1}, \tDuration-Overall:\t{2}, \tCompleted:\tReadAllHashes",
                        FileInfoList.Count, watchProcessDuration.GetTimeSpanWithDays(), watchOverAllDuration.GetTimeSpanWithDays());
                    watchProcessDuration.Reset();
                    watchProcessDuration.Start();

                    cGlobalSettings.oManualReset.WaitOne();
                    if (cGlobalSettings.abortNow)
                    {
                        cGlobalSettings.oLogger.WriteLogVerbose("\tScanning aborted");
                        return;
                    }
                    /// start comparing
                    /// 
                    //cGlobalSettings.oLogger.WriteLogVerbose("\tStart : Comparing similar photos");

                  //  imgProcessor.compareForSimilarPhotos(MaxImageTimeTakenDifference, userSelectedGpsValue);

                    /// Make group of files have same hash, 
                    /// Case when not able to get thumbnails of image then for those images grouping is done on basis of file hash.
                    //if (cGlobalSettings.CurrentScanMode == eScanMode.GoogleDrive ||
                    //    cGlobalSettings.CurrentScanMode == eScanMode.Dropbox || cGlobalSettings.CurrentScanMode == eScanMode.BoxCloud || cGlobalSettings.CurrentScanMode == eScanMode.AmazonS3)
                    //{
                    //    imgProcessor.compareForExactPhotos_Cloud();
                    //}

                    watchProcessDuration.Stop();
                    cGlobalSettings.oLogger.WriteLogVerbose("\tTotal Photos:\t{0}, \tDuration-Current:\t{1}, \tDuration-Overall:\t{2}, \tCompleted:\tcompareForSimilarPhotos",
                        FileInfoList.Count, watchProcessDuration.GetTimeSpanWithDays(), watchOverAllDuration.GetTimeSpanWithDays());
                    watchProcessDuration.Reset();
                    watchProcessDuration.Start();

#else /// For Google Drive when check on bases of CheckSum 


                    switch (cGlobalSettings.CurrentScanMode)
                    {
                        case eScanMode.FileSearch:
                            {
                                if (cGlobalSettings.isSimilarMatchChecked)
                                {
                                    if (Program.IsCommandLine)
                                        matchingLevel = cGlobalSettings.GetMatchingLevelEx((enumClass.eMatchingLevel)Program.MatchingLevel);
                                    else
                                        matchingLevel = cGlobalSettings.GetMatchingLevel();

                                    // Get filter params
                                    MaxImageTimeTakenDifference = cGlobalSettings.GetTimeInterval();
                                    userSelectedGpsValue = cGlobalSettings.GetGPS();
                                }
                                else
                                {
                                    // Find keys for which hash has to be calculated
                                    imgProcessor.compareForExactPhotos();
                                }

                                /// start getting hash for all the files
                                /// ==== calculating all hashes
                                imgProcessor.ReadAllHashes();

                                watchProcessDuration.Stop();
                                cGlobalSettings.oLogger.WriteLogVerbose("\tTotal Photos:\t{0}, \tDuration-Current:\t{1}, \tDuration-Overall:\t{2}, \tCompleted:\tReadAllHashes",
                                    FileInfoList.Count, watchProcessDuration.GetTimeSpanWithDays(), watchOverAllDuration.GetTimeSpanWithDays());
                                watchProcessDuration.Reset();
                                watchProcessDuration.Start();

                                cGlobalSettings.oManualReset.WaitOne();
                                if (cGlobalSettings.abortNow)
                                {
                                    cGlobalSettings.oLogger.WriteLogVerbose("\tScanning aborted");
                                    return;
                                }
                                /// start comparing
                                /// 
                                //cGlobalSettings.oLogger.WriteLogVerbose("\tStart : Comparing similar photos");

                                imgProcessor.compareForSimilarPhotos(MaxImageTimeTakenDifference, userSelectedGpsValue);

                                watchProcessDuration.Stop();
                                cGlobalSettings.oLogger.WriteLogVerbose("\tTotal Photos:\t{0}, \tDuration-Current:\t{1}, \tDuration-Overall:\t{2}, \tCompleted:\tcompareForSimilarPhotos",
                                    FileInfoList.Count, watchProcessDuration.GetTimeSpanWithDays(), watchOverAllDuration.GetTimeSpanWithDays());
                                watchProcessDuration.Reset();
                                watchProcessDuration.Start();
                            }
                            break;
                        case eScanMode.GoogleDrive:
                            {
                                imgProcessor.compareForExactPhotos_Cloud();
                            }
                            break;
                        case eScanMode.Dropbox:
                            break;
                        case eScanMode.DeleteEmptyFolder:
                            break;
                    }
#endif
                }
                catch (Exception ex)
                {
                    cGlobalSettings.oLogger.WriteLogException("ScanThread() compareForSimilarPhotos:: ", ex);
                }
                finally
                {
                    imgProcessor.OnScanProgress -= new ImageProcessor.OnScanProgressProcess(imgProcessor_OnScanProgress);
                }

                var res = cGlobalSettings.arrAllFilesGrouping.Select(x => x.childrenKey).Where(x => x.Count > 1);
                int totalGroups = res.Count();
                int overAllDuplicatesCount = 0;
                Int64 overAllDuplicatesSize = 0;

                if (totalGroups > 0) // There are duplicate images, show delete button
                {
                    overAllDuplicatesCount = res.Sum(x => x.Count);
                    overAllDuplicatesSize = res.Sum(p => p.Sum(pp => cGlobalSettings.listImageFileInfo[pp].fileSize));

                    //overAllDuplicatesCount = cGlobalSettings.arrAllFilesGrouping.Where(x => x.childrenKey.Count > 1).Sum(x => x.childrenKey.Count);
                    //cGlobalSettings.oLogger.WriteLogVerbose("\tCounts :: Minimum matching level = " + 0.85);
                    //cGlobalSettings.oLogger.WriteLogVerbose("\tTotal Images processed :" + cGlobalSettings.listImageFileInfo.Count);
                    //cGlobalSettings.oLogger.WriteLogVerbose("\tTotal Duplicate Groups :" + totalGroups);
                    //cGlobalSettings.oLogger.WriteLogVerbose("\tTotal Duplicate Photos :" + cGlobalSettings.arrAllFilesGrouping.Where(x => x.childrenKey.Count > 1).Sum(x => x.childrenKey.Count));                    
                    cGlobalSettings.oLogger.WriteLogVerbose("\tTotalImages:\t{0}, \tDuplicates:\t{1}, \tGroups:\t{2}, \tMatchingLevel:\t{3}",
                        cGlobalSettings.listImageFileInfo.Count, overAllDuplicatesCount, totalGroups, 0.85);

                    onGroupCreated(matchingLevel);
                    bMoveToResultsTab = true;
                    //Program.oMainReference.footer_showScanDuplicateButton((int)enumClass.eBtnVisableStatus.Disable, false, false);

                    /*
#if SQLITE_NEEDED

                                        cGlobalSettings.sqliteLogger.InsertImageFileLog(res.SelectMany(p => p));

#endif*/

                }
                else // There is no duplicate images, show scan for duplicate button
                {
                    if (cGlobalSettings.MatchSettingsData.MatchMethod == enumClass.eMatchMethod.Similar)
                    {
                        scanCompleteMessage1 = cResourceManager.LoadString("DPF_SCAN_PHOTOS_NO_SIMILAR_PHOTOS_FOUND");
                        scanCompleteMessage2 = cResourceManager.LoadString("DPF_SCAN_PHOTOS_HINT_SIMILAR_PHOTOS");
                    }
                    else
                    {
                        scanCompleteMessage1 = cResourceManager.LoadString("DPF_SCAN_PHOTOS_NO_DUPLICATE_PHOTOS_FOUND");
                        // scanCompleteMessage2 = cResourceManager.LoadString("DPF_SCAN_PHOTOS_HINT_DUPLICATE_PHOTOS");                        
                        scanCompleteMessage2 = string.Empty;
                    }
                    // Program.oMainReference.showSettingsTab();

                    bMoveToResultsTab = false;
                }

                cGlobalSettings.OverAllDuplicatePhotos = overAllDuplicatesCount;
                cGlobalSettings.OverAllDuplicatePhotosSize = overAllDuplicatesSize;
                cGlobalSettings.oRegSettings.SetTotalDuplicatesFound(cGlobalSettings.OverAllDuplicatePhotos);
                cGlobalSettings.oRegSettings.SetTotalDuplicatesFoundStr(cGlobalSettings.OverAllDuplicatePhotos); //VG300320
                cGlobalSettings.oRegSettings.SetTotalDuplicatesSpace(cGlobalSettings.OverAllDuplicatePhotosSize);

                // Calculate all count
               // Program.oMainReference.oResult.showCurrentDuplicateCount(true);  ////have to add result user control;;;; will modify then add
                // Send scan result for tracking 
               // cGlobalSettings.oProductTracker.SendStats(cClientEnum.requesttype.SCAN); ////have to add class
                cGlobalSettings.oRegSettings.SetLastScanDate(DateTime.Now);


            }
            catch (System.Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("ScanThread", ex);
            }
            finally
            {
                try
                {
                    OnScanCompleted(scanCompleteMessage1, scanCompleteMessage2, bMoveToResultsTab, 100);

                    imgProcessor = null;

                    watchOverAllDuration.Stop();
                    cGlobalSettings.oLogger.WriteLogVerbose("\tTotal Photos:\t{0}, \tDuration-Current:\t{1}, \tDuration-Overall:\t{2}, \tCompleted:\tScanning",
                    FileInfoList.Count, watchProcessDuration.GetTimeSpanWithDays(), watchOverAllDuration.GetTimeSpanWithDays(), false, true);


                    if (FileInfoList != null) FileInfoList.Clear(); FileInfoList = null;
                }
                catch (System.Exception ex)
                {
                    cGlobalSettings.oLogger.WriteLogException("ScanThread-finally", ex);
                }
            }
        }




        void imgProcessor_OnScanProgress(cClientEnum.eScanPhase scanPhaseType, string message, int percentageCompleted, string counter, string subMessage)
        {
            OnScanProgress(scanPhaseType, message, percentageCompleted, counter, subMessage);
        }




