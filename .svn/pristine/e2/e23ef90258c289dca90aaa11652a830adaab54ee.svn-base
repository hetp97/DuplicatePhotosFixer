        public delegate void InitilizeControlProcess();
        public event InitilizeControlProcess InitilizeControl;

        public delegate void OnItemCreatedProcess(int key, int groupCounter);
        public event OnItemCreatedProcess OnItemCreated;

        public delegate void OnItemAddedProcess();
        public event OnItemAddedProcess OnItemAdded;

        public delegate bool isImageListViewHaveItemsProcess();
        public event isImageListViewHaveItemsProcess isImageListViewHaveItems;

        public void showDuplicates(float matchingLevel)
        {
            new Thread(() =>
            {
                try
                {
                    //ScanLock.EnterWriteLock();

                    ShowResultThread(matchingLevel);
                }
                finally
                {
                    //if (ScanLock.IsWriteLockHeld) ScanLock.ExitWriteLock();
                }

            })
            { Name = "ShowResultThread" }.Start();
        }

        void ShowResultThread(float matchingLevel)
        {
            Dictionary<int, int> ItemsToAdded = null;
            Stopwatch watch = null;
            try
            {
                watch = new Stopwatch();
                cGlobalSettings.oLogger.WriteLogVerbose("\tStart : Loading result ");
                watch.Start();
                /* Initialize a control :
                 * visible
                 * clear old items
                 * remove message if any
                 */

                cGlobalSettings.isImageListViewLoaded = false;
                cGlobalSettings.TotalDuplicatePhotosSize = 0;

                int groupCounter = 0;
                var res = cGlobalSettings.arrAllFilesGrouping.Select(x => x.childrenKey).Where(x => x.Count > 1);

                if (cGlobalSettings.currentItemsList != null)
                    cGlobalSettings.currentItemsList.Clear();
                else
                    cGlobalSettings.currentItemsList = new List<int>();


                // Add items to imageListView control, for selected matching level.

                /*Create a list of items with their key and groupNumber
                 Use it to add after items to ImageListView.
                 */
                ItemsToAdded = new Dictionary<int, int>();
                string nsjh = "";
                foreach (var keyGroups in res)
                {
                    int itemsAddedInGroup = 0;

                    int LastKey = -1;
                    foreach (int key in keyGroups)
                    {
                        if (cGlobalSettings.listImageFileInfo[key].match >= matchingLevel)
                        {
                            if (itemsAddedInGroup == 0)
                                groupCounter++;

                            //---------- Added ---------------
                            LastKey = key;
                            cGlobalSettings.currentItemsList.Add(key);
                            //ItemsToAdded.Add(key, groupCounter);

                            ItemsToAdded.Add(key, groupCounter); // Add item to dictionary

                            //isFirst = false;
                            itemsAddedInGroup++;
                        }
                    }

                    // Check is there a single item for a group, if true then remove item and decrease the group counter.
                    if (itemsAddedInGroup == 1)
                    {
                        if (LastKey > -1)
                            ItemsToAdded.Remove(LastKey);
                        //OnItemRemoved(groupCounter); // Remove a item of a group

                        groupCounter--;
                    }
                }


                // ----------------- Now add items to list -----------------
                bool isChanged = isResultChanged();
                if (isChanged)
                {
                    // Initialize the control
                    InitilizeControl();

                    // Reset all group number to 0
                    cGlobalSettings.listImageFileInfo.ToDictionary(x => x.Key, x => x.Value).All(p =>
                    {
                        p.Value.groupNumber = 0;
                        return true;
                    });


                    // Create items
                    foreach (var groupItem in ItemsToAdded)
                    {
#if false
                        cGlobalSettings.oLogger1.WriteLog("Group" + groupItem.Value + "\t|\tFile:" + cGlobalSettings.listImageFileInfo[groupItem.Key].filePath);
#endif
                        OnItemCreated(groupItem.Key, groupItem.Value);
                    }

                    // Add created items to Result panel
                    OnItemAdded();

                    // Update Mark status in DB also

#if SQLITE_NEEDED

                    cGlobalSettings.sqliteLogger.InsertImageFileLog(res.SelectMany(p => p));

#endif


                    if (cGlobalSettings.previousItemsList != null) cGlobalSettings.previousItemsList.Clear();
                    cGlobalSettings.previousItemsList = null;
                    cGlobalSettings.previousItemsList = new List<int>();
                    cGlobalSettings.previousItemsList.AddRange(cGlobalSettings.currentItemsList.ToList<int>());

                    // After add items, show duplicate count values.
               //     Program.oMainReference.ucResult_showCurrentDuplicateCount(true); ////have to add Result uc
                }
                else
                {
                    cGlobalSettings.oLogger.WriteLogVerbose("\tNo change in result for matching level = " + matchingLevel);
                }

                cGlobalSettings.oLogger.WriteLogVerbose("\tDuplicates:\t{0}, \tGroups:\t{1}, \tMarkPhotos:\t{2}, \tMarkPhotosSize:{3}, \tMatchingLevel:\t{4}",
                    cGlobalSettings.TotalDuplicatePhotos, cGlobalSettings.TotalDuplicateGroups, cGlobalSettings.TotalDuplicateMarkPhotos, cGlobalSettings.TotalDuplicateMarkPhotosSize, matchingLevel);


                if (res.Count() > 0) // There are duplicate images, show delete button
                {
                    if (cGlobalSettings.TotalDuplicateMarkPhotos > 0)
                    {
                        Program.oMainReference.footer_showScanDuplicateButton((int)enumClass.eBtnVisableStatus.Active, false, false);

                    }
                    else
                        Program.oMainReference.footer_showScanDuplicateButton((int)enumClass.eBtnVisableStatus.Disable, false, false);

                    //if (oImageListView != null)
                    res = null;

                    //#if !SHOW_TUTE1
                    if (cGlobalSettings.TotalDuplicatePhotos > 0 /*&& (cGlobal.setupType == eSetupType.ADD_All) || cGlobal.setupType == eSetupType.REGULAR*/)
                        new Thread(() =>
                        {
                            try
                            {
                                //Program.oMainReference.UIThread(() =>
                                //Program.oMainReference.ShowNagDupsList());
                                if (true)
                                {
                                    Thread.Sleep(500);
                                    if (cGlobalSettings.bShowAfterScanMarkWindow)
                                    {
                                        Program.oMainReference.UIThread(() =>
                                        {
                                            Program.oMainReference.ShowFormAfterScanMark();
                                        });
                                        cGlobalSettings.bShowAfterScanMarkWindow = false;
                                    }
                                }
                                //else if (RegistryTool.isResultLoadFirstTime && cGlobalSettings.oScanSettings.LanguageCode.ToLower() == "en")
                                //{
                                //    Thread.Sleep(1000);

                                //    Program.oMainReference.UIThread(() =>
                                //    {
                                //        Program.oMainReference.ShowFormGuide(ePointControl.AutoMark);
                                //        //Program.oMainReference.ShowTutorial(true);
                                //        RegistryTool.isResultLoadFirstTime = false;
                                //    });
                                //}
                            }
                            catch (Exception ex)
                            {
                                cGlobalSettings.oLogger.WriteLogException("", ex);
                            }
                        }).Start();

                    //#endif

                    if (!isImageListViewHaveItems())
                    {
                        Program.oMainReference.ucResult_showDuplicateStatusMessage();
                    }
                }
                else // There is no duplicate images, show scan for duplicate button
                {
                    if (cGlobalSettings.MatchSettingsData.MatchMethod == enumClass.eMatchMethod.Similar)
                        Program.oMainReference.showMessage(cResourceManager.LoadString("DPF_SCAN_PHOTOS_NO_SIMILAR_PHOTOS_FOUND"), cResourceManager.LoadString("DPF_SCAN_PHOTOS_HINT_SIMILAR_PHOTOS"));
                    else
                        Program.oMainReference.showMessage(cResourceManager.LoadString("DPF_SCAN_PHOTOS_NO_DUPLICATE_PHOTOS_FOUND"), cResourceManager.LoadString("DPF_SCAN_PHOTOS_HINT_DUPLICATE_PHOTOS"));

                    Program.oMainReference.footer_showScanDuplicateButton((int)enumClass.eBtnVisableStatus.Active, true, true);
                  //  Program.oMainReference.showSettingsTab(); //will add fn according to WPF
                }
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("showResult ::", ex);
            }
            finally
            {
                cGlobalSettings.isImageListViewLoaded = true;
                if (ItemsToAdded == null) ItemsToAdded.Clear(); ItemsToAdded = null;

                watch.Stop();
                cGlobalSettings.oLogger.WriteLogVerbose("\tTotal duration loading result seconds :" + watch.Elapsed.Seconds);
                cGlobalSettings.oLogger.WriteLogVerbose("\tComplete : Loading Result", false, true);

                watch = null;
            }
        }


        public bool isResultChanged()
        {
            bool isChange = true;
            if (cGlobalSettings.previousItemsList == null)
            {
                cGlobalSettings.previousItemsList = new List<int>();
                isChange = true;
            }
            else
            {
                if (cGlobalSettings.previousItemsList.SequenceEqual(cGlobalSettings.currentItemsList))
                    isChange = false;
            }


            return isChange;
        }

        int progressCounter = 0;
        //static string ext = @"(.icns|.eps|.flc|.fli|.cel|.fpx|.gif|.GIF|.jp2|.jpf|.jpx|.j2k|.j2c|.jpeg|.jpg|.jpe|.pntg|.mpo|.exr|.png|.pict|.pct|.pic|.qtif|.qti|.pic|.PIC|.hd|.HDR|.sgi|.tga|.tiff|.tif|.bmp|.ico)";
        public void DirSearch(string sDir, ref List<FileInfo> imgPath, bool bScanSubFolders)
        {
            DirectoryInfo di = null;
            try
            {
                cGlobalSettings.oManualReset.WaitOne();
                if (cGlobalSettings.abortNow)
                    return;
                di = new DirectoryInfo(sDir);

                //if (App.oMainReference.ExcludedFolderList.Contains(di.FullName))
                //    return;  ///have to add excludeFolderList

                if (di.Parent != null)
                    if ((di.Attributes & FileAttributes.Hidden) == FileAttributes.Hidden)
                        return;

                //if (AppFunctions.isDefaultExcludePath(di.FullName, true))
                //    return;  ///have to add excludeFolderList


                //if (!Program.oMainReference.ExcludedFolderList.Contains(di.FullName))


                if (ignoreRules.IsDirectoryIgnored(di.FullName))
                    return;

                foreach (FileInfo info in di.GetFiles())
                {
                    try
                    {
                        cGlobalSettings.oManualReset.WaitOne();
                        if (cGlobalSettings.abortNow)
                            return;

                        if (info.Length < cGlobalSettings.MinFileSize)
                            continue;

                        if (Regex.IsMatch(info.Extension, @"^.*\." + cGlobalSettings.ImageFileExtensionsList.Replace(".", "") + "$", RegexOptions.IgnoreCase | RegexOptions.IgnorePatternWhitespace) && info.Extension != "")
                        {
                            progressCounter++;
                            if ((progressCounter % 100) == 0)
                            {
                                OnScanProgress(cClientEnum.eScanPhase.Search, cResourceManager.LoadString("DPF_SCAN_PHOTOS_ADDING_PHOTOS"), 10, imgPath.Count + "" /*> 0 ? string.Format(cResourceManager.LoadString("DPF_SCAN_PHOTOS_PHOTOS_ADDED"), imgPath.Count) : ""*/, di.FullName, true);
                            }
                            imgPath.Add(info);

                        }
                    }
                    catch (System.Exception ex)
                    {
                        cGlobalSettings.oLogger.WriteLogException("DirSearch-di.GetFiles", ex);
                    }
                }


                progressCounter++;
                if ((progressCounter % 25) == 0)
                {
                    OnScanProgress(cClientEnum.eScanPhase.Search, cResourceManager.LoadString("DPF_SCAN_PHOTOS_ADDING_PHOTOS"), 10, imgPath.Count + "" /*> 0 ? string.Format(cResourceManager.LoadString("DPF_SCAN_PHOTOS_PHOTOS_ADDED"), imgPath.Count) : ""*/, di.FullName, true);
                }

                if (!bScanSubFolders)
                    return;

                foreach (string d in Directory.GetDirectories(sDir))
                {
                    cGlobalSettings.oManualReset.WaitOne();
                    if (cGlobalSettings.abortNow)
                        return;

                    try
                    {
                        DirSearch(d, ref imgPath, bScanSubFolders);
                    }
                    catch
                    {

                    }
                }
            }
            catch (System.UnauthorizedAccessException ex)
            {
                cGlobalSettings.oLogger.WriteLogException("DirSearch :: Dir:" + sDir, ex); ;
            }
            catch (System.Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("DirSearch :: Dir:" + sDir, ex);
                //Console.WriteLine(excpt.Message);
            }
            finally
            {
                if (di != null)
                {
                    di = null;
                }
            }
        }

