    public class ScanPhotos
    {

        /*
         Three events are created
         * Scan started,
         * Scan in progress,
         * Scan completed
         */

        IgnoreRules ignoreRules = null;

        string lastFolderPath = string.Empty;
        int FolderIndex = 0;

        public ScanPhotos()
        {
            if (ignoreRules == null)
                ignoreRules = new IgnoreRules();
            ignoreRules.GenerateRegEx();


            //if (cGlobalSettings.oProductTracker == null)
            //    cGlobalSettings.oProductTracker = new csProductTracker();

        }

        public delegate void OnScanStartProcess(string startMsg);
        public event OnScanStartProcess OnScanStart;

        public delegate void OnScanProgressProcess(cClientEnum.eScanPhase scanPhaseType, string message, int percentageCompleted, string counterMsg, string progressInfo, bool showScanBar = false, bool bConfirmationBox = false);
        public event OnScanProgressProcess OnScanProgress;

        public delegate void OnScanCompletedProcess(string messageHeader, string messageDesc, bool bMoveToResultsTab, int percentageCompleted);
        public event OnScanCompletedProcess OnScanCompleted;

        public delegate void onGroupCreatedProcess(float matchingLevel);
        public event onGroupCreatedProcess onGroupCreated;

        ReaderWriterLockSlim ScanLock = new ReaderWriterLockSlim();

        public void startCompare()
        {
            new Thread(() =>
            {
                try
                {
                    ScanLock.EnterWriteLock();

                    cGlobalSettings.b_SCAN_STARTED = true;

                    /* Write a log of user settings */
                    StringBuilder builder = null;
                    try
                    {
                        builder = new StringBuilder();
                        builder.Append("\r\n============================");
                        builder.Append("\r\nScanning start");
                        builder.Append("\r\nFilter N Sort :: Extensions : " + cGlobalSettings.ImageFileExtensionsList).Append("\t|\tMin size :" + cGlobalSettings.MinFileSize);
                        builder.Append("\r\nAuto Mark :: Priority :" + RegistryTool.priorityOrder);
                        builder.Append("\r\nComparision Method :: IsSimilarMatch:" + (cGlobalSettings.MatchSettingsData.MatchMethod == enumClass.eMatchMethod.Similar));
                        if (cGlobalSettings.MatchSettingsData.MatchMethod == enumClass.eMatchMethod.Similar)
                        {
                            builder.Append("\r\nMatching Level :" + (int)cGlobalSettings.MatchSettingsData.MatchLevel);
                            builder.Append("\t|\tBitmap Size : " + cGlobalSettings.MatchSettingsData.BitmapSize);
                            builder.Append("\t|\tTime Interval : " + (int)cGlobalSettings.MatchSettingsData.TimeInterval + "seconds");
                            builder.Append("\t|\tGPS : " + (int)cGlobalSettings.MatchSettingsData.GPS + " meters");
                        }

                        cGlobalSettings.oLogger.WriteLog(builder.ToString());
                    }
                    catch (Exception)
                    {
                        ;
                    }
                    finally { if (builder != null) builder = null; }

                    ScanThread();
                }
                finally
                {
                    cGlobalSettings.b_SCAN_STARTED = false;
                    if (ScanLock.IsWriteLockHeld) ScanLock.ExitWriteLock();
                }

            })
            { Name = "ScanThread" }.Start();
        }

        public int getFolderIndex(string directoryName)
        {
            //return 0;
            if (string.Compare(directoryName, lastFolderPath, true) == 0)
            {
                return FolderIndex;
            }
            else
            {
                lastFolderPath = directoryName;
                return FolderIndex++;
            }

        }


