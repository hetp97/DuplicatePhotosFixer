<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucMainBoder"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
              xmlns:cust ="clr-namespace:DuplicatePhotosFixer.CustomControl"
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="235" d:DesignWidth="725" Background="Black">

    <UserControl.Resources>
        <Style  x:Key="btn_customStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                            <ContentControl Content="{TemplateBinding Content}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="False">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource frgclr_gray}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Border  BorderBrush="{DynamicResource clr_darkborder}"  BorderThickness="0 1 0 0">
            <Border.Background>
                <ImageBrush ImageSource="{DynamicResource img_top_header}"/>
            </Border.Background>
            <Grid Grid.Row="0" Background="#3E3E3E"  >
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>

            </Grid.ColumnDefinitions>
            <!--<Image x:Name="dpf_logo" Source="/Resources/Application-0.png" HorizontalAlignment="Left"
                           Margin="5 10 0 0" Width="50" Height="50"/>-->
                <Label x:Name="lblAppTitle" Content="Duplicate Photos Fixer Pro" Foreground="#ECECEC" VerticalAlignment="Top"
                   HorizontalAlignment="Center" 
                   FontSize="18"
                  />
            <Grid Grid.Column="1">

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" >
                    <DockPanel VerticalAlignment="Top" Margin="0 5 0 0">
                            <StackPanel Orientation="Horizontal" Margin=" 0 0 10 0" Cursor="Hand" PreviewMouseLeftButtonDown="stkLang_PreviewMouseLeftButtonDown" x:Name="stkLang">
                                <StackPanel.ContextMenu>
                                    <ContextMenu x:Name="mnuLang">
                                        <MenuItem Header="English" x:Name="mnuEnglish" Tag="en" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_english}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="English" x:Name="mnuJapanese" Tag="ja" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_japnese}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="English" x:Name="mnuGerman" Tag="de" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_german}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="English" x:Name="mnuDutch" Tag="nl" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_dutch}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="English" x:Name="mnuFinnish" Tag="fi" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_finnish}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="English" x:Name="mnuFrench" Tag="fr" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_french}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="English" x:Name="mnuDanish" Tag="da" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_danish}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="English" x:Name="mnuItalian" Tag="it" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_italian}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="English" x:Name="mnuNorwegian" Tag="no" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_norwegian}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Portugal" x:Name="mnuPortugal" Tag="ptbr" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_portuguese}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Russian" x:Name="mnuRussian" Tag="ru" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_russian}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Spanish" x:Name="mnuSpanish" Tag="es" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_spanish}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Swedish" x:Name="mnuSwedish" Tag="sv" Click="mnulangItem_Click">
                                            <MenuItem.Icon>
                                                <Image Stretch="None" Source="{DynamicResource img_sweddish}"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </StackPanel.ContextMenu>
                                <Image Grid.Column="0"
                                           x:Name="imgLang"
                   Margin="0"
                   Stretch="None"
                   Source="/Resources/en.png" />
                                <Image Grid.Column="0"                   
                                           Stretch="None"
                                           Margin="3 0 0 0"
                                            Source="{DynamicResource img_dropdownarrow}" />

                            </StackPanel>
                            <!--<cust:ImageButton x:Name="lnkLblLang"                                                              
                                  Image="{DynamicResource img_en_flag}"
                                         Cursor="Hand"
                                   Style="{DynamicResource stl_btnLanguage}"
                        HoverImage="{DynamicResource  img_cart}"
                                  SelectedImage="{DynamicResource  img_cart}"
                                          Click="lnkLblLang_Click">
                            <ComboBox x:Name="languageComboBox" SelectionChanged="LanguageComboBox_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Image x:Name="flag_img" Source="{Binding FlagImagePath}" Width="20" Height="20" Margin="0 0 5 0"/>
                                            <TextBlock Text="{Binding LanguageName}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                        </cust:ImageButton>
                        <cust:ImageButton x:Name="lnkLblLangArrow"   VerticalAlignment="Top" Margin="0 5 0 0"                                                           
                                 
                                   Style="{DynamicResource stl_btnLanguageArrow}"
                                     Image="{DynamicResource img_dropdownarrow}"   
                        HoverImage="{DynamicResource  img_cart}"
                                          Cursor="Hand"
                                  SelectedImage="{DynamicResource  img_cart}" Click="lnkLblLangArrow_Click">

                                <ComboBox x:Name="languageComboBox1" SelectionChanged="LanguageComboBox_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="{Binding FlagImagePath}" Width="20" Height="20" Margin="0 0 5 0"/>
                                            <TextBlock Text="{Binding LanguageName}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </cust:ImageButton>-->

                    </DockPanel>
                    <!--<cust:ImageButton x:Name="btnCart"                                                              
                                  Image="{DynamicResource img_cart}"
                                   Style="{DynamicResource stl_btnCart}"
                        HoverImage="{DynamicResource  img_cart}"
                                  SelectedImage="{DynamicResource  img_cart}">
                    </cust:ImageButton>-->
                    <cust:ImageButton x:Name="btnActionCenter"  
                                      Margin=" 0 2 0 0"
                                  Image="{DynamicResource img_actioncenter}"
                                   Style="{DynamicResource stl_btnAction}"
                        HoverImage="{DynamicResource  img_cart}"
                                      Cursor="Hand"                                      
                                  SelectedImage="{DynamicResource  img_close_clicked}" Click="btnActionCenter_Click">
                    </cust:ImageButton>
                    <Image Source="{DynamicResource img_footer}" x:Name="linkDivider" Margin="0 3 0 0" Width="25" Height="15" VerticalAlignment="Top" />
                    <cust:ImageButton x:Name="linklblSettings"
                              DockPanel.Dock="Right"
                              Margin="0 0 0 0"                           
                             Image="{DynamicResource img_settings_sm}"  
                              HoverImage="{DynamicResource img_dropdownarrow}"
                              SelectedImage="{DynamicResource img_dropdownarrow}"
                    FontSize="14" VerticalAlignment="Top" Padding="5 0" 
                              Content="Settings"                             
                              Visibility="Visible"
                    
                    Style="{DynamicResource stl_btnSettings}" Click="linklblSettings_Click">

                    </cust:ImageButton>

                    <cust:ImageButton x:Name="lnkLblHelp"
                              DockPanel.Dock="Right"
                              Margin="0,0,10,0"                                   
                             Image="{DynamicResource img_dropdownarrow}"  
                              HoverImage="{DynamicResource img_dropdownarrow}"
                              SelectedImage="{DynamicResource img_dropdownarrow}"
                    FontSize="14" VerticalAlignment="Top" Padding="5 0" 
                              Content="? Help"                                       
                              Visibility="Visible"                    
                    Style="{DynamicResource StyleMainBorderHelpButton}" Click="lnkLblHelp_Click">
                      
                    </cust:ImageButton>
                    <Popup x:Name="settingspopup"  IsOpen="False" Placement="Mouse" StaysOpen="False">
                        <StackPanel >
                          
                            <Button x:Name="btnHelp" Height="28" BorderThickness="1 1 1 0" 
                                    BorderBrush="#000" Background="{DynamicResource bgclr_soliddark}"  >
                                <DockPanel Background="{DynamicResource bgclr_soliddark}" >
                                        <Border Background="#292929" >
                                    <Image Source="{DynamicResource img_helpicon}" Margin="2"  Width="15"/>
                                    </Border>
                                    <!--<Border BorderBrush="{DynamicResource clr_grayborder}" BorderThickness="0 0 0 1">-->
                                        <TextBlock Text="Help" Padding="0" Width="150" Foreground="#9e9e9e"
                                                   VerticalAlignment="Center" Margin="10 0 0 0"/>
                                    <!--</Border>-->
                                </DockPanel>
                                   
                            </Button>

                                <Button x:Name="btnContactus" Height="28" BorderThickness="1 1 1 0" 
                                    BorderBrush="#000" Background="{DynamicResource bgclr_soliddark}" Style="{DynamicResource btn_customStyle}">
                                    <DockPanel Background="{DynamicResource bgclr_soliddark}" >
                                        <Border Background="#292929" BorderBrush="#000">
                                            <Image Source="{DynamicResource img_contactus}" Margin="2"  Width="15"/>
                                    </Border>
                                    <!--<Border BorderBrush="{DynamicResource clr_grayborder}" BorderThickness="0 0 0 1">-->
                                        <TextBlock Text="Contact us" Padding="0" Width="150"  Foreground="#9e9e9e"
                                                    VerticalAlignment="Center" Margin="10 0 0 0"/>
                                    <!--</Border>-->
                                </DockPanel>
                            </Button>

                                <Button x:Name="btnClearCache" Height="28" BorderThickness="1 1 1 0" 
                                    BorderBrush="#000" Background="{DynamicResource bgclr_soliddark}" Click="btnClearCache_Click" Style="{DynamicResource btn_customStyle}" >
                                    <DockPanel Background="{DynamicResource bgclr_soliddark}" >
                                        <Border Background="#292929" BorderBrush="#000">
                                            <Image Source="{DynamicResource img_cache}" Margin="2"  Width="15"/>
                                        </Border>
                                        <!--<Border BorderBrush="{DynamicResource clr_grayborder}" BorderThickness="0 0 0 1">-->
                                        <TextBlock Text="Clear Cache" Padding="0" Width="150"  Foreground="#9e9e9e"
                                                    VerticalAlignment="Center" Margin="10 0 0 0"/>
                                        <!--</Border>-->
                                    </DockPanel>
                                </Button>


                                <Button x:Name="btnRegistration" Height="28" BorderThickness="1 1 1 0" 
                                    BorderBrush="#000" Background="{DynamicResource bgclr_soliddark}" Click="btnRegistration_Click" Style="{DynamicResource btn_customStyle}" >
                                    <DockPanel Background="{DynamicResource bgclr_soliddark}" >
                                        <Border Background="#292929" BorderBrush="#000">
                                            <Image Source="{DynamicResource img_registration}" Margin="2"  Width="15"/>
                                        </Border>
                                        <!--<Border BorderBrush="{DynamicResource clr_grayborder}" BorderThickness="0 0 0 1">-->
                                        <TextBlock Text="Enter Registration Key" Padding="0" Width="150"  Foreground="#9e9e9e"
                                                    VerticalAlignment="Center" Margin="10 0 0 0"/>
                                        <!--</Border>-->
                                    </DockPanel>
                                </Button>


                                <Button x:Name="btnupdates" Height="28" BorderThickness="1 1 1 0" 
                                    BorderBrush="#000" Background="{DynamicResource bgclr_soliddark}" Style="{DynamicResource btn_customStyle}">
                                    <DockPanel Background="{DynamicResource bgclr_soliddark}" >
                                        <Border Background="#292929" BorderBrush="#000">
                                            <Image Source="{DynamicResource img_updates}" Margin="2"  Width="15"/>
                                        </Border>
                                        <!--<Border BorderBrush="{DynamicResource clr_grayborder}" BorderThickness="0 0 0 1">-->
                                        <TextBlock Text="Check for Updates" Padding="0" Width="150"  Foreground="#9e9e9e"
                                                    VerticalAlignment="Center" Margin="10 0 0 0"/>
                                        <!--</Border>-->
                                    </DockPanel>
                                </Button>


                                <Button x:Name="btnfeedback" Height="28" BorderThickness="1 1 1 0" 
                                    BorderBrush="#000" Background="{DynamicResource bgclr_soliddark}" Style="{DynamicResource btn_customStyle}">
                                    <DockPanel Background="{DynamicResource bgclr_soliddark}" >
                                        <Border Background="#292929" BorderBrush="#000">
                                            <Image Source="{DynamicResource img_feedback}" Margin="2" 
                                                    Width="15" HorizontalAlignment="Left"/>
                                        </Border>
                                        <!--<Border BorderBrush="{DynamicResource clr_grayborder}" BorderThickness="0 0 0 1">-->
                                        <TextBlock Text="FeedBack" Padding="0" Width="150"  Foreground="#9e9e9e"
                                                    VerticalAlignment="Center" Margin="10 0 0 0" />
                                        <!--</Border>-->
                                    </DockPanel>
                                </Button>


                                <Button x:Name="btnVideo" Height="28" BorderThickness="1 1 1 0" 
                                    BorderBrush="#000" Background="{DynamicResource bgclr_soliddark}" Style="{DynamicResource btn_customStyle}">
                                    <DockPanel Background="{DynamicResource bgclr_soliddark}" >
                                        <Border Background="#292929" BorderBrush="#000">
                                            <Image Source="{DynamicResource img_video}" Margin="2" Width="15"/>
                                        </Border>
                                        <!--<Border BorderBrush="{DynamicResource clr_grayborder}" BorderThickness="0 0 0 1">-->
                                        <TextBlock Text="Go to video channel" Padding="0" Width="150"  Foreground="#9e9e9e"
                                                    VerticalAlignment="Center" Margin="10 0 0 0"/>
                                        <!--</Border>-->
                                    </DockPanel>
                                </Button>


                                <Button x:Name="btnAboutus" Height="28" BorderThickness="1" Style="{DynamicResource btn_customStyle}"
                                    BorderBrush="#000" Background="{DynamicResource bgclr_soliddark}" Click="btnAboutus_Click" >
                                    <DockPanel Background="{DynamicResource bgclr_soliddark}" >
                                        <Border Background="#292929" BorderBrush="#000">
                                            <Image Source="{DynamicResource img_about_icon}" Margin="2"  Width="15"/>
                                        </Border>
                                        <!--<Border BorderBrush="{DynamicResource clr_grayborder}" BorderThickness="0 0 0 1">-->
                                        <TextBlock Text="About us" Padding="0" Width="150"  Foreground="#9e9e9e"
                                                    VerticalAlignment="Center" Margin="10 0 0 0"/>
                                        <!--</Border>-->
                                    </DockPanel>
                                </Button>

                            </StackPanel>
                    </Popup>

                    <DockPanel HorizontalAlignment="Right">
                        <cust:ImageButton x:Name="btn_close"  DockPanel.Dock="Right"                              
                                  Margin="0,0,5,0"
                                  Image="{DynamicResource img_close_normal}"
                                   Style="{DynamicResource StyleMainBorderButtons}"
                        HoverImage="{DynamicResource  img_close_hover}"
                                  SelectedImage="{DynamicResource  img_close_clicked}" Click="btn_close_Click" >
                        </cust:ImageButton>
                     
                        <cust:ImageButton x:Name="btnMaximize"     DockPanel.Dock="Right"                         
                                 
                                  Image="{DynamicResource img_max_normal}"
                                   Style="{DynamicResource StyleMainBorderButtons}"
                        HoverImage="{DynamicResource  img_max_hover}"
                                  SelectedImage="{DynamicResource  img_max_clicked}" Click="btnMaximize_Click" >
                        </cust:ImageButton>
                        <cust:ImageButton x:Name="btnMinimize"   DockPanel.Dock="Right"                                                         
                                  Image="{DynamicResource img_min_normal}"
                                   Style="{DynamicResource StyleMainBorderButtons}"
                        HoverImage="{DynamicResource  img_min_hover}"
                                  SelectedImage="{DynamicResource  img_min_clicked}" Click="btnMinimize_Click" >
                        </cust:ImageButton>

                    </DockPanel>


                </StackPanel>
            </Grid>
        </Grid>

        </Border>
    </Grid>
</UserControl>
