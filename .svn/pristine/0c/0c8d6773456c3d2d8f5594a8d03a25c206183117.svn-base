<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucfooterPromoADU"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
             mc:Ignorable="d" 
             d:DesignHeight="53" d:DesignWidth="1000" Background="#464646">
    <Grid>
        <Border Grid.Row="2" BorderBrush="{DynamicResource clr_darkborder}" BorderThickness="0 1 0 0">
            <Border.Background>
                <ImageBrush ImageSource="{DynamicResource img_top_header}"/>
            </Border.Background>
            <Grid Grid.Row="2" Height="51" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition/>
                
                </Grid.ColumnDefinitions>
                <Button x:Name="btn_back" Grid.Column="0"  Height="32" Width="82" Content="Back" HorizontalAlignment="Left" Margin="20 0"
                    BorderThickness="0" Style="{DynamicResource stl_btnBack}" >
                    <Button.Background>
                        <ImageBrush ImageSource="{DynamicResource img_btnback}"/>
                    </Button.Background>
                </Button>
                <cust:ImageButton x:Name="btn_footer"
                              HorizontalAlignment="Right"                          
                              Width="150"
                              Height="34"
                                  Margin="0 0 10 0"
                                  Grid.Column="1"
                             Image="{DynamicResource img_play_icon}"  
                              HoverImage="{DynamicResource img_dropdownarrow}"
                              SelectedImage="{DynamicResource img_dropdownarrow}"
                    FontSize="14"  Padding="5" 
                              Content="Watch Tutorial"      
                              Visibility="Visible"                    
                    Style="{DynamicResource stl_btnfooter}">

                </cust:ImageButton>
            </Grid>
        </Border>
        </Grid>
</UserControl>
