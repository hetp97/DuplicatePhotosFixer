<Window x:Class="DuplicatePhotosFixer.Views.frmExitNag"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
        xmlns:local="clr-namespace:DuplicatePhotosFixer.Views"
        mc:Ignorable="d"
        Title="frmExitNag" Height="312" Width="513" WindowStyle="None" AllowsTransparency="True" WindowStartupLocation="CenterScreen" ShowInTaskbar="False">
    <Window.Resources>

        <Style TargetType="Button" x:Name="style_btn_close">
            <Setter Property="Background" Value="#888888"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>

            </Style.Triggers>
        </Style>

    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <DockPanel>
              
                <cust:ImageButton
                            x:Name="btn_close"
                            Height="10"
                           
                            Width="15"
                            Margin="5 0"
                            DockPanel.Dock="Right"
                            Style="{DynamicResource imageButton}"
                            Image="{DynamicResource img_close_plain}"
                            HoverImage="{DynamicResource img_close_plain}"
                            SelectedImage="{DynamicResource img_close_plain}" Click="btn_selectionAssistanceOptionB_Click"  />

                <TextBlock x:Name="clblPlsWait" Text="Before Closing Duplicate Photos Fixer Pro"
                           Foreground="Black"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="5 10 0 0"/>
               
            </DockPanel>

            <TextBlock x:Name="lbl1" TextWrapping="Wrap" 
                       Margin="5 5 0 0"
                       FontSize="13"
                       Foreground="Black">
                Duplicate Photos Fixer Pro can remove all duplicate photos from your PC with<LineBreak/> a single click and recover tons of disk space.
            </TextBlock>

            <DockPanel HorizontalAlignment="Center">
                <TextBlock x:Name="lbl_discValue" 
                           Foreground="#ED2F3C"
                           FontSize="55"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                            Margin="3 0 3 0">
                    50%
                </TextBlock>
                <StackPanel>
                    <TextBlock x:Name="lbl_discount"
                           FontSize="21"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="#111111"
                           Margin="3 5 3 0">
                    DISCOUNT 
                    </TextBlock>
                    <TextBlock x:Name="lbl_dis"
                           FontSize="18" 
                               FontWeight="Bold"
                               Foreground="#000">
                    Only for You!

                    </TextBlock>
                </StackPanel>
                
            </DockPanel>
            <TextBlock x:Name="llbl_removeAll"
                       HorizontalAlignment="Center"
                       FontSize="16"
                       Foreground="#404040"
                       FontWeight="Regular"
                     
                      >
               Remove all duplicate photos
            </TextBlock>
            <DockPanel HorizontalAlignment="Center">
               

                <Button x:Name="btn_claimOffer"
                        Width="277"
                        Height="42"
                        Style="{DynamicResource stylGreenBtn}"
                        FontSize="15"
                        FontWeight="Bold"
                        Margin="0 10 0 0"
                      Content="CLAIM OFFER - 50 %"
                        >
                    <Button.Template>
                        <ControlTemplate>
                            <DockPanel Background="#01C025">
                                <TextBlock Text="CLAIM OFFER 50% OFF" Foreground="#fff" Margin="20 0 10 0"
                                           VerticalAlignment="Center"
                                           FontSize="19" FontWeight="Bold"/>
                                <Image Source="{DynamicResource img_green_btn_arrow}" Stretch="None" HorizontalAlignment="Left"/>

                            </DockPanel>
                        </ControlTemplate>
                    </Button.Template>
                    
                </Button>
                <!--<Image x:Name="img_mbc" Source="/Resources/mbc_icon.png"
                       Width="64"
                       Height="64"
                      
                      Margin="0 0 20 0"
                       VerticalAlignment="Center"/>-->

            </DockPanel>
        </StackPanel>
        <Grid Grid.Row="1" Background="#262626">
            <Button x:Name="btn_exit" 
                        Width="109"
                        Height="30"
                        Background="#DDDDDD"
                        Content="Exit" 
                        HorizontalAlignment="Right"
                  
                    FontWeight="Regular" 
                    Margin="0 0 20 0" Click="btn_exit_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#DDDDDD" />
                        
                        <Setter Property="TextBlock.TextAlignment" Value="Center" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bdr_main" BorderBrush="#8c8c8c"  BorderThickness="1"  Background="#DDDDDD" >
                                        <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="Black">
                                        </ContentPresenter>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">

                                            <Setter Property="Background" TargetName="bdr_main" Value="Transparent"></Setter>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="true">
                                                                <Setter Property="BorderBrush" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                                <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                                <Setter Property="Background" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                            </Trigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                                                <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                                            </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
            <StackPanel Orientation="Horizontal">
                <Image x:Name="img_mb" Source="/Resources/mbc_icon.png" 
                        Margin="5 0 5 0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="txt5" Foreground="#fff"
                               FontWeight="Regular"
                               FontSize="14">
                        No-Risk, Money Back Guarantee.
                    </TextBlock>
                    <TextBlock x:Name="txt6" Foreground="#fff"
                               FontWeight="Regular"
                               FontSize="12">
                        Satisfication guaranteed or your money back.
                    </TextBlock>
                </StackPanel>


            </StackPanel>
        </Grid>
    </Grid>
</Window>
