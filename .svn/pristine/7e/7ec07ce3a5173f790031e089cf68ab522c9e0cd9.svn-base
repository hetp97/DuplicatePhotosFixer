<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <!--region mainHeader -->
    <!--===========================================-->
    <!-- Help Menu -->
    <!--- ForeGround Colors -->
    <SolidColorBrush x:Key="cl_fg_helpmenuItem" Color="#000"/>
    <!-- Background Colors -->
    <SolidColorBrush x:Key="cl_bg_dropdown" Color="#EBEBEB"/>
    <!-- Border -->
    <SolidColorBrush x:Key="cl_br_dropdown" Color="#E8E8E8"/>
    <!--============================================-->

    <!--endregion-->
    <!-- Foregroud Colors  -->
    
        <!-- Settings Nag -->
    <!--=========================================-->
    
    <SolidColorBrush x:Key="cl_fg_tabItem" Color="#464646"/>
    <SolidColorBrush x:Key="cl_fg_tabhover" Color="#000000"/>
    <SolidColorBrush x:Key="cl_fg_setCont" Color="#3D3D3D"/>
  
    <SolidColorBrush x:Key="cl_fg_setHeading" Color="#000"/>

       <!--  Border color  -->
    <!--=========================================-->
    
    <!-- Settings Nag -->
   
    <SolidColorBrush x:Key="cl_br_setting" Color="#D8D8D8"/>

    <!-- Background color  -->
<!--=========================================-->
    <SolidColorBrush x:Key="cl_bgSettingsHeading" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="cl_bg_settingsNag" Color="#fff"/>
    <SolidColorBrush x:Key="cl_bg_SettingsTab" Color="#EBEBEB"/>
    <SolidColorBrush x:Key="cl_bg_TabControl" Color="#EBEBEB"/>
    <SolidColorBrush x:Key="cl_bg_settingsTabItemHover" Color="#fff"/>
    <!-- Settings Nag -->

    <SolidColorBrush x:Key="cl_bg_tab" Color="#EBEBEB"/>
    <SolidColorBrush x:Key="cl_bg_primary" Color="#fff"/>


