        }

        private void rdbtnExactMatch_Click(object sender, RoutedEventArgs e)
        {
            if (rdbtnExactMatch.IsChecked == false)
                return;
            cGlobalSettings.MatchSettingsData.MatchMethod = eMatchMethod.Exact;

            cGlobalSettings.ImageResize = (int)vmHomeComparisonMethod.GetBitmapSizeEx(enumClass.eBitmapSize._80x80_pixels);
            objModel.SaveMatchSettings();

        }

        private void rdbtnSimilarMatch_Click(object sender, RoutedEventArgs e)
        {
            if (rdbtnSimilarMatch.IsChecked == false)
                return;

            cGlobalSettings.MatchSettingsData.MatchMethod = eMatchMethod.Similar;
            cGlobalSettings.ImageResize = (int)vmHomeComparisonMethod.GetBitmapSizeEx(cGlobalSettings.MatchSettingsData.BitmapSize);
            objModel.SaveMatchSettings();
        }

        public void ChangeScanMode(eScanMode scanMode)
        {

            chk_rotatedImages.IsChecked= true;
            chk_flippedImages.IsChecked = true;
            switch (scanMode)
            {
                case eScanMode.GoogleDrive:
                    {
                        //rbtn_exactMatch.Checked = true;
                    }
                    break;
                case eScanMode.Dropbox:
                    {
                        chk_rotatedImages.IsChecked = true;
                        chk_flippedImages.IsChecked = true;
                    }
                    break;
                case eScanMode.BoxCloud:
                    {
                        chk_rotatedImages.IsChecked = true;
                        chk_flippedImages.IsChecked = true;
                    }
                    break;
                case eScanMode.AmazonS3:
                    {
                        chk_rotatedImages.IsChecked = true;
                        chk_flippedImages.IsChecked = true;
                    }
                    break;
                //case eScanMode.DeleteEmptyFolder:
                    break;
                case eScanMode.FileSearch:
                default:
                    //rbtn_FileSystem.Checked = true;
                    break;
            }
        }

