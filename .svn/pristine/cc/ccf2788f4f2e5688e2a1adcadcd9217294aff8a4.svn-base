using System;
using System.Collections.Generic;
using System.Collections.ObjectModel;
using System.ComponentModel;
using System.IO;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows;
using DuplicatePhotoFixer.ClassDictionary;
using DuplicatePhotosFixer.HelperClasses;
using DuplicatePhotosFixer.Helpers;

namespace DuplicatePhotosFixer.Models
{
    public class vmFileFormatSettings : INotifyPropertyChanged
    {
        public event PropertyChangedEventHandler PropertyChanged;
        public void OnPropertyChanged(string name)
        {
            PropertyChangedEventHandler handler = PropertyChanged;
            if (handler != null)
            {
                handler(this, new PropertyChangedEventArgs(name));
            }
        }

        

        long _sMinSizeValue;
        public long sMinSizeValue
        {
            get
            {
                return _sMinSizeValue;
            }
            set
            {
                _sMinSizeValue = value;
                
                OnPropertyChanged("sMinSizeValue");

            }
        }

        string _sMinSize;
        public string sMinSize
        {
            get
            {
                return _sMinSize;
            }

            set
            {
                _sMinSize = value;
             
                OnPropertyChanged("sMinSize");
            }
        }

        public List<csFileTypes> lstFileType { get; set; }
        public vmFileFormatSettings()
        {
            Init();
        }

        void Init()
        {
            LoadFileFormat();
            LoadSavedSettings();
            LoadFileSize();
        }


      
        void LoadFileFormat()
        {
            try
            {
                csFileTypes.getLastFileTypesList();
               
                lstFileType = new List<csFileTypes>();
                var FileTypesToAdd = cGlobalSettings.listFileType.Where(p => p.Key > -1);
               

                foreach(var item in FileTypesToAdd)
                {
                    lstFileType.Add(new csFileTypes()
                    {
                        isChecked = item.Value.isChecked,
                        fileTypeText = item.Value.fileTypeText,
                        FileDialogFilterItem = item.Value.FileDialogFilterItem,
                        ImageFileExtension = item.Value.ImageFileExtension,
                        IsNewLibSupportedExt = item.Value.IsNewLibSupportedExt

                    });
                }

              

            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("vmFileFormatSettings:: LoadFileFormat: ", ex);

            }         

        }

        void LoadFileSize()
        {
            try
            {
                csFileTypes.getMinimumSize();
                if (cGlobalSettings.MinFileSize < 1048576) 
                {
                    
                    sMinSizeValue = cGlobalSettings.MinFileSize / 1024;
                              
                }
                else
                {
                    sMinSizeValue= cGlobalSettings.MinFileSize / 1048576; 
                    
                }


            }
            catch (Exception ex)
            {

                cGlobalSettings.oLogger.WriteLogException("vmFileFormatSettings:: LoadFileSize: ", ex);
            }


        }
        public void SetUIPropertiesValue()
        {
            if (cGlobalSettings.FileFormatSettings == null)
            {
                LoadFileFormatSettings();
            }
           
        }
        public void LoadFileFormatSettings(bool bLoadDefaultFocefully = false)
        {
            try
            {
                if (bLoadDefaultFocefully)
                {
                    LoadDefaultSettings();
                    return;
                }
                LoadSavedSettings();

                if (cGlobalSettings.GeneralSettingsData == null)
                    LoadFileFormatSettings(true);

            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("vmFileFormatSettings:: LoadGeneralMethodSettings: ", ex);
            }
        }

        void LoadDefaultSettings()
        {
            try
            {
                csFileTypes.getLastFileTypesList();
                cGlobalSettings.FileFormatSettings = new csFileTypes()
                {
                    isChecked = cGlobalSettings.listFileType[-1].isChecked,
                    fileTypeText = cGlobalSettings.listFileType[-1].fileTypeText,
                    FileDialogFilterItem = cGlobalSettings.listFileType[-1].FileDialogFilterItem,
                    ImageFileExtension = cGlobalSettings.listFileType[-1].ImageFileExtension
                    
                };
            }


            catch (Exception ex)
            {

                cGlobalSettings.oLogger.WriteLogException("vmFileFormatSettings:: LoadDefaultSettings: ", ex);
            }
        }
        void LoadSavedSettings()
        {
            try
            {
                if (File.Exists(cGlobalSettings.xmlFileFormatSettings))
                {
                    /// Desearlize the strings
                    /// Fill FileFormatSettingsData
                    /// 
                    cGlobalSettings.FileFormatSettings = cSerializer.DeSerializeObject<csFileTypes>(cGlobalSettings.xmlFileFormatSettings);
                }
            }
            catch (Exception ex)
            {

          
            }
        }
        public void SaveFileFormatSettings()
        {
            try
            {
                /// Save cGlobalSettings.FileFormatSettings in xml file 
                /// 
                cSerializer.SerializeToXML<csFileTypes>(cGlobalSettings.FileFormatSettings, cGlobalSettings.xmlFileFormatSettings);
            }
            catch (Exception ex)
            {

            }
        }
    }
}
