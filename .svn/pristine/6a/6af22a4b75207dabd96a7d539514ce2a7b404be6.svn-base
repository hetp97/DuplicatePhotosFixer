<UserControl x:Class="DuplicatePhotosFixer.UserControls.ucRecommendedApp"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls"
             xmlns:cust="clr-namespace:DuplicatePhotosFixer.CustomControl"
             mc:Ignorable="d" 
             d:DesignHeight="493" d:DesignWidth="996" Background="{DynamicResource cl_bg_actioncenter}">
    <Grid>
        <ScrollViewer>
            <StackPanel>
                <DockPanel Height="78" Background="{DynamicResource cl_bg_AppDes}" Margin="0 10">
                    <Image x:Name="asr_img" Source="{DynamicResource img_tsr_logo}"  Margin="15 0"
                           Width="50" Height="50"/>
                    <StackPanel Margin="0 12">
                        <TextBlock x:Name="app_name1" Text ="Advance Screen Recorder" Foreground="{DynamicResource cl_fg_AppName_ac}" FontSize="15" FontWeight="SemiBold" Padding="0 0 0 5" />
                        <TextBlock x:Name="app_info" FontSize="13" Foreground="{DynamicResource cl_fg_AppInfo_ac}">
                        <Italic>Screen Recorder </Italic>
                        </TextBlock>
                    </StackPanel>
                    <cust:ImageButton
                        x:Name="linklblInstall"
                              DockPanel.Dock="Right"
                              Margin="0 0 30 0"  
                              Cursor="Hand"
                             Image="{DynamicResource img_download}"  
                              HoverImage="{DynamicResource img_download}"
                              SelectedImage="{DynamicResource img_download}"
                    FontSize="14" VerticalAlignment="Center" Padding="5 0" 
                              Content="Install Now"                             
                              Visibility="Visible"
                    Style="{DynamicResource ImageTextbtn}">
                    </cust:ImageButton>
                    <TextBlock x:Name="app_desc1"  Foreground="{DynamicResource cl_fg_AppDes_ac}"
                               MinWidth="450" Margin="0 10 0 0"
                               TextWrapping="Wrap" HorizontalAlignment="Center" FontSize="13" DockPanel.Dock="Right">
                       Record online classes, webinars streaming content limitlessly.
                    </TextBlock>
                </DockPanel>
                <DockPanel Height="78" Background="{DynamicResource cl_bg_AppDes}" Margin="0 10">
                    <Image x:Name="systweak_img" Source="{DynamicResource img_adu_logo}" Stretch="None"/>
                    <StackPanel Margin="0 12">
                        <TextBlock x:Name="app_name2" Text ="Systweak Antivirus" Foreground="{DynamicResource cl_fg_AppName_ac}" FontSize="15" FontWeight="SemiBold" Padding="0 0 0 5" />
                        <TextBlock x:Name="app_info2" FontSize="13" Foreground="{DynamicResource cl_fg_AppInfo_ac}">
                        <Italic>Systweak for Antivirus</Italic>
                        </TextBlock>
                    </StackPanel>
                    <cust:ImageButton
                        x:Name="linklblInstall2"
                              DockPanel.Dock="Right"
                              Margin="0 0 30 0"                           
                             Image="{DynamicResource img_download}"  
                              HoverImage="{DynamicResource img_dropdownarrow}"
                              SelectedImage="{DynamicResource img_dropdownarrow}"
                    FontSize="14" VerticalAlignment="Center" Padding="5 0" 
                              Content="Install Now"                             
                              Visibility="Visible"
                    
                    Style="{DynamicResource ImageTextbtn}">
                    </cust:ImageButton>
                    <TextBlock x:Name="app_desc2" Foreground="{DynamicResource cl_fg_AppDes_ac}" Width="450"
                             HorizontalAlignment="Center"
                               TextWrapping="Wrap" 
                               Margin="30 10 0 0"
                               FontSize="13" DockPanel.Dock="Right">
                        Systweak Antivirus shields your computer against malware, spyware , adware and trojan hiding in your PC to make sure that  its is protected against malicious threats.
                    </TextBlock>

                </DockPanel>
              
              
                <DockPanel Height="78" Background="{DynamicResource cl_bg_AppDes}" Margin="0 10">
                    <Image x:Name="systweakVPN_img" Source="{DynamicResource img_adu_logo}" Stretch="None"/>
                    <StackPanel Margin="0 12">
                        <TextBlock x:Name="app_name3" VerticalAlignment="Center" Text ="Systweak VPN" Foreground="{DynamicResource cl_fg_AppName_ac}" FontSize="15" FontWeight="SemiBold" Padding="0 10 0 5" />
                    </StackPanel>
                    <cust:ImageButton
                        x:Name="linklblInstall3" 
                              DockPanel.Dock="Right" 
                              Margin="0 0 30 0"                           
                             Image="{DynamicResource img_download}"  
                              HoverImage="{DynamicResource img_download}"
                              SelectedImage="{DynamicResource img_download}"
                    FontSize="14" VerticalAlignment="Center" Padding="5 0" 
                              Content="Install Now"                             
                              Visibility="Visible"                 
                    Style="{DynamicResource ImageTextbtn}">
                    </cust:ImageButton>
                    <TextBlock x:Name="app_desc3" Foreground="{DynamicResource cl_fg_AppDes_ac}" 
                               Width="430" HorizontalAlignment="Center"
                               TextWrapping="Wrap" Margin="40 10 0 0" FontSize="13" DockPanel.Dock="Right">
                        Systweak VPN hides your IP address, lets you access favorite websites , entertainment content without any restrictions.
                    </TextBlock>
                </DockPanel>
                <DockPanel Height="78" Background="{DynamicResource cl_bg_AppDes}" Margin="0 10">
                    <Image x:Name="rightbackup_img" Source="{DynamicResource img_right-backup}"
                            Margin="15 0"
                           Width="50" Height="50"/>
                    <StackPanel Margin="0 12">
                        <TextBlock x:Name="app_name4" VerticalAlignment="Center" Text ="Right Backup" Foreground="{DynamicResource cl_fg_AppName_ac}" FontSize="15" FontWeight="SemiBold" Padding="0 10 0 5" />
                    </StackPanel>
                    <cust:ImageButton
                        x:Name="linklblInstall4"
                              DockPanel.Dock="Right"
                              Margin="0 0 30 0"                           
                             Image="{DynamicResource img_download}"  
                              HoverImage="{DynamicResource img_download}"
                              SelectedImage="{DynamicResource img_download}"
                    FontSize="14" VerticalAlignment="Center" Padding="5 0" 
                              Content="Install Now"                             
                              Visibility="Visible"
                    
                    Style="{DynamicResource ImageTextbtn}">
                    </cust:ImageButton>
                    <TextBlock x:Name="app_desc4" Foreground="{DynamicResource cl_fg_AppDes_ac}" Width="400"
                               TextWrapping="Wrap" HorizontalAlignment="Center" Margin="15 10 0 0"
                               FontSize="13" DockPanel.Dock="Right">
                     The easiest , safest and most secure online storage
                    </TextBlock>
                </DockPanel>

                <DockPanel Height="78" Background="{DynamicResource cl_bg_AppDes}" Margin="0 10">
                    <Image x:Name="sysSoftwareUpdator_img" Source="{DynamicResource img_adu_logo}" Stretch="None"/>
                    <StackPanel Margin="0 12">
                        <TextBlock x:Name="app_name5" VerticalAlignment="Center" Text ="Systweak Software Updator" Foreground="{DynamicResource cl_fg_AppName_ac}" FontSize="15" FontWeight="SemiBold" Padding="0 10 0 5" />
                    </StackPanel>
                    <cust:ImageButton
                        x:Name="linklblInstall5"
                              DockPanel.Dock="Right"
                              Margin="0 0 30 0"                           
                             Image="{DynamicResource img_download}"  
                              HoverImage="{DynamicResource img_download}"
                              SelectedImage="{DynamicResource img_download}"
                    FontSize="14" VerticalAlignment="Center" Padding="5 0" 
                              Content="Install Now"                             
                              Visibility="Visible"
                    
                    Style="{DynamicResource ImageTextbtn}">
                    </cust:ImageButton>
                    <TextBlock x:Name="app_desc5" Foreground="{DynamicResource cl_fg_AppDes_ac}"
                               Width="480" Margin="0 10 0 0"
                               TextWrapping="Wrap" HorizontalAlignment="Center"  FontSize="13" DockPanel.Dock="Right">
                        Systweak Software Updater keeps installed software up to date on your Windows PC.
                    </TextBlock>
                </DockPanel>

                <DockPanel Height="78" Background="{DynamicResource cl_bg_AppDes}" Margin="0 10">
                    <Image x:Name="tweakpassManager_img" Source="{DynamicResource img_adu_logo}" Stretch="None"/>
                    <StackPanel Margin="0 12">
                        <TextBlock x:Name="app_name6" Text ="TweakPass Password Manager" Foreground="{DynamicResource cl_fg_AppName_ac}" FontSize="15" FontWeight="SemiBold" Padding="0 0 0 5" />
                        <TextBlock x:Name="app_info6" FontSize="13" Foreground="{DynamicResource cl_fg_AppInfo_ac}">
                        <Italic>Safeguard your passwords in vault </Italic>
                        </TextBlock>
                    </StackPanel>
                    <cust:ImageButton
                        x:Name="linklblInstall6"
                              DockPanel.Dock="Right"
                              Margin="0 0 30 0"                           
                              Image="{DynamicResource img_download}"  
                              HoverImage="{DynamicResource img_dropdownarrow}"
                              SelectedImage="{DynamicResource img_dropdownarrow}"
                    FontSize="14" VerticalAlignment="Center" Padding="5 0" 
                              Content="Install Now"                             
                              Visibility="Visible"                   
                    Style="{DynamicResource ImageTextbtn}">
                    </cust:ImageButton>
                    <TextBlock x:Name="app_desc6" Foreground="{DynamicResource cl_fg_AppDes_ac}" 
                               Width="470" HorizontalAlignment="Center" Margin="0 10 0 0"
                               TextWrapping="Wrap" FontSize="13" DockPanel.Dock="Right">
                       Safeguard your sensitive information with World's strongest AES  encryption technology.Never forgot a password again
                    </TextBlock>
                </DockPanel>

                <DockPanel Height="78" Background="{DynamicResource cl_bg_AppDes}" Margin="0 10">
                    <Image x:Name="DFF_img" Source="{DynamicResource img_dff_logo}" Stretch="None"/>
                    <StackPanel Margin="0 12">
                        <TextBlock x:Name="app_name7" VerticalAlignment="Center" Text ="Duplicate Files Fixer" Foreground="{DynamicResource cl_fg_AppName_ac}" FontSize="15" FontWeight="SemiBold" Padding="0 10 0 5" />
                    </StackPanel>
                    <cust:ImageButton
                        x:Name="linklblInstall7"
                              DockPanel.Dock="Right"
                              Margin="0 0 30 0"                           
                             Image="{DynamicResource launch_img}"  
                              HoverImage="{DynamicResource launch_img}"
                              SelectedImage="{DynamicResource launch_img}"
                    FontSize="14" VerticalAlignment="Center" Padding="5 0" 
                              Content="Launch Now"                             
                              Visibility="Visible"
                    
                    Style="{DynamicResource ImageTextbtn}">
                    </cust:ImageButton>
                    <TextBlock x:Name="app_desc7" Foreground="{DynamicResource cl_fg_AppDes_ac}" Width="410"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap" Margin="20 10 0 0" FontSize="13" DockPanel.Dock="Right">
                       Recover disk space by removing duplicates
                    </TextBlock>
                </DockPanel>
                <DockPanel Height="78" Background="{DynamicResource cl_bg_AppDes}" Margin="0 10">
                    <Image x:Name="adu_img" Source="{DynamicResource img_adu_logo}" Stretch="None"/>
                    <StackPanel Margin="0 12">
                        <TextBlock x:Name="app_name8" VerticalAlignment="Center" Text ="Advance Driver Updator" Foreground="{DynamicResource cl_fg_AppName_ac}" FontSize="15" FontWeight="SemiBold" Padding="0 10 0 5" />
                    </StackPanel>
                    <cust:ImageButton
                        x:Name="linklblInstall8"
                              DockPanel.Dock="Right"
                              Margin="0 0 30 0"                           
                             Image="{DynamicResource launch_img}"  
                              HoverImage="{DynamicResource launch_img}"
                              SelectedImage="{DynamicResource launch_img}"
                    FontSize="14" VerticalAlignment="Center" Padding="5 0" 
                              Content="Launch Now"                             
                              Visibility="Visible"
                    
                    Style="{DynamicResource ImageTextbtn}">
                    </cust:ImageButton>
                    <TextBlock x:Name="app_desc8" Foreground="{DynamicResource cl_fg_AppDes_ac}" Width="430" HorizontalAlignment="Center"
                               TextWrapping="Wrap" Margin="0 10 0 0" FontSize="13" DockPanel.Dock="Right">
                    This tool identifies outdated or missing driversallows you to update in single click for uninterrupted and improved PC peformance
                    </TextBlock>
                </DockPanel>

                <DockPanel Height="78" Background="{DynamicResource cl_bg_AppDes}" Margin="0 10">
                    <Image x:Name="TweakShotScreenCapture_img" Source="{DynamicResource img_tsr_logo}" 
                            Margin="15 0"
                           Width="50" Height="50"/>
                    <StackPanel Margin="0 12">
                        <TextBlock x:Name="app_name9" VerticalAlignment="Center"
                                   Text ="TweakShot Screen Capture" Foreground="{DynamicResource cl_fg_AppName_ac}" FontSize="15" FontWeight="SemiBold" Padding="0 10 0 5" />
                    </StackPanel>
                    <cust:ImageButton
                        x:Name="linklblInstall9"
                              DockPanel.Dock="Right"
                              Margin="0 0 30 0"                           
                             Image="{DynamicResource launch_img}"  
                              HoverImage="{DynamicResource launch_img}"
                              SelectedImage="{DynamicResource launch_img}"
                    FontSize="14" VerticalAlignment="Center" Padding="5 0" 
                              Content="Launch Now"                             
                              Visibility="Visible"
               
                    Style="{DynamicResource ImageTextbtn}">
                    </cust:ImageButton>
                    <TextBlock x:Name="app_desc9" Foreground="{DynamicResource cl_fg_AppDes_ac}"  Width="450" HorizontalAlignment="Center"
                               TextWrapping="Wrap" Margin="0 10 0 0" FontSize="13" DockPanel.Dock="Right">
                    Record Screen Activities including online classes , live streaming events,online webinars and more in just one click.
                    </TextBlock>
                </DockPanel>
                <DockPanel Height="78" Background="{DynamicResource cl_bg_AppDes}" Margin="0 10">
                    <Image x:Name="spe_img" Source="{DynamicResource img_adu_logo}" Stretch="None"/>
                    <StackPanel Margin="0 12">
                        <TextBlock x:Name="app_name10" VerticalAlignment="Center" Text ="Systweak PDF Editor" Foreground="{DynamicResource cl_fg_AppName_ac}" FontSize="15" FontWeight="SemiBold" Padding="0 10 0 5" />
                    </StackPanel>
                    <cust:ImageButton
                        x:Name="linklblInstall10"
                              DockPanel.Dock="Right"
                              Margin="0 0 30 0"                           
                             Image="{DynamicResource launch_img}"  
                              HoverImage="{DynamicResource launch_img}"
                              SelectedImage="{DynamicResource launch_img}"
                    FontSize="14" VerticalAlignment="Center" Padding="5 0" 
                              Content="Launch Now"                             
                              Visibility="Visible"
                    
                    Style="{DynamicResource ImageTextbtn}">
                    </cust:ImageButton>
                    <TextBlock x:Name="app_desc10" Foreground="{DynamicResource cl_fg_AppDes_ac}" Width="410"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap" Margin="0 10" FontSize="13" DockPanel.Dock="Right">
                 A quick and straightforward solution to edit, convert, sign , protect ,compress PDFs and make scanned PDFs searchable and selectable.
                    </TextBlock>
                </DockPanel>


            </StackPanel>
        </ScrollViewer>  
    </Grid>
</UserControl>
