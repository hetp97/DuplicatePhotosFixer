    <Style x:Key="stl_btnfooter" TargetType="{x:Type cust:ImageButton}">

        <Setter Property="Background"
                    Value="Transparent" />
        <Setter Property="Cursor"
                    Value="Hand" />
        <Setter Property="BorderBrush"
                Value="#646464"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Border x:Name="Border"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                HorizontalAlignment="Center"
                               Padding="3 0 0 0"
                                Background="{TemplateBinding Background}"
                              BorderBrush="{TemplateBinding BorderBrush}"
                            VerticalAlignment="Center"
                                BorderThickness="0.8">
                        <Grid HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top">
                                <Image  
                                    Margin="0,5,0,0"
                                      Width="25"
                                    Height="25"
                                           x:Name="img_playbtn"
                                           SnapsToDevicePixels="False"
                                           Source="{TemplateBinding Image}"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                <TextBlock  Padding="5,0,3,0"
                                            Margin="0,5,0,0"
                                            x:Name="lnkwatchtutorial"
                                           FontSize="14"
                                            VerticalAlignment="Center"
                                          Foreground="White"
                                            Text="{TemplateBinding Content}"
                                            TextWrapping="WrapWithOverflow"/>


                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="stl_imgbtn" TargetType="{x:Type cust:ImageButton}">

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cust:ImageButton}">
                    <Image x:Name="btnActionCenter"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                           Stretch="None"
                          Margin="{TemplateBinding Margin}"
                          Source="{TemplateBinding Image}"
                                HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalAlignment}" />



                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
   
   


