using System;
using System.Collections.Generic;
using System.Collections.ObjectModel;
using System.ComponentModel;
using System.IO;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows;
using DuplicatePhotosFixer.ClassDictionary;
using DuplicatePhotosFixer.HelperClasses;
using DuplicatePhotosFixer.Helpers;
using DuplicatePhotosFixer.UserControls;
using Xceed.Wpf.Toolkit;

namespace DuplicatePhotosFixer.Models
{
    public class vmFileFormatSettings : INotifyPropertyChanged
    {
        public event PropertyChangedEventHandler PropertyChanged;
        public void OnPropertyChanged(string name)
        {
            PropertyChangedEventHandler handler = PropertyChanged;
            if (handler != null)
            {
                handler(this, new PropertyChangedEventArgs(name));
            }
        }

        ObservableCollection<csFileTypes> _lstFileType { get; set; }
        public ObservableCollection<csFileTypes> lstFileType
        {
            get
            {
                return _lstFileType;
            }
            set
            {
                _lstFileType = value;
                OnPropertyChanged("lstFileType");
            }
        }

        int _sizeInKB;

        public int SizeInKB
        {
            get
            {
                return _sizeInKB;
            }
            set
            {
                if (_sizeInKB != value)
                {
                    _sizeInKB = value;
                    OnPropertyChanged("SizeInKB");
                }
            }
        }




        long _sMinSizeValue;
        public long sMinSizeValue
        {
            get
            {
                return _sMinSizeValue;
            }
            set
            {
                _sMinSizeValue = value;
                
                OnPropertyChanged("sMinSizeValue");

            }
        }

        int _sMinSize;
        public int sMinSize
        {
            get
            {
                return _sMinSize;
            }

            set
            {
                _sMinSize = value;
             
                OnPropertyChanged("sMinSize");
            }
        }

        //string _sMinSizeType;
        //public string sMinSizeType
        //{
        //    get
        //    {
        //        return _sMinSizeType;
        //    }

        //    set
        //    {
        //        //_sMinSizeType = cResourceManager.LoadString("DPF_PREFERENCES_FORMATS").Split(new char[] { ',' }, StringSplitOptions.RemoveEmptyEntries);
        //        //_sMinSizeType = cResourceManager.LoadString("DPF_PREFERENCES_FORMATS").Split(new char[] { ',' }, StringSplitOptions.RemoveEmptyEntries);

        //        OnPropertyChanged("sMinSize");
        //    }
        //}

       
        public vmFileFormatSettings()
        {
           
            Init();
        }

        
        void Init()
        {
            LoadFileFormat(false);
            //LoadSavedSettings();
            LoadFileSize();
           
        }


      
        void LoadFileFormat(bool bUpdateXML)
        {
            try
            {

               /* csFileTypes.getLastFileTypesList()*/;
                lstFileType = new ObservableCollection<csFileTypes>();
                var FileTypesToAdd = cGlobalSettings.listFileType.Where(p => p.Key > -1);

                foreach (var item in FileTypesToAdd)
                {
                    lstFileType.Add(item.Value);
                }

                if (bUpdateXML)
                {
                    SaveFileFormatSettings();
                }

            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("vmFileFormatSettings:: LoadFileFormat: ", ex);

            }         

        }

        public enum SizeUnit
        {
            KB = 0,
            MB = 1
        }
        SizeUnit rVal;

        void ValueToIndex()
        {
           
            try
            {
                if (sMinSize == 0)
                {
                    rVal = SizeUnit.KB;
                }
                else
                {
                    rVal = SizeUnit.MB;
                }
            }
            catch (Exception)
            {

            }
        }

        public void MinValueChange()
        {
            ValueToIndex();
        }


        //public void MinValueChange()
        //{
        //    ValueToIndex();
        //}

        void LoadFileSize()
        {
            try
            {
                csFileTypes.getMinimumSize();
                if (cGlobalSettings.MinFileSize < 1048576) 
                {

                    sMinSizeValue = cGlobalSettings.MinFileSize / 1024;                  


                }
                else
                {
                    sMinSizeValue= cGlobalSettings.MinFileSize / 1048576;
                   
                }
         


            }
            catch (Exception ex)
            {

                cGlobalSettings.oLogger.WriteLogException("vmFileFormatSettings:: LoadFileSize: ", ex);
            }


        }
        public void SetUIPropertiesValue()
        {
            if (cGlobalSettings.FileFormatSettings == null)
            {
                LoadFileFormatSettings();
            }
           
        }

        public void LoadFileFormatSettings(bool bLoadDefaultFocefully = false)
        {
            try
            {
                if (bLoadDefaultFocefully)
                {
                    cGlobalSettings.listFileType = null;
                }
                else
                {
                    /// First check for already saved list. 
                    /// 
                    LoadSavedSettings();
                }
                /// Else load default list
                if (cGlobalSettings.listFileType == null || cGlobalSettings.listFileType.Count <= 0)
                {
                    csFileTypes.initillizeFileTypes();

                    SaveFileFormatSettings();
                }

            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("vmFileFormatSettings:: LoadFileFormatSettings: ", ex);
            }
        }

       

        public bool UpdateCheckStatus(csFileTypes ExtToRemove, bool bCheckedState)
        {
            bool bUpdated = false;
            try
            {
              
                    ExtToRemove.isChecked = bCheckedState == true;
                    bUpdated = true;
                    SaveFileFormatSettings();
                
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("vmFileFormatSettings:: UpdateCheckStatus: ", ex);
            }

            return bUpdated;
        }

        public void LoadDefaultSettings()
        {
            try
            {
                //csFileTypes.getLastFileTypesList();
                lstFileType = new ObservableCollection<csFileTypes>();
                var FileTypesToAdd = cGlobalSettings.listFileType.Where(p => p.Key > -1);

                foreach (var item in FileTypesToAdd)
                {
                    lstFileType.Add(item.Value);
                }
            }


            catch (Exception ex)
            {

                cGlobalSettings.oLogger.WriteLogException("vmFileFormatSettings:: LoadDefaultSettings: ", ex);
            }
        }
        void LoadSavedSettings()
        {
              try
                {
                    string strXMLPath = cGlobalSettings.xmlFileFormatSettings;

                    if (File.Exists(strXMLPath))
                    {
                        bool bSuccess = cSerializer.DeSerializeData<int, csFileTypes>(ref cGlobalSettings.listFileType, strXMLPath);
                    }

                    if (cGlobalSettings.listFileType == null)
                        cGlobalSettings.listFileType = new Dictionary<int, csFileTypes>();
                }
              
            
            catch (Exception ex)
            {

          
            }
        }
        public static bool SaveFileFormatSettings()
        {

            return cSerializer.SerializeData<int, csFileTypes>(cGlobalSettings.listFileType, cGlobalSettings.xmlFileFormatSettings);
           
        }
    }
}
