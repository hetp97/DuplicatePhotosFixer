    /// <summary>
    /// Interaction logic for ucHomeMain.xaml
    /// </summary>
    public partial class ucHomeMain : UserControl
    {
        ucHomeViewModel objHomeViewModel = null;
        public ucHomeMain()
        {
            objHomeViewModel = new ucHomeViewModel();
            this.DataContext = objHomeViewModel;

            InitializeComponent();
            Init();

        }

        private void Init()
        {
            objHomeViewModel.ctrlOwner = this;
            LoadStrings();
            // LoadFonts();
            UpdateData();
            LoadScanPathsSource(false);
        }

        void LoadScanPathsSource(bool bLoadCurrentTypeListOnly)
        {
            try
            {
                grid_file_folder.ItemsSource = objHomeViewModel.lstScanPathsInclude;
               
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("ucHomeMain:: LoadData: ", ex);
            }
        }
        private void LoadStrings()
        {
            scan_heading.Text = cResourceManager.LoadString("IDS_INCLUDE_FOLDER_LABEL");
            btnAddPhotos.Content = cResourceManager.LoadString("DPF_HOME_UC_ADD_PHOTOS_TEXT");
            btnAddfolders.Content = cResourceManager.LoadString("DPF_HOME_UC_ADD_FOLDER_TEXT");
           // btnScanForDuplicates.Content = cResourceManager.LoadString("DPF_FOOTER_UC_SCAN_FOR_DUPLICATES_TEXT");
            //--------- Context Menu strings
          
            //revelInFolderToolStripMenuItem.Header = cResourceManager.LoadString("DPF_HOME_UC_REVEAL_EXPLORER");
            //checkAllToolStripMenuItem.Text = cResourceManager.LoadString("DPF_HOME_UC_CHECK_ALL");
            //unCheckAllToolStripMenuItem.Text = cResourceManager.LoadString("DPF_HOME_UC_UNCHECK_ALL");
            //removeToolStripMenuItem.Text = cResourceManager.LoadString("DPF_HOME_UC_REMOVE_SCAN_PATH");
            //removeAllToolStripMenuItem.Text = cResourceManager.LoadString("DPF_HOME_UC_REMOVE_ALL_PATHS");

        }
        void UpdateData()
        {
            try
            {
                if (cboScanModes.SelectedIndex < 0)
                    cboScanModes.SelectedIndex = 0;

            }
            catch (Exception ex)
            {

            }
        }
        private void btnAddPhotos_Click(object sender, RoutedEventArgs e)
        {
            try
            {
                StartAddPhotos();

            }
            catch (Exception ex)
            {

                cGlobalSettings.oLogger.WriteLogException("btnAddPhotos_Click:: ", ex);
            }
                        
        }

        void StartAddPhotos()
        {
            try
            {
                if (objHomeViewModel.AddPhotoPaths(true, cGlobalSettings.CurrentTypeOfInclusion))
                {
                    LoadScanPathsSource(true);

                }
            }
            catch (Exception)
            {

                
            }
        }
        private void btnAddFolder_Click(object sender, RoutedEventArgs e)
        {
            try
            {
                StartAddFolder();
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("btn_addFolder_Click:: ", ex);
            }
        }

        void StartAddFolder()
        {
            try
            {
                if (objHomeViewModel.AddScanPaths(true, cGlobalSettings.CurrentTypeOfInclusion))
                {
                    LoadScanPathsSource(true);
                    
                }
            }
            catch (Exception exc)
            {

            }
        }

         
    
        private void btn_deleteCurrentRow_Click(object sender, RoutedEventArgs e)
        {
            try
            {

                System.Windows.Controls.Button btn_deleteCurrentRow = sender as System.Windows.Controls.Button;
                if (btn_deleteCurrentRow.Tag == null)
                    return;

                if (btn_deleteCurrentRow.Tag is csScanPaths)
                {
                    objHomeViewModel.RemoveScanPath(btn_deleteCurrentRow.Tag as csScanPaths);
                    LoadScanPathsSource(true);
                }
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("btn_action_Click:: ucHome: ", ex);
            }
        }

       

        private void cboScanModes_SelectionChanged(object sender, SelectionChangedEventArgs e)
        {
            try
            {
                if (cboScanModes.SelectedIndex < 0)
                    return;

                ScanModeData SelectedMode = (ScanModeData)cboScanModes.SelectedItem;

                cGlobalSettings.CurrentScanMode = SelectedMode.ModeType;

                App.oMainReference.InitScanner();
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("ucHomeMain:: cboScanModes_SelectionChanged: ", ex);
            }
        }

       
    }
    }

