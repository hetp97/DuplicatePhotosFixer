namespace DuplicatePhotosFixer.Models
{
    class ucHomeViewModel
    {
        public UserControl ctrlOwner = null;
        MainScanHelper objMainScanHelper = null;
        public List<ScanModeData> lstScanModeData { get; set; }
        public ObservableCollection<csScanPaths> lstScanPathsInclude { get; set; }
        public ObservableCollection<csScanPaths> lstScanPathsExclude { get; set; }
        public ObservableCollection<csScanPaths> lstScanPathsProtected { get; set; }

        public ucHomeViewModel()
        {
            Init();
        }

        void Init()
        {
            try
            {
                objMainScanHelper = new MainScanHelper();

                lstScanPathsInclude = new ObservableCollection<csScanPaths>();
                lstScanPathsExclude = new ObservableCollection<csScanPaths>();
                lstScanPathsProtected = new ObservableCollection<csScanPaths>();

                FillScanModes();
                FillScanPaths(false);
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("ucHomeViewModel:: Init: ", ex);
            }
        }

        void FillScanModes()
        {
            try
            {
                lstScanModeData = new List<ScanModeData>();
                var fontSize = 12.0;
                lstScanModeData.Add(new ScanModeData() { ModeName = cResourceManager.LoadString("DPF_SCAN_COMPUTER"), ModeIcon = @"\Resources\pc.png", IconMargin = "0", ModeType = eScanMode.FileSearch, cboFontSize = fontSize, ItemHeight = 40 });
                lstScanModeData.Add(new ScanModeData() { ModeName = cResourceManager.LoadString("DPF_SCAN_GOOGLE"), ModeIcon = @"\Resources\drive.png", IconMargin = "0", ModeType = eScanMode.GoogleDrive, cboFontSize = fontSize, ItemHeight = 40 });
                lstScanModeData.Add(new ScanModeData() { ModeName = cResourceManager.LoadString("IDS_SCAN_DROPBOX"), ModeIcon = @"\Resources\dropbox_img.png", IconMargin = "0", ModeType = eScanMode.Dropbox, cboFontSize = fontSize, ItemHeight = 40 });
                //if (cGlobal.IS_LB_BUILD != 1)
                ////lstScanModeData.Add(new ScanModeData() { ModeName = cResourceManager.LoadString("DFF_MOBI_SMARTSCAN"), ModeIcon = @"\Resources\mob_scan.png", IconMargin = "0", ModeType = eScanMode.MobileSmartScan, cboFontSize = fontSize, ItemHeight = cGlobal.IS_LB_BUILD == 1 ? 0 : 40 });
                ////lstScanModeData.Add(new ScanModeData() { ModeName = cResourceManager.LoadString("DFF_DELETE_EMPTY"), ModeIcon = @"\Resources\def_scanmode.png", IconMargin = "0", ModeType = eScanMode.DeleteEmptyFolder, cboFontSize = fontSize, ItemHeight = 40 });
                //////if (cGlobal.IS_LB_BUILD != 1)
                ////lstScanModeData.Add(new ScanModeData() { ModeName = string.Format("EML {0}", cResourceManager.LoadString("DFF_SCAN_MODE")), ModeIcon = @"\Resources\email-scan-icon.png", IconMargin = "0", ModeType = eScanMode.EML, cboFontSize = fontSize, ItemHeight = cGlobal.IS_LB_BUILD == 1 ? 0 : 40 });

            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("ucHomeViewModel:: FillScanModes: ", ex);
            }
        }

        void FillScanPaths(bool bLoadCurrentTypeListOnly)    ///for scan mode cb
        {
            try
            {
                /// Get xml files data 
                /// 
                csXmlOperations.LoadScanPathsList();
                if (bLoadCurrentTypeListOnly)
                {
                    switch (cGlobalSettings.CurrentTypeOfInclusion)
                    {
                        case eTypeOfInclusion.Included:
                            lstScanPathsInclude = new ObservableCollection<csScanPaths>();
                            break;
                        case eTypeOfInclusion.Excluded:
                            lstScanPathsExclude = new ObservableCollection<csScanPaths>();
                            break;
                        case eTypeOfInclusion.Protected:
                            lstScanPathsProtected = new ObservableCollection<csScanPaths>();
                            break;
                        default:
                            break;
                    }
                }

                for (int i = 0; i < cGlobalSettings.listScanPaths.Count; i++)
                {
                    if (bLoadCurrentTypeListOnly && cGlobalSettings.listScanPaths[i].TypeOfInclusion != cGlobalSettings.CurrentTypeOfInclusion)
                        continue;

                    switch (cGlobalSettings.listScanPaths[i].TypeOfInclusion)
                    {
                        case eTypeOfInclusion.Included:
                            lstScanPathsInclude.Add(cGlobalSettings.listScanPaths[i]);
                            break;
                        case eTypeOfInclusion.Excluded:
                            lstScanPathsExclude.Add(cGlobalSettings.listScanPaths[i]);
                            break;
                        case eTypeOfInclusion.Protected:
                            lstScanPathsProtected.Add(cGlobalSettings.listScanPaths[i]);
                            break;
                        default:
                            break;
                    }

                    if (cGlobalSettings.listScanPaths[i].TypeOfInclusion != eTypeOfInclusion.Included)
                        continue;
                }
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("ucHomeViewModel:: FilScanPaths: ", ex);
            }
        }

        public bool AddScanPaths(bool bShowErrorMsg, eTypeOfInclusion typeOfInclusion)
        {
            bool bAdded = false;
            try
            {
                string statusMessage = string.Empty;
                string[] selectedPaths = null;
                if (!cGlobalSettings.objScanner.Browse(out selectedPaths))
                    return false;

                if (selectedPaths == null || selectedPaths.Length <= 0)
                    return false;

                /// Validate Path and add in a scan path list
                /// 
                bool isListUpdated = false;
                for (int i = 0; i < selectedPaths.Length; i++)
                {

                    csScanPaths scanPathData = new csScanPaths()
                    {
                        IsSelected = true,
                        PathType = cClientEnum.ePathType.folder,
                        ScanPath = selectedPaths[i],
                        TypeOfInclusion = typeOfInclusion,
                        IncludeSubfolder = true,
                        
                    };

                    if (objMainScanHelper.ValidateScanPath(selectedPaths[i], ref statusMessage))
                    {
                        cGlobalSettings.listScanPaths.Add(scanPathData);
                        isListUpdated = true;
                    }
                }

                if (!string.IsNullOrEmpty(statusMessage))
                {
                    MessageBox.Show(statusMessage);
                }


                /// Save path in xml
                /// 
                if (isListUpdated)
                {
                    csXmlOperations.SaveScanPathsList(cGlobalSettings.listScanPaths);
                    FillScanPaths(true);
                    bAdded = true;
                }
            }
            catch (Exception ex)
            {

            }
            return bAdded;
        }

        bool ValidatePath(string strPath)
        {
            ///ToDo:
            bool isValid = true;

            return isValid;
        }

        public bool RemoveScanPath(csScanPaths RemoveScanPath)
        {
            try
            {
                cGlobalSettings.listScanPaths.Remove(RemoveScanPath);
                csXmlOperations.SaveScanPathsList(cGlobalSettings.listScanPaths);
                FillScanPaths(true);
                return true;
            }
            catch (Exception ex)
            {
                cGlobalSettings.oLogger.WriteLogException("ucHomeViewModel:: RemoveScanPath: ", ex);
            }
            return false;
        }
    }
}
