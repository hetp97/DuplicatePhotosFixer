<UserControl x:Class="DuplicatePhotosFixer.UserControls.Selection_Assistant.ucFolders"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DuplicatePhotosFixer.UserControls.Selection_Assistant"
             mc:Ignorable="d" 
             d:DesignHeight="260" d:DesignWidth="643" Background="{DynamicResource cl_bg_theme}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="47"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="51"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Margin="10 10 10 20">
                <DataGrid x:Name="addedFolderPath" Background="Transparent" BorderBrush="{DynamicResource cl_br_selcAss}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style  TargetType="{x:Type DataGridColumnHeader}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type DataGridColumnHeader}">
                                        <Border BorderBrush="{DynamicResource cl_br_selcAss}"
                                    BorderThickness=" 0.5 0 0.6 0.6"
                                Background="{DynamicResource cl_bg_theme}"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                            <TextBlock Text="{TemplateBinding Content}" Padding="5,5,0,0" Height="28"  Width="{TemplateBinding Width}" TextAlignment="Left"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource cl_fg_selcAss}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                </DataGrid>
            </Grid>

            <Grid Grid.Column="1">
                <StackPanel Grid.Column="1" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="top" Orientation="Vertical" Margin="0,19,0,0">
                    <Button x:Name="btnMoveUp" Width="34" Height="34" Margin="0,1,0,7" MinHeight="15" BorderBrush="Transparent" 
                         Style="{DynamicResource stl_btnBack}">
                        <Button.Background>
                            <ImageBrush x:Name="btnUpArrow" ImageSource="{DynamicResource img_arrowUp}"/>
                        </Button.Background>
                    </Button>
                    <Button x:Name="btnMoveDown" Width="34" Height="34" Margin="0,3,0,7" BorderBrush="Transparent" 
                         Style="{DynamicResource stl_btnBack}">
                        <Button.Background>
                            <ImageBrush x:Name="btnDownArrow" ImageSource="{DynamicResource img_arrowDown}"/>
                        </Button.Background>

                    </Button>

                </StackPanel>
            </Grid>
            <!--<StackPanel Grid.Column="1" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="top" Orientation="Vertical" Margin="0,19,0,0">
                    <Button x:Name="btnMoveUp" Width="34" Height="34" Margin="0,1,0,7" MinHeight="15" BorderThickness="1"  >
                        <Button.Template>
                            <ControlTemplate>
                                <Border>
                                    <Grid>
                                        <Border Name="Mask" BorderBrush="#ADADAD" BorderThickness="1">
                                            <Border.Background>
                                                <LinearGradientBrush EndPoint="0.504,1.5" StartPoint="0.504,0.03">
                                                    <GradientStop Color="#ECEBEC" Offset="0" />
                                                    <GradientStop Color="#E1E1E1" Offset="0.567" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <StackPanel>
                                            <Image x:Name="imgMoveup" Source="{DynamicResource img_arrow_up}" Stretch="None" Margin="0 5 0 0"/>

                                            <StackPanel.OpacityMask>
                                                <VisualBrush Visual="{Binding ElementName=Mask}" />
                                            </StackPanel.OpacityMask>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="false">
                                        --><!--<Setter TargetName="imgMoveup" Property="Foreground" Value="Gray"/>--><!--
                                        <Setter TargetName="Mask" Property="Background" Value="#0078D7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="btnMoveDown" Width="34" Height="34" Margin="0,3,0,7" >
                        <Button.Template>
                            <ControlTemplate>
                                <Border>
                                    <Grid>
                                        <Border Name="Mask" BorderBrush="#ADADAD" BorderThickness="1">
                                            <Border.Background>
                                                <LinearGradientBrush EndPoint="0.504,1.5" StartPoint="0.504,0.03">
                                                    <GradientStop Color="#ECEBEC" Offset="0" />
                                                    <GradientStop Color="#E1E1E1" Offset="0.567" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <StackPanel>
                                            <Image x:Name="imgMoveup" Source="{DynamicResource img_arrow_up}" Stretch="None" Margin="0 5 0 0"/>
                                            <StackPanel.OpacityMask>
                                                <VisualBrush Visual="{Binding ElementName=Mask}" />
                                            </StackPanel.OpacityMask>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="false">
                                        --><!--<Setter TargetName="imgMoveup" Property="Foreground" Value="Gray"/>--><!--
                                        <Setter TargetName="Mask" Property="Background" Value="#0078D7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </Grid>-->
            
        </Grid>
        <Grid Grid.Row="1" Margin="10 0 10 0">
            <Border BorderBrush="{DynamicResource cl_br_selcAss}" BorderThickness="1" Margin="0 5 0 0">
                <DockPanel>
                    <Button x:Name="browseFoldersPath" Content="..." DockPanel.Dock="Right" Width="25" Height="19" FontWeight="Bold"
                            Margin="0 0  10 0"/>
                <TextBlock x:Name="tbFoldersPrioritySelectPath" VerticalAlignment="Center" />
            </DockPanel>
            </Border>

        </Grid>
        <Grid Grid.Row="2">
            <DockPanel>
                <Button x:Name="btnAdd" Content="Add" Grid.Column="2" Width="80" Height="30" 
                         DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,10,0" >
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="TextBlock.TextAlignment" Value="Center" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bdr_main"  BorderThickness="1" BorderBrush="{DynamicResource cl_br_selcAss}" Background="Transparent">
                                            <ContentPresenter x:Name="cpName" HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="White">
                                            </ContentPresenter>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" TargetName="bdr_main" Value="#494949"></Setter>
                                                <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                <Setter Property="Background" TargetName="bdr_main" Value="#494949"></Setter>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="true">
                                                <Setter Property="BorderBrush" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                                <Setter Property="TextElement.Foreground" TargetName="cpName" Value="#FFFFFF"></Setter>
                                                <Setter Property="Background" TargetName="bdr_main" Value="#5D5D5D"></Setter>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="cpName" Property="TextElement.Foreground" Value="#747373" />
                                                <Setter TargetName="bdr_main" Property="Background" Value="#b0b0b0" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <TextBlock x:Name="lbl_Note" Padding="10 5 0 0" Foreground="#e9e9e9" TextWrapping="Wrap">
                    * You can set the priority of folders here. Duplicate photos in folders with high priority will <LineBreak/>
                        not be marked for deletion.
                </TextBlock>
                
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
